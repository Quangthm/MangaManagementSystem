<AuthorizeView>
    <Authorized>
        <form action="/api/auth/logout" method="post" data-enhance="false" class="logout-form">
            <button type="submit" class="logout-form__button">Logout</button>
        </form>
    </Authorized>
</AuthorizeView>

<style>
    .logout-form {
        width: 100%;
    }

    .logout-form__button {
        width: 100%;
        padding: 10px 16px;
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 4px;
        background: transparent;
        color: #e2e8f0;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-transform: none;
    }

    .logout-form__button:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: rgba(255, 255, 255, 0.55);
    }
</style>
