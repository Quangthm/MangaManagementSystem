@namespace MangaManagementSystem.Web.Components.Shared

<MudButton Href="@Href"
           Variant="Variant.Outlined"
           Color="Color.Default"
           FullWidth="true"
           Class="google-auth-button"
           Style="text-transform:none; border-color:#dadce0; color:#3c4043;">
    <span class="google-auth-button__content">
        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
             alt=""
             width="18"
             height="18"
             class="google-auth-button__icon" />
        <span>@Text</span>
    </span>
</MudButton>

<style>
    .google-auth-button__content {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-weight: 500;
    }

    .google-auth-button__icon {
        display: block;
    }
</style>

@code {
    [Parameter] public string Href { get; set; } = "/signin-google";
    [Parameter] public string Text { get; set; } = "Login with Google";
}
