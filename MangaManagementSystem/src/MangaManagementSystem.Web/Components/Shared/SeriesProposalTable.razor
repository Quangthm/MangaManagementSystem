@using MangaManagementSystem.Web.Components.Shared
@using MangaManagementSystem.Application.DTOs.Manga
@using MudBlazor

<div class="mf-proposal-page">
    @* ── Filter / Search / Sort toolbar ── *@
    <div class="mf-proposal-toolbar">
        <div class="mf-proposal-chips">
            @foreach (var opt in _statusOptions)
            {
                var isActive = _selectedStatusCode == opt.Code;
                var count = opt.Code == "ALL"
                    ? (Items?.Count ?? 0)
                    : (Items?.Count(p => p.StatusCode == opt.Code) ?? 0);
                <button @onclick="@(() => OnStatusChipClicked(opt.Code))"
                        style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(isActive ? 600 : 500); cursor: pointer; white-space: nowrap;
                               background: @(isActive ? "#4f46e5" : "#f1f5f9"); color: @(isActive ? "#fff" : "#475569");
                               border: 1px solid @(isActive ? "#4f46e5" : "#e2e8f0"); transition: all 0.15s ease;">
                    @opt.Label (@count)
                </button>
            }
        </div>

        <div class="mf-proposal-toolbar-right">
            <MudTextField T="string" @bind-Value="_searchText"
                           @bind-Value:after="ResetPageAndState"
                           Placeholder="Search by title or series"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.Search"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Immediate="true"
                           Style="font-size: 0.8rem; width: 240px;" />

            <MudSelect T="string" @bind-Value="_sortMode"
                        @bind-Value:after="ResetPageAndState"
                        Variant="Variant.Outlined" Margin="Margin.Dense"
                        Dense="true"
                        Style="font-size: 0.8rem; width: 180px;">
                <MudSelectItem T="string" Value="@("submitted")">Recently Submitted</MudSelectItem>
                <MudSelectItem T="string" Value="@("reviewed")">Reviewed Date</MudSelectItem>
                <MudSelectItem T="string" Value="@("title")">Proposal Title A-Z</MudSelectItem>
                <MudSelectItem T="string" Value="@("status")">Status</MudSelectItem>
            </MudSelect>
        </div>
    </div>

    @* ── Genre / Tag filter row ── *@
    @if (ShowGenreFilter || ShowTagFilter)
    {
        <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-bottom: 20px;">
            @if (ShowGenreFilter && _availableGenres.Count > 0)
            {
                <ReferenceMultiSelectFilter TItem="GenreDto"
                                            Label="Genre"
                                            SearchPlaceholder="Search genres..."
                                            EmptyText="No genres found."
                                            HighlightColor="#eef2ff"
                                            Items="_availableGenres"
                                            SelectedIds="_filterGenreIds.ToList()"
                                            GetItemId="g => g.GenreId"
                                            GetItemName="g => g.GenreName"
                                            GetItemDescription="g => g.Description"
                                            SelectedIdsChanged="OnGenreFilterChanged" />
            }
            @if (ShowTagFilter && _availableTags.Count > 0)
            {
                <ReferenceMultiSelectFilter TItem="TagDto"
                                            Label="Tag"
                                            SearchPlaceholder="Search tags..."
                                            EmptyText="No tags found."
                                            HighlightColor="#f0fdf4"
                                            Items="_availableTags"
                                            SelectedIds="_filterTagIds.ToList()"
                                            GetItemId="t => t.TagId"
                                            GetItemName="t => t.TagName"
                                            GetItemDescription="t => t.Description"
                                            SelectedIdsChanged="OnTagFilterChanged" />
            }
            @if (_filterGenreIds.Count > 0 || _filterTagIds.Count > 0)
            {
                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Error"
                           OnClick="ClearRefFilters"
                           Style="font-size: 0.72rem; text-transform: none;">
                    Clear filters
                </MudButton>
            }
        </div>
    }

    @* ── Empty state ── *@
    @if (Items is null || Items.Count == 0)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 64px 24px; color: #94a3b8; gap: 16px;">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="font-size: 56px; opacity: 0.5;" />
            <div style="font-size: 0.95rem; font-weight: 500; color: #64748b; text-align: center; max-width: 360px;">
                No proposals match your filter.
            </div>
        </div>
    }
    else if (FilteredSortedItems.Count == 0)
    {
        <div style="display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 64px 24px; color: #94a3b8; gap: 16px;">
            <MudIcon Icon="@Icons.Material.Filled.Inbox" Style="font-size: 56px; opacity: 0.5;" />
            <div style="font-size: 0.95rem; font-weight: 500; color: #64748b; text-align: center; max-width: 360px;">
                No proposals match your current filters.
            </div>
        </div>
    }
    else
    {
        @* ── Proposal table ── *@
        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
            <div style="display: grid; grid-template-columns: @GetGridColumns(); padding: 10px 20px; background: #f8fafc; border-bottom: 1px solid #e2e8f0; font-size: 0.72rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em;">
                <span>Series</span>
                <span>Proposal</span>
                <span>Version</span>
                @if (ShowSubmitterColumn)
                {
                    <span>Submitted By</span>
                }
                <span>Submitted</span>
                @if (ShowReviewerColumns)
                {
                    <span>Reviewer</span>
                    <span>Reviewed</span>
                }
                <span>Status</span>
                <span>Markup</span>
                <span></span>
            </div>
            @foreach (var p in PagedItems)
            {
                <div @onclick="@(() => RowClicked.InvokeAsync(p.SeriesProposalId))"
                     style="display: grid; grid-template-columns: @GetGridColumns(); padding: 12px 20px; border-bottom: 1px solid #f1f5f9; align-items: center; cursor: pointer; transition: background 0.12s;"
                     onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                    <span style="font-weight: 600; font-size: 0.85rem; color: #111827; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@p.SeriesTitle">@p.SeriesTitle</span>
                    <span style="font-size: 0.85rem; color: #374151; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@p.ProposalTitle">@p.ProposalTitle</span>
                    <span style="font-size: 0.8rem; color: #64748b;">v@(p.ProposalVersionNo)</span>
                    @if (ShowSubmitterColumn)
                    {
                        <span style="font-size: 0.8rem; color: #64748b;">@p.SubmittedByDisplayName</span>
                    }
                    <span style="font-size: 0.78rem; color: #64748b;">@p.SubmittedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</span>
                    @if (ShowReviewerColumns)
                    {
                        <span style="font-size: 0.8rem; color: #64748b;">@(string.IsNullOrWhiteSpace(p.ReviewerDisplayName) ? "—" : p.ReviewerDisplayName)</span>
                        <span style="font-size: 0.78rem; color: #64748b;">@(p.ReviewedAtUtc.HasValue ? p.ReviewedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy") : "—")</span>
                    }
                    <span style="display: inline-block;">
                        <span style="background: @StatusColor(p.StatusCode); color: #fff; font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; font-weight: 600; white-space: nowrap;">
                            @StatusDisplayLabel(p.StatusCode)
                        </span>
                    </span>
                    <span>
                        @if (p.HasMarkup)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.AttachFile" Size="Size.Small" Style="color: #10b981; font-size: 16px;" />
                        }
                    </span>
                    <span style="text-align: right;">
                        <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color: #cbd5e1;" />
                    </span>
                </div>
            }
        </div>

        @* ── Pagination ── *@
        @if (TotalPages > 1)
        {
            <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 20px;">
                <MudButton Size="Size.Small" Variant="Variant.Outlined"
                           Disabled="@(_currentPage <= 1)"
                           OnClick="@(() => { _currentPage--; })">
                    Prev
                </MudButton>

                @for (int pg = 1; pg <= TotalPages; pg++)
                {
                    int pageNum = pg;
                    bool isCurrent = pageNum == _currentPage;
                    <MudButton Size="Size.Small"
                               Variant="@(isCurrent ? Variant.Filled : Variant.Outlined)"
                               Color="@(isCurrent ? Color.Primary : Color.Default)"
                               OnClick="@(() => { _currentPage = pageNum; })">
                        @pageNum
                    </MudButton>
                }

                <MudButton Size="Size.Small" Variant="Variant.Outlined"
                           Disabled="@(_currentPage >= TotalPages)"
                           OnClick="@(() => { _currentPage++; })">
                    Next
                </MudButton>
            </div>
        }
    }
</div>

@code {
    [Parameter] public IReadOnlyList<SeriesProposalListItemModel> Items { get; set; } = Array.Empty<SeriesProposalListItemModel>();
    [Parameter] public string DefaultStatusFilterCode { get; set; } = "ALL";
    [Parameter] public bool ShowGenreFilter { get; set; } = true;
    [Parameter] public bool ShowTagFilter { get; set; } = true;
    [Parameter] public bool ShowSubmitterColumn { get; set; } = true;
    [Parameter] public bool ShowReviewerColumns { get; set; } = true;
    [Parameter] public EventCallback<Guid> RowClicked { get; set; }
    [Parameter] public IReadOnlyList<GenreDto> AvailableGenres { get; set; } = Array.Empty<GenreDto>();
    [Parameter] public IReadOnlyList<TagDto> AvailableTags { get; set; } = Array.Empty<TagDto>();
    [Parameter] public int PageSize { get; set; } = 10;

    private sealed record StatusOption(string Code, string Label);

    private static readonly StatusOption[] _statusOptions =
    [
        new("ALL", "All"),
        new("UNDER_EDITORIAL_REVIEW", "Under Editorial Review"),
        new("UNDER_BOARD_REVIEW", "Under Board Review"),
        new("REVISION_REQUESTED", "Revision Requested"),
        new("APPROVED", "Approved"),
        new("CANCELLED", "Cancelled"),
        new("WITHDRAWN", "Withdrawn"),
    ];

    private string _selectedStatusCode = "ALL";
    private string _searchText = "";
    private string _sortMode = "submitted";
    private int _currentPage = 1;
    private HashSet<Guid> _filterGenreIds = new();
    private HashSet<Guid> _filterTagIds = new();

    private IReadOnlyList<GenreDto> _availableGenres = Array.Empty<GenreDto>();
    private IReadOnlyList<TagDto> _availableTags = Array.Empty<TagDto>();

    protected override void OnInitialized()
    {
        _selectedStatusCode = NormalizeStatusCode(DefaultStatusFilterCode);
    }

    protected override void OnParametersSet()
    {
        _availableGenres = AvailableGenres;
        _availableTags = AvailableTags;
    }

    private static string NormalizeStatusCode(string? code)
    {
        if (string.IsNullOrWhiteSpace(code)) return "ALL";
        if (code.Equals("ALL", StringComparison.OrdinalIgnoreCase)) return "ALL";
        // If it's already a known code, return it.
        if (_statusOptions.Any(o => string.Equals(o.Code, code, StringComparison.OrdinalIgnoreCase)))
            return code.ToUpperInvariant();
        // If it's a label, map it back to code.
        var match = _statusOptions.FirstOrDefault(o =>
            string.Equals(o.Label, code, StringComparison.OrdinalIgnoreCase));
        return match?.Code ?? "ALL";
    }

    private void OnStatusChipClicked(string code)
    {
        _selectedStatusCode = code;
        _currentPage = 1;
        StateHasChanged();
    }

    private void ResetPageAndState()
    {
        _currentPage = 1;
        StateHasChanged();
    }

    private void OnGenreFilterChanged(HashSet<Guid> ids)
    {
        _filterGenreIds = ids;
        _currentPage = 1;
        StateHasChanged();
    }

    private void OnTagFilterChanged(HashSet<Guid> ids)
    {
        _filterTagIds = ids;
        _currentPage = 1;
        StateHasChanged();
    }

    private void ClearRefFilters()
    {
        _filterGenreIds.Clear();
        _filterTagIds.Clear();
        _currentPage = 1;
        StateHasChanged();
    }

    private IReadOnlyList<SeriesProposalListItemModel> FilteredSortedItems
    {
        get
        {
            if (Items is null) return Array.Empty<SeriesProposalListItemModel>();

            IEnumerable<SeriesProposalListItemModel> result = Items;

            if (_selectedStatusCode != "ALL")
                result = result.Where(p => p.StatusCode == _selectedStatusCode);

            if (!string.IsNullOrWhiteSpace(_searchText))
            {
                var term = _searchText.Trim();
                result = result.Where(p =>
                    p.SeriesTitle.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    p.ProposalTitle.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    p.SubmittedByDisplayName.Contains(term, StringComparison.OrdinalIgnoreCase));
            }

            if (_filterGenreIds.Count > 0)
                result = result.Where(p => _filterGenreIds.All(fgId => p.Genres.Any(g => g.GenreId == fgId)));

            if (_filterTagIds.Count > 0)
                result = result.Where(p => _filterTagIds.All(ftId => p.Tags.Any(t => t.TagId == ftId)));

            result = _sortMode switch
            {
                "reviewed" => result.OrderByDescending(p => p.ReviewedAtUtc ?? DateTime.MinValue),
                "title" => result.OrderBy(p => p.ProposalTitle, StringComparer.OrdinalIgnoreCase),
                "status" => result.OrderBy(p => StatusDisplayLabel(p.StatusCode), StringComparer.OrdinalIgnoreCase),
                _ => result.OrderByDescending(p => p.SubmittedAtUtc),
            };

            return result.ToList().AsReadOnly();
        }
    }

    private int TotalPages => PageSize <= 0
        ? 0
        : (int)Math.Ceiling((double)FilteredSortedItems.Count / PageSize);

    private IReadOnlyList<SeriesProposalListItemModel> PagedItems =>
        FilteredSortedItems
            .Skip((_currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList()
            .AsReadOnly();

    private string GetGridColumns()
    {
        // Base: Series, Proposal, Version, Submitted, Status, Markup, chevron
        var cols = new List<string> { "2fr", "2fr", "80px", "110px", "130px", "60px", "40px" };
        if (ShowSubmitterColumn)
            cols.Insert(3, "130px");
        if (ShowReviewerColumns)
        {
            cols.Insert(cols.Count - 3, "120px");
            cols.Insert(cols.Count - 3, "100px");
        }
        return string.Join(" ", cols);
    }

    private static string StatusDisplayLabel(string statusCode) => statusCode switch
    {
        "UNDER_EDITORIAL_REVIEW" => "Under Editorial Review",
        "UNDER_BOARD_REVIEW" => "Under Board Review",
        "REVISION_REQUESTED" => "Revision Requested",
        "APPROVED" => "Approved",
        "CANCELLED" => "Cancelled",
        "WITHDRAWN" => "Withdrawn",
        _ => statusCode.Replace("_", " "),
    };

    private static string StatusColor(string statusCode) => statusCode switch
    {
        "UNDER_EDITORIAL_REVIEW" => "#0ea5e9",
        "UNDER_BOARD_REVIEW" => "#8b5cf6",
        "REVISION_REQUESTED" => "#f59e0b",
        "APPROVED" => "#059669",
        "CANCELLED" => "#dc2626",
        "WITHDRAWN" => "#64748b",
        _ => "#64748b",
    };
}
