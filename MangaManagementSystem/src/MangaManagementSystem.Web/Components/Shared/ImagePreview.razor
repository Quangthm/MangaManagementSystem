@using Microsoft.AspNetCore.Components
@inject IDialogService DialogService

@if (!string.IsNullOrWhiteSpace(ImageUrl))
{
    <button type="button"
            class="mf-ip-thumb"
            style="@ThumbnailButtonStyle"
            @onclick="OpenPreview"
            @onclick:stopPropagation="true">
        <img src="@ImageUrl"
             alt="@AltText"
             style="@ThumbnailImageStyle" />
    </button>
}

@code {
    [Parameter] public string? ImageUrl { get; set; }
    [Parameter] public string AltText { get; set; } = string.Empty;
    [Parameter] public string? Title { get; set; }
    [Parameter] public int ThumbnailWidth { get; set; } = 200;
    [Parameter] public int ThumbnailHeight { get; set; } = 300;
    [Parameter] public string ThumbnailObjectFit { get; set; } = "cover";

    private string ThumbnailButtonStyle =>
        $"width:{ThumbnailWidth}px;min-width:{ThumbnailWidth}px;max-width:{ThumbnailWidth}px;" +
        $"height:{ThumbnailHeight}px;min-height:{ThumbnailHeight}px;max-height:{ThumbnailHeight}px;" +
        "overflow:hidden;display:inline-flex;align-items:center;justify-content:center;" +
        "padding:0;border:0;border-radius:8px;background:white;cursor:zoom-in;box-sizing:border-box;";

    private string ThumbnailImageStyle =>
        $"width:100%;height:100%;max-width:100%;max-height:100%;" +
        $"object-fit:{ThumbnailObjectFit};object-position:center;display:block;";

    private async Task OpenPreview()
    {
        if (string.IsNullOrWhiteSpace(ImageUrl))
            return;

        var parameters = new DialogParameters
        {
            { "ImageUrl", ImageUrl },
            { "AltText", AltText },
            { "Title", Title }
        };

        var options = new DialogOptions
        {
            FullScreen = true,
            CloseOnEscapeKey = true,
            BackdropClick = true,
            CloseButton = false,
            NoHeader = true
        };

        await DialogService.ShowAsync<ImagePreviewDialog>(
            Title ?? "Image Preview",
            parameters,
            options);
    }
}
