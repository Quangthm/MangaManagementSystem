@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Application.Interfaces
@using MangaManagementSystem.Web.Components.Shared
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IFileResourceService FileResourceService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<AuthorizeView>
    <Authorized>
        @if (_loading)
        {
            <MudSkeleton Width="36px" Height="36px" />
        }
        else
        {
            <MudMenu OffsetY="true">
                <ActivatorContent>
                    <MudAvatar Size="Size.Medium" Image="@_avatarUrl" Class="mf-avatar" Color="Color.Primary">
                        @if (string.IsNullOrEmpty(_avatarUrl))
                        {
                            @(_initial ?? "?")
                        }
                    </MudAvatar>
                </ActivatorContent>

                <ChildContent>
                    <MudMenuItem OnClick="OpenProfileSettings">Profile Settings</MudMenuItem>
                    <MudMenuItem OnClick="OpenProfileSettings">Reset Password</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem>
                        <LogoutForm />
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        }
    </Authorized>

    <NotAuthorized>
        <MudButton Href="/login" Variant="Variant.Text">Sign in</MudButton>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _loading = true;
    private string? _avatarUrl;
    private string? _initial;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;

            if (user?.Identity?.IsAuthenticated == true)
            {
                var idClaim = user.FindFirst(ClaimTypes.NameIdentifier);

                if (Guid.TryParse(idClaim?.Value, out var uid))
                {
                    var dto = await UserService.GetUserByIdAsync(uid);

                    if (dto != null)
                    {
                        _initial = BuildInitial(dto.DisplayName, dto.Username);

                        if (dto.AvatarFileId.HasValue)
                        {
                            var file = await FileResourceService.GetFileResourceByIdAsync(dto.AvatarFileId.Value);

                            if (file != null &&
                                file.DeletedAtUtc == null &&
                                !string.IsNullOrWhiteSpace(file.CloudinarySecureUrl))
                            {
                                _avatarUrl = file.CloudinarySecureUrl;
                            }
                        }
                    }
                }
            }
        }
        catch
        {
            Snackbar.Add("Failed to load profile info.", Severity.Warning);
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenProfileSettings()
    {
        NavigationManager.NavigateTo("/profile/settings");
    }

    private static string BuildInitial(string? displayName, string? username)
    {
        var source = !string.IsNullOrWhiteSpace(displayName)
            ? displayName.Trim()
            : username?.Trim();

        return string.IsNullOrWhiteSpace(source)
            ? "?"
            : source[..1].ToUpperInvariant();
    }
}

<style>
    .mf-avatar {
        cursor: pointer;
    }
</style>