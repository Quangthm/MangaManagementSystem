@using MangaManagementSystem.Application.Common
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api

@implements IDisposable

@inject INotificationApiClient NotificationApiClient
@inject NavigationManager Navigation
@inject ILogger<NotificationBell> Logger

<MudMenu>
    <ActivatorContent>
        <button type="button"
                class="mf-notification-bell-button"
                title="Notifications"
                aria-label="@BuildBellAriaLabel()"
                @onclick="HandleBellOpenedAsync">

            <svg class="mf-notification-bell-icon"
                 viewBox="0 0 24 24"
                 aria-hidden="true">
                <path d="M12 22a2.5 2.5 0 0 0 2.35-1.67h-4.7A2.5 2.5 0 0 0 12 22Zm7-6.5-1.75-2.1V9a5.25 5.25 0 0 0-4.25-5.15V3a1 1 0 0 0-2 0v.85A5.25 5.25 0 0 0 6.75 9v4.4L5 15.5V17h14v-1.5Z" />
            </svg>

            @if (_unreadCount > 0)
            {
                <span class="mf-notification-badge"
                      aria-hidden="true">
                    @FormatUnreadCount()
                </span>
            }
        </button>
    </ActivatorContent>

    <ChildContent>
        <div class="mf-notification-panel"
             @onclick:stopPropagation="true">

            <div class="mf-notification-header">
                <div>
                    <strong>Notifications</strong>

                    <small>
                        @BuildNotificationSummary()
                    </small>
                </div>

                <button type="button"
                        class="mf-notification-mark-all"
                        disabled="@(_operationInProgress || _unreadCount == 0)"
                        @onclick="MarkAllAsReadAsync">
                    Mark all as read
                </button>
            </div>

            @if (_loading)
            {
                <div class="mf-notification-state">
                    <span class="mf-notification-spinner"
                          aria-hidden="true"></span>

                    <span>Loading notifications...</span>
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(_errorMessage))
            {
                <div class="mf-notification-state mf-notification-error">
                    <strong>Unable to load notifications</strong>

                    <span>@_errorMessage</span>

                    <button type="button"
                            class="mf-notification-retry"
                            @onclick="RefreshAsync">
                        Try again
                    </button>
                </div>
            }
            else if (_notifications.Count == 0)
            {
                <div class="mf-notification-state">
                    <svg class="mf-notification-empty-icon"
                         viewBox="0 0 24 24"
                         aria-hidden="true">
                        <path d="M12 22a2.5 2.5 0 0 0 2.35-1.67h-4.7A2.5 2.5 0 0 0 12 22Zm7-6.5-1.75-2.1V9a5.25 5.25 0 0 0-4.25-5.15V3a1 1 0 0 0-2 0v.85A5.25 5.25 0 0 0 6.75 9v4.4L5 15.5V17h14v-1.5Z" />
                    </svg>

                    <strong>No notifications yet</strong>

                    <span>New account and system updates will appear here.</span>
                </div>
            }
            else
            {
                <div class="mf-notification-list">
                    @foreach (var notification in _notifications)
                    {
                        <div class="@BuildNotificationItemClass(notification)">
                            <button type="button"
                                    class="mf-notification-main-action"
                                    disabled="@(!CanNavigateToRelatedEntity(notification) || _operationInProgress)"
                                    aria-label="@BuildNotificationNavigationLabel(notification)"
                                    @onclick="() => HandleNotificationClickAsync(notification)">
                                <span class="mf-notification-status"
                                      aria-hidden="true"></span>

                                <span class="mf-notification-content">
                                    <span class="mf-notification-title">
                                        @BuildNotificationTitle(notification)
                                    </span>

                                    <span class="mf-notification-message">
                                        @notification.Message
                                    </span>

                                    <time class="mf-notification-time"
                                          datetime="@notification.CreatedAtUtc.ToString("O")">
                                        @FormatCreatedAt(notification.CreatedAtUtc)
                                    </time>
                                </span>
                            </button>

                            <span class="mf-notification-item-action">
                                @if (!notification.ReadAtUtc.HasValue)
                                {
                                    <button type="button"
                                            class="mf-notification-mark-one"
                                            disabled="@_operationInProgress"
                                            @onclick="() => MarkAsReadAsync(notification)">
                                        Mark as read
                                    </button>
                                }
                                else
                                {
                                    <span class="mf-notification-read-label">
                                        Read
                                    </span>
                                }
                            </span>
                        </div>
                    }
                </div>

                @if (_hasMore)
                {
                    <div class="mf-notification-load-more-row">
                        <button type="button"
                                class="mf-notification-load-more"
                                disabled="@(_operationInProgress || _loadMoreInProgress)"
                                @onclick="LoadMoreAsync">
                            @(_loadMoreInProgress
                                ? "Loading..."
                                : "Load more")
                        </button>
                    </div>
                }
            }
        </div>
    </ChildContent>
</MudMenu>

@code {
    private const int PageSize = 20;
    private const int PageRequestSize = PageSize + 1;

    private readonly List<NotificationDto> _notifications =
        new();

    private bool _loading = true;
    private bool _loadInProgress;
    private bool _loadMoreInProgress;
    private bool _hasMore;
    private bool _operationInProgress;
    private bool _disposed;
    private int _unreadCount;
    private string? _errorMessage;

    protected override async Task OnAfterRenderAsync(
        bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RefreshAsync();
    }

    private Task HandleBellOpenedAsync()
    {
        return RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (_disposed || _loadInProgress)
        {
            return;
        }

        _loadInProgress = true;
        _loading = true;
        _errorMessage = null;

        try
        {
            var notificationsTask =
                NotificationApiClient
                    .GetNotificationsAsync(0, PageRequestSize);

            var unreadCountTask =
                NotificationApiClient
                    .GetUnreadCountAsync();

            await Task.WhenAll(
                notificationsTask,
                unreadCountTask);

            var notifications =
                await notificationsTask;

            var unreadCount =
                await unreadCountTask;

            _notifications.Clear();

            var initialItemCount =
                Math.Min(
                    PageSize,
                    notifications.Count);

            for (var index = 0;
                 index < initialItemCount;
                 index++)
            {
                _notifications.Add(
                    notifications[index]);
            }

            _hasMore =
                notifications.Count > PageSize;

            _unreadCount =
                Math.Max(0, unreadCount);
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to load notifications in the notification bell.");

            _errorMessage =
                "Please refresh and try again.";
        }
        finally
        {
            _loading = false;
            _loadInProgress = false;
        }

        if (!_disposed)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadMoreAsync()
    {
        if (_disposed
            || _operationInProgress
            || _loadMoreInProgress
            || !_hasMore)
        {
            return;
        }

        _loadMoreInProgress = true;
        _errorMessage = null;

        try
        {
            var nextPage =
                await NotificationApiClient
                    .GetNotificationsAsync(
                        _notifications.Count,
                        PageRequestSize);

            var pageItemCount =
                Math.Min(
                    PageSize,
                    nextPage.Count);

            for (var index = 0;
                 index < pageItemCount;
                 index++)
            {
                var notification =
                    nextPage[index];

                var alreadyLoaded =
                    _notifications.Exists(
                        item =>
                            item.NotificationId
                            == notification.NotificationId);

                if (alreadyLoaded)
                {
                    continue;
                }

                _notifications.Add(
                    notification);
            }

            _hasMore =
                nextPage.Count > PageSize;
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to load more notifications.");

            _errorMessage =
                "More notifications could not be loaded.";
        }
        finally
        {
            _loadMoreInProgress = false;
        }
    }
    private async Task HandleNotificationClickAsync(
        NotificationDto notification)
    {
        if (_disposed || _operationInProgress)
        {
            return;
        }

        var targetRoute =
            BuildNotificationRoute(notification);

        if (string.IsNullOrWhiteSpace(targetRoute))
        {
            return;
        }

        if (!notification.ReadAtUtc.HasValue)
        {
            var markedAsRead =
                await TryMarkAsReadAsync(notification);

            if (!markedAsRead)
            {
                return;
            }
        }

        Navigation.NavigateTo(targetRoute);
    }

    private async Task MarkAsReadAsync(
        NotificationDto notification)
    {
        await TryMarkAsReadAsync(notification);
    }

    private async Task<bool> TryMarkAsReadAsync(
        NotificationDto notification)
    {
        if (_disposed || _operationInProgress)
        {
            return false;
        }

        if (notification.ReadAtUtc.HasValue)
        {
            return true;
        }

        _operationInProgress = true;
        _errorMessage = null;

        try
        {
            var succeeded =
                await NotificationApiClient
                    .MarkAsReadAsync(
                        notification.NotificationId);

            if (!succeeded)
            {
                _errorMessage =
                    "This notification is no longer available.";

                return false;
            }

            var index =
                _notifications.FindIndex(
                    item =>
                        item.NotificationId
                        == notification.NotificationId);

            if (index >= 0
                && !_notifications[index]
                    .ReadAtUtc.HasValue)
            {
                _notifications[index] =
                    _notifications[index] with
                    {
                        ReadAtUtc = DateTime.UtcNow
                    };

                _unreadCount =
                    Math.Max(
                        0,
                        _unreadCount - 1);
            }

            return true;
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to mark notification {NotificationId} as read.",
                notification.NotificationId);

            _errorMessage =
                "The notification could not be updated.";

            return false;
        }
        finally
        {
            _operationInProgress = false;
        }
    }
    private async Task MarkAllAsReadAsync()
    {
        if (_disposed
            || _operationInProgress
            || _unreadCount == 0)
        {
            return;
        }

        _operationInProgress = true;
        _errorMessage = null;

        try
        {
            await NotificationApiClient
                .MarkAllAsReadAsync();

            var readAtUtc =
                DateTime.UtcNow;

            for (var index = 0;
                 index < _notifications.Count;
                 index++)
            {
                var notification =
                    _notifications[index];

                if (notification.ReadAtUtc.HasValue)
                {
                    continue;
                }

                _notifications[index] =
                    notification with
                    {
                        ReadAtUtc = readAtUtc
                    };
            }

            _unreadCount = 0;
        }
        catch (Exception exception)
        {
            Logger.LogWarning(
                exception,
                "Failed to mark all notifications as read.");

            _errorMessage =
                "Notifications could not be updated.";
        }
        finally
        {
            _operationInProgress = false;
        }
    }

    private string BuildBellAriaLabel()
    {
        return _unreadCount > 0
            ? $"Open notifications. {_unreadCount} unread."
            : "Open notifications.";
    }

    private string BuildNotificationSummary()
    {
        return _unreadCount switch
        {
            <= 0 => "You are all caught up",
            1 => "1 unread notification",
            _ => $"{_unreadCount} unread notifications"
        };
    }

    private string FormatUnreadCount()
    {
        return _unreadCount > 99
            ? "99+"
            : _unreadCount.ToString();
    }

    private static string BuildNotificationTitle(
        NotificationDto notification)
    {
        return string.IsNullOrWhiteSpace(
                notification.Title)
            ? "System notification"
            : notification.Title.Trim();
    }

    private static string BuildNotificationItemClass(
        NotificationDto notification)
    {
        var stateClass =
            notification.ReadAtUtc.HasValue
                ? "mf-notification-item"
                : "mf-notification-item is-unread";

        return CanNavigateToRelatedEntity(notification)
            ? $"{stateClass} is-navigable"
            : stateClass;
    }

    private static bool CanNavigateToRelatedEntity(
        NotificationDto notification)
    {
        return BuildNotificationRoute(notification)
            is not null;
    }

    private static string BuildNotificationNavigationLabel(
        NotificationDto notification)
    {
        return CanNavigateToRelatedEntity(notification)
            ? $"Open {BuildNotificationTitle(notification)}"
            : BuildNotificationTitle(notification);
    }

    private static string? BuildNotificationRoute(
        NotificationDto notification)
    {
        if (string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes
                    .ChapterReview,
                StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.Chapter,
                StringComparison.Ordinal)
            && notification.RelatedEntityId.HasValue
            && notification.RelatedEntityId.Value
                != Guid.Empty)
        {
            return "/editor/chapters";
        }

        if (string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes.ProposalReview,
                StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.SeriesProposal,
                StringComparison.Ordinal)
            && notification.RelatedEntityId.HasValue
            && notification.RelatedEntityId.Value != Guid.Empty)
        {
            return $"/editor/proposals/{notification.RelatedEntityId.Value:D}";
        }

        if (string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes.BoardDecision,
                StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.SeriesBoardPoll,
                StringComparison.Ordinal)
            && notification.NotificationId != Guid.Empty
            && notification.RelatedEntityId.HasValue
            && notification.RelatedEntityId.Value != Guid.Empty)
        {
            return $"/notifications/board-decision/{notification.NotificationId:D}";
        }

        if (string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes.ProposalDecision,
                StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.SeriesProposal,
                StringComparison.Ordinal)
            && notification.RelatedEntityId.HasValue
            && notification.RelatedEntityId.Value != Guid.Empty)
        {
            return $"/mangaka/proposals/{notification.RelatedEntityId.Value:D}";
        }

        if (string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes.ChapterDecision,
                StringComparison.OrdinalIgnoreCase)
            && string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.Chapter,
                StringComparison.Ordinal)
            && notification.RelatedEntityId.HasValue
            && notification.RelatedEntityId.Value != Guid.Empty)
        {
            return "/mangaka/chapters";
        }

        if (!string.Equals(
                notification.NotificationTypeCode,
                NotificationTypeCodes.TaskAssignment,
                StringComparison.OrdinalIgnoreCase))
        {
            return null;
        }

        if (!string.Equals(
                notification.RelatedEntityType,
                NotificationRelatedEntityTypes.ChapterPageTask,
                StringComparison.Ordinal))
        {
            return null;
        }

        if (!notification.RelatedEntityId.HasValue
            || notification.RelatedEntityId.Value
                == Guid.Empty)
        {
            return null;
        }

        return $"/assistant/task/{notification.RelatedEntityId.Value:D}";
    }

    private static string FormatCreatedAt(
        DateTime createdAtUtc)
    {
        var normalizedCreatedAtUtc =
            createdAtUtc.Kind == DateTimeKind.Utc
                ? createdAtUtc
                : DateTime.SpecifyKind(
                    createdAtUtc,
                    DateTimeKind.Utc);

        var elapsed =
            DateTime.UtcNow
            - normalizedCreatedAtUtc;

        if (elapsed < TimeSpan.Zero)
        {
            elapsed = TimeSpan.Zero;
        }

        if (elapsed < TimeSpan.FromMinutes(1))
        {
            return "Just now";
        }

        if (elapsed < TimeSpan.FromHours(1))
        {
            return $"{(int)elapsed.TotalMinutes}m ago";
        }

        if (elapsed < TimeSpan.FromDays(1))
        {
            return $"{(int)elapsed.TotalHours}h ago";
        }

        if (elapsed < TimeSpan.FromDays(7))
        {
            return $"{(int)elapsed.TotalDays}d ago";
        }

        return normalizedCreatedAtUtc
            .ToLocalTime()
            .ToString("dd MMM yyyy");
    }

    public void Dispose()
    {
        _disposed = true;
    }
}

<style>
    .mf-notification-bell-button {
        position: relative;
        width: 36px;
        height: 36px;
        flex: 0 0 36px;
        border: 1px solid rgba(148, 163, 184, 0.28);
