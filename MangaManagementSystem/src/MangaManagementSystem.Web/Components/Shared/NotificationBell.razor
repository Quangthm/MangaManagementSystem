        background: #e0e7ff;
    }

    .mf-notification-mark-all:disabled {
        color: #94a3b8;
        cursor: not-allowed;
        opacity: 0.72;
    }

    .mf-notification-list {
        max-height: 430px;
        overflow-y: auto;
    }

    .mf-notification-item {
        width: 100%;
        border: 0;
        border-bottom: 1px solid #eef2f7;
        padding: 13px 16px;
        background: #ffffff;
        color: inherit;
        display: flex;
        align-items: flex-start;
        gap: 11px;
        text-align: left;
        cursor: default;
        transition: background-color 0.14s ease;
    }

    .mf-notification-item.is-unread {
        background: #f5f3ff;
