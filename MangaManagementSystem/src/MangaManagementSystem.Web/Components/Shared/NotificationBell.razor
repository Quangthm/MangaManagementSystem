        font-size: 12px;
        font-weight: 800;
        cursor: pointer;
    }

    .mf-notification-load-more:hover:not(:disabled) {
        background: #e0e7ff;
    }

    .mf-notification-load-more:disabled {
        color: #94a3b8;
        cursor: not-allowed;
        opacity: 0.72;
    }
    .mf-notification-content {
        min-width: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 5px;
    }

    .mf-notification-title {
        color: #0f172a;
        font-size: 13px;
        font-weight: 800;
        line-height: 1.3;
    }

    .mf-notification-message {
        color: #475569;
        font-size: 12px;
        line-height: 1.45;
        overflow-wrap: anywhere;
    }

    .mf-notification-time {
        color: #94a3b8;
        font-size: 11px;
        font-weight: 700;
    }

    .mf-notification-state {
        min-height: 220px;
        padding: 30px 24px;
        color: #64748b;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 9px;
        text-align: center;
        font-size: 12px;
    }

    .mf-notification-state strong {
        color: #334155;
        font-size: 14px;
    }

    .mf-notification-error {
        color: #b91c1c;
    }

    .mf-notification-empty-icon {
        width: 34px;
        height: 34px;
        margin-bottom: 3px;
        fill: #94a3b8;
    }

    .mf-notification-spinner {
        width: 24px;
        height: 24px;
        border: 3px solid #e2e8f0;
        border-top-color: #7c3aed;
        border-radius: 50%;
        animation: mf-notification-spin 0.8s linear infinite;
    }

    @@keyframes mf-notification-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>
