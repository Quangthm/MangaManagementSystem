        flex: 1;
        border: 0;
        padding: 0;
        background: transparent;
        color: inherit;
        display: flex;
        align-items: flex-start;
        gap: 11px;
        text-align: left;
        cursor: pointer;
    }

    .mf-notification-main-action:disabled {
        cursor: default;
        opacity: 1;
    }

    .mf-notification-main-action:focus-visible {
        border-radius: 8px;
        outline: 2px solid #8b5cf6;
        outline-offset: 3px;
