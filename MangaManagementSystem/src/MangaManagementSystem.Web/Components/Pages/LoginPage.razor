@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Login - MangaFlow</PageTitle>

<div class="mf-gradient-bg d-flex align-center justify-center pa-4">
    <MudContainer MaxWidth="MaxWidth.Small">
        <div class="text-center mb-6">
            <MudText Typo="Typo.h3" Class="font-weight-bold mf-gradient-text">MangaFlow</MudText>
            <MudText Typo="Typo.h6" Class="mf-muted mt-2">Welcome back to your workspace</MudText>
        </div>

        <MudPaper Class="mf-card" Elevation="8">
            <div style="background:linear-gradient(90deg,#4f46e5,#9333ea); border-radius:22px 22px 0 0" class="pa-6 text-center">
                <MudText Typo="Typo.h5" Class="font-weight-bold text-white">Login to Your Account</MudText>
            </div>
            <div class="pa-8">
                <form action="/api/auth/login" method="post" data-enhance="false" class="login-form">
                    <AntiforgeryToken />
                    <MudStack Spacing="3">
                        <div class="login-form__field">
                            <label class="login-form__label" for="username">Username or Email</label>
                            <input id="username"
                                   name="username"
                                   type="text"
                                   class="login-form__input"
                                   required
                                   autocomplete="username" />
                        </div>
                        <div class="login-form__field">
                            <label class="login-form__label" for="password">Password</label>
                            <input id="password"
                                   name="password"
                                   type="password"
                                   class="login-form__input"
                                   required
                                   autocomplete="current-password" />
                        </div>
                        <MudText Align="Align.Right"><MudLink Href="#">Forgot Password?</MudLink></MudText>
                        <button type="submit" class="login-form__submit">
                            Login
                        </button>
                    </MudStack>
                </form>

                <MudDivider Class="my-4" />

                <form action="/api/auth/google-login" method="post" data-enhance="false">
                    <AntiforgeryToken />
                    <button type="submit" class="google-auth-button">
                        <span class="google-auth-button__content">
                            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                                 alt=""
                                 width="18"
                                 height="18"
                                 class="google-auth-button__icon" />
                            <span>Login with Google</span>
                        </span>
                    </button>
                </form>

                <MudDivider Class="my-4" />
                <MudText Align="Align.Center">
                    Don't have an account? <MudLink Href="/register">Create Account</MudLink>
                </MudText>
            </div>
        </MudPaper>

        <MudText Align="Align.Center" Class="mt-4"><MudLink Href="/">← Back to Home</MudLink></MudText>
    </MudContainer>
</div>

<style>
    .login-form__field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .login-form__label {
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(0, 0, 0, 0.6);
    }

    .login-form__input {
        width: 100%;
        padding: 16px 14px;
        border: 1px solid rgba(0, 0, 0, 0.23);
        border-radius: 4px;
        font-size: 1rem;
        font-family: inherit;
        box-sizing: border-box;
    }

    .login-form__input:focus {
        outline: 2px solid #594ae2;
        border-color: #594ae2;
    }

    .login-form__submit {
        width: 100%;
        padding: 14px 16px;
        border: none;
        border-radius: 4px;
        background: #594ae2;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.0892857143em;
        text-transform: uppercase;
        cursor: pointer;
        margin-top: 8px;
    }

    .login-form__submit:hover {
        background: #4a3ec9;
    }

    .google-auth-button {
        display: block;
        width: 100%;
        padding: 10px 16px;
        border: 1px solid #dadce0;
        border-radius: 4px;
        background: #fff;
        color: #3c4043;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-transform: none;
    }

    .google-auth-button:hover {
        background: #f8f9fa;
    }

    .google-auth-button__content {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        font-weight: 500;
    }

    .google-auth-button__icon {
        display: block;
    }
</style>

@code {
    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("verified", out _))
        {
            Snackbar.Add("Email verified successfully. You can sign in once an administrator approves your account.", Severity.Success);
        }

        if (query.TryGetValue("error", out var error))
        {
            var message = error.ToString() switch
            {
                "GoogleAuthFailed" => "Google sign-in failed. Please try again or use email login.",
                "GoogleEmailMissing" => "Google did not return an email address for this account. Try another Google account or use email login.",
                "UserNotInDatabase" or "UserNotFoundOrInactive" => "No active account found for this Google email. Register first or contact an administrator.",
                "account_pending" => "Your account is pending email verification or admin approval. Complete verification or wait for approval.",
                "InvalidCredentials" or "invalid" => "Invalid credentials. Please check your username and password.",
                _ => "Unable to sign in. Please try again."
            };
            Snackbar.Add(message, Severity.Error);
        }
    }
}
