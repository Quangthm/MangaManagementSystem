@page "/login"
@using Microsoft.AspNetCore.WebUtilities
@using MangaManagementSystem.Web.Options
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject Microsoft.Extensions.Options.IOptions<RecaptchaOptions> RecaptchaOptions


<PageTitle>Login - MangaFlow</PageTitle>

<div class="mf-gradient-bg d-flex align-center justify-center pa-4">
    <MudContainer MaxWidth="MaxWidth.Small">
        <div class="text-center mb-6">
            <MudText Typo="Typo.h3" Class="font-weight-bold mf-gradient-text">MangaFlow</MudText>
            <MudText Typo="Typo.h6" Class="mf-muted mt-2">Welcome back to your workspace</MudText>
        </div>

        <MudPaper Class="mf-card" Elevation="8">
            <div style="background:linear-gradient(90deg,#4f46e5,#9333ea); border-radius:22px 22px 0 0" class="pa-6 text-center">
                <MudText Typo="Typo.h5" Class="font-weight-bold text-white">Login to Your Account</MudText>
            </div>
            <div class="pa-8">
                @if (!string.IsNullOrWhiteSpace(_pageAlertMessage))
                {
                    <MudAlert Severity="@_pageAlertSeverity" Class="mb-4">
                        @_pageAlertMessage
                    </MudAlert>
                }
                <form action="/api/auth/login" method="post" data-enhance="false" class="login-form">
                    <AntiforgeryToken />
                    <MudStack Spacing="3">
                        <div class="login-form__field">
                            <label class="login-form__label" for="username">Username or Email</label>
                            <input id="username"
                                   name="username"
                                   type="text"
                                   class="login-form__input"
                                   required
                                   autocomplete="username" />
                        </div>
                        <div class="login-form__field">
                            <label class="login-form__label" for="password">Password</label>
                            <div class="login-form__password-wrapper">
                                <input id="password"
                                       name="password"
                                       type="@LoginPasswordInputType"
                                       class="login-form__input login-form__input--password"
                                       required
                                       autocomplete="current-password" />
                                <button type="button"
                                        class="login-form__password-toggle"
                                        aria-label="@LoginPasswordToggleLabel"
                                        title="@LoginPasswordToggleLabel"
                                        @onclick="ToggleLoginPasswordVisibility">
                                    <MudIcon Icon="@LoginPasswordToggleIcon" Size="Size.Medium" />
                                </button>
                            </div>
                        </div>
                        <MudText Align="Align.Right"><MudLink Href="/forgot-password">Forgot Password?</MudLink></MudText>
                        <div id="login-recaptcha" class="my-2 d-flex justify-center"></div>
                        <button type="submit" class="login-form__submit">
                            Login
                        </button>
                    </MudStack>
                </form>

                <MudDivider Class="my-4" />

                <form action="/api/auth/google-login" method="post" data-enhance="false">
                    <AntiforgeryToken />
                    <button type="submit" class="google-auth-button">
                        <span class="google-auth-button__content">
                            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                                 alt=""
                                 width="18"
                                 height="18"
                                 class="google-auth-button__icon" />
                            <span>Login with Google</span>
                        </span>
                    </button>
                </form>

                <MudDivider Class="my-4" />
                <MudText Align="Align.Center">
                    Don't have an account? <MudLink Href="/register">Create Account</MudLink>
                </MudText>
            </div>
        </MudPaper>

        <MudText Align="Align.Center" Class="mt-4"><MudLink Href="/">Back to Home</MudLink></MudText>
    </MudContainer>
</div>

<style>
    .login-form__field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .login-form__label {
        font-size: 0.75rem;
        font-weight: 500;
        color: rgba(0, 0, 0, 0.6);
    }

    .login-form__input {
        width: 100%;
        padding: 16px 14px;
        border: 1px solid rgba(0, 0, 0, 0.23);
        border-radius: 4px;
        font-size: 1rem;
        font-family: inherit;
        box-sizing: border-box;
    }

    .login-form__input:focus {
        outline: 2px solid #594ae2;
        border-color: #594ae2;
    }

    .login-form__submit {
        width: 100%;
        padding: 14px 16px;
        border: none;
        border-radius: 4px;
        background: #594ae2;
        color: #fff;
        font-size: 0.875rem;
        font-weight: 500;
        letter-spacing: 0.0892857143em;
        text-transform: uppercase;
        cursor: pointer;
        margin-top: 8px;
    }

    .login-form__submit:hover {
        background: #4a3ec9;
    }

    .google-auth-button {
        display: block;
        width: 100%;
        padding: 10px 16px;
        border: 1px solid #dadce0;
        border-radius: 4px;
        background: #fff;
        color: #3c4043;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-transform: none;
    }

    .google-auth-button:hover {
        background: #f8f9fa;
    }

    .google-auth-button__content {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        font-weight: 500;
    }

    .google-auth-button__icon {
        display: block;
    }

    .login-form__password-wrapper {
        position: relative;
        width: 100%;
        display: block;
    }

    .login-form__input--password {
        padding-right: 54px;
    }

    .login-form__password-toggle {
        position: absolute;
        top: 50%;
        right: 10px;
        transform: translateY(-50%);
        width: 38px;
        height: 38px;
        padding: 0;
        border: none;
        border-radius: 50%;
        background: transparent;
        color: rgba(0, 0, 0, 0.58);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        z-index: 2;
    }

    .login-form__password-toggle:hover {
        background: rgba(89, 74, 226, 0.08);
        color: #594ae2;
    }
</style>

@code {
    private string? _pageAlertMessage;
    private Severity _pageAlertSeverity = Severity.Info;
    private bool _showLoginPassword;

    private string LoginPasswordInputType =>
        _showLoginPassword
            ? "text"
            : "password";

    private string LoginPasswordToggleIcon =>
        _showLoginPassword
            ? Icons.Material.Filled.VisibilityOff
            : Icons.Material.Filled.Visibility;

    private string LoginPasswordToggleLabel =>
        _showLoginPassword
            ? "Hide password"
            : "Show password";

    private void ToggleLoginPasswordVisibility()
    {
        _showLoginPassword =
            !_showLoginPassword;
    }

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
if (query.TryGetValue("error", out var error))
        {
            var errorCode =
                error.ToString()
                    .Trim()
                    .ToLowerInvariant();

            _pageAlertMessage =
                errorCode switch
                {
                    AuthErrorCodes.GoogleOAuthFailed =>
                        "Google sign-in could not be completed. Please try again.",

                    AuthErrorCodes.GoogleEmailMissing =>
                        "Google did not return an email address for this account. Try another Google account or use email login.",

                    AuthErrorCodes.AccountNotFound =>
                        "No active account was found for this Google email. Register first or contact an administrator.",

                    AuthErrorCodes.AccountPending =>
                        "Your account has been created and is waiting for Admin approval.",

                    AuthErrorCodes.AccountDisabled =>
                        "This account has been disabled. Please contact an Admin.",

                    AuthErrorCodes.AccountRejected =>
                        "This account registration was rejected. Please contact an Admin for more information.",

                    AuthErrorCodes.AccountConfigurationInvalid =>
                        "This account is not configured correctly. Please contact support.",

                    AuthErrorCodes.RecaptchaFailed =>
                        "reCAPTCHA verification failed. Please complete the captcha.",

                    _ =>
                        "Username/email or password is incorrect."
                };

            _pageAlertSeverity =
                errorCode is
                    AuthErrorCodes.InvalidCredentials
                    or AuthErrorCodes.RecaptchaFailed
                    ? Severity.Error
                    : Severity.Warning;
        }
    }

    private int? _recaptchaWidgetId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var siteKey = RecaptchaOptions.Value.SiteKey;
                _recaptchaWidgetId = await JSRuntime.InvokeAsync<int?>("recaptchaInterop.render", "login-recaptcha", siteKey);
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error rendering login reCAPTCHA: " + ex.Message);
            }
        }
    }
}
