@page "/workspace/tasks/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Mangaka,Tantou Editor,Assistant")]
@inject NavigationManager Nav
@inject MangaManagementSystem.Web.Services.Api.IAssistantTaskApiClient AssistantTaskApi
@inject MangaManagementSystem.Web.Services.Api.IMangakaTaskApiClient MangakaTaskApi
@inject AuthenticationStateProvider AuthStateProvider

@if (!string.IsNullOrWhiteSpace(_redirectUrl))
{
    <div style="padding: 32px; text-align: center; color: #64748b; font-size: 0.9rem;">
        Redirecting to workspace...
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="max-width: 480px; margin: 64px auto; text-align: center; padding: 32px;">
        <div style="font-size: 48px; color: #cbd5e1; margin-bottom: 16px;">
            <svg style="width: 48px; height: 48px; margin: 0 auto; display: block;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
        </div>
        <div style="font-weight: 700; font-size: 1.1rem; color: #111827; margin-bottom: 8px;">Unable to open workspace</div>
        <div style="color: #64748b; font-size: 0.9rem; margin-bottom: 24px;">@_error</div>
        @if (!string.IsNullOrWhiteSpace(_returnUrl))
        {
            <a href="@_returnUrl" style="color: #4f46e5; font-weight: 500; text-decoration: none;">&larr; Go back</a>
        }
        else
        {
            <a href="/assistant/tasks" style="color: #4f46e5; font-weight: 500; text-decoration: none;">&larr; Back to Tasks</a>
        }
    </div>
}
else
{
    <div style="padding: 32px; text-align: center; color: #94a3b8; font-size: 0.85rem;">
        Loading task...
    </div>
}

@code {
    [Parameter] public Guid TaskId { get; set; }
    [SupplyParameterFromQuery] public string? returnUrl { get; set; }

    private string? _redirectUrl;
    private string? _error;
    private string? _returnUrl;

    protected override async Task OnInitializedAsync()
    {
        _returnUrl = returnUrl;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated != true)
            {
                _error = "You must be logged in to access the workspace.";
                return;
            }

            var userIdStr = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!Guid.TryParse(userIdStr, out var userId))
            {
                _error = "Invalid user identification.";
                return;
            }

            _returnUrl ??= GetDefaultReturnUrl(user);

            var task = await ResolveTaskForCurrentUserAsync(user, userId);
            if (task is null)
            {
                _error = BuildTaskLookupError(user);
                return;
            }

            if (string.IsNullOrWhiteSpace(task.SeriesSlug))
            {
                _error = "Task is missing series information.";
                return;
            }

            string queryParams = $"?taskId={TaskId}";

            if (task.ChapterId.HasValue)
            {
                queryParams += $"&chapterId={task.ChapterId.Value}";
            }

            if (!string.IsNullOrWhiteSpace(_returnUrl))
            {
                queryParams += $"&returnUrl={Uri.EscapeDataString(_returnUrl)}";
            }

            _redirectUrl = $"/series/{task.SeriesSlug}/workspace{queryParams}";
            Nav.NavigateTo(_redirectUrl);
        }
        catch (Exception ex)
        {
            _error = $"An error occurred: {ex.Message}";
        }
    }

    private async Task<MangaManagementSystem.Application.DTOs.Manga.ChapterPageTaskDto?> ResolveTaskForCurrentUserAsync(
        ClaimsPrincipal user,
        Guid userId)
    {
        if (user.IsInRole("Assistant"))
        {
            return await AssistantTaskApi.GetTaskDetailAsync(userId, TaskId);
        }

        return await MangakaTaskApi.GetTaskDetailAsync(userId, TaskId);
    }

    private static string GetDefaultReturnUrl(ClaimsPrincipal user)
    {
        if (user.IsInRole("Assistant"))
        {
            return "/assistant/tasks";
        }

        if (user.IsInRole("Mangaka"))
        {
            return "/mangaka/review-submissions";
        }

        if (user.IsInRole("Tantou Editor"))
        {
            return "/editor/chapters";
        }

        return "/";
    }

    private string BuildTaskLookupError(ClaimsPrincipal user)
    {
        if (user.IsInRole("Assistant"))
        {
            return $"Task {TaskId} was not found in the current assistant assignment list.";
        }

        if (user.IsInRole("Tantou Editor"))
        {
            return $"Task {TaskId} could not be resolved for the current editor account through this workspace redirect.";
        }

        return $"Task {TaskId} was not found for the current user.";
    }
}
