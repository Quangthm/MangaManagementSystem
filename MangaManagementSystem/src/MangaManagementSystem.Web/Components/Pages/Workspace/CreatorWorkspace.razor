    {
        "ASSIGNED" => "#eff6ff",
        "UNDER_REVIEW" => "#fef3c7",
        "COMPLETED" => "#f0fdf4",
        "CANCELLED" => "#f1f5f9",
        _ => "#f1f5f9"
    };

    private static string GetTaskStatusText(string? status) => status switch
    {
        "ASSIGNED" => "#1e40af",
        "UNDER_REVIEW" => "#92400e",
        "COMPLETED" => "#166534",
        "CANCELLED" => "#64748b",
