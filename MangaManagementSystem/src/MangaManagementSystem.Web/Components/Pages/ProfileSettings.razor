    {
        _avatarPreviewDataUrl = null;
        _selectedAvatarBytes = null;
        _selectedAvatarFileName = null;
        _selectedAvatarUploadFileName = null;
        _selectedAvatarSizeLabel = null;
        _selectedAvatarContentType = "image/jpeg";
    }

