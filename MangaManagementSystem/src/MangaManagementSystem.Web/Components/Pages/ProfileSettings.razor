@page "/profile/settings"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.IO
@using System.Text.Json
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.Interfaces
@attribute [Authorize]

@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IFileResourceService FileResourceService
@inject IFileStorageService FileStorageService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager

<PageTitle>Profile Settings - MangaFlow</PageTitle>

<div class="mf-settings-page">
    <section class="mf-settings-shell">
        <div class="mf-page-heading">
            <div>
                <MudText Typo="Typo.h4" Class="font-weight-bold">Profile Settings</MudText>
                <MudText Typo="Typo.body2" Class="mf-muted">
                    Manage your account information, portfolio document, and password security.
                </MudText>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="mf-loading-box">
                <MudProgressCircular Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mf-muted">Loading profile...</MudText>
            </div>
        }
        else if (_currentUser == null)
        {
            <MudAlert Severity="Severity.Error">
                Unable to load current user. Please login again.
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_operationMessage))
            {
                <MudAlert Severity="@_operationSeverity" Dense="true" Class="mb-3">
                    @_operationMessage
                </MudAlert>
            }

            <MudPaper Class="mf-account-panel">
                <aside class="mf-settings-menu">
                    <div class="mf-menu-user">
                        <div class="mf-menu-avatar">
                            @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                            {
                                <img src="@_avatarUrl" alt="User avatar" />
                            }
                            else
                            {
                                <span>@_avatarInitial</span>
                            }
                        </div>

                        <div class="mf-menu-user-meta">
                            <strong>@_currentUser.DisplayName</strong>
                            <span>@_currentUser.Username</span>
                            <span>@_currentUser.Email</span>
                        </div>
                    </div>

                    <div class="mf-menu-divider"></div>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Profile)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Profile)">
                        <span>Profile</span>
                        <small>Identity and avatar</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Portfolio)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Portfolio)">
                        <span>Portfolio</span>
                        <small>PDF, DOC, DOCX</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Security)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Security)">
                        <span>Security</span>
                        <small>Password OTP</small>
                    </button>
                </aside>

                <main class="mf-settings-content">
                    <div class="mf-content-header">
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentSectionTitle</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">@CurrentSectionDescription</MudText>
                        </div>

                        <div class="mf-status-line">
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                @_currentRoleName
                            </MudChip>

                            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                                @_currentUser.StatusCode
                            </MudChip>
                        </div>
                    </div>

                    @if (_activeSection == ProfileSettingsSection.Profile)
                    {
                        <div class="mf-profile-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">Avatar</MudText>

                                <div class="mf-avatar-editor">
                                    <div class="mf-avatar-preview">
                                        @if (!string.IsNullOrWhiteSpace(_avatarPreviewDataUrl))
                                        {
                                            <img src="@_avatarPreviewDataUrl" alt="Selected avatar preview" />
                                        }
                                        else if (!string.IsNullOrWhiteSpace(_avatarUrl))
                                        {
                                            <img src="@_avatarUrl" alt="Current avatar preview" />
                                        }
                                        else
                                        {
                                            <span>@_avatarInitial</span>
                                        }
                                    </div>

                                    <div class="mf-avatar-actions">
                                        <label class="mf-upload-button">
                                            <InputFile OnChange="SelectAvatarAsync"
                                                       accept="image/png,image/jpeg,image/jpg,image/webp"
                                                       class="mf-file-input-hidden" />
                                            Choose Image
                                        </label>

                                        <MudText Typo="Typo.caption" Class="mf-muted">
                                            PNG, JPG, JPEG, WEBP · max 10MB · recommended 512x512px.
                                        </MudText>

                                        @if (!string.IsNullOrWhiteSpace(_selectedAvatarFileName))
                                        {
                                            <div class="mf-selected-file">
                                                <strong>@_selectedAvatarFileName</strong>
                                                <span>@_selectedAvatarSizeLabel</span>
                                            </div>
                                        }

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Disabled="@(_isBusy || _selectedAvatarBytes == null)"
                                                   OnClick="UploadAvatarDirectAsync">
                                            Upload Avatar
                                        </MudButton>
                                    </div>
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-3">Account Information</MudText>

                                <div class="mf-form-grid">
                                    <MudTextField T="string"
                                                  Value="@_currentUser.Username"
                                                  Label="Username"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.Email"
                                                  Label="Email"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentRoleName"
                                                  Label="Role"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.StatusCode"
                                                  Label="Status"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <div class="mf-form-full">
                                        <MudTextField T="string"
                                                      @bind-Value="_displayName"
                                                      Label="Display Name"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      Disabled="@_isBusy" />
                                    </div>
                                </div>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="UpdateDisplayNameDirectAsync"
                                           Class="mt-3">
                                    Save Display Name
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Portfolio)
                    {
                        <div class="mf-portfolio-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Current Portfolio</MudText>

                                <div class="mf-document-current">
                                    @if (!string.IsNullOrWhiteSpace(_portfolioUrl))
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">@_portfolioTypeLabel</span>

                                            <div class="mf-document-body">
                                                <strong>@(string.IsNullOrWhiteSpace(_portfolioFileName) ? "Portfolio document linked" : _portfolioFileName)</strong>
                                                <span>Current portfolio document is linked to this account.</span>
                                            </div>
                                        </div>

                                        <MudButton Href="@_portfolioUrl"
                                                   Target="_blank"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Class="mt-3">
                                            Open Current Portfolio
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">FILE</span>

                                            <div class="mf-document-body">
                                                <strong>No portfolio document</strong>
                                                <span>Upload a PDF, DOC, or DOCX file to link a portfolio to this account.</span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Upload Portfolio Document</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Accepted formats: PDF, DOC, DOCX. Maximum file size: 10MB.
                                </MudText>

                                <label class="mf-document-dropzone">
                                    <InputFile OnChange="SelectPortfolioAsync"
                                               accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.pdf,.doc,.docx"
                                               class="mf-file-input-hidden" />
                                    <span>Choose Document</span>
                                    <small>PDF, DOC, DOCX · max 10MB</small>
                                </label>

                                @if (!string.IsNullOrWhiteSpace(_selectedPortfolioFileName))
                                {
                                    <div class="mf-selected-file mt-3">
                                        <strong>@_selectedPortfolioFileName</strong>
                                        <span>@_selectedPortfolioSizeLabel</span>
                                    </div>
                                }

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@(_isBusy || _selectedPortfolioBytes == null)"
                                           OnClick="UploadPortfolioDirectAsync"
                                           Class="mt-3">
                                    Upload Portfolio
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Security)
                    {
                        <div class="mf-security-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Reset Password</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Email OTP is required to confirm password reset.
                                </MudText>

                                <MudTextField T="string"
                                              @bind-Value="_newPassword"
                                              Label="New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy" />

                                <MudTextField T="string"
                                              @bind-Value="_confirmPassword"
                                              Label="Confirm New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy"
                                              Class="mt-3" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="SendOtpForPasswordAsync"
                                           Class="mt-3">
                                    Send OTP
                                </MudButton>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">OTP Confirmation</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Code will be sent to <strong>@_currentUser.Email</strong>.
                                </MudText>

                                @if (_otpSentForPassword)
                                {
                                    <MudTextField T="string"
                                                  @bind-Value="_otpCodePassword"
                                                  Label="OTP Code"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="6"
                                                  Disabled="@_isBusy" />

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               Disabled="@_isBusy"
                                               OnClick="ConfirmPasswordResetAsync"
                                               Class="mt-3">
                                        Confirm Reset
                                    </MudButton>
                                }
                                else
                                {
                                    <div class="mf-empty-note">
                                        Enter a new password and request OTP.
                                    </div>
                                }
                            </section>
                        </div>
                    }
                </main>
            </MudPaper>
        }
    </section>
</div>

@code {
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private const string ActionPasswordOtp = "PROFILE_PASSWORD_RESET";

    private const string AuditDisplayNameUpdated = "USER_PROFILE_DISPLAY_NAME_UPDATED";
    private const string AuditAvatarUpdated = "USER_PROFILE_AVATAR_UPDATED";
    private const string AuditPortfolioUpdated = "USER_PROFILE_PORTFOLIO_UPDATED";
    private const string AuditPasswordReset = "USER_PROFILE_PASSWORD_RESET";

    private bool _isLoading = true;
    private bool _isBusy;

    private UserDto? _currentUser;
    private Guid _currentUserId;
    private string _currentRoleName = "User";

    private string _displayName = string.Empty;
    private string _avatarInitial = "?";
    private string? _avatarUrl;
    private string? _portfolioUrl;
    private string? _portfolioFileName;
    private string _portfolioTypeLabel = "FILE";

    private string? _operationMessage;
    private Severity _operationSeverity = Severity.Info;

    private string? _avatarPreviewDataUrl;
    private byte[]? _selectedAvatarBytes;
    private string? _selectedAvatarFileName;
    private string? _selectedAvatarUploadFileName;
    private string? _selectedAvatarSizeLabel;
    private string _selectedAvatarContentType = "image/jpeg";

    private string? _selectedPortfolioFileName;
    private string? _selectedPortfolioUploadFileName;
    private string? _selectedPortfolioSizeLabel;
    private byte[]? _selectedPortfolioBytes;
    private string? _selectedPortfolioContentType;

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _otpSentForPassword;
    private string _otpCodePassword = string.Empty;

    private ProfileSettingsSection _activeSection = ProfileSettingsSection.Profile;

    private string CurrentSectionTitle => _activeSection switch
    {
        ProfileSettingsSection.Profile => "Profile",
        ProfileSettingsSection.Portfolio => "Portfolio Document",
        ProfileSettingsSection.Security => "Security",
        _ => "Profile"
    };

    private string CurrentSectionDescription => _activeSection switch
    {
        ProfileSettingsSection.Profile => "Update your display name and profile picture.",
        ProfileSettingsSection.Portfolio => "Manage your PDF, DOC, or DOCX portfolio document.",
        ProfileSettingsSection.Security => "Reset password with email OTP confirmation.",
        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
    }

    private void SelectSection(ProfileSettingsSection section)
    {
        _activeSection = section;
        _operationMessage = null;
    }

    private string GetMenuClass(ProfileSettingsSection section)
    {
        return _activeSection == section
            ? "mf-menu-item active"
            : "mf-menu-item";
    }

    private async Task LoadCurrentUserAsync()
    {
        _isLoading = true;
        _operationMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            var idClaim = principal.FindFirst(ClaimTypes.NameIdentifier);

            if (!Guid.TryParse(idClaim?.Value, out _currentUserId))
            {
                SetOperation("Unable to resolve current user id.", Severity.Error);
                return;
            }

            _currentUser = await UserService.GetUserByIdAsync(_currentUserId);

            if (_currentUser == null)
            {
                SetOperation("Unable to load current user profile.", Severity.Error);
                return;
            }

            _currentRoleName =
                principal.FindFirst(ClaimTypes.Role)?.Value
                ?? principal.FindFirst("role")?.Value
                ?? _currentUser.RoleName
                ?? "User";

            _displayName = _currentUser.DisplayName;
            _avatarInitial = BuildInitial(_currentUser.DisplayName, _currentUser.Username);

            await LoadCurrentFilesAsync();
        }
        catch (Exception ex)
        {
            SetOperation(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCurrentFilesAsync()
    {
        _avatarUrl = null;
        _portfolioUrl = null;
        _portfolioFileName = null;
        _portfolioTypeLabel = "FILE";

        if (_currentUser?.AvatarFileId.HasValue == true)
        {
            var avatarFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.AvatarFileId.Value);

            if (avatarFile != null &&
                avatarFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(avatarFile.CloudinarySecureUrl))
            {
                _avatarUrl = BuildVersionedUrl(avatarFile.CloudinarySecureUrl, avatarFile.FileResourceId);
            }
        }

        if (_currentUser?.PortfolioFileId.HasValue == true)
        {
            var portfolioFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.PortfolioFileId.Value);

            if (portfolioFile != null &&
                portfolioFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(portfolioFile.CloudinarySecureUrl))
            {
                _portfolioUrl = BuildVersionedUrl(portfolioFile.CloudinarySecureUrl, portfolioFile.FileResourceId);
                _portfolioFileName = portfolioFile.OriginalFileName;
                _portfolioTypeLabel = BuildDocumentTypeLabel(portfolioFile.OriginalFileName, portfolioFile.ContentType);
            }
        }
    }

    private async Task UpdateDisplayNameDirectAsync()
    {
        if (_currentUser == null)
        {
            return;
        }

        var trimmed = _displayName.Trim();

        if (string.IsNullOrWhiteSpace(trimmed))
        {
            SetOperation("Display name cannot be empty.", Severity.Warning);
            return;
        }

        if (string.Equals(trimmed, _currentUser.DisplayName, StringComparison.Ordinal))
        {
            SetOperation("Display name is unchanged.", Severity.Info);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldDisplayName = _currentUser.DisplayName;

            var updated = await UserService.UpdateDisplayNameAsync(
                _currentUserId,
                trimmed);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditDisplayNameUpdated,
                JsonSerializer.Serialize(new
                {
                    oldDisplayName,
                    newDisplayName = trimmed,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;
            _displayName = updated.DisplayName;
            _avatarInitial = BuildInitial(updated.DisplayName, updated.Username);

            SetOperation("Display name updated successfully.", Severity.Success);
            Snackbar.Add("Display name updated successfully.", Severity.Success);
        });
    }

    private async Task SelectAvatarAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;

        if (file == null)
        {
            return;
        }

        if (!IsSupportedAvatarFile(file.Name, file.ContentType))
        {
            SetOperation("Avatar must be PNG, JPG, JPEG, or WEBP.", Severity.Warning);
            return;
        }

        if (file.Size > MaxUploadBytes)
        {
            SetOperation("Avatar file must be 10MB or smaller.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var bytes = await ReadFileBytesAsync(file);
            var normalizedContentType = NormalizeAvatarContentType(file.Name, file.ContentType);

            _selectedAvatarBytes = bytes;
            _selectedAvatarFileName = Path.GetFileName(file.Name);
            _selectedAvatarUploadFileName = BuildUniqueStoredFileName(file.Name, "avatar");
            _selectedAvatarSizeLabel = FormatFileSize(file.Size);
            _selectedAvatarContentType = normalizedContentType;
            _avatarPreviewDataUrl = BuildDataUrl(normalizedContentType, bytes);

            SetOperation("Avatar selected. Upload when ready.", Severity.Info);
        });
    }

    private async Task UploadAvatarDirectAsync()
    {
        if (_selectedAvatarBytes == null ||
            string.IsNullOrWhiteSpace(_selectedAvatarUploadFileName) ||
            string.IsNullOrWhiteSpace(_selectedAvatarFileName))
        {
            SetOperation("Please select an avatar image first.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldAvatarFileId = _currentUser?.AvatarFileId;
            var displayFileName = _selectedAvatarFileName!;

            var upload = await FileStorageService.UploadFileAsync(
                _selectedAvatarBytes,
                _selectedAvatarUploadFileName,
                _selectedAvatarContentType,
                "USER_AVATAR");

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    "USER_AVATAR",
                    displayFileName,
                    upload.PublicId,
                    upload.SecureUrl,
                    upload.ContentType,
                    upload.FileSizeBytes,
                    upload.Sha256Hash,
                    _currentUserId));

            var updated = await UserService.UpdateAvatarFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditAvatarUpdated,
                JsonSerializer.Serialize(new
                {
                    oldAvatarFileId,
                    newAvatarFileId = fileResource.FileResourceId,
                    fileName = displayFileName,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;
            _avatarUrl = BuildVersionedUrl(fileResource.CloudinarySecureUrl, fileResource.FileResourceId);

            ClearAvatarSelection();

            SetOperation("Avatar uploaded successfully.", Severity.Success);
            Snackbar.Add("Avatar uploaded successfully.", Severity.Success);
        });
    }

    private async Task SelectPortfolioAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;

        if (file == null)
        {
            return;
        }

        if (!IsSupportedPortfolioFile(file.Name, file.ContentType))
        {
            SetOperation("Portfolio must be PDF, DOC, or DOCX.", Severity.Warning);
            return;
        }

        if (file.Size > MaxUploadBytes)
        {
            SetOperation("Portfolio file must be 10MB or smaller.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var bytes = await ReadFileBytesAsync(file);

            _selectedPortfolioFileName = Path.GetFileName(file.Name);
            _selectedPortfolioUploadFileName = BuildUniqueStoredFileName(file.Name, "portfolio");
            _selectedPortfolioSizeLabel = FormatFileSize(file.Size);
            _selectedPortfolioContentType = NormalizePortfolioContentType(file.Name, file.ContentType);
            _selectedPortfolioBytes = bytes;

            SetOperation("Portfolio document selected. Upload when ready.", Severity.Info);
        });
    }

    private async Task UploadPortfolioDirectAsync()
    {
        if (_selectedPortfolioBytes == null ||
            string.IsNullOrWhiteSpace(_selectedPortfolioUploadFileName) ||
            string.IsNullOrWhiteSpace(_selectedPortfolioFileName) ||
            string.IsNullOrWhiteSpace(_selectedPortfolioContentType))
        {
            SetOperation("Please select a portfolio document first.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldPortfolioFileId = _currentUser?.PortfolioFileId;
            var displayFileName = _selectedPortfolioFileName!;
            var displayContentType = _selectedPortfolioContentType!;

            var upload = await FileStorageService.UploadFileAsync(
                _selectedPortfolioBytes,
                _selectedPortfolioUploadFileName,
                displayContentType,
                "REGISTRATION_PORTFOLIO");

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    "REGISTRATION_PORTFOLIO",
                    displayFileName,
                    upload.PublicId,
                    upload.SecureUrl,
                    upload.ContentType,
                    upload.FileSizeBytes,
                    upload.Sha256Hash,
                    _currentUserId));

            var updated = await UserService.UpdatePortfolioFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditPortfolioUpdated,
                JsonSerializer.Serialize(new
                {
                    oldPortfolioFileId,
                    newPortfolioFileId = fileResource.FileResourceId,
                    fileName = displayFileName,
                    contentType = fileResource.ContentType,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;

            _portfolioUrl = BuildVersionedUrl(fileResource.CloudinarySecureUrl, fileResource.FileResourceId);
            _portfolioFileName = displayFileName;
            _portfolioTypeLabel = BuildDocumentTypeLabel(displayFileName, fileResource.ContentType);

            ClearPortfolioSelection();

            SetOperation("Portfolio uploaded successfully.", Severity.Success);
            Snackbar.Add("Portfolio uploaded successfully.", Severity.Success);

            StateHasChanged();
        });
    }

    private async Task SendOtpForPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            SetOperation("New password cannot be empty.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            SetOperation("New password must be at least 8 characters.", Severity.Warning);
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            SetOperation("Confirm password does not match.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            await UserService.SendProfileOtpAsync(_currentUserId, ActionPasswordOtp);

            _otpSentForPassword = true;
            _otpCodePassword = string.Empty;

            SetOperation("OTP sent to your registered email.", Severity.Info);
            Snackbar.Add("OTP sent to your registered email.", Severity.Info);
        });
    }

    private async Task ConfirmPasswordResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_otpCodePassword))
        {
            SetOperation("OTP code is required.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var verified = await UserService.VerifyProfileOtpAsync(
                _currentUserId,
                ActionPasswordOtp,
                _otpCodePassword);

            if (!verified)
            {
                SetOperation("Invalid or expired OTP.", Severity.Error);
                return;
            }

            await UserService.ResetPasswordAsync(_currentUserId, _newPassword);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditPasswordReset,
                JsonSerializer.Serialize(new
                {
                    confirmedBy = "EMAIL_OTP",
                    passwordChanged = true
                }));

            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
            _otpSentForPassword = false;
            _otpCodePassword = string.Empty;

            SetOperation("Password reset successfully.", Severity.Success);
            Snackbar.Add("Password reset successfully.", Severity.Success);
        });
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            SetOperation(ex.Message, Severity.Error);
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

