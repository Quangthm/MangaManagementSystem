@using System.Globalization
@using Microsoft.JSInterop
@using SixLabors.ImageSharp.Processing
@page "/profile/settings"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.IO
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.Interfaces
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize]
@implements IAsyncDisposable

@inject AuthenticationStateProvider AuthStateProvider
@inject IProfileApiClient ProfileApiClient
@inject IProfilePasswordApiClient ProfilePasswordApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime


<PageTitle>Profile Settings - MangaFlow</PageTitle>

<div class="mf-settings-page">
    <section class="mf-settings-shell">
        <div class="mf-page-heading">
            <div class="mf-page-heading-content">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mf-back-dashboard-button"
                           OnClick="BackToDashboard">
                    ← Back to Dashboard
                </MudButton>

                <div>
                    <MudText Typo="Typo.h4"
                             Class="font-weight-bold">
                        Profile Settings
                    </MudText>

                    <MudText Typo="Typo.body2"
                             Class="mf-muted">
                        Manage your account information, portfolio document, and password security.
                    </MudText>
                </div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="mf-loading-box">
                <MudProgressCircular Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mf-muted">Loading profile...</MudText>
            </div>
        }
        else if (_currentUser == null)
        {
            <MudAlert Severity="Severity.Error">
                Unable to load current user. Please login again.
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_operationMessage))
            {
                <MudAlert Severity="@_operationSeverity" Dense="true" Class="mb-3">
                    @_operationMessage
                </MudAlert>
            }

            <MudPaper Class="mf-account-panel">
                <aside class="mf-settings-menu">
                    <div class="mf-menu-user">
                        <div class="mf-menu-avatar">
                            @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                            {
                                <img src="@_avatarUrl" alt="User avatar" />
                            }
                            else
                            {
                                <span>@_avatarInitial</span>
                            }
                        </div>

                        <div class="mf-menu-user-meta">
                            <strong>@_currentUser.DisplayName</strong>
                            <span>@_currentUser.Username</span>
                            <span>@_currentUser.Email</span>
                        </div>
                    </div>

                    <div class="mf-menu-divider"></div>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Profile)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Profile)">
                        <span>Profile</span>
                        <small>Identity and avatar</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Portfolio)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Portfolio)">
                        <span>Portfolio</span>
                        <small>PDF, DOC, DOCX</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Security)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Security)">
                        <span>Security</span>
                        <small>Password OTP</small>
                    </button>
                </aside>

                <main class="mf-settings-content">
                    <div class="mf-content-header">
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentSectionTitle</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">@CurrentSectionDescription</MudText>
                        </div>

                        <div class="mf-status-line">
                            <MudChip T="string"
                                     Color="Color.Primary"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @_currentRoleName
                            </MudChip>

                            <MudChip T="string"
                                     Color="Color.Success"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @_currentUser.StatusCode
                            </MudChip>
                        </div>
                    </div>

                    @if (_activeSection == ProfileSettingsSection.Profile)
                    {
                        <div class="mf-profile-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-3">
                                    Avatar
                                </MudText>

                                <div class="mf-avatar-editor">
                                    <div class="mf-avatar-preview">
                                        @if (!string.IsNullOrWhiteSpace(_avatarPreviewDataUrl))
                                        {
                                            <img src="@_avatarPreviewDataUrl"
                                                 alt="Selected avatar preview" />
                                        }
                                        else if (!string.IsNullOrWhiteSpace(_avatarUrl))
                                        {
                                            <img src="@_avatarUrl"
                                                 alt="Current avatar preview" />
                                        }
                                        else
                                        {
                                            <span>@_avatarInitial</span>
                                        }
                                    </div>

                                    <div class="mf-avatar-actions">
                                        <label class="mf-upload-button">
                                            <InputFile @key="_avatarInputKey"
                                                       OnChange="SelectAvatarAsync"
                                                       accept="image/png,image/jpeg,image/jpg,image/webp"
                                                       class="mf-file-input-hidden" />
                                            Choose Image
                                        </label>

                                        <MudText Typo="Typo.caption" Class="mf-muted">
                                            Choose an image, adjust its position and zoom,
                                            then upload the cropped result.
                                        </MudText>

                                        @if (!string.IsNullOrWhiteSpace(_selectedAvatarFileName))
                                        {
                                            <div class="mf-selected-file">
                                                <strong>@_selectedAvatarFileName</strong>
                                                <span>@_selectedAvatarSizeLabel</span>
                                            </div>
                                        }

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Disabled="@(_isBusy || _selectedAvatarBytes == null)"
                                                   OnClick="UploadAvatarDirectAsync">
                                            Upload Avatar
                                        </MudButton>
                                    </div>
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-3">
                                    Account Information
                                </MudText>

                                <div class="mf-form-grid">
                                    <MudTextField T="string"
                                                  Value="@_currentUser.Username"
                                                  Label="Username"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.Email"
                                                  Label="Email"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentRoleName"
                                                  Label="Role"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.StatusCode"
                                                  Label="Status"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <div class="mf-form-full">
                                        <MudTextField T="string"
                                                      @bind-Value="_displayName"
                                                      Label="Display Name"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      Disabled="@_isBusy" />
                                    </div>
                                </div>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="UpdateDisplayNameDirectAsync"
                                           Class="mt-3">
                                    Save Display Name
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Portfolio)
                    {
                        <div class="mf-portfolio-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Current Portfolio
                                </MudText>

                                <div class="mf-document-current">
                                    @if (!string.IsNullOrWhiteSpace(_portfolioUrl))
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">
                                                @_portfolioTypeLabel
                                            </span>

                                            <div class="mf-document-body">
                                                <strong>
                                                    @(string.IsNullOrWhiteSpace(_portfolioFileName)
                                                        ? "Portfolio document linked"
                                                        : _portfolioFileName)
                                                </strong>

                                                <span>
                                                    Current portfolio document is linked to this account.
                                                </span>
                                            </div>
                                        </div>

                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Class="mt-3"
                                                   OnClick="OpenCurrentPortfolioPreviewAsync">
                                            Preview Current Portfolio
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">FILE</span>

                                            <div class="mf-document-body">
                                                <strong>No portfolio document</strong>
                                                <span>
                                                    Upload a PDF, DOC, or DOCX file to link
                                                    a portfolio to this account.
                                                </span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Upload Portfolio Document
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Accepted formats: PDF, DOC, DOCX.
                                    Maximum file size: 10MB.
                                </MudText>

                                <label class="mf-document-dropzone">
                                    <InputFile OnChange="SelectPortfolioAsync"
                                               accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.pdf,.doc,.docx"
                                               class="mf-file-input-hidden" />

                                    <span>Choose Document</span>
                                    <small>PDF, DOC, DOCX · max 10MB</small>
                                </label>

                                @if (!string.IsNullOrWhiteSpace(_selectedPortfolioFileName))
                                {
                                    <div class="mf-selected-file mt-3">
                                        <strong>@_selectedPortfolioFileName</strong>
                                        <span>@_selectedPortfolioSizeLabel</span>
                                    </div>
                                }

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@(_isBusy || _selectedPortfolioBytes == null)"
                                           OnClick="UploadPortfolioDirectAsync"
                                           Class="mt-3">
                                    Upload Portfolio
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Security)
                    {
                        <div class="mf-security-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Reset Password
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Email OTP is required to confirm password reset.
                                </MudText>

                                <MudTextField T="string"
                                              @bind-Value="_newPassword"
                                              Label="New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy" />

                                <MudTextField T="string"
                                              @bind-Value="_confirmPassword"
                                              Label="Confirm New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy"
                                              Class="mt-3" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="SendOtpForPasswordAsync"
                                           Class="mt-3">
                                    Send OTP
                                </MudButton>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    OTP Confirmation
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Code will be sent to
                                    <strong>@_currentUser.Email</strong>.
                                </MudText>

                                @if (_otpSentForPassword)
                                {
                                    <MudTextField T="string"
                                                  @bind-Value="_otpCodePassword"
                                                  Label="OTP Code"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="6"
                                                  Disabled="@_isBusy" />

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               Disabled="@_isBusy"
                                               OnClick="ConfirmPasswordResetAsync"
                                               Class="mt-3">
                                        Confirm Reset
                                    </MudButton>
                                }
                                else
                                {
                                    <div class="mf-empty-note">
                                        Enter a new password and request OTP.
                                    </div>
                                }
                            </section>
                        </div>
                    }
                </main>
            </MudPaper>
        }
    </section>
</div>

@if (_showAvatarCropDialog)
{
    <div class="mf-crop-overlay"
         @onclick="CancelAvatarCropAsync">

        <section class="mf-crop-dialog"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="avatar-crop-title"
                 @onclick:stopPropagation="true">

            <header class="mf-crop-header">
                <div>
                    <h2 id="avatar-crop-title">Adjust Avatar</h2>
                    <p>
                        Drag the image to reposition it and use the slider to zoom.
                    </p>
                </div>

                <button type="button"
                        class="mf-crop-close"
                        aria-label="Close avatar crop editor"
                        disabled="@_avatarCropBusy"
                        @onclick="CancelAvatarCropAsync">
                    ×
                </button>
            </header>

            <div class="mf-crop-body">
                <div class="mf-crop-stage">
                    <canvas id="@AvatarCropCanvasId"
                            class="@(_avatarCropReady
                                                        ? "mf-crop-canvas is-ready"
                                                        : "mf-crop-canvas")"
                            width="480"
                            height="480">
                    </canvas>

                    @if (!_avatarCropReady)
                    {
                        <div class="mf-crop-loading">
                            Loading image...
                        </div>
                    }
                </div>

                <aside class="mf-crop-controls">
                    <div>
                        <strong>Square crop</strong>
                        <p>Output: 512 × 512 PNG</p>
                    </div>

                    <label for="avatar-crop-zoom">Zoom</label>

                    <div class="mf-crop-zoom-row">
                        <button type="button"
                                title="Zoom out"
                                disabled="@(!_avatarCropReady || _avatarCropBusy)"
                                @onclick="ZoomAvatarOutAsync">
                            −
                        </button>

                        <input id="avatar-crop-zoom"
                               type="range"
                               min="1"
                               max="3"
                               step="0.01"
                               value="@_avatarCropZoom.ToString(CultureInfo.InvariantCulture)"
                               disabled="@(!_avatarCropReady || _avatarCropBusy)"
                               @oninput="AvatarCropZoomChangedAsync" />

                        <button type="button"
                                title="Zoom in"
                                disabled="@(!_avatarCropReady || _avatarCropBusy)"
                                @onclick="ZoomAvatarInAsync">
                            +
                        </button>
                    </div>

                    <button type="button"
                            class="mf-crop-reset"
                            disabled="@(!_avatarCropReady || _avatarCropBusy)"
                            @onclick="ResetAvatarCropAsync">
                        Reset position and zoom
                    </button>

                    <div class="mf-crop-help">
                        <span>Drag the image inside the fixed square.</span>
                        <span>The circular border shows the final avatar view.</span>
                    </div>
                </aside>
            </div>

            <footer class="mf-crop-footer">
                <button type="button"
                        class="mf-crop-cancel"
                        disabled="@_avatarCropBusy"
                        @onclick="CancelAvatarCropAsync">
                    Cancel
                </button>

                <button type="button"
                        class="mf-crop-confirm"
                        disabled="@(!_avatarCropReady || _avatarCropBusy)"
                        @onclick="ConfirmAvatarCropAsync">
                    @(_avatarCropBusy
                        ? "Processing..."
                        : "Use This Image")
                </button>
            </footer>
        </section>
    </div>
}

@if (_showPortfolioPreview && _currentPortfolio != null)
{
    <MudDialog @bind-Visible="_showPortfolioPreview"
               Options="_portfolioPreviewDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6" Class="font-weight-bold">
                <MudIcon Icon="@Icons.Material.Filled.Preview"
                         Class="mr-2" />
                Portfolio Preview - @_currentPortfolio.OriginalFileName
            </MudText>
        </TitleContent>

        <DialogContent>
            @if (_isImagePreview)
            {
                <div class="d-flex justify-center my-2">
                    <MudImage Src="@_currentPortfolio.CloudinarySecureUrl"
                              Alt="Portfolio Image"
                              Fluid="true"
                              Class="rounded"
                              Style="max-height: 60vh; object-fit: contain;" />
                </div>
            }
            else
            {
                <div style="height: 80vh;">
                    <MudText Typo="Typo.caption"
                             Class="mf-muted text-center mb-2">
                        If the document does not load,
                        <MudLink Href="@($"/api/portfolio/{_currentPortfolio.FileResourceId}")"
                                 Target="_blank">
                            click here to open it in a new tab
                        </MudLink>.
                    </MudText>

                    <iframe src="@($"/api/portfolio/{_currentPortfolio.FileResourceId}")"
                            width="100%"
                            style="height: calc(80vh - 80px); border: none; border-radius: 4px; position: relative; z-index: 0;">
                    </iframe>
                </div>
            }
        </DialogContent>
    </MudDialog>
}


<style>
    .mf-settings-page {
        width: 100%;
        padding: 18px 24px;
        background: #f8fafc;
        min-height: calc(100vh - 24px);
    }

    .mf-settings-shell {
        width: min(100%, 1320px);
        margin: 0 auto;
    }

    .mf-page-heading-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .mf-back-dashboard-button {
        margin-left: -10px;
        margin-bottom: 6px;
        padding-left: 10px;
        padding-right: 10px;
        border-radius: 9px;
        font-weight: 700;
        text-transform: none;
    }

        .mf-back-dashboard-button:hover {
            background: #eef2ff;
        }

    .mf-page-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 16px;
    }

    .mf-muted {
        color: #64748b;
    }

    .mf-account-panel {
        display: grid;
        grid-template-columns: 300px minmax(0, 1fr);
        min-height: 610px;
        border: 1px solid #e5e7eb;
        border-radius: 24px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 14px 32px rgba(15, 23, 42, 0.08);
    }

    .mf-settings-menu {
        padding: 22px;
        border-right: 1px solid #e5e7eb;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    }

    .mf-menu-user {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 18px;
    }

    .mf-menu-avatar {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        font-weight: 800;
        border: 3px solid #ffffff;
        box-shadow: 0 10px 20px rgba(79, 70, 229, 0.18);
        flex: 0 0 auto;
    }

        .mf-menu-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .mf-menu-user-meta {
        min-width: 0;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .mf-menu-user-meta strong {
            color: #0f172a;
            font-size: 15px;
            line-height: 1.2;
            word-break: break-word;
        }

        .mf-menu-user-meta span {
            color: #64748b;
            font-size: 12px;
            word-break: break-word;
        }

    .mf-menu-divider {
        height: 1px;
        background: #e5e7eb;
        margin: 14px 0 18px;
    }

    .mf-menu-item {
        width: 100%;
        border: 0;
        background: transparent;
        text-align: left;
        padding: 13px 14px;
        border-radius: 14px;
        margin-bottom: 8px;
        cursor: pointer;
        display: flex;
        flex-direction: column;
        gap: 3px;
        transition: background .15s ease, color .15s ease, box-shadow .15s ease;
    }

        .mf-menu-item span {
            color: #0f172a;
            font-weight: 800;
            font-size: 14px;
        }

        .mf-menu-item small {
            color: #64748b;
            font-size: 12px;
        }

        .mf-menu-item:hover {
            background: #eef2ff;
        }

        .mf-menu-item.active {
            background: #4f46e5;
            box-shadow: 0 10px 18px rgba(79, 70, 229, 0.22);
        }

            .mf-menu-item.active span,
            .mf-menu-item.active small {
                color: #ffffff;
            }

    .mf-settings-content {
        padding: 24px;
        min-width: 0;
    }

    .mf-content-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 18px;
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 20px;
    }

    .mf-status-line {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }

    .mf-profile-grid,
    .mf-security-grid,
    .mf-portfolio-grid {
        display: grid;
        grid-template-columns: minmax(340px, .85fr) minmax(440px, 1.15fr);
        gap: 18px;
        align-items: stretch;
    }

    .mf-card {
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        background: #ffffff;
        padding: 22px;
        min-height: 285px;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.035);
    }

    .mf-avatar-editor {
        display: flex;
        align-items: center;
        gap: 28px;
        flex-wrap: wrap;
    }

    .mf-avatar-preview {
        width: 190px;
        height: 190px;
        flex: 0 0 190px;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: #ffffff;
        border: 5px solid #eef2ff;
        box-shadow: 0 14px 30px rgba(79, 70, 229, 0.22), 0 0 0 1px rgba(79, 70, 229, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        font-weight: 900;
    }

        .mf-avatar-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
            display: block;
        }

    .mf-avatar-actions {
        min-width: 220px;
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }

    .mf-upload-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #4f46e5;
        color: #4f46e5;
        background: #ffffff;
        font-weight: 800;
        border-radius: 10px;
        padding: 9px 14px;
        cursor: pointer;
        transition: background .15s ease, color .15s ease;
    }

        .mf-upload-button:hover {
            background: #eef2ff;
        }

    .mf-file-input-hidden {
        display: none;
    }

    .mf-selected-file {
        width: 100%;
        padding: 10px 12px;
        border-radius: 12px;
        background: #f1f5f9;
        color: #334155;
        font-size: 13px;
        word-break: break-word;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

        .mf-selected-file span {
            color: #64748b;
            font-size: 12px;
        }

