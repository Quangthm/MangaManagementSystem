    private async Task RunBusyAsync(
        Func<Task> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            SetOperation(
                ex.Message,
                Severity.Error);

            Snackbar.Add(
                ex.Message,
                Severity.Error);
