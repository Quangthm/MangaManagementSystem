@page "/profile/settings"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.IO
@using System.Text.Json
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.Interfaces
@attribute [Authorize]

@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IFileResourceService FileResourceService
@inject IFileStorageService FileStorageService
@inject IAuditEventService AuditEventService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime

<PageTitle>Profile Settings - MangaFlow</PageTitle>

<div class="mf-page">
    <div class="mf-page-header">
        <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Profile Settings</MudText>
        <MudText Typo="Typo.body1" Class="mf-muted">
            Manage your profile, avatar, portfolio, and password. Profile changes are verified and audit logged.
        </MudText>
    </div>

    @if (_isLoading)
    {
        <MudPaper Class="pa-6 mf-card" Elevation="0">
            <MudProgressCircular Indeterminate="true" />
            <MudText Class="mt-3">Loading profile...</MudText>
        </MudPaper>
    }
    else if (_currentUser == null)
    {
        <MudAlert Severity="Severity.Error">
            Unable to load current user. Please login again.
        </MudAlert>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_operationMessage))
        {
            <MudAlert Severity="@_operationSeverity" Class="mb-4" Dense="true">
                @_operationMessage
            </MudAlert>
        }

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card mf-profile-summary" Elevation="0">
                    <MudStack AlignItems="AlignItems.Center" Spacing="2">
                        <div class="mf-profile-avatar-view" @key="_avatarUrl">
                            @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                            {
                                <img src="@_avatarUrl" alt="User avatar" />
                            }
                            else
                            {
                                <span>@_avatarInitial</span>
                            }
                        </div>

                        <MudText Typo="Typo.h6" Class="font-weight-bold text-center">
                            @_currentUser.DisplayName
                        </MudText>

                        <MudText Typo="Typo.body2" Class="mf-muted text-center">
                            @_currentUser.Email
                        </MudText>

                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                            @_currentUser.RoleName
                        </MudChip>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudStack Spacing="2">
                        <div>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Username</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">@_currentUser.Username</MudText>
                        </div>

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Account Status</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">@_currentUser.StatusCode</MudText>
                        </div>

                        <div>
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Audit Status</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">
                                Display name, avatar, portfolio, and password changes are recorded in audit logs.
                            </MudText>
                        </div>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Display Name</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">
                                Update the name shown across the workspace.
                            </MudText>
                        </div>
                    </MudStack>

                    <MudTextField T="string"
                                  Label="Display Name"
                                  @bind-Value="_displayName"
                                  Variant="Variant.Outlined"
                                  Immediate="true" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-3"
                               Disabled="@_isSavingDisplayName"
                               OnClick="UpdateDisplayNameAsync">
                        @(_isSavingDisplayName ? "Saving..." : "Update Display Name")
                    </MudButton>
                </MudPaper>

                <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Avatar</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">
                                Select an image, review the crop preview, then confirm upload.
                            </MudText>
                        </div>
                    </MudStack>

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        Supported files: PNG, JPG, JPEG, WEBP. The saved avatar uses a square center crop.
                    </MudAlert>

                    <InputFile OnChange="SelectAvatarForCropAsync"
                               accept="image/png,image/jpeg,image/jpg,image/webp" />

                    @if (!string.IsNullOrWhiteSpace(_avatarPreviewDataUrl))
                    {
                        <MudGrid Class="mt-4">
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                                    Original Preview
                                </MudText>

                                <img src="@_avatarPreviewDataUrl"
                                     class="mf-preview-image" />
                            </MudItem>

                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                                    Crop Preview
                                </MudText>

                                <div class="mf-avatar-crop-preview">
                                    <img src="@_avatarPreviewDataUrl" />
                                </div>
                            </MudItem>
                        </MudGrid>

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_isUploadingAvatar"
                                       OnClick="ConfirmAndUploadAvatarAsync">
                                @(_isUploadingAvatar ? "Uploading..." : "Confirm & Upload Avatar")
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Disabled="@_isUploadingAvatar"
                                       OnClick="@(() => CancelAvatarSelection())">
                                Cancel
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>

                <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Portfolio</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">
                                Upload a portfolio file. Image portfolios include crop preview before saving.
                            </MudText>
                        </div>
                    </MudStack>

                    @if (!string.IsNullOrWhiteSpace(_portfolioUrl))
                    {
                        <MudAlert Severity="Severity.Success" Dense="true" Class="mb-3">
                            Current portfolio: @_portfolioFileName
                        </MudAlert>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   Href="@_portfolioUrl"
                                   Target="_blank"
                                   Class="mb-3">
                            Open Current Portfolio
                        </MudButton>
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                            No portfolio file is available.
                        </MudAlert>
                    }

                    <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
                        Supported files: PDF, DOC, DOCX, PNG, JPG, JPEG, WEBP. Image files can be cropped before upload.
                    </MudAlert>

                    <InputFile OnChange="SelectPortfolioAsync"
                               accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,image/jpg,image/webp" />

                    @if (_pendingPortfolioBytes != null)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-3">
                            Pending portfolio: @_pendingPortfolioFileName. Please confirm before saving.
                        </MudAlert>

                        @if (_pendingPortfolioIsImage && !string.IsNullOrWhiteSpace(_portfolioPreviewDataUrl))
                        {
                            <MudGrid Class="mt-4">
                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                                        Original Preview
                                    </MudText>

                                    <img src="@_portfolioPreviewDataUrl"
                                         class="mf-preview-image" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">
                                        Crop Preview
                                    </MudText>

                                    <div class="mf-portfolio-crop-preview">
                                        <img src="@_portfolioPreviewDataUrl" />
                                    </div>
                                </MudItem>
                            </MudGrid>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mf-muted mt-3">
                                This file type does not support image crop preview. It will be uploaded after confirmation.
                            </MudText>
                        }

                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       Disabled="@_isUploadingPortfolio"
                                       OnClick="ConfirmAndUploadPortfolioAsync">
                                @(_isUploadingPortfolio ? "Uploading..." : "Confirm & Upload Portfolio")
                            </MudButton>

                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Default"
                                       Disabled="@_isUploadingPortfolio"
                                       OnClick="@(() => CancelPortfolioSelection())">
                                Cancel
                            </MudButton>
                        </MudStack>
                    }
                </MudPaper>

                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Security / Reset Password</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">
                                Verify your current password before setting a new password.
                            </MudText>
                        </div>
                    </MudStack>

                    <MudTextField T="string"
                                  Label="Current Password"
                                  @bind-Value="_currentPassword"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined" />

                    <MudTextField T="string"
                                  Label="New Password"
                                  @bind-Value="_newPassword"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mt-3" />

                    <MudTextField T="string"
                                  Label="Confirm New Password"
                                  @bind-Value="_confirmPassword"
                                  InputType="InputType.Password"
                                  Variant="Variant.Outlined"
                                  Class="mt-3" />

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Error"
                               Class="mt-3"
                               Disabled="@_isResettingPassword"
                               OnClick="ResetPasswordAsync">
                        @(_isResettingPassword ? "Resetting..." : "Reset Password")
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</div>

<style>
    .mf-profile-summary {
        position: sticky;
        top: 24px;
    }

    .mf-profile-avatar-view {
        width: 96px;
        height: 96px;
        border-radius: 50%;
        overflow: hidden;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 32px;
        font-weight: 700;
        border: 2px solid #e5e7eb;
    }

        .mf-profile-avatar-view img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

    .mf-preview-image {
        max-width: 100%;
        max-height: 260px;
        border-radius: 12px;
        border: 1px solid #ddd;
        object-fit: contain;
        background: #fff;
    }

    .mf-avatar-crop-preview {
        width: 220px;
        height: 220px;
        border-radius: 50%;
        overflow: hidden;
        border: 1px solid #ddd;
        background: #fff;
    }

        .mf-avatar-crop-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .mf-portfolio-crop-preview {
        width: 260px;
        height: 260px;
        overflow: hidden;
        border-radius: 12px;
        border: 1px solid #ddd;
        background: #fff;
    }

        .mf-portfolio-crop-preview img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
</style>

@code {
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private bool _isLoading = true;
    private bool _isSavingDisplayName;
    private bool _isUploadingAvatar;
    private bool _isUploadingPortfolio;
    private bool _isResettingPassword;

    private Guid _currentUserId;
    private UserDto? _currentUser;

    private string? _displayName;
    private string? _avatarUrl;
    private string _avatarInitial = "?";

    private string? _portfolioUrl;
    private string? _portfolioFileName;

    private string? _avatarPreviewDataUrl;
    private string? _pendingAvatarFileName;
    private string? _pendingAvatarContentType;
    private byte[]? _pendingAvatarBytes;

    private byte[]? _pendingPortfolioBytes;
    private string? _pendingPortfolioFileName;
    private string? _pendingPortfolioContentType;
    private bool _pendingPortfolioIsImage;
    private string? _portfolioPreviewDataUrl;

    private string? _currentPassword;
    private string? _newPassword;
    private string? _confirmPassword;

    private string? _operationMessage;
    private Severity _operationSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAsync();
    }

    private async Task LoadProfileAsync()
    {
        try
        {
            _isLoading = true;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            var idClaim = principal.FindFirst(ClaimTypes.NameIdentifier)?.Value;

            if (!Guid.TryParse(idClaim, out _currentUserId))
            {
                SetOperationMessage("Unable to identify current user. Please login again.", Severity.Error);
                _currentUser = null;
                return;
            }

            _currentUser = await UserService.GetUserByIdAsync(_currentUserId);

            if (_currentUser == null)
            {
                SetOperationMessage("Current user was not found. Please login again.", Severity.Error);
                return;
            }

            _displayName = _currentUser.DisplayName;
            _avatarInitial = BuildInitial(_currentUser.DisplayName, _currentUser.Username);

            await LoadFileUrlsAsync();
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Failed to load profile: {ex.GetBaseException().Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadFileUrlsAsync()
    {
        _avatarUrl = null;
        _portfolioUrl = null;
        _portfolioFileName = null;

        if (_currentUser?.AvatarFileId.HasValue == true)
        {
            var avatarFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.AvatarFileId.Value);

            if (avatarFile != null &&
                avatarFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(avatarFile.CloudinarySecureUrl))
            {
                _avatarUrl = BuildVersionedUrl(avatarFile.CloudinarySecureUrl, avatarFile.FileResourceId);
            }
        }

        if (_currentUser?.PortfolioFileId.HasValue == true)
        {
            var portfolioFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.PortfolioFileId.Value);

            if (portfolioFile != null &&
                portfolioFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(portfolioFile.CloudinarySecureUrl))
            {
                _portfolioUrl = $"/api/portfolio/{portfolioFile.FileResourceId}";
                _portfolioFileName = portfolioFile.OriginalFileName;
            }
        }
    }

    private async Task UpdateDisplayNameAsync()
    {
        if (string.IsNullOrWhiteSpace(_displayName))
        {
            SetOperationMessage("Display name cannot be empty.", Severity.Warning);
            return;
        }

        try
        {
            _isSavingDisplayName = true;

            var oldDisplayName = _currentUser?.DisplayName;
            var newDisplayName = _displayName.Trim();

            _currentUser = await UserService.UpdateDisplayNameAsync(
                _currentUserId,
                newDisplayName);

            _displayName = _currentUser.DisplayName;
            _avatarInitial = BuildInitial(_currentUser.DisplayName, _currentUser.Username);

            await WriteAuditAsync(
                "USER_PROFILE_DISPLAY_NAME_UPDATED",
                new
                {
                    oldDisplayName,
                    newDisplayName
                });

            SetOperationMessage("Display name updated successfully and audit logged.", Severity.Success);
            Snackbar.Add("Display name updated successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Failed to update display name: {ex.GetBaseException().Message}", Severity.Error);
        }
        finally
        {
            _isSavingDisplayName = false;
        }
    }

    private async Task SelectAvatarForCropAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
        {
            return;
        }

        var contentType = file.ContentType?.ToLowerInvariant() ?? string.Empty;

        if (!IsImageContentType(contentType))
        {
            SetOperationMessage("Avatar must be PNG, JPG, JPEG, or WEBP.", Severity.Warning);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxUploadBytes);
            using var memory = new MemoryStream();

            await stream.CopyToAsync(memory);

            _pendingAvatarBytes = memory.ToArray();
            _pendingAvatarFileName = file.Name;
            _pendingAvatarContentType = file.ContentType;

            var base64 = Convert.ToBase64String(_pendingAvatarBytes);
            _avatarPreviewDataUrl = $"data:{file.ContentType};base64,{base64}";

            SetOperationMessage("Avatar selected. Review the crop preview before uploading.", Severity.Info);
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Failed to prepare avatar: {ex.GetBaseException().Message}", Severity.Error);
        }
    }

    private async Task ConfirmAndUploadAvatarAsync()
    {
        if (string.IsNullOrWhiteSpace(_avatarPreviewDataUrl) ||
            _pendingAvatarBytes == null ||
            string.IsNullOrWhiteSpace(_pendingAvatarFileName) ||
            string.IsNullOrWhiteSpace(_pendingAvatarContentType))
        {
            SetOperationMessage("Please select an avatar first.", Severity.Warning);
            return;
        }

        var confirm = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            "Do you want to replace your current avatar with this cropped image?");

        if (!confirm)
        {
            SetOperationMessage("Avatar update cancelled.", Severity.Info);
            return;
        }

        try
        {
            _isUploadingAvatar = true;

            var croppedDataUrl = await CropImageOrFallbackAsync(_avatarPreviewDataUrl, 512, 0.92);
            var avatarBytes = ConvertDataUrlToBytes(croppedDataUrl);
            var avatarFileName = BuildUniqueCroppedAvatarFileName(_pendingAvatarFileName);
            var avatarContentType = "image/jpeg";

            var upload = await FileStorageService.UploadFileAsync(
                avatarBytes,
                avatarFileName,
                avatarContentType,
                "USER_AVATAR",
                null);

            var fileResource = await FileResourceService.CreateFileResourceAsync(new CreateFileResourceDto(
                "USER_AVATAR",
                upload.OriginalFileName,
                upload.PublicId,
                upload.SecureUrl,
                upload.ContentType,
                upload.FileSizeBytes,
                upload.Sha256Hash,
                _currentUserId
            ));

            _currentUser = await UserService.UpdateAvatarFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            _avatarUrl = BuildVersionedUrl(fileResource.CloudinarySecureUrl, fileResource.FileResourceId);
            _avatarInitial = BuildInitial(_currentUser.DisplayName, _currentUser.Username);

            await WriteAuditAsync(
                "USER_PROFILE_AVATAR_UPDATED",
                new
                {
                    avatarFileResourceId = fileResource.FileResourceId,
                    originalFileName = fileResource.OriginalFileName,
                    contentType = fileResource.ContentType,
                    cropApplied = true
                });

            CancelAvatarSelection(showMessage: false);

            SetOperationMessage("Avatar updated successfully and audit logged.", Severity.Success);
            Snackbar.Add("Avatar updated successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Avatar update failed: {ex.GetBaseException().Message}", Severity.Error);
        }
        finally
        {
            _isUploadingAvatar = false;
        }
    }

    private void CancelAvatarSelection(bool showMessage = true)
    {
        _avatarPreviewDataUrl = null;
        _pendingAvatarBytes = null;
        _pendingAvatarFileName = null;
        _pendingAvatarContentType = null;

        if (showMessage)
        {
            SetOperationMessage("Avatar change cancelled.", Severity.Info);
        }
    }

    private async Task SelectPortfolioAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;

        if (file == null)
        {
            return;
        }

        var contentType = file.ContentType?.ToLowerInvariant() ?? string.Empty;

        var allowed = IsPortfolioContentType(contentType);

        if (!allowed)
        {
            SetOperationMessage("Portfolio must be PDF, DOC, DOCX, PNG, JPG, JPEG, or WEBP.", Severity.Warning);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(MaxUploadBytes);
            using var memory = new MemoryStream();

            await stream.CopyToAsync(memory);

            _pendingPortfolioBytes = memory.ToArray();
            _pendingPortfolioFileName = file.Name;
            _pendingPortfolioContentType = file.ContentType;
            _pendingPortfolioIsImage = IsImageContentType(contentType);

            if (_pendingPortfolioIsImage)
            {
                var base64 = Convert.ToBase64String(_pendingPortfolioBytes);
                _portfolioPreviewDataUrl = $"data:{file.ContentType};base64,{base64}";
                SetOperationMessage("Image portfolio selected. Review the crop preview before uploading.", Severity.Info);
            }
            else
            {
                _portfolioPreviewDataUrl = null;
                SetOperationMessage("Document portfolio selected. Please confirm before uploading.", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Failed to prepare portfolio: {ex.GetBaseException().Message}", Severity.Error);
        }
    }

    private async Task ConfirmAndUploadPortfolioAsync()
    {
        if (_pendingPortfolioBytes == null ||
            string.IsNullOrWhiteSpace(_pendingPortfolioFileName) ||
            string.IsNullOrWhiteSpace(_pendingPortfolioContentType))
        {
            SetOperationMessage("Please select a portfolio file first.", Severity.Warning);
            return;
        }

        var confirm = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Do you want to replace your current portfolio with '{_pendingPortfolioFileName}'?");

        if (!confirm)
        {
            SetOperationMessage("Portfolio update cancelled.", Severity.Info);
            return;
        }

        try
        {
            _isUploadingPortfolio = true;

            byte[] portfolioBytes = _pendingPortfolioBytes;
            string portfolioFileName = BuildUniquePortfolioFileName(_pendingPortfolioFileName);
            string portfolioContentType = _pendingPortfolioContentType;
            bool cropApplied = false;

            if (_pendingPortfolioIsImage && !string.IsNullOrWhiteSpace(_portfolioPreviewDataUrl))
            {
                var croppedDataUrl = await CropImageOrFallbackAsync(_portfolioPreviewDataUrl, 1024, 0.92);
                portfolioBytes = ConvertDataUrlToBytes(croppedDataUrl);
                portfolioFileName = BuildUniqueCroppedPortfolioFileName(_pendingPortfolioFileName);
                portfolioContentType = "image/jpeg";
                cropApplied = true;
            }

            var upload = await FileStorageService.UploadFileAsync(
                portfolioBytes,
                portfolioFileName,
                portfolioContentType,
                "REGISTRATION_PORTFOLIO",
                null);

            var fileResource = await FileResourceService.CreateFileResourceAsync(new CreateFileResourceDto(
                "REGISTRATION_PORTFOLIO",
                upload.OriginalFileName,
                upload.PublicId,
                upload.SecureUrl,
                upload.ContentType,
                upload.FileSizeBytes,
                upload.Sha256Hash,
                _currentUserId
            ));

            _currentUser = await UserService.UpdatePortfolioFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            _portfolioUrl = $"/api/portfolio/{fileResource.FileResourceId}";
            _portfolioFileName = fileResource.OriginalFileName;

            await WriteAuditAsync(
                "USER_PROFILE_PORTFOLIO_UPDATED",
                new
                {
                    portfolioFileResourceId = fileResource.FileResourceId,
                    originalFileName = fileResource.OriginalFileName,
                    contentType = fileResource.ContentType,
                    cropApplied
                });

            CancelPortfolioSelection(showMessage: false);

            SetOperationMessage("Portfolio updated successfully and audit logged.", Severity.Success);
            Snackbar.Add("Portfolio updated successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Portfolio update failed: {ex.GetBaseException().Message}", Severity.Error);
        }
        finally
        {
            _isUploadingPortfolio = false;
        }
    }

    private void CancelPortfolioSelection(bool showMessage = true)
    {
        _pendingPortfolioBytes = null;
        _pendingPortfolioFileName = null;
        _pendingPortfolioContentType = null;
        _pendingPortfolioIsImage = false;
        _portfolioPreviewDataUrl = null;

        if (showMessage)
        {
            SetOperationMessage("Portfolio change cancelled.", Severity.Info);
        }
    }

    private async Task ResetPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword))
        {
            SetOperationMessage("Current password is required.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            SetOperationMessage("New password cannot be empty.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            SetOperationMessage("New password must be at least 8 characters.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            SetOperationMessage("Password confirmation does not match.", Severity.Warning);
            return;
        }

        var confirm = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            "Do you want to reset your password?");

        if (!confirm)
        {
            SetOperationMessage("Password reset cancelled.", Severity.Info);
            return;
        }

        try
        {
            _isResettingPassword = true;

            await UserService.ResetPasswordAsync(
                _currentUserId,
                _currentPassword,
                _newPassword);

            await WriteAuditAsync(
                "USER_PROFILE_PASSWORD_RESET",
                new
                {
                    verifiedCurrentPassword = true
                });

            _currentPassword = null;
            _newPassword = null;
            _confirmPassword = null;

            SetOperationMessage("Password reset successfully and audit logged.", Severity.Success);
            Snackbar.Add("Password reset successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Password reset failed: {ex.GetBaseException().Message}", Severity.Error);
        }
        finally
        {
            _isResettingPassword = false;
        }
    }

    private async Task WriteAuditAsync(string actionCode, object detail)
    {
        try
        {
            var detailJson = JsonSerializer.Serialize(detail);

            await AuditEventService.CreateAuditEventAsync(new CreateAuditEventDto(
                _currentUserId,
                _currentUser?.RoleName,
                actionCode,
                "User",
                _currentUserId.ToString(),
                detailJson
            ));
        }
        catch (Exception ex)
        {
            SetOperationMessage($"Profile updated, but audit log failed: {ex.GetBaseException().Message}", Severity.Warning);
        }
    }

    private async Task<string> CropImageOrFallbackAsync(string dataUrl, int size, double quality)
    {
        try
        {
            return await JSRuntime.InvokeAsync<string>(
                "profileSettingsCrop.cropCenter",
                dataUrl,
                size,
                quality);
        }
        catch
        {
            return dataUrl;
        }
    }

    private static byte[] ConvertDataUrlToBytes(string dataUrl)
    {
        var commaIndex = dataUrl.IndexOf(',');

        if (commaIndex < 0)
        {
            return Convert.FromBase64String(dataUrl);
        }

        var base64 = dataUrl[(commaIndex + 1)..];
        return Convert.FromBase64String(base64);
    }

    private static bool IsImageContentType(string? contentType)
    {
        return contentType?.ToLowerInvariant() is "image/png" or "image/jpeg" or "image/jpg" or "image/webp";
    }

    private static bool IsPortfolioContentType(string? contentType)
    {
        return IsImageContentType(contentType) ||
               contentType?.ToLowerInvariant() is
                   "application/pdf" or
                   "application/msword" or
                   "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
    }

    private void SetOperationMessage(string message, Severity severity)
    {
        _operationMessage = message;
        _operationSeverity = severity;
    }

    private static string BuildInitial(string? displayName, string? username)
    {
        var source = !string.IsNullOrWhiteSpace(displayName)
            ? displayName.Trim()
            : username?.Trim();

        return string.IsNullOrWhiteSpace(source)
            ? "?"
            : source[..1].ToUpperInvariant();
    }

    private static string BuildVersionedUrl(string url, Guid fileResourceId)
    {
        var separator = url.Contains('?') ? "&" : "?";
        return $"{url}{separator}v={fileResourceId:N}";
    }

    private static string BuildUniqueCroppedAvatarFileName(string? originalFileName)
    {
        var baseName = string.IsNullOrWhiteSpace(originalFileName)
            ? "avatar"
            : Path.GetFileNameWithoutExtension(originalFileName);

        return $"{SanitizeFileName(baseName)}_cropped_{DateTimeOffset.UtcNow:yyyyMMddHHmmssfff}_{Guid.NewGuid():N}.jpg";
    }

    private static string BuildUniquePortfolioFileName(string? originalFileName)
    {
        var extension = Path.GetExtension(originalFileName);

        if (string.IsNullOrWhiteSpace(extension))
        {
            extension = ".bin";
        }

        var baseName = string.IsNullOrWhiteSpace(originalFileName)
            ? "portfolio"
            : Path.GetFileNameWithoutExtension(originalFileName);

        return $"{SanitizeFileName(baseName)}_{DateTimeOffset.UtcNow:yyyyMMddHHmmssfff}_{Guid.NewGuid():N}{extension}";
    }

    private static string BuildUniqueCroppedPortfolioFileName(string? originalFileName)
    {
        var baseName = string.IsNullOrWhiteSpace(originalFileName)
            ? "portfolio"
            : Path.GetFileNameWithoutExtension(originalFileName);

        return $"{SanitizeFileName(baseName)}_cropped_{DateTimeOffset.UtcNow:yyyyMMddHHmmssfff}_{Guid.NewGuid():N}.jpg";
    }

    private static string SanitizeFileName(string value)
    {
        var invalidChars = Path.GetInvalidFileNameChars();
        var cleaned = new string(value
            .Where(ch => !invalidChars.Contains(ch))
            .ToArray());

        cleaned = cleaned.Replace(' ', '_');

        return string.IsNullOrWhiteSpace(cleaned)
            ? "file"
            : cleaned;
    }
}