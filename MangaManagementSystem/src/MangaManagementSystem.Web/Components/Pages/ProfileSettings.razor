@page "/profile/settings"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.IO
@using System.Text.Json
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.Interfaces
@attribute [Authorize]

@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IFileResourceService FileResourceService
@inject IFileStorageService FileStorageService
@inject ISnackbar Snackbar
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>Profile Settings - MangaFlow</PageTitle>

<div class="mf-settings-page">
    <section class="mf-profile-shell">
        <div class="mf-profile-top">
            <div class="mf-user-block">
                <div class="mf-avatar-large">
                    @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                    {
                        <img src="@_avatarUrl" alt="User avatar" />
                    }
                    else
                    {
                        <span>@_avatarInitial</span>
                    }
                </div>

                <div class="mf-user-meta">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mb-1">Profile Settings</MudText>
                    <MudText Typo="Typo.body2" Class="mf-muted">
                        Manage username, display name, avatar, portfolio, and password.
                    </MudText>

                    @if (_currentUser != null)
                    {
                        <div class="mf-user-line">
                            <strong>@_currentUser.DisplayName</strong>
                            <span class="mf-username-chip">@_currentUser.Username</span>
                            <span>@_currentUser.Email</span>

                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                                @_currentRoleName
                            </MudChip>

                            <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Size="Size.Small">
                                @_currentUser.StatusCode
                            </MudChip>
                        </div>
                    }
                </div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="mf-loading-box">
                <MudProgressCircular Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mf-muted">Loading profile...</MudText>
            </div>
        }
        else if (_currentUser == null)
        {
            <MudAlert Severity="Severity.Error">
                Unable to load current user. Please login again.
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_operationMessage))
            {
                <MudAlert Severity="@_operationSeverity" Dense="true" Class="mb-3">
                    @_operationMessage
                </MudAlert>
            }

            <div class="mf-summary-grid">
                <div class="mf-summary-card">
                    <span>Username</span>
                    <strong>@_currentUser.Username</strong>
                    <small>Login account</small>
                </div>

                <div class="mf-summary-card">
                    <span>Display Name</span>
                    <strong>@_currentUser.DisplayName</strong>
                    <small>Shown in workspace</small>
                </div>

                <div class="mf-summary-card">
                    <span>Avatar</span>
                    <strong>@(_currentUser.AvatarFileId.HasValue ? "Linked" : "Not Set")</strong>
                    <small>Profile image</small>
                </div>

                <div class="mf-summary-card">
                    <span>Portfolio</span>
                    <strong>@(_currentUser.PortfolioFileId.HasValue ? "Linked" : "Not Set")</strong>
                    <small>Profile document/image</small>
                </div>
            </div>

            <MudPaper Class="mf-main-panel">
                <MudTabs Rounded="true" Elevation="0" PanelClass="mf-tab-content">
                    <MudTabPanel Text="Profile">
                        <div class="mf-two-col">
                            <div class="mf-section-card">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">Profile Information</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Username is read-only. Display name can be updated by the logged-in user.
                                </MudText>

                                <MudTextField T="string"
                                              Value="@_currentUser.Username"
                                              Label="Username"
                                              Variant="Variant.Outlined"
                                              ReadOnly="true"
                                              Disabled="true" />

                                <MudTextField T="string"
                                              @bind-Value="_displayName"
                                              Label="Display Name"
                                              Variant="Variant.Outlined"
                                              Immediate="true"
                                              Disabled="@_isBusy"
                                              Class="mt-3" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="UpdateDisplayNameDirectAsync"
                                           Class="mt-3">
                                    Save Display Name
                                </MudButton>
                            </div>

                            <div class="mf-help-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Update Rule</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted">
                                    Username is shown for account identity and is not editable here. Display name is updated directly after login session verification. OTP is only required for password reset.
                                </MudText>
                            </div>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Avatar">
                        <div class="mf-upload-layout">
                            <div class="mf-upload-control">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">Avatar</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Select an image, preview it, then upload directly.
                                </MudText>

                                <label class="mf-upload-box">
                                    <InputFile OnChange="SelectAvatarAsync"
                                               accept="image/png,image/jpeg,image/jpg,image/webp"
                                               class="mf-file-input-hidden" />
                                    <span class="mf-upload-title">Choose avatar image</span>
                                    <small>PNG, JPG, JPEG, WEBP up to 10MB</small>
                                </label>

                                @if (!string.IsNullOrWhiteSpace(_selectedAvatarFileName))
                                {
                                    <div class="mf-selected-file">
                                        @_selectedAvatarFileName
                                    </div>
                                }

                                <div class="mf-button-row">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@(_isBusy || _selectedAvatarBytes == null)"
                                               OnClick="UploadAvatarDirectAsync">
                                        Upload Avatar
                                    </MudButton>

                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Default"
                                               Disabled="@(_isBusy || _selectedAvatarBytes == null)"
                                               OnClick="CancelAvatarSelection">
                                        Clear
                                    </MudButton>
                                </div>
                            </div>

                            <div class="mf-preview-grid">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">Original Preview</MudText>
                                    <div class="mf-preview-box">
                                        @if (!string.IsNullOrWhiteSpace(_avatarOriginalPreviewDataUrl))
                                        {
                                            <img src="@_avatarOriginalPreviewDataUrl" alt="Original avatar preview" />
                                        }
                                        else
                                        {
                                            <span>No image selected</span>
                                        }
                                    </div>
                                </div>

                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">Crop Preview</MudText>
                                    <div class="mf-preview-box mf-preview-square">
                                        @if (!string.IsNullOrWhiteSpace(_avatarCropPreviewDataUrl))
                                        {
                                            <img src="@_avatarCropPreviewDataUrl" alt="Cropped avatar preview" />
                                        }
                                        else
                                        {
                                            <span>No crop yet</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Portfolio">
                        <div class="mf-upload-layout">
                            <div class="mf-upload-control">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">Portfolio</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Upload image/PDF/DOC/DOCX. Image files show original and crop preview before saving.
                                </MudText>

                                <label class="mf-upload-box mf-portfolio-upload">
                                    <InputFile OnChange="SelectPortfolioAsync"
                                               accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,image/jpg,image/webp"
                                               class="mf-file-input-hidden" />
                                    <span class="mf-upload-title">Choose portfolio file</span>
                                    <small>Image, PDF, DOC, DOCX up to 10MB</small>
                                </label>

                                @if (!string.IsNullOrWhiteSpace(_selectedPortfolioFileName))
                                {
                                    <div class="mf-selected-file">
                                        @_selectedPortfolioFileName
                                    </div>
                                }

                                <div class="mf-button-row">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Disabled="@(_isBusy || _selectedPortfolioBytes == null)"
                                               OnClick="UploadPortfolioDirectAsync">
                                        Upload Portfolio
                                    </MudButton>

                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Default"
                                               Disabled="@(_isBusy || _selectedPortfolioBytes == null)"
                                               OnClick="CancelPortfolioSelection">
                                        Clear
                                    </MudButton>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(_portfolioUrl))
                                {
                                    <MudButton Href="@_portfolioUrl"
                                               Target="_blank"
                                               Variant="Variant.Text"
                                               Color="Color.Primary"
                                               Class="mt-2">
                                        Open Current Portfolio
                                    </MudButton>
                                }
                            </div>

                            <div class="mf-preview-grid">
                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">Original Preview</MudText>
                                    <div class="mf-preview-box">
                                        @if (_selectedPortfolioIsImage && !string.IsNullOrWhiteSpace(_portfolioOriginalPreviewDataUrl))
                                        {
                                            <img src="@_portfolioOriginalPreviewDataUrl" alt="Original portfolio preview" />
                                        }
                                        else if (_selectedPortfolioBytes != null)
                                        {
                                            <span>Document selected</span>
                                        }
                                        else
                                        {
                                            <span>No file selected</span>
                                        }
                                    </div>
                                </div>

                                <div>
                                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-2">Crop Preview</MudText>
                                    <div class="mf-preview-box">
                                        @if (_selectedPortfolioIsImage && !string.IsNullOrWhiteSpace(_portfolioCropPreviewDataUrl))
                                        {
                                            <img src="@_portfolioCropPreviewDataUrl" alt="Cropped portfolio preview" />
                                        }
                                        else if (_selectedPortfolioBytes != null)
                                        {
                                            <span>Crop not required</span>
                                        }
                                        else
                                        {
                                            <span>No crop yet</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </MudTabPanel>

                    <MudTabPanel Text="Security">
                        <div class="mf-two-col">
                            <div class="mf-section-card">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">Reset Password</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Only password reset requires OTP confirmation. This works for Google-login users because no current password is required.
                                </MudText>

                                <MudTextField T="string"
                                              @bind-Value="_newPassword"
                                              Label="New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy" />

                                <MudTextField T="string"
                                              @bind-Value="_confirmPassword"
                                              Label="Confirm New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy"
                                              Class="mt-3" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="SendOtpForPasswordAsync"
                                           Class="mt-3">
                                    Send OTP
                                </MudButton>
                            </div>

                            <div class="mf-help-card">
                                <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Email OTP Confirmation</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    OTP will be sent to <strong>@_currentUser.Email</strong>. The code expires in 5 minutes.
                                </MudText>

                                @if (_otpSentForPassword)
                                {
                                    <MudTextField T="string"
                                                  @bind-Value="_otpCodePassword"
                                                  Label="OTP Code"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="6"
                                                  Disabled="@_isBusy" />

                                    <div class="mf-button-row">
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   Disabled="@_isBusy"
                                                   OnClick="ConfirmPasswordResetAsync">
                                            Confirm Reset
                                        </MudButton>

                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Default"
                                                   Disabled="@_isBusy"
                                                   OnClick="CancelPasswordOtp">
                                            Cancel
                                        </MudButton>
                                    </div>
                                }
                                else
                                {
                                    <div class="mf-empty-note">
                                        Enter a new password and request OTP to continue.
                                    </div>
                                }
                            </div>
                        </div>
                    </MudTabPanel>
                </MudTabs>
            </MudPaper>
        }
    </section>
</div>

@code {
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private const string ActionPasswordOtp = "PROFILE_PASSWORD_RESET";

    private const string AuditDisplayNameUpdated = "USER_PROFILE_DISPLAY_NAME_UPDATED";
    private const string AuditAvatarUpdated = "USER_PROFILE_AVATAR_UPDATED";
    private const string AuditPortfolioUpdated = "USER_PROFILE_PORTFOLIO_UPDATED";
    private const string AuditPasswordReset = "USER_PROFILE_PASSWORD_RESET";

    private bool _isLoading = true;
    private bool _isBusy;

    private UserDto? _currentUser;
    private Guid _currentUserId;
    private string _currentRoleName = "User";

    private string _displayName = string.Empty;
    private string _avatarInitial = "?";
    private string? _avatarUrl;
    private string? _portfolioUrl;

    private string? _operationMessage;
    private Severity _operationSeverity = Severity.Info;

    private string? _avatarOriginalPreviewDataUrl;
    private string? _avatarCropPreviewDataUrl;
    private byte[]? _selectedAvatarBytes;
    private string? _selectedAvatarFileName;
    private string _selectedAvatarContentType = "image/jpeg";

    private string? _selectedPortfolioFileName;
    private string? _portfolioOriginalPreviewDataUrl;
    private string? _portfolioCropPreviewDataUrl;
    private byte[]? _selectedPortfolioBytes;
    private string? _selectedPortfolioContentType;
    private bool _selectedPortfolioIsImage;

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _otpSentForPassword;
    private string _otpCodePassword = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
    }

    private async Task LoadCurrentUserAsync()
    {
        _isLoading = true;
        _operationMessage = null;

        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            var idClaim = principal.FindFirst(ClaimTypes.NameIdentifier);

            if (!Guid.TryParse(idClaim?.Value, out _currentUserId))
            {
                SetOperation("Unable to resolve current user id.", Severity.Error);
                return;
            }

            _currentUser = await UserService.GetUserByIdAsync(_currentUserId);

            if (_currentUser == null)
            {
                SetOperation("Unable to load current user profile.", Severity.Error);
                return;
            }

            _currentRoleName =
                principal.FindFirst(ClaimTypes.Role)?.Value
                ?? principal.FindFirst("role")?.Value
                ?? _currentUser.RoleName
                ?? "User";

            _displayName = _currentUser.DisplayName;
            _avatarInitial = BuildInitial(_currentUser.DisplayName, _currentUser.Username);

            await LoadCurrentFilesAsync();
        }
        catch (Exception ex)
        {
            SetOperation(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCurrentFilesAsync()
    {
        _avatarUrl = null;
        _portfolioUrl = null;

        if (_currentUser?.AvatarFileId.HasValue == true)
        {
            var avatarFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.AvatarFileId.Value);

            if (avatarFile != null &&
                avatarFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(avatarFile.CloudinarySecureUrl))
            {
                _avatarUrl = BuildVersionedUrl(avatarFile.CloudinarySecureUrl, avatarFile.FileResourceId);
            }
        }

        if (_currentUser?.PortfolioFileId.HasValue == true)
        {
            var portfolioFile = await FileResourceService.GetFileResourceByIdAsync(_currentUser.PortfolioFileId.Value);

            if (portfolioFile != null &&
                portfolioFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(portfolioFile.CloudinarySecureUrl))
            {
                _portfolioUrl = BuildVersionedUrl(portfolioFile.CloudinarySecureUrl, portfolioFile.FileResourceId);
            }
        }
    }

    private async Task UpdateDisplayNameDirectAsync()
    {
        if (_currentUser == null)
        {
            return;
        }

        var trimmed = _displayName.Trim();

        if (string.IsNullOrWhiteSpace(trimmed))
        {
            SetOperation("Display name cannot be empty.", Severity.Warning);
            return;
        }

        if (string.Equals(trimmed, _currentUser.DisplayName, StringComparison.Ordinal))
        {
            SetOperation("Display name is unchanged.", Severity.Info);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldDisplayName = _currentUser.DisplayName;

            var updated = await UserService.UpdateDisplayNameAsync(
                _currentUserId,
                trimmed);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditDisplayNameUpdated,
                JsonSerializer.Serialize(new
                {
                    oldDisplayName,
                    newDisplayName = trimmed,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;
            _displayName = updated.DisplayName;
            _avatarInitial = BuildInitial(updated.DisplayName, updated.Username);

            SetOperation("Display name updated successfully.", Severity.Success);
            Snackbar.Add("Display name updated successfully.", Severity.Success);
        });
    }

    private async Task SelectAvatarAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;

        if (file == null)
        {
            return;
        }

        if (!IsImageContentType(file.ContentType))
        {
            SetOperation("Avatar must be an image file.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var originalBytes = await ReadFileBytesAsync(file);
            var originalDataUrl = BuildDataUrl(file.ContentType, originalBytes);

            var croppedDataUrl = await TryCropImageDataUrlAsync(
                originalDataUrl,
                512,
                0.92);

            _avatarOriginalPreviewDataUrl = originalDataUrl;
            _avatarCropPreviewDataUrl = croppedDataUrl;
            _selectedAvatarBytes = DataUrlToBytes(croppedDataUrl);
            _selectedAvatarFileName = BuildCroppedFileName(file.Name, "avatar");
            _selectedAvatarContentType = "image/jpeg";

            SetOperation("Avatar selected. Review the preview and upload when ready.", Severity.Info);
        });
    }

    private async Task UploadAvatarDirectAsync()
    {
        if (_selectedAvatarBytes == null || string.IsNullOrWhiteSpace(_selectedAvatarFileName))
        {
            SetOperation("Please select an avatar image first.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldAvatarFileId = _currentUser?.AvatarFileId;

            var upload = await FileStorageService.UploadFileAsync(
                _selectedAvatarBytes,
                _selectedAvatarFileName,
                _selectedAvatarContentType,
                "USER_AVATAR");

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    "USER_AVATAR",
                    upload.OriginalFileName,
                    upload.PublicId,
                    upload.SecureUrl,
                    upload.ContentType,
                    upload.FileSizeBytes,
                    upload.Sha256Hash,
                    _currentUserId));

            var updated = await UserService.UpdateAvatarFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditAvatarUpdated,
                JsonSerializer.Serialize(new
                {
                    oldAvatarFileId,
                    newAvatarFileId = fileResource.FileResourceId,
                    fileName = fileResource.OriginalFileName,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;
            await LoadCurrentFilesAsync();
            CancelAvatarSelection();

            SetOperation("Avatar uploaded successfully.", Severity.Success);
            Snackbar.Add("Avatar uploaded successfully.", Severity.Success);
        });
    }

    private async Task SelectPortfolioAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;

        if (file == null)
        {
            return;
        }

        if (!IsImageContentType(file.ContentType) && !IsDocumentContentType(file.ContentType))
        {
            SetOperation("Portfolio must be an image, PDF, DOC, or DOCX file.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var originalBytes = await ReadFileBytesAsync(file);

            _selectedPortfolioFileName = Path.GetFileName(file.Name);
            _selectedPortfolioContentType = file.ContentType;
            _selectedPortfolioBytes = originalBytes;
            _selectedPortfolioIsImage = IsImageContentType(file.ContentType);

            _portfolioOriginalPreviewDataUrl = null;
            _portfolioCropPreviewDataUrl = null;

            if (_selectedPortfolioIsImage)
            {
                var originalDataUrl = BuildDataUrl(file.ContentType, originalBytes);

                var croppedDataUrl = await TryCropImageDataUrlAsync(
                    originalDataUrl,
                    900,
                    0.92);

                _portfolioOriginalPreviewDataUrl = originalDataUrl;
                _portfolioCropPreviewDataUrl = croppedDataUrl;
                _selectedPortfolioBytes = DataUrlToBytes(croppedDataUrl);
                _selectedPortfolioFileName = BuildCroppedFileName(file.Name, "portfolio");
                _selectedPortfolioContentType = "image/jpeg";
            }

            SetOperation("Portfolio selected. Review the file and upload when ready.", Severity.Info);
        });
    }

    private async Task UploadPortfolioDirectAsync()
    {
        if (_selectedPortfolioBytes == null ||
            string.IsNullOrWhiteSpace(_selectedPortfolioFileName) ||
            string.IsNullOrWhiteSpace(_selectedPortfolioContentType))
        {
            SetOperation("Please select a portfolio file first.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            var oldPortfolioFileId = _currentUser?.PortfolioFileId;

            var upload = await FileStorageService.UploadFileAsync(
                _selectedPortfolioBytes,
                _selectedPortfolioFileName,
                _selectedPortfolioContentType,
                "REGISTRATION_PORTFOLIO");

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    "REGISTRATION_PORTFOLIO",
                    upload.OriginalFileName,
                    upload.PublicId,
                    upload.SecureUrl,
                    upload.ContentType,
                    upload.FileSizeBytes,
                    upload.Sha256Hash,
                    _currentUserId));

            var updated = await UserService.UpdatePortfolioFileAsync(
                _currentUserId,
                fileResource.FileResourceId);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditPortfolioUpdated,
                JsonSerializer.Serialize(new
                {
                    oldPortfolioFileId,
                    newPortfolioFileId = fileResource.FileResourceId,
                    fileName = fileResource.OriginalFileName,
                    contentType = fileResource.ContentType,
                    confirmedBy = "AUTHENTICATED_SESSION"
                }));

            _currentUser = updated;
            await LoadCurrentFilesAsync();
            CancelPortfolioSelection();

            SetOperation("Portfolio uploaded successfully.", Severity.Success);
            Snackbar.Add("Portfolio uploaded successfully.", Severity.Success);
        });
    }

    private async Task SendOtpForPasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            SetOperation("New password cannot be empty.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            SetOperation("New password must be at least 8 characters.", Severity.Warning);
            return;
        }

        if (!string.Equals(_newPassword, _confirmPassword, StringComparison.Ordinal))
        {
            SetOperation("Confirm password does not match.", Severity.Warning);
            return;
        }

        await RunBusyAsync(async () =>
        {
            await UserService.SendProfileOtpAsync(_currentUserId, ActionPasswordOtp);

            _otpSentForPassword = true;
            _otpCodePassword = string.Empty;

            SetOperation("OTP sent to your registered email. The code expires in 5 minutes.", Severity.Info);
            Snackbar.Add("OTP sent to your registered email.", Severity.Info);
        });
    }

    private async Task ConfirmPasswordResetAsync()
    {
        await RunBusyAsync(async () =>
        {
            var verified = await UserService.VerifyProfileOtpAsync(
                _currentUserId,
                ActionPasswordOtp,
                _otpCodePassword);

            if (!verified)
            {
                SetOperation("Invalid or expired OTP.", Severity.Error);
                return;
            }

            await UserService.ResetPasswordAsync(_currentUserId, _newPassword);

            await UserService.RecordProfileAuditAsync(
                _currentUserId,
                AuditPasswordReset,
                JsonSerializer.Serialize(new
                {
                    confirmedBy = "EMAIL_OTP",
                    passwordChanged = true
                }));

            _newPassword = string.Empty;
            _confirmPassword = string.Empty;
            _otpSentForPassword = false;
            _otpCodePassword = string.Empty;

            SetOperation("Password reset successfully.", Severity.Success);
            Snackbar.Add("Password reset successfully.", Severity.Success);
        });
    }

    private async Task RunBusyAsync(Func<Task> action)
    {
        if (_isBusy)
        {
            return;
        }

        _isBusy = true;

        try
        {
            await action();
        }
        catch (Exception ex)
        {
            SetOperation(ex.Message, Severity.Error);
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void CancelAvatarSelection()
    {
        _avatarOriginalPreviewDataUrl = null;
        _avatarCropPreviewDataUrl = null;
        _selectedAvatarBytes = null;
        _selectedAvatarFileName = null;
        _selectedAvatarContentType = "image/jpeg";
    }

    private void CancelPortfolioSelection()
    {
        _selectedPortfolioFileName = null;
        _portfolioOriginalPreviewDataUrl = null;
        _portfolioCropPreviewDataUrl = null;
        _selectedPortfolioBytes = null;
        _selectedPortfolioContentType = null;
        _selectedPortfolioIsImage = false;
    }

    private void CancelPasswordOtp()
    {
        _otpSentForPassword = false;
        _otpCodePassword = string.Empty;
    }

    private async Task<string> TryCropImageDataUrlAsync(string originalDataUrl, int size, double quality)
    {
        try
        {
            using var timeoutCts = new System.Threading.CancellationTokenSource(TimeSpan.FromSeconds(10));

            var croppedDataUrl = await JSRuntime.InvokeAsync<string>(
                "profileSettingsCrop.cropCenter",
                timeoutCts.Token,
                new object?[] { originalDataUrl, size, quality });

            if (!string.IsNullOrWhiteSpace(croppedDataUrl))
            {
                return croppedDataUrl;
            }
        }
        catch
        {
            // If browser-side crop is cancelled or fails, keep the original image.
        }

        return originalDataUrl;
    }

    private async Task<byte[]> ReadFileBytesAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(MaxUploadBytes);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        return ms.ToArray();
    }

    private static bool IsImageContentType(string? contentType)
    {
        return contentType?.ToLowerInvariant() is
            "image/png" or
            "image/jpeg" or
            "image/jpg" or
            "image/webp";
    }

    private static bool IsDocumentContentType(string? contentType)
    {
        return contentType?.ToLowerInvariant() is
            "application/pdf" or
            "application/msword" or
            "application/vnd.openxmlformats-officedocument.wordprocessingml.document";
    }

    private static string BuildDataUrl(string contentType, byte[] bytes)
    {
        return $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
    }

    private static byte[] DataUrlToBytes(string dataUrl)
    {
        var commaIndex = dataUrl.IndexOf(',');

        if (commaIndex < 0)
        {
            return Convert.FromBase64String(dataUrl);
        }

        return Convert.FromBase64String(dataUrl[(commaIndex + 1)..]);
    }

    private static string BuildCroppedFileName(string originalFileName, string prefix)
    {
        var safeName = Path.GetFileNameWithoutExtension(originalFileName)
            .Replace(" ", "-", StringComparison.Ordinal)
            .ToLowerInvariant();

        if (string.IsNullOrWhiteSpace(safeName))
        {
            safeName = prefix;
        }

        return $"{safeName}_cropped_{DateTime.UtcNow:yyyyMMddHHmmssfff}_{Guid.NewGuid():N}.jpg";
    }

    private static string BuildInitial(string? displayName, string? username)
    {
        var source = !string.IsNullOrWhiteSpace(displayName)
            ? displayName.Trim()
            : username?.Trim();

        return string.IsNullOrWhiteSpace(source)
            ? "?"
            : source[..1].ToUpperInvariant();
    }

    private static string BuildVersionedUrl(string url, Guid fileResourceId)
    {
        var separator = url.Contains('?') ? "&" : "?";
        return $"{url}{separator}v={fileResourceId:N}";
    }

    private void SetOperation(string message, Severity severity)
    {
        _operationMessage = message;
        _operationSeverity = severity;
    }
}

