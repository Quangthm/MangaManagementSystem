@using System.Globalization
@using Microsoft.JSInterop
@page "/profile/settings"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using System.IO
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.Interfaces
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize]
@implements IAsyncDisposable

@inject AuthenticationStateProvider AuthStateProvider
@inject IProfileApiClient ProfileApiClient
@inject IProfilePasswordApiClient ProfilePasswordApiClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime


<PageTitle>Profile Settings - MangaFlow</PageTitle>

<div class="mf-settings-page">
    <section class="mf-settings-shell">
        <div class="mf-page-heading">
            <div class="mf-page-heading-content">
                <MudButton Variant="Variant.Text"
                           Color="Color.Primary"
                           Class="mf-back-dashboard-button"
                           OnClick="BackToDashboard">
                    ← Back to Dashboard
                </MudButton>

                <div>
                    <MudText Typo="Typo.h4"
                             Class="font-weight-bold">
                        Profile Settings
                    </MudText>

                    <MudText Typo="Typo.body2"
                             Class="mf-muted">
                        Manage your account information, portfolio document, and password security.
                    </MudText>
                </div>
            </div>
        </div>

        @if (_isLoading)
        {
            <div class="mf-loading-box">
                <MudProgressCircular Indeterminate="true" />
                <MudText Typo="Typo.body2" Class="mf-muted">Loading profile...</MudText>
            </div>
        }
        else if (_currentUser == null)
        {
            <MudAlert Severity="Severity.Error">
                Unable to load current user. Please login again.
            </MudAlert>
        }
        else
        {
            @if (!string.IsNullOrWhiteSpace(_operationMessage))
            {
                <MudAlert Severity="@_operationSeverity" Dense="true" Class="mb-3">
                    @_operationMessage
                </MudAlert>
            }

            <MudPaper Class="mf-account-panel">
                <aside class="mf-settings-menu">
                    <div class="mf-menu-user">
                        <div class="mf-menu-avatar">
                            @if (!string.IsNullOrWhiteSpace(_avatarUrl))
                            {
                                <img src="@_avatarUrl" alt="User avatar" />
                            }
                            else
                            {
                                <span>@_avatarInitial</span>
                            }
                        </div>

                        <div class="mf-menu-user-meta">
                            <strong>@_currentUser.DisplayName</strong>
                            <span>@_currentUser.Username</span>
                            <span>@_currentUser.Email</span>
                        </div>
                    </div>

                    <div class="mf-menu-divider"></div>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Profile)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Profile)">
                        <span>Profile</span>
                        <small>Identity and avatar</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Portfolio)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Portfolio)">
                        <span>Portfolio</span>
                        <small>PDF, DOC, DOCX</small>
                    </button>

                    <button type="button"
                            class="@GetMenuClass(ProfileSettingsSection.Security)"
                            @onclick="() => SelectSection(ProfileSettingsSection.Security)">
                        <span>Security</span>
                        <small>Password OTP</small>
                    </button>
                </aside>

                <main class="mf-settings-content">
                    <div class="mf-content-header">
                        <div>
                            <MudText Typo="Typo.h5" Class="font-weight-bold">@CurrentSectionTitle</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">@CurrentSectionDescription</MudText>
                        </div>

                        <div class="mf-status-line">
                            <MudChip T="string"
                                     Color="Color.Primary"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @_currentRoleName
                            </MudChip>

                            <MudChip T="string"
                                     Color="Color.Success"
                                     Variant="Variant.Outlined"
                                     Size="Size.Small">
                                @_currentUser.StatusCode
                            </MudChip>
                        </div>
                    </div>

                    @if (_activeSection == ProfileSettingsSection.Profile)
                    {
                        <div class="mf-profile-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-3">
                                    Avatar
                                </MudText>

                                <div class="mf-avatar-editor">
                                    <div class="mf-avatar-preview">
                                        @if (!string.IsNullOrWhiteSpace(_avatarPreviewDataUrl))
                                        {
                                            <img src="@_avatarPreviewDataUrl"
                                                 alt="Selected avatar preview" />
                                        }
                                        else if (!string.IsNullOrWhiteSpace(_avatarUrl))
                                        {
                                            <img src="@_avatarUrl"
                                                 alt="Current avatar preview" />
                                        }
                                        else
                                        {
                                            <span>@_avatarInitial</span>
                                        }
                                    </div>

                                    <div class="mf-avatar-actions">
                                        <label class="mf-upload-button">
                                            <InputFile @key="_avatarInputKey"
                                                       OnChange="SelectAvatarAsync"
                                                       accept="image/png,image/jpeg,image/jpg,image/webp"
                                                       class="mf-file-input-hidden" />
                                            Choose Image
                                        </label>

                                        <MudText Typo="Typo.caption" Class="mf-muted">
                                            Choose an image, adjust its position and zoom,
                                            then upload the cropped result.
                                        </MudText>

                                        @if (!string.IsNullOrWhiteSpace(_selectedAvatarFileName))
                                        {
                                            <div class="mf-selected-file">
                                                <strong>@_selectedAvatarFileName</strong>
                                                <span>@_selectedAvatarSizeLabel</span>
                                            </div>
                                        }

                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Disabled="@(_isBusy || _selectedAvatarBytes == null)"
                                                   OnClick="UploadAvatarDirectAsync">
                                            Upload Avatar
                                        </MudButton>
                                    </div>
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-3">
                                    Account Information
                                </MudText>

                                <div class="mf-form-grid">
                                    <MudTextField T="string"
                                                  Value="@_currentUser.Username"
                                                  Label="Username"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.Email"
                                                  Label="Email"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentRoleName"
                                                  Label="Role"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <MudTextField T="string"
                                                  Value="@_currentUser.StatusCode"
                                                  Label="Status"
                                                  Variant="Variant.Outlined"
                                                  ReadOnly="true"
                                                  Disabled="true" />

                                    <div class="mf-form-full">
                                        <MudTextField T="string"
                                                      @bind-Value="_displayName"
                                                      Label="Display Name"
                                                      Variant="Variant.Outlined"
                                                      Immediate="true"
                                                      Disabled="@_isBusy" />
                                    </div>
                                </div>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="UpdateDisplayNameDirectAsync"
                                           Class="mt-3">
                                    Save Display Name
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Portfolio)
                    {
                        <div class="mf-portfolio-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Current Portfolio
                                </MudText>

                                <div class="mf-document-current">
                                    @if (!string.IsNullOrWhiteSpace(_portfolioUrl))
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">
                                                @_portfolioTypeLabel
                                            </span>

                                            <div class="mf-document-body">
                                                <strong>
                                                    @(string.IsNullOrWhiteSpace(_portfolioFileName)
                                                        ? "Portfolio document linked"
                                                        : _portfolioFileName)
                                                </strong>

                                                <span>
                                                    Current portfolio document is linked to this account.
                                                </span>
                                            </div>
                                        </div>

                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Primary"
                                                   Class="mt-3"
                                                   OnClick="OpenCurrentPortfolioPreviewAsync">
                                            Preview Current Portfolio
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <div class="mf-document-row">
                                            <span class="mf-document-badge">FILE</span>

                                            <div class="mf-document-body">
                                                <strong>No portfolio document</strong>
                                                <span>
                                                    Upload a PDF, DOC, or DOCX file to link
                                                    a portfolio to this account.
                                                </span>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Upload Portfolio Document
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Accepted formats: PDF, DOC, DOCX.
                                    Maximum file size: 10MB.
                                </MudText>

                                <label class="mf-document-dropzone">
                                    <InputFile OnChange="SelectPortfolioAsync"
                                               accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.pdf,.doc,.docx"
                                               class="mf-file-input-hidden" />

                                    <span>Choose Document</span>
                                    <small>PDF, DOC, DOCX · max 10MB</small>
                                </label>

                                @if (!string.IsNullOrWhiteSpace(_selectedPortfolioFileName))
                                {
                                    <div class="mf-selected-file mt-3">
                                        <strong>@_selectedPortfolioFileName</strong>
                                        <span>@_selectedPortfolioSizeLabel</span>
                                    </div>
                                }

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@(_isBusy || _selectedPortfolioBytes == null)"
                                           OnClick="UploadPortfolioDirectAsync"
                                           Class="mt-3">
                                    Upload Portfolio
                                </MudButton>
                            </section>
                        </div>
                    }
                    else if (_activeSection == ProfileSettingsSection.Security)
                    {
                        <div class="mf-security-grid">
                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    Reset Password
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Email OTP is required to confirm password reset.
                                </MudText>

                                <MudTextField T="string"
                                              @bind-Value="_newPassword"
                                              Label="New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy" />

                                <MudTextField T="string"
                                              @bind-Value="_confirmPassword"
                                              Label="Confirm New Password"
                                              InputType="InputType.Password"
                                              Variant="Variant.Outlined"
                                              Disabled="@_isBusy"
                                              Class="mt-3" />

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Disabled="@_isBusy"
                                           OnClick="SendOtpForPasswordAsync"
                                           Class="mt-3">
                                    Send OTP
                                </MudButton>
                            </section>

                            <section class="mf-card">
                                <MudText Typo="Typo.subtitle1"
                                         Class="font-weight-bold mb-2">
                                    OTP Confirmation
                                </MudText>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                    Code will be sent to
                                    <strong>@_currentUser.Email</strong>.
                                </MudText>

                                @if (_otpSentForPassword)
                                {
                                    <MudTextField T="string"
                                                  @bind-Value="_otpCodePassword"
                                                  Label="OTP Code"
                                                  Variant="Variant.Outlined"
                                                  MaxLength="6"
                                                  Disabled="@_isBusy" />

                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Success"
                                               Disabled="@_isBusy"
                                               OnClick="ConfirmPasswordResetAsync"
                                               Class="mt-3">
                                        Confirm Reset
                                    </MudButton>
                                }
                                else
                                {
                                    <div class="mf-empty-note">
                                        Enter a new password and request OTP.
                                    </div>
                                }
                            </section>
                        </div>
                    }
                </main>
            </MudPaper>
        }
    </section>
</div>

@if (_showAvatarCropDialog)
{
    <div class="mf-crop-overlay"
         @onclick="CancelAvatarCropAsync">

        <section class="mf-crop-dialog"
                 role="dialog"
                 aria-modal="true"
                 aria-labelledby="avatar-crop-title"
                 @onclick:stopPropagation="true">

            <header class="mf-crop-header">
                <div>
                    <h2 id="avatar-crop-title">Adjust Avatar</h2>
                    <p>
                        Drag the image to reposition it and use the slider to zoom.
                    </p>
                </div>

                <button type="button"
                        class="mf-crop-close"
                        aria-label="Close avatar crop editor"
                        disabled="@_avatarCropBusy"
                        @onclick="CancelAvatarCropAsync">
                    ×
                </button>
            </header>

            <div class="mf-crop-body">
                <div class="mf-crop-stage">
                    <canvas id="@AvatarCropCanvasId"
                            class="@(_avatarCropReady
                                                        ? "mf-crop-canvas is-ready"
                                                        : "mf-crop-canvas")"
                            width="480"
                            height="480">
                    </canvas>

                    @if (!_avatarCropReady)
                    {
                        <div class="mf-crop-loading">
                            Loading image...
                        </div>
                    }
                </div>

                <aside class="mf-crop-controls">
                    <div>
                        <strong>Square crop</strong>
                        <p>Output: 512 × 512 PNG</p>
                    </div>

                    <label for="avatar-crop-zoom">Zoom</label>

                    <div class="mf-crop-zoom-row">
                        <button type="button"
                                title="Zoom out"
                                disabled="@(!_avatarCropReady || _avatarCropBusy)"
                                @onclick="ZoomAvatarOutAsync">
                            −
                        </button>

                        <input id="avatar-crop-zoom"
                               type="range"
                               min="1"
                               max="3"
                               step="0.01"
                               value="@_avatarCropZoom.ToString(CultureInfo.InvariantCulture)"
                               disabled="@(!_avatarCropReady || _avatarCropBusy)"
                               @oninput="AvatarCropZoomChangedAsync" />

                        <button type="button"
                                title="Zoom in"
                                disabled="@(!_avatarCropReady || _avatarCropBusy)"
                                @onclick="ZoomAvatarInAsync">
                            +
                        </button>
                    </div>

                    <button type="button"
                            class="mf-crop-reset"
                            disabled="@(!_avatarCropReady || _avatarCropBusy)"
                            @onclick="ResetAvatarCropAsync">
                        Reset position and zoom
                    </button>

                    <div class="mf-crop-help">
                        <span>Drag the image inside the fixed square.</span>
                        <span>The circular border shows the final avatar view.</span>
                    </div>
                </aside>
            </div>

            <footer class="mf-crop-footer">
                <button type="button"
                        class="mf-crop-cancel"
                        disabled="@_avatarCropBusy"
                        @onclick="CancelAvatarCropAsync">
                    Cancel
                </button>

                <button type="button"
                        class="mf-crop-confirm"
                        disabled="@(!_avatarCropReady || _avatarCropBusy)"
                        @onclick="ConfirmAvatarCropAsync">
                    @(_avatarCropBusy
                        ? "Processing..."
                        : "Use This Image")
                </button>
            </footer>
        </section>
    </div>
}

@if (_showPortfolioPreview && _currentPortfolio != null)
{
    <MudDialog @bind-Visible="_showPortfolioPreview"
               Options="_portfolioPreviewDialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6" Class="font-weight-bold">
                <MudIcon Icon="@Icons.Material.Filled.Preview"
                         Class="mr-2" />
                Portfolio Preview - @_currentPortfolio.OriginalFileName
            </MudText>
        </TitleContent>

        <DialogContent>
            @if (_isImagePreview)
            {
                <div class="d-flex justify-center my-2">
                    <MudImage Src="@($"/api/portfolio/{_currentPortfolio.FileResourceId}")"
                              Alt="Portfolio Image"
                              Fluid="true"
                              Class="rounded"
                              Style="max-height: 60vh; object-fit: contain;" />
                </div>
            }
            else
            {
                <div style="height: 80vh;">
                    <MudText Typo="Typo.caption"
                             Class="mf-muted text-center mb-2">
                        If the document does not load,
                        <MudLink Href="@($"/api/portfolio/{_currentPortfolio.FileResourceId}")"
                                 Target="_blank">
                            click here to open it in a new tab
                        </MudLink>.
                    </MudText>

                    <iframe src="@($"/api/portfolio/{_currentPortfolio.FileResourceId}")"
                            width="100%"
                            style="height: calc(80vh - 80px); border: none; border-radius: 4px; position: relative; z-index: 0;">
                    </iframe>
                </div>
            }
        </DialogContent>
    </MudDialog>
}

@code {
    private const long MaxUploadBytes = 10 * 1024 * 1024;

    private const string ActionPasswordOtp = "PROFILE_PASSWORD_RESET";

    private const string AvatarCropCanvasId =
        "profile-settings-avatar-crop-canvas";

    private bool _isLoading = true;
    private bool _isBusy;

    private UserDto? _currentUser;
    private Guid _currentUserId;
    private string _currentRoleName = "User";

    private string _displayName = string.Empty;
    private string _avatarInitial = "?";
    private string? _avatarUrl;
    private string? _portfolioUrl;
    private string? _portfolioFileName;
    private string _portfolioTypeLabel = "FILE";

    private FileResourceDto? _currentPortfolio;
    private bool _showPortfolioPreview;
    private bool _isImagePreview;

    private readonly DialogOptions _portfolioPreviewDialogOptions =
        new()
        {
            FullWidth = true,
            MaxWidth = MaxWidth.ExtraLarge,
            CloseButton = true
        };

    private string? _operationMessage;
    private Severity _operationSeverity = Severity.Info;

    private IJSObjectReference? _avatarCropModule;

    private bool _showAvatarCropDialog;
    private bool _initializeAvatarCrop;
    private bool _avatarCropReady;
    private bool _avatarCropBusy;

    private string? _avatarCropSourceDataUrl;
    private string? _pendingAvatarOriginalFileName;

    private double _avatarCropZoom = 1;
    private int _avatarInputKey;

    private string? _avatarPreviewDataUrl;
    private byte[]? _selectedAvatarBytes;
    private string? _selectedAvatarFileName;
    private string? _selectedAvatarUploadFileName;
    private string? _selectedAvatarSizeLabel;
    private string _selectedAvatarContentType = "image/jpeg";

    private string? _selectedPortfolioFileName;
    private string? _selectedPortfolioUploadFileName;
    private string? _selectedPortfolioSizeLabel;
    private byte[]? _selectedPortfolioBytes;
    private string? _selectedPortfolioContentType;

    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _otpSentForPassword;
    private string _otpCodePassword = string.Empty;

    private ProfileSettingsSection _activeSection =
        ProfileSettingsSection.Profile;

    private string CurrentSectionTitle => _activeSection switch
    {
        ProfileSettingsSection.Profile => "Profile",
        ProfileSettingsSection.Portfolio => "Portfolio Document",
        ProfileSettingsSection.Security => "Security",
        _ => "Profile"
    };

    private string CurrentSectionDescription => _activeSection switch
    {
        ProfileSettingsSection.Profile =>
            "Update your display name and profile picture.",

        ProfileSettingsSection.Portfolio =>
            "Manage your PDF, DOC, or DOCX portfolio document.",

        ProfileSettingsSection.Security =>
            "Reset password with email OTP confirmation.",

        _ => string.Empty
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_showAvatarCropDialog ||
            !_initializeAvatarCrop ||
            string.IsNullOrWhiteSpace(
                _avatarCropSourceDataUrl))
        {
            return;
        }

        _initializeAvatarCrop = false;

        try
        {
            /*
             * Thêm version vào URL để trình duyệt không dùng
             * lại module JavaScript lỗi đã lưu trong cache.
             */
            _avatarCropModule ??=
                await JSRuntime.InvokeAsync<IJSObjectReference>(
                    "import",
                    "./js/profile-settings-crop.js?v=20260614-04");

            await _avatarCropModule.InvokeVoidAsync(
                "initialize",
                AvatarCropCanvasId,
                _avatarCropSourceDataUrl);

            _avatarCropReady = true;
        }
        catch (Exception ex)
        {
            _showAvatarCropDialog = false;
            _avatarCropReady = false;

            SetOperation(
                $"Unable to open avatar crop editor: {ex.Message}",
                Severity.Error);

            Snackbar.Add(
                $"Unable to open avatar crop editor: {ex.Message}",
                Severity.Error);
        }

        StateHasChanged();
    }
    private void BackToDashboard()
    {
        var normalizedRole =
            _currentRoleName?
                .Trim()
                .ToLowerInvariant()
            ?? string.Empty;

        var dashboardUrl = normalizedRole switch
        {
            "admin" => "/admin",

            "mangaka" => "/mangaka",

            "assistant" => "/assistant",

            "tantou editor" => "/editor",

            "editorial board member" => "/ranking",

            "editorial board chief" => "/ranking",

            _ => "/dashboard"
        };

        NavigationManager.NavigateTo(dashboardUrl);
    }
    private void SelectSection(ProfileSettingsSection section)
    {
        _activeSection = section;
        _operationMessage = null;
    }

    private string GetMenuClass(ProfileSettingsSection section)
    {
        return _activeSection == section
            ? "mf-menu-item active"
            : "mf-menu-item";
    }

    private async Task LoadCurrentUserAsync()
    {
        _isLoading = true;
        _operationMessage = null;

        try
        {
            var authState =
                await AuthStateProvider.GetAuthenticationStateAsync();

            var principal = authState.User;

            if (principal?.Identity?.IsAuthenticated != true)
            {
                NavigationManager.NavigateTo("/login");
                return;
            }

            var idClaim =
                principal.FindFirst(ClaimTypes.NameIdentifier);

            if (!Guid.TryParse(idClaim?.Value, out _currentUserId))
            {
                SetOperation(
                    "Unable to resolve current user id.",
                    Severity.Error);

                return;
            }

            _currentUser =
                await ProfileApiClient.GetProfileAsync(_currentUserId);

            if (_currentUser == null)
            {
                SetOperation(
                    "Unable to load current user profile.",
                    Severity.Error);

                return;
            }

            _currentRoleName =
                principal.FindFirst(ClaimTypes.Role)?.Value
                ?? principal.FindFirst("role")?.Value
                ?? _currentUser.RoleName
                ?? "User";

            _displayName =
                _currentUser.DisplayName;

            _avatarInitial =
                BuildInitial(
                    _currentUser.DisplayName,
                    _currentUser.Username);

            await LoadCurrentFilesAsync();
        }
        catch (Exception ex)
        {
            SetOperation(ex.Message, Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCurrentFilesAsync()
    {
        _avatarUrl = null;
        _portfolioUrl = null;
        _portfolioFileName = null;
        _portfolioTypeLabel = "FILE";

        if (_currentUser?.AvatarFileId.HasValue == true)
        {
            var avatarFile =
                await ProfileApiClient.GetFileAsync(
                    _currentUser.AvatarFileId.Value);

            if (avatarFile != null &&
                avatarFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(
                    avatarFile.CloudinarySecureUrl))
            {
                _avatarUrl =
                    BuildVersionedUrl(
                        avatarFile.CloudinarySecureUrl,
                        avatarFile.FileResourceId);
            }
        }

        if (_currentUser?.PortfolioFileId.HasValue == true)
        {
            var portfolioFile =
                await ProfileApiClient.GetFileAsync(
                    _currentUser.PortfolioFileId.Value);

            if (portfolioFile != null &&
                portfolioFile.DeletedAtUtc == null &&
                !string.IsNullOrWhiteSpace(
                    portfolioFile.CloudinarySecureUrl))
            {
                _portfolioUrl =
                    $"/api/portfolio/{portfolioFile.FileResourceId:D}";

                _portfolioFileName =
                    portfolioFile.OriginalFileName;

                _portfolioTypeLabel =
                    BuildDocumentTypeLabel(
                        portfolioFile.OriginalFileName,
                        portfolioFile.ContentType);
