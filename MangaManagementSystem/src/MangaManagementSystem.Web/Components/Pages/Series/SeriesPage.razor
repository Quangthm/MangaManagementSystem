@page "/series/{Slug}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Components.Pages.Mangaka
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize]
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ISeriesApiClient SeriesApiClient
@inject AuthenticationStateProvider AuthStateProvider

<div style="min-height: 100vh; background: #f8fafc; padding: 40px 32px;">
    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 80px 0;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_series is null)
    {
        <div style="max-width: 600px; margin: 0 auto; text-align: center; padding: 80px 0;">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 56px; color: #cbd5e1; margin-bottom: 16px;" />
            <div style="font-weight: 700; font-size: 1.2rem; color: #111827; margin-bottom: 8px;">Series Not Found</div>
            <div style="color: #64748b; font-size: 0.9rem; margin-bottom: 24px;">
                No series was found for the URL <code style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px;">/series/@Slug</code>.
            </div>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo("/mangaka"))">
                Back to Dashboard
            </MudButton>
        </div>
    }
    else
    {
        <div style="max-width: 900px; margin: 0 auto;">
            @* Back navigation *@
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Style="color: #64748b; margin-bottom: 24px;"
                       OnClick="@(() => Nav.NavigateTo("/mangaka"))">
                Back to Dashboard
            </MudButton>

            @* ── Series header card: cover + metadata ── *@
            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; margin-bottom: 24px;">
                <div style="display: flex; gap: 0; align-items: stretch;">

                    @* ── Cover ── *@
                    <div style="width: 220px; flex-shrink: 0; background: #f1f5f9; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        @if (!string.IsNullOrWhiteSpace(_series.CoverUrl))
                        {
                            <img src="@_series.CoverUrl" alt="Cover"
                                 style="width: 220px; height: 310px; object-fit: cover; display: block;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                     Style="font-size: 72px; color: #cbd5e1;" />
                        }
                    </div>

                    @* ── Main info ── *@
                    <div style="flex: 1; padding: 28px 28px; display: flex; flex-direction: column;">
                        @* Title *@
                        <div style="font-weight: 800; font-size: 1.5rem; color: #111827; margin-bottom: 10px; line-height: 1.2;">
                            @_series.Title
                        </div>

                        @* Badges *@
                        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px;">
                            <span style="background: @SeriesStatusHelper.BadgeColor(_series.StatusCode); color: @SeriesStatusHelper.TextColor(_series.StatusCode); font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 600;">
                                @SeriesStatusHelper.DisplayName(_series.StatusCode)
                            </span>
                            <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                @_series.Genre
                            </span>
                            @if (!string.IsNullOrWhiteSpace(_series.ContentLanguageCode))
                            {
                                <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                    @LanguageLabel(_series.ContentLanguageCode)
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_series.PublicationFrequencyCode))
                            {
                                <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                    @_series.PublicationFrequencyCode.Replace("_", " ")
                                </span>
                            }
                        </div>

                        @* Contributors *@
                        @if (_series.ContributorDisplayNames.Count > 0)
                        {
                            <div style="margin-bottom: 14px;">
                                <span style="font-size: 0.72rem; color: #94a3b8; text-transform: uppercase; font-weight: 600; letter-spacing: 0.05em;">Mangaka</span>
                                <div style="color: #374151; font-size: 0.9rem; font-weight: 500; margin-top: 2px;">
                                    @string.Join(", ", _series.ContributorDisplayNames)
                                </div>
                            </div>
                        }

                        @* Synopsis *@
                        @if (!string.IsNullOrWhiteSpace(_series.Synopsis))
                        {
                            <div style="color: #374151; font-size: 0.9rem; line-height: 1.6; flex-grow: 1;">
                                @_series.Synopsis
                            </div>
                        }

                        @* Open Workspace button *@
                        <div style="margin-top: 16px;">
                            @if (_workspaceAccess is { CanAccess: true })
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="false"
                                           StartIcon="@Icons.Material.Filled.OpenInNew"
                                           OnClick="@(() => Nav.NavigateTo($"/series/{Slug}/workspace"))">
                                    Open Workspace
                                </MudButton>
                            }
                            else if (_workspaceAccess is { CanAccess: false })
                            {
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="true"
                                               StartIcon="@Icons.Material.Filled.Lock">
                                        Open Workspace
                                    </MudButton>
                                    <span style="font-size: 0.75rem; color: #94a3b8;">Workspace access is only available to assigned contributors.</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            @* ── Chapter list ── *@
            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; margin-bottom: 24px;">
                <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                    <div>
                        <span style="font-weight: 700; font-size: 1rem; color: #111827;">Chapters</span>
                        @if (_series.TotalChapterCount > 0)
                        {
                            <span style="color: #94a3b8; font-size: 0.85rem; margin-left: 6px;">(@_series.TotalChapterCount)</span>
                        }
                    </div>
                    <span style="font-size: 0.8rem; color: #94a3b8;">
                        Page @_series.ChapterPage of @_series.TotalChapterPages
                    </span>
                </div>

                @if (_series.Chapters.Count == 0)
                {
                    <div style="padding: 48px 24px; text-align: center; color: #94a3b8;">
                        <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Style="font-size: 40px; opacity: 0.4;" />
                        <div style="margin-top: 8px; font-size: 0.9rem;">No chapters yet.</div>
                    </div>
                }
                else
                {
                    @foreach (var ch in _series.Chapters)
                    {
                        <div style="padding: 12px 24px; border-bottom: 1px solid #f8fafc; display: flex; align-items: center; justify-content: space-between; cursor: pointer; transition: background 0.12s;"
                             @onclick="@(() => Nav.NavigateTo($"/series/{Slug}/workspace?chapterId={ch.ChapterId}"))"
                             onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background=''">
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <span style="font-weight: 700; font-size: 0.85rem; color: #111827; min-width: 60px;">Ch. @ch.ChapterNumberLabel</span>
                                @if (!string.IsNullOrWhiteSpace(ch.Title))
                                {
                                    <span style="color: #374151; font-size: 0.9rem;">@ch.Title</span>
                                }
                                else
                                {
                                    <span style="color: #cbd5e1; font-size: 0.9rem; font-style: italic;">Untitled</span>
                                }
                            </div>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <span style="background: #f1f5f9; color: #475569; font-size: 0.7rem; padding: 2px 8px; border-radius: 8px; font-weight: 500;">@ch.StatusCode</span>
                                @if (ch.ReleasedAtUtc.HasValue)
                                {
                                    <span style="font-size: 0.75rem; color: #94a3b8;">@ch.ReleasedAtUtc.Value.ToString("MMM d, yyyy")</span>
                                }
                                else if (ch.PlannedReleaseDate.HasValue)
                                {
                                    <span style="font-size: 0.75rem; color: #cbd5e1;">Planned @ch.PlannedReleaseDate.Value.ToString("MMM d, yyyy")</span>
                                }
                                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Style="color: #cbd5e1; font-size: 18px;" />
                            </div>
                        </div>
                    }

                    @* Pagination *@
                    @if (_series.TotalChapterPages > 1)
                    {
                        <div style="padding: 16px 24px; display: flex; align-items: center; justify-content: center; gap: 8px; border-top: 1px solid #f1f5f9;">
                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       Disabled="@(_series.ChapterPage <= 1)"
                                       OnClick="@(() => LoadChaptersAsync(_series.ChapterPage - 1))">
                                Prev
                            </MudButton>

                            @for (int p = 1; p <= _series.TotalChapterPages; p++)
                            {
                                int pageNum = p;
                                bool isCurrent = pageNum == _series.ChapterPage;
                                <MudButton Size="Size.Small"
                                           Variant="@(isCurrent ? Variant.Filled : Variant.Outlined)"
                                           Color="@(isCurrent ? Color.Primary : Color.Default)"
                                           OnClick="@(() => LoadChaptersAsync(pageNum))">
                                    @pageNum
                                </MudButton>
                            }

                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       Disabled="@(_series.ChapterPage >= _series.TotalChapterPages)"
                                       OnClick="@(() => LoadChaptersAsync(_series.ChapterPage + 1))">
                                Next
                            </MudButton>
                        </div>
                    }
                }
            </div>

            @* ── URL info ── *@
            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 14px 20px; display: flex; align-items: center; gap: 10px; margin-bottom: 40px;">
                <MudIcon Icon="@Icons.Material.Filled.Link" Style="font-size: 18px; color: #94a3b8;" />
                <span style="color: #94a3b8; font-size: 0.8rem;">Stable series URL:</span>
                <code style="color: #6366f1; font-size: 0.8rem; background: #eef2ff; padding: 2px 8px; border-radius: 4px;">/series/@Slug</code>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string Slug { get; set; } = string.Empty;

    private SeriesDetailDto? _series;
    private SeriesWorkspaceEntryDto? _workspaceAccess;
    private bool _loading = true;
    private Guid? _currentUserId;

    private static string LanguageLabel(string? code) => code switch
    {
        "ja" => "Japanese",
        "en" => "English",
        "vi" => "Vietnamese",
        _ => code ?? "—"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var uid))
                _currentUserId = uid;
        }
        catch { }

        try
        {
            _series = await SeriesApiClient.GetSeriesDetailAsync(Slug);

            if (_series is not null && _currentUserId.HasValue)
            {
                _workspaceAccess = await SeriesApiClient.GetWorkspaceEntryAsync(_currentUserId.Value, Slug);
            }
        }
        catch
        {
            _series = null;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadChaptersAsync(int chapterPage)
    {
        if (chapterPage < 1) return;
        try
        {
            _series = await SeriesApiClient.GetSeriesDetailAsync(Slug, chapterPage);
            StateHasChanged();
        }
        catch { }
    }
}
