@page "/series/{Slug}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject NavigationManager Nav
@inject ISeriesService SeriesService
@inject ISnackbar Snackbar
@using MangaManagementSystem.Application.Interfaces
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Components.Pages.Mangaka

@* ── Minimal stub for /series/{slug} ── *@
@* Full chapter management, workspace entry, and reader features will be added later. *@

<div style="min-height: 100vh; background: #f8fafc; padding: 40px 32px;">
    @if (_loading)
    {
        <div style="display: flex; justify-content: center; padding: 80px 0;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </div>
    }
    else if (_series == null)
    {
        <div style="max-width: 600px; margin: 0 auto; text-align: center; padding: 80px 0;">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size: 56px; color: #cbd5e1; margin-bottom: 16px;" />
            <div style="font-weight: 700; font-size: 1.2rem; color: #111827; margin-bottom: 8px;">Series Not Found</div>
            <div style="color: #64748b; font-size: 0.9rem; margin-bottom: 24px;">
                No series was found for the URL <code style="background: #f1f5f9; padding: 2px 6px; border-radius: 4px;">@Slug</code>.
            </div>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo("/mangaka"))">
                Back to Dashboard
            </MudButton>
        </div>
    }
    else
    {
        <div style="max-width: 800px; margin: 0 auto;">
            @* Back navigation *@
            <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                       Variant="Variant.Text"
                       Style="color: #64748b; margin-bottom: 24px;"
                       OnClick="@(() => Nav.NavigateTo("/mangaka"))">
                Back to Dashboard
            </MudButton>

            @* Series header *@
            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; overflow: hidden; margin-bottom: 24px;">
                @* Cover + info row *@
                <div style="display: flex; gap: 0; align-items: stretch;">
                    @* Cover *@
                    <div style="width: 140px; flex-shrink: 0; background: #f1f5f9; display: flex; align-items: center; justify-content: center; overflow: hidden;">
                        @if (!string.IsNullOrWhiteSpace(_series.CoverUrl))
                        {
                            <img src="@_series.CoverUrl" alt="Cover"
                                 style="width: 140px; height: 200px; object-fit: cover; display: block;" />
                        }
                        else
                        {
                            <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                     Style="font-size: 56px; color: #cbd5e1;" />
                        }
                    </div>

                    @* Info *@
                    <div style="flex: 1; padding: 28px 28px;">
                        <div style="font-weight: 800; font-size: 1.5rem; color: #111827; margin-bottom: 12px; line-height: 1.2;">
                            @_series.Title
                        </div>

                        <div style="display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px;">
                            <span style="background: @SeriesStatusHelper.BadgeColor(_series.StatusCode); color: @SeriesStatusHelper.TextColor(_series.StatusCode); font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 600;">
                                @SeriesStatusHelper.DisplayName(_series.StatusCode)
                            </span>
                            <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                @_series.Genre
                            </span>
                            @if (!string.IsNullOrWhiteSpace(_series.ContentLanguageCode))
                            {
                                <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                    @LanguageLabel(_series.ContentLanguageCode)
                                </span>
                            }
                            @if (!string.IsNullOrWhiteSpace(_series.PublicationFrequencyCode))
                            {
                                <span style="background: #f1f5f9; color: #475569; font-size: 0.72rem; padding: 3px 10px; border-radius: 12px; font-weight: 500;">
                                    @_series.PublicationFrequencyCode.Replace("_", " ")
                                </span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_series.Synopsis))
                        {
                            <div style="color: #374151; font-size: 0.9rem; line-height: 1.6;">
                                @_series.Synopsis
                            </div>
                        }
                    </div>
                </div>
            </div>

            @* Placeholder notice *@
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Style="margin-bottom: 24px;">
                <strong>Coming soon:</strong> Chapter list, workspace entry, and production management tools will be added in a future update.
            </MudAlert>

            @* URL info *@
            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 16px 20px; display: flex; align-items: center; gap: 10px;">
                <MudIcon Icon="@Icons.Material.Filled.Link" Style="font-size: 18px; color: #94a3b8;" />
                <span style="color: #94a3b8; font-size: 0.8rem;">Stable series URL:</span>
                <code style="color: #6366f1; font-size: 0.8rem; background: #eef2ff; padding: 2px 8px; border-radius: 4px;">/series/@Slug</code>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Slug { get; set; } = string.Empty;

    private SeriesDto? _series;
    private bool _loading = true;

    private static string LanguageLabel(string? code) => code switch
    {
        "ja" => "Japanese",
        "en" => "English",
        "vi" => "Vietnamese",
        _ => code ?? "—"
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load all series and find by slug. A dedicated GetBySlugAsync is a future
            // optimisation; for MVP the series count is small and this avoids a new
            // repository method for a stub page.
            var all = await SeriesService.GetAllSeriesAsync();
            _series = all.FirstOrDefault(s =>
                string.Equals(s.Slug, Slug, StringComparison.OrdinalIgnoreCase));
        }
        catch
        {
            _series = null;
        }
        finally
        {
            _loading = false;
        }
    }
}
