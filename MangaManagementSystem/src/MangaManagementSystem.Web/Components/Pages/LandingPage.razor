@page "/"
@layout PublicLayout
@inject NavigationManager Nav

<PageTitle>MangaFlow — Manga Production Workflow Management</PageTitle>

<div class="mf-landing">

    @* ═══════════════════════════════════════════════════
       HERO
       ═══════════════════════════════════════════════════ *@
    <div class="mf-landing-hero">
        <div class="mf-float-shape mf-float-shape-1"></div>
        <div class="mf-float-shape mf-float-shape-2"></div>
        <div class="mf-float-shape mf-float-shape-3"></div>
        <div class="mf-float-shape mf-float-shape-4"></div>
        <div class="mf-float-shape mf-float-shape-5"></div>
        <div class="mf-hero-grid"></div>

        <MudContainer MaxWidth="MaxWidth.Large" Class="py-4">

            @* Nav *@
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="py-3">
                <MudText Typo="Typo.h5" Class="font-weight-bold mf-gradient-text" Style="cursor:default;">MangaFlow</MudText>
                <MudStack Row="true" Spacing="2" Class="d-none d-md-flex">
                    <MudButton Href="#features" Variant="Variant.Text">Features</MudButton>
                    <MudButton Href="#workflow" Variant="Variant.Text">Workflow</MudButton>
                </MudStack>
                <MudStack Row="true" Spacing="2">
                    <MudButton Href="/login" Variant="Variant.Text">Login</MudButton>
                    <MudButton Href="/register" Variant="Variant.Filled" Color="Color.Primary">Create Account</MudButton>
                </MudStack>
            </MudStack>

            @* Hero body *@
            <MudGrid Class="py-12 py-md-16 mf-fade-up">
                <MudItem xs="12" md="6" Class="d-flex flex-column justify-center">
                    <MudText Typo="Typo.h2" Class="font-weight-bold mb-4 mf-shimmer-text" Style="line-height:1.15;">
                        Manage Manga Production<br />from Draft to Publication
                    </MudText>
                    <MudText Typo="Typo.body1" Class="mf-muted mb-6" Style="font-size:1.1rem;line-height:1.7;max-width:520px;">
                        Coordinate chapters, pages, assistant tasks, editorial reviews, board approvals, and publishing progress in one role-based platform.
                    </MudText>
                    <MudStack Row="true" Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" Href="/register">Create Account</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Large" Href="/login">Login</MudButton>
                    </MudStack>
                </MudItem>

            </MudGrid>
        </MudContainer>
    </div>

    @* ═══════════════════════════════════════════════════
       FEATURES
       ═══════════════════════════════════════════════════ *@
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-16" id="features">
        <div class="text-center mb-14 mf-fade-up" style="animation-delay:0.1s;">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-3">Everything You Need for Manga Production</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted" Style="font-size:1.05rem;max-width:580px;margin:0 auto;">
                From chapter creation to publication tracking — MangaFlow brings every role and every stage into one dashboard.
            </MudText>
        </div>

        <div class="mf-feature-grid">
            @{ int fi = 0; }
            @foreach (var feature in Features)
            {
                <div class="mf-feature-item mf-fade-up" style="animation-delay:@(0.25 + fi * 0.08)s;">
                    <div class="mf-feature-icon-wrap">
                        <MudIcon Icon="@feature.Icon" Size="Size.Medium" Style="color:var(--mf-primary);" />
                    </div>
                    <div>
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">@feature.Title</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted" Style="line-height:1.6;">@feature.Description</MudText>
                    </div>
                </div>
                fi++;
            }
        </div>
    </MudContainer>

    @* ═══════════════════════════════════════════════════
       WORKFLOW
       ═══════════════════════════════════════════════════ *@
    <div class="mf-pipeline-section">
        <MudContainer MaxWidth="MaxWidth.Large" Class="py-16" id="workflow">
            <div class="text-center mb-14 mf-fade-up">
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-3">Streamlined Production Workflow</MudText>
                <MudText Typo="Typo.body1" Class="mf-muted" Style="font-size:1.05rem;max-width:520px;margin:0 auto;">
                    Four clear stages from creation to release, designed for manga production teams.
                </MudText>
            </div>

            <div class="mf-pipeline">
                @for (int i = 0; i < Workflow.Count; i++)
                {
                    var step = Workflow[i];
                    <div class="mf-pipeline-node mf-fade-up" style="animation-delay:@(i * 0.1)s;">
                        <div class="mf-node-circle">@step.No</div>
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-1" Style="margin-top:12px;">@step.Title</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted" Style="line-height:1.5;">@step.Description</MudText>
                    </div>
                }
                <div class="mf-pipeline-line"></div>
            </div>
        </MudContainer>
    </div>

    @* ═══════════════════════════════════════════════════
       CTA
       ═══════════════════════════════════════════════════ *@
    <MudContainer MaxWidth="MaxWidth.Large" Class="py-16">
        <div class="mf-cta mf-fade-up">
            <div class="mf-cta-particle mf-cta-particle-1"></div>
            <div class="mf-cta-particle mf-cta-particle-2"></div>
            <div class="mf-cta-particle mf-cta-particle-3"></div>
            <div class="mf-cta-particle mf-cta-particle-4"></div>
            <div style="position:relative;z-index:1;">
                <MudText Typo="Typo.h4" Class="font-weight-bold mb-2" Style="color:white;">
                    Ready to manage your manga workflow?
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-6" Style="color:rgba(255,255,255,.7);max-width:500px;margin-left:auto;margin-right:auto;">
                    Start coordinating production work with clear roles, reviews, approvals, and progress tracking.
                </MudText>
                <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" Href="/register">Create Account</MudButton>
                    <MudButton Variant="Variant.Outlined" Size="Size.Large" Href="/login"
                               Style="color:white;border-color:rgba(255,255,255,.4);">Login</MudButton>
                </MudStack>
            </div>
        </div>
    </MudContainer>

    @* ═══════════════════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════════════════ *@
    <footer class="mf-landing-footer">
        <MudContainer MaxWidth="MaxWidth.Large">
            <div class="mf-footer-inner">
                <MudText Typo="Typo.body2" Class="mf-muted">
                    MangaFlow &mdash; Manga Production Workflow Management System
                </MudText>
                <div class="mf-footer-links">
                    <MudButton Href="#features" Variant="Variant.Text" Size="Size.Small">Features</MudButton>
                    <MudButton Href="#workflow" Variant="Variant.Text" Size="Size.Small">Workflow</MudButton>
                    <MudText Typo="Typo.body2" Class="mf-muted">&copy; 2026</MudText>
                </div>
            </div>
        </MudContainer>
    </footer>

</div>

@code {
    private readonly List<FeatureItem> Features = new()
    {
        new(Icons.Material.Filled.LibraryBooks, "Chapter & Page Management",
            "Organize chapters, track page progress, manage revisions, and maintain version history for manuscripts."),
        new(Icons.Material.Filled.Assignment, "Task Assignment",
            "Assign tasks to mangaka and assistants, set deadlines, and coordinate team workflows."),
        new(Icons.Material.Filled.RateReview, "Editorial Review",
            "Review dialogue, layout, annotations, and editorial feedback before publication."),
        new(Icons.Material.Filled.HowToVote, "Board Approval",
            "Editorial board reviews approved manuscripts and makes publication decisions."),
        new(Icons.Material.Filled.PublishedWithChanges, "Publishing Tracking",
            "Track manuscripts through the publishing pipeline and release schedule."),
        new(Icons.Material.Filled.Shield, "Audit & Permission Control",
            "Use role-based access and audit logs for accountable workflow management.")
    };

    private readonly List<StepItem> Workflow = new()
    {
        new("1", "Create", "Mangaka creates series, chapters, and pages."),
        new("2", "Review", "Editors annotate and review production material."),
        new("3", "Approve", "Board members vote and make decisions."),
        new("4", "Publish", "Approved work moves into release tracking.")
    };

    private record FeatureItem(string Icon, string Title, string Description);
    private record StepItem(string No, string Title, string Description);
}
