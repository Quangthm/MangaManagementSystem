@page "/board-chief"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Editorial Board Chief")]
@inject NavigationManager Nav

<RankingLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Editorial Board Chief Workspace</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Series ranking, board decisions, voting, and administrative oversight</MudText>
        </div>

        <MudAlert Severity="Severity.Info" Class="mb-6">
            <MudText Typo="Typo.caption" Class="font-weight-bold">Welcome</MudText>
            <MudText Class="mt-1">As a Board Chief, you have full access to board functions, including creating polls and overseeing series decisions.</MudText>
        </MudAlert>

        <MudGrid Class="mb-6">
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Series Ranking</MudText>
                    <MudText Class="mf-muted">View and analyze reader poll results.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-3" OnClick="@(() => Nav.NavigateTo("/ranking"))">
                        View Rankings
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Board Decisions</MudText>
                    <MudText Class="mf-muted">View board poll outcomes and decisions.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-3" OnClick="@(() => Nav.NavigateTo("/board-decision"))">
                        View Decisions
                    </MudButton>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Board Polls</MudText>
                    <MudText Class="mf-muted">Create and manage board polls for series decisions.</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-3" OnClick="@(() => Nav.NavigateTo("/board/polls"))">
                        Manage Polls
                    </MudButton>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Series Requiring Attention</MudText>
            <MudText Class="mf-muted">No series currently in the danger zone requiring board review.</MudText>
        </MudPaper>
    </div>
</RankingLayout>
