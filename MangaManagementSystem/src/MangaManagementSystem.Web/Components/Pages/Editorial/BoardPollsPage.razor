@page "/demo/mangaflow/decisions"
@namespace MangaManagementSystem.Web.Components.Pages.Editorial

@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Web.Services.EditorialBoard

@inject IEditorialBoardApiClient EditorialBoardApiClient

<MangaFlowShell Title="Decision Center"
                Subtitle="Review current board polls, track votes, and manage board decisions."
                ActiveMenu="decisions">
    <ChildContent>
        @if (_isLoading)
        {
            <section class="mf-card">
                <div class="mf-strong">Loading decision center...</div>
                <div class="mf-muted">Fetching current board polls from database.</div>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="mf-card">
                <div class="mf-strong">Cannot load decision center</div>
                <div class="mf-muted">@_errorMessage</div>

                <button class="mf-btn mf-btn-primary mf-gap-small"
                        @onclick="LoadPageDataAsync">
                    Retry
                </button>
            </section>
        }
        else
        {
            <div class="mf-grid mf-grid-3">
                <KpiCard Label="Current Polls"
                         Value="@_polls.Count.ToString(CultureInfo.InvariantCulture)"
                         Description="Active decision sessions"
                         Icon="O"
                         Tone="green" />

                <KpiCard Label="Total Votes"
                         Value="@_polls.Sum(p => p.TotalVotes).ToString(CultureInfo.InvariantCulture)"
                         Description="Votes already submitted"
                         Icon="C"
                         Tone="blue" />

                <KpiCard Label="My Pending Votes"
                         Value="@_polls.Count(p => !HasCurrentUserVoted(p)).ToString(CultureInfo.InvariantCulture)"
                         Description="Polls waiting for your vote"
                         Icon="U"
                         Tone="orange" />
            </div>

            <h2 class="mf-section-title">Current Polls</h2>

            @if (_polls.Count == 0)
            {
                <section class="mf-card">
                    <div class="mf-strong">No current polls</div>
                    <div class="mf-muted">
                        When Board Chief opens a serialization or cancellation poll, it will appear here from SQL Server.
                    </div>
                </section>
            }
            else
            {
                <div class="mf-grid mf-grid-2">
                    @foreach (var poll in _polls)
                    {
                        <article class="mf-poll-card">
                            <div class="mf-row">
                                <div>
                                    <h3>@poll.PollName</h3>
                                    <div class="mf-muted">@poll.Code · @poll.PollTypeCode</div>
                                </div>

                                <div class="mf-poll-card-header-actions">
                                    <button type="button"
                                            class="mf-btn mf-btn-soft"
                                            @onclick:stopPropagation="true"
                                            @onclick="() => OpenSeriesInformation(poll)">
                                        Information
                                    </button>

                                    <StatusBadge Status="Open" />
                                </div>
                            </div>

                            <VoteBreakdown Approve="@poll.ApproveVotes"
                                           Reject="@poll.RejectVotes"
                                           Abstain="@poll.AbstainVotes"
                                           TotalMembers="@TotalBoardMembers" />

                            <div class="mf-row mf-gap-small">
                                <div class="mf-muted">@DeadlineText(poll)</div>

                                @if (HasCurrentUserVoted(poll))
                                {
                                    <StatusBadge Status="@($"Voted {poll.CurrentUserChoiceCode}")" />
                                }
                                else
                                {
                                    <StatusBadge Status="Not Voted" />
                                }
                            </div>

                            <div class="mf-actions end">
                                <button class="mf-btn mf-btn-primary"
                                        @onclick="() => OpenVotingCenter(poll)">
                                    @(HasCurrentUserVoted(poll) ? "View Poll" : "Vote / View Poll")
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }

            @if (_selectedPoll is not null)
            {
                <div class="mf-modal-backdrop" @onclick="CloseVotingCenter">
                    <div class="mf-voting-modal" @onclick:stopPropagation="true">
                        <div class="mf-voting-header">
                            <div>
                                <h2>@_selectedPoll.PollName</h2>
                                <p>@_selectedPoll.Code · @_selectedPoll.PollTypeCode · @DeadlineText(_selectedPoll)</p>
                            </div>

                            <div class="mf-voting-header-actions">
                                <span class="mf-deadline-pill">@DeadlineText(_selectedPoll)</span>

                                <AuthorizeView Roles="Editorial Board Chief">
                                    <Authorized>
                                        @if (!IsEditingDeadline(_selectedPoll))
                                        {
                                            <button type="button"
                                                    class="mf-btn mf-btn-soft mf-deadline-header-btn"
                                                    @onclick="() => StartDeadlineEditor(_selectedPoll)">
                                                Update Deadline
                                            </button>
                                        }
                                    </Authorized>
                                </AuthorizeView>

                                <button class="mf-icon-btn"
                                        @onclick="CloseVotingCenter">
                                    ×
                                </button>
                            </div>
                        </div>

                        <AuthorizeView Roles="Editorial Board Chief">
                            <Authorized>
                                @if (IsEditingDeadline(_selectedPoll))
                                {
                                    <div class="mf-deadline-editor mf-deadline-editor-header">
                                        <label>Update deadline</label>

                                        <input class="mf-input"
                                               type="date"
                                               value="@_deadlineDraftText"
                                               @onchange="OnDeadlineDateChanged" />

                                        <div class="mf-actions tight">
                                            <button type="button"
                                                    class="mf-btn mf-btn-primary"
                                                    disabled="@_isSavingDeadline"
                                                    @onclick="() => SaveDeadlineAsync(_selectedPoll)">
                                                @(_isSavingDeadline ? "Saving..." : "Save")
                                            </button>

                                            <button type="button"
                                                    class="mf-btn"
                                                    disabled="@_isSavingDeadline"
                                                    @onclick="() => ClearDeadlineAsync(_selectedPoll)">
                                                Clear
                                            </button>

                                            <button type="button"
                                                    class="mf-btn"
                                                    disabled="@_isSavingDeadline"
                                                    @onclick="CancelDeadlineEditor">
                                                Cancel
                                            </button>
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(_deadlineMessage)
                                            && _deadlineEditorPollId == _selectedPoll.PollId)
                                        {
                                            <div class="mf-alert info">
                                                @_deadlineMessage
                                            </div>
                                        }
                                    </div>
                                }
                            </Authorized>
                        </AuthorizeView>

                        <div class="mf-voting-body">
                            <main class="mf-voting-main">
                                <section class="mf-card">
                                    <div class="mf-series-title-row">
                                        <h2>@_selectedPoll.SeriesTitle</h2>

                                        <button type="button"
                                                class="mf-btn mf-btn-soft"
                                                @onclick:stopPropagation="true"
                                                @onclick="OpenSelectedSeriesInformation">
                                            Information
                                        </button>
                                    </div>

                                    <div class="mf-proposal-summary-box">
                                        <strong>Poll Reason</strong>
                                        <p>@_selectedPoll.PollReason</p>
                                    </div>

                                    <div class="mf-editor-recommendation">
                                        <strong>Current Vote</strong>

                                        <p>
                                            @if (HasCurrentUserVoted(_selectedPoll))
                                            {
                                                <span>You voted @_selectedPoll.CurrentUserChoiceCode.</span>
                                            }
                                            else
                                            {
                                                <span>You have not voted yet.</span>
                                            }
                                        </p>
                                    </div>
                                </section>

                                @if (HasCurrentUserVoted(_selectedPoll))
                                {
                                    <section class="mf-card">
                                        <h3>Your Vote Status</h3>

                                        <div class="mf-alert info">
                                            You already voted <strong>@GetCurrentVoteDisplay(_selectedPoll)</strong>.
                                            Your vote cannot be changed.
                                        </div>

                                        @if (!string.IsNullOrWhiteSpace(_selectedPoll.CurrentUserVoteReason))
                                        {
                                            <div class="mf-proposal-summary-box">
                                                <strong>Your Reason / Comment</strong>
                                                <p>@_selectedPoll.CurrentUserVoteReason</p>
                                            </div>
                                        }
                                    </section>
                                }
                                else
                                {
                                    <section class="mf-card">
                                        <h3>Cast Your Vote</h3>

                                        <div class="mf-vote-options">
                                            <button class='@VoteOptionClass("APPROVE")'
                                                    @onclick='() => SelectChoice("APPROVE")'>
                                                <span>✓</span>
                                                Approve
                                            </button>

                                            <button class='@VoteOptionClass("REJECT")'
                                                    @onclick='() => SelectChoice("REJECT")'>
                                                <span>×</span>
                                                Reject
                                            </button>

                                            <button class='@VoteOptionClass("ABSTAIN")'
                                                    @onclick='() => SelectChoice("ABSTAIN")'>
                                                <span>–</span>
                                                Abstain
                                            </button>
                                        </div>

                                        <textarea class="mf-textarea"
                                                  placeholder="@VoteReasonPlaceholder"
                                                  @bind="_voteReason">
                                        </textarea>

                                        @if (!string.IsNullOrWhiteSpace(_voteMessage))
                                        {
                                            <div class="mf-alert info">@_voteMessage</div>
                                        }

                                        <button class="mf-btn mf-btn-primary full"
                                                disabled="@_isSavingVote"
                                                @onclick="SubmitVoteAsync">
                                            @(_isSavingVote ? "Saving..." : "Submit Vote")
                                        </button>
                                    </section>
                                }
                            </main>

                            <aside class="mf-voting-side">
                                <section class="mf-card">
                                    <h3>Live Results</h3>

                                    <div class="mf-live-total">
                                        <strong>@_selectedPoll.TotalVotes/@TotalBoardMembers</strong>
                                        <span>Participation</span>
                                    </div>

                                    @RenderResultRow("Approve", "approve", _selectedPoll.ApproveVotes, _selectedPoll.TotalVotes)
                                    @RenderResultRow("Reject", "reject", _selectedPoll.RejectVotes, _selectedPoll.TotalVotes)
                                    @RenderResultRow("Abstain", "abstain", _selectedPoll.AbstainVotes, _selectedPoll.TotalVotes)

                                    <div class="mf-trajectory-box">
                                        <span>Computed Result</span>
                                        <strong>@_selectedPoll.ComputedResultCode</strong>
                                        <p>Result is recalculated from database vote summary.</p>
                                    </div>
                                </section>
                            </aside>
                        </div>
                    </div>
                </div>
            }

            @if (_informationPoll is not null)
            {
                <div class="mf-modal-backdrop mf-information-modal-backdrop"
                     @onclick="CloseSeriesInformation">
                    <div class="mf-modal large" @onclick:stopPropagation="true">
                        <div class="mf-modal-header">
                            <div>
                                <div class="mf-modal-meta">
                                    <span class="mf-code">@_informationPoll.Code</span>
                                    <StatusBadge Status="@_informationPoll.PollStatusCode" />
                                </div>

                                <h2>@_informationPoll.SeriesTitle</h2>
                            </div>

                            <button type="button"
                                    class="mf-icon-btn"
                                    @onclick="CloseSeriesInformation">
                                ×
                            </button>
                        </div>

                        <div class="mf-cover-info-layout">
                            <section class="mf-cover-panel">
                                <h3 class="mf-clear-title">Cover Page</h3>

                                @if (!string.IsNullOrWhiteSpace(_informationPoll.CoverImageUrl))
                                {
                                    <img class="mf-cover-large"
                                         src="@_informationPoll.CoverImageUrl"
                                         alt="Series cover" />
                                }
                                else
                                {
                                    <div class="mf-cover-large-placeholder">
                                        No cover page
                                    </div>
                                }
                            </section>

                            <section class="mf-info-panel">
                                <h3 class="mf-clear-title">Series Information</h3>

                                <div class="mf-grid mf-grid-2">
                                    <div class="mf-info-tile">
                                        <span>Author</span>
                                        <strong>@_informationPoll.Author</strong>
                                    </div>

                                    <div class="mf-info-tile mf-genres-tile">
                                        <span>Genre</span>

                                        @if (InformationGenres.Count == 0)
                                        {
                                            <strong>Unknown Genre</strong>
                                        }
                                        else
                                        {
                                            <div class="mf-genre-list">
                                                @foreach (var genre in VisibleInformationGenres)
                                                {
                                                    <span class="mf-genre-pill">@genre</span>
                                                }
                                            </div>

                                            @if (InformationGenres.Count > MaxVisibleInformationGenres)
                                            {
                                                <button type="button"
                                                        class="mf-info-expand-toggle"
                                                        @onclick="ToggleInformationGenres">
                                                    @(_showAllInformationGenres
                                                        ? "Show less"
                                                        : $"+{HiddenInformationGenreCount} more")
                                                </button>
                                            }
                                        }
                                    </div>

                                    <div class="mf-info-tile mf-tags-tile">
                                        <span>Tags</span>

                                        @if (InformationTags.Count == 0)
                                        {
                                            <strong>No tags</strong>
                                        }
                                        else
                                        {
                                            <div class="mf-tag-list">
                                                @foreach (var tag in VisibleInformationTags)
                                                {
                                                    <span class="mf-tag-pill">@tag</span>
                                                }
                                            </div>

                                            @if (InformationTags.Count > MaxVisibleInformationTags)
                                            {
                                                <button type="button"
                                                        class="mf-info-expand-toggle"
                                                        @onclick="ToggleInformationTags">
                                                    @(_showAllInformationTags
                                                        ? "Show less"
                                                        : $"+{HiddenInformationTagCount} more")
                                                </button>
                                            }
                                        }
                                    </div>

                                    <div class="mf-info-tile">
                                        <span>Publication Frequency</span>
                                        <strong>@(_informationPoll.PublicationFrequencyCode ?? "N/A")</strong>
                                    </div>

                                    <div class="mf-info-tile">
                                        <span>Poll Type</span>
                                        <strong>@_informationPoll.PollTypeCode</strong>
                                    </div>

                                    <div class="mf-info-tile">
                                        <span>Poll Status</span>
                                        <strong>@_informationPoll.PollStatusCode</strong>
                                    </div>
                                </div>

                                <div class="mf-info-tile wide mf-gap-small">
                                    <span>Synopsis</span>
                                    <p>@_informationPoll.Synopsis</p>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            }
        }
    </ChildContent>
</MangaFlowShell>

@code {
    private const string DefaultRejectReason =
        "Rejected by board member during voting.";

    private const int TotalBoardMembers = 9;

    private const int MaxVisibleInformationGenres = 3;
    private const int MaxVisibleInformationTags = 3;

    private IReadOnlyList<EditorialBoardPollDto> _polls = Array.Empty<EditorialBoardPollDto>();

    private EditorialBoardPollDto? _selectedPoll;
    private EditorialBoardPollDto? _informationPoll;

    private bool _isLoading = true;
    private bool _isSavingVote;

    private string? _errorMessage;
    private string? _voteMessage;
    private string _selectedChoice = string.Empty;
    private string? _voteReason;

    private Guid? _deadlineEditorPollId;
    private string _deadlineDraftText = string.Empty;
    private string? _deadlineMessage;
    private bool _isSavingDeadline;

    private bool _showAllInformationGenres;
    private bool _showAllInformationTags;

    private string VoteReasonPlaceholder => _selectedChoice == "REJECT"
        ? "Reason / comment. If empty, a default rejection reason will be saved."
        : "Reason / comment. Optional for Approve or Abstain.";

    protected override async Task OnInitializedAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            await LoadPollsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _polls = Array.Empty<EditorialBoardPollDto>();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadPollsAsync()
    {
        _polls = await EditorialBoardApiClient.GetOpenPollsAsync();
    }

    private void OpenVotingCenter(EditorialBoardPollDto poll)
    {
        _selectedPoll = poll;
        _informationPoll = null;
        _selectedChoice = poll.CurrentUserChoiceCode ?? string.Empty;
        _voteReason = poll.CurrentUserVoteReason;
        _voteMessage = null;
    }

    private void CloseVotingCenter()
    {
        _selectedPoll = null;
        _informationPoll = null;
        _selectedChoice = string.Empty;
        _voteReason = null;
        _voteMessage = null;
        CancelDeadlineEditor();
    }

    private void OpenSeriesInformation(EditorialBoardPollDto poll)
    {
        _informationPoll = poll;
        _showAllInformationGenres = false;
        _showAllInformationTags = false;
    }

    private void OpenSelectedSeriesInformation()
    {
        if (_selectedPoll is null)
        {
            return;
        }

        OpenSeriesInformation(_selectedPoll);
    }

    private void CloseSeriesInformation()
    {
        _informationPoll = null;
        _showAllInformationGenres = false;
        _showAllInformationTags = false;
    }

    private void SelectChoice(string choiceCode)
    {
        _selectedChoice = choiceCode;

        _voteMessage = choiceCode == "REJECT" && string.IsNullOrWhiteSpace(_voteReason)
            ? "Reject will be saved with a default reason if you leave the comment empty."
            : null;
    }

    private string VoteOptionClass(string choiceCode)
    {
        var tone = choiceCode.ToLowerInvariant();

        return _selectedChoice == choiceCode
            ? $"mf-vote-option {tone} selected"
            : $"mf-vote-option {tone}";
    }

    private async Task SubmitVoteAsync()
    {
        if (_selectedPoll is null)
        {
            return;
        }

        if (HasCurrentUserVoted(_selectedPoll))
        {
            _voteMessage = "You already voted. Your vote cannot be changed.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_selectedChoice))
        {
            _voteMessage = "Please choose Approve, Reject, or Abstain.";
            return;
        }

        _isSavingVote = true;
        _voteMessage = null;

        var pollId = _selectedPoll.PollId;
        var voteReason = NormalizeVoteReason();

        try
        {
            await EditorialBoardApiClient.CastVoteAsync(
                pollId,
                new CastVoteRequest(_selectedChoice, voteReason));

            await LoadPollsAsync();

            _selectedPoll = _polls.FirstOrDefault(p => p.PollId == pollId);

            if (_selectedPoll is not null)
            {
                _selectedChoice = _selectedPoll.CurrentUserChoiceCode ?? _selectedChoice;
                _voteReason = _selectedPoll.CurrentUserVoteReason;
            }

            _voteMessage = "Vote saved successfully. This result is stored in database.";
        }
        catch (Exception ex)
        {
            _voteMessage = ex.Message;
        }
        finally
        {
            _isSavingVote = false;
        }
    }

    private string? NormalizeVoteReason()
    {
        if (_selectedChoice == "REJECT")
        {
            return string.IsNullOrWhiteSpace(_voteReason)
                ? DefaultRejectReason
                : _voteReason.Trim();
        }

        return string.IsNullOrWhiteSpace(_voteReason)
            ? null
            : _voteReason.Trim();
    }

    private static bool HasCurrentUserVoted(EditorialBoardPollDto poll)
    {
        return !string.IsNullOrWhiteSpace(poll.CurrentUserChoiceCode);
    }

    private static string GetCurrentVoteDisplay(EditorialBoardPollDto poll)
    {
        return string.IsNullOrWhiteSpace(poll.CurrentUserChoiceCode)
            ? "Not voted"
            : poll.CurrentUserChoiceCode;
    }

    private static string DeadlineText(EditorialBoardPollDto poll)
    {
        if (poll.EndsAtUtc is null)
        {
            return "No deadline";
        }

        var dateStr = poll.EndsAtUtc.Value
            .ToLocalTime()
            .ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

        return $"Deadline: {dateStr}";
    }

    private IReadOnlyList<string> InformationGenres =>
        _informationPoll is null
            ? Array.Empty<string>()
            : SplitGenreDisplay(_informationPoll.Genre);

    private IReadOnlyList<string> InformationTags =>
        _informationPoll is null
            ? Array.Empty<string>()
            : SplitCommaDisplay(_informationPoll.TagsDisplay);

    private IEnumerable<string> VisibleInformationGenres =>
        _showAllInformationGenres
            ? InformationGenres
            : InformationGenres.Take(MaxVisibleInformationGenres);

    private IEnumerable<string> VisibleInformationTags =>
        _showAllInformationTags
            ? InformationTags
            : InformationTags.Take(MaxVisibleInformationTags);

    private int HiddenInformationGenreCount =>
        Math.Max(0, InformationGenres.Count - MaxVisibleInformationGenres);

    private int HiddenInformationTagCount =>
        Math.Max(0, InformationTags.Count - MaxVisibleInformationTags);

    private void ToggleInformationGenres()
    {
        _showAllInformationGenres = !_showAllInformationGenres;
    }

    private void ToggleInformationTags()
    {
        _showAllInformationTags = !_showAllInformationTags;
    }

    private bool IsEditingDeadline(EditorialBoardPollDto poll)
    {
        return _deadlineEditorPollId == poll.PollId;
    }

    private void StartDeadlineEditor(EditorialBoardPollDto poll)
    {
        _deadlineEditorPollId = poll.PollId;
        _deadlineDraftText = poll.EndsAtUtc?.ToLocalTime().ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
            ?? DateTime.Today.AddDays(7).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        _deadlineMessage = null;
    }

    private void CancelDeadlineEditor()
    {
        _deadlineEditorPollId = null;
        _deadlineDraftText = string.Empty;
        _deadlineMessage = null;
    }

    private void OnDeadlineDateChanged(ChangeEventArgs args)
    {
        _deadlineDraftText = args.Value?.ToString() ?? string.Empty;
        _deadlineMessage = null;
    }

    private async Task SaveDeadlineAsync(EditorialBoardPollDto poll)
    {
        if (_isSavingDeadline)
        {
            return;
        }

        if (!DateTime.TryParse(
                _deadlineDraftText,
                CultureInfo.InvariantCulture,
                DateTimeStyles.None,
                out var parsedDate))
        {
            _deadlineMessage = "Please choose a valid deadline date.";
            return;
        }

        var localDeadline = parsedDate.Date
            .AddHours(23)
            .AddMinutes(59)
            .AddSeconds(59);

        await UpdateDeadlineAsync(
            poll,
            localDeadline.ToUniversalTime());
    }

    private async Task ClearDeadlineAsync(EditorialBoardPollDto poll)
    {
        await UpdateDeadlineAsync(poll, null);
    }

    private async Task UpdateDeadlineAsync(
        EditorialBoardPollDto poll,
        DateTime? endsAtUtc)
    {
        if (_isSavingDeadline)
        {
            return;
        }

        _isSavingDeadline = true;
        _deadlineMessage = null;

        try
        {
            await EditorialBoardApiClient.UpdatePollDeadlineAsync(
                poll.PollId,
                new UpdateBoardPollDeadlineRequest(endsAtUtc));

            await LoadPollsAsync();

            if (_selectedPoll is not null && _selectedPoll.PollId == poll.PollId)
            {
                _selectedPoll = _polls.FirstOrDefault(item => item.PollId == poll.PollId);
            }

            if (_informationPoll is not null && _informationPoll.PollId == poll.PollId)
            {
                _informationPoll = _polls.FirstOrDefault(item => item.PollId == poll.PollId);
            }

            _deadlineEditorPollId = null;
            _deadlineDraftText = string.Empty;
            _deadlineMessage = "Deadline updated successfully.";
        }
        catch (Exception ex)
        {
            _deadlineMessage = ex.Message;
        }
        finally
        {
            _isSavingDeadline = false;
        }
    }

    private static IReadOnlyList<string> SplitGenreDisplay(string? genreDisplay)
    {
        if (string.IsNullOrWhiteSpace(genreDisplay))
        {
            return Array.Empty<string>();
        }

        return genreDisplay
            .Split(" / ", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(genre => !string.IsNullOrWhiteSpace(genre))
            .ToList();
    }

    private static IReadOnlyList<string> SplitCommaDisplay(string? display)
    {
        if (string.IsNullOrWhiteSpace(display))
        {
            return Array.Empty<string>();
        }

        return display
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToList();
    }

    private RenderFragment RenderResultRow(string label, string tone, int count, int total) => __builder =>
    {
        var percent = total > 0
            ? (int)Math.Round(count * 100.0 / total)
            : 0;

        <div class="mf-result-row @tone">
            <div>
                <strong>@label</strong>
                <span>@count (@percent%)</span>
            </div>

            <div class="mf-result-bar">
                <div style="width: @percent%;"></div>
            </div>
        </div>
    };
}