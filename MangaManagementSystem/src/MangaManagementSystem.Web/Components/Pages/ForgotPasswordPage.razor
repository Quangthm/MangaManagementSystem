@page "/forgot-password"
@using MangaManagementSystem.Web.Services.Api
@inject IPasswordResetApiClient PasswordResetApiClient
@inject NavigationManager NavigationManager

<PageTitle>Forgot Password - MangaFlow</PageTitle>

<div class="mf-gradient-bg d-flex align-center justify-center pa-4">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Class="pa-8 mf-card" Elevation="8">
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">
                Forgot Password
            </MudText>

            <MudText Class="mf-muted mb-6">
                Enter your account email. If the account exists, MangaFlow will send a one-time reset link.
            </MudText>

            @if (_submitted)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    If an account exists for that email, a password reset link has been sent.
                </MudAlert>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="/login">
                    Back to Login
                </MudButton>
            }
            else
            {
                <MudStack Spacing="3">
                    <MudTextField Label="Email"
                                  @bind-Value="_email"
                                  Variant="Variant.Outlined"
                                  InputType="InputType.Email"
                                  Required="true"
                                  Disabled="_busy" />

                    @if (!string.IsNullOrWhiteSpace(_validationMessage))
                    {
                        <MudAlert Severity="Severity.Error">
                            @_validationMessage
                        </MudAlert>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="_busy"
                               OnClick="SubmitAsync">
                        @if (_busy)
                        {
                            <MudProgressCircular Size="Size.Small"
                                                 Indeterminate="true"
                                                 Class="mr-2" />
                        }
                        Send Reset Link
                    </MudButton>

                    <MudButton Variant="Variant.Text"
                               FullWidth="true"
                               Href="/login">
                        Back to Login
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudContainer>
</div>

@code {
    private string _email = string.Empty;
    private string? _validationMessage;
    private bool _busy;
    private bool _submitted;

    private async Task SubmitAsync()
    {
        if (_busy)
        {
            return;
        }

        _validationMessage = null;

        if (string.IsNullOrWhiteSpace(_email)
            || !_email.Contains('@'))
        {
            _validationMessage =
                "Enter a valid email address.";

            return;
        }

        _busy = true;

        try
        {
            var resetPageUrl =
                new Uri(
                    new Uri(NavigationManager.BaseUri),
                    "reset-password")
                .ToString();

            await PasswordResetApiClient
                .RequestPasswordResetAsync(
                    _email.Trim(),
                    resetPageUrl);
        }
        catch
        {
            // Keep the response identical so the page never reveals
            // whether an email address exists in the system.
        }
        finally
        {
            _busy = false;
            _submitted = true;
        }
    }
}
