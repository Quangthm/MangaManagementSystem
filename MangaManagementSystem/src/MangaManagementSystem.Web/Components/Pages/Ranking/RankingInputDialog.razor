@using System.Globalization

@if (Open)
{
    <div style="position:fixed; inset:0; z-index:1400; background:rgba(0,0,0,.45); display:flex; align-items:center; justify-content:center;">
        <MudPaper Elevation="12" Class="pa-0" Style="width:460px; max-width:calc(100vw - 32px); border-radius:16px; overflow:hidden;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-4">
                <MudAvatar Color="Color.Default" Rounded="true">
                    <MudIcon Icon="@Icons.Material.Filled.Add" />
                </MudAvatar>

                <MudText Typo="Typo.h6" Class="fw-800">
                    Create Ranking Input
                </MudText>

                <MudSpacer />

                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               Disabled="@Saving"
                               OnClick="CloseAsync" />
            </MudStack>

            <MudDivider />

            <MudStack Spacing="3" Class="pa-4">
                <MudSelect T="Guid"
                           Label="Publication Week"
                           Required="true"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Value="@_form.PublicationPeriodId"
                           ValueChanged="OnPublicationPeriodChangedAsync"
                           Error="@HasError(nameof(InsertFormState.PublicationPeriodId))"
                           ErrorText="@GetError(nameof(InsertFormState.PublicationPeriodId))">
                    @foreach (var period in PublicationPeriods)
                    {
                        <MudSelectItem T="Guid" Value="@period.PublicationPeriodId">
                            @period.Label
                        </MudSelectItem>
                    }
                </MudSelect>

                <MudAutocomplete T="CatalogEntry"
                                 Label="Series"
                                 Placeholder="Search and select a series"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 Required="true"
                                 Clearable="true"
                                 Dense="true"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false"
                                 CoerceValue="false"
                                 MinCharacters="0"
                                 MaxItems="20"
                                 SearchFunc="SearchSeriesInternalAsync"
                                 ToStringFunc="FormatSeries"
                                 Value="@_form.Series"
                                 ValueChanged="OnSeriesChangedAsync"
                                 Adornment="Adornment.Start"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 Error="@HasError(nameof(InsertFormState.Series))"
                                 ErrorText="@GetError(nameof(InsertFormState.Series))">
                    <ItemTemplate>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Image="@context.CoverUrl"
                                       Rounded="true"
                                       Size="Size.Small" />

                            <div>
                                <MudText Typo="Typo.body2" Class="fw-700">
                                    @context.Title
                                </MudText>

                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @context.SeriesId
                                </MudText>
                            </div>
                        </MudStack>
                    </ItemTemplate>

                    <NoItemsTemplate>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-2">
                            No available series found in the database.
                        </MudText>
                    </NoItemsTemplate>
                </MudAutocomplete>

                <MudGrid Spacing="2">
                    <MudItem xs="12" md="6">
                        <MudNumericField T="int?"
                                         Label="Reading Count"
                                         Required="true"
                                         Min="1"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Value="@_form.ReadingCount"
                                         ValueChanged="OnReadingCountChangedAsync"
                                         Error="@HasError(nameof(InsertFormState.ReadingCount))"
                                         ErrorText="@GetError(nameof(InsertFormState.ReadingCount))" />
                    </MudItem>

                    <MudItem xs="12" md="6">
                        <MudNumericField T="int?"
                                         Label="Rating Count"
                                         Required="true"
                                         Min="1"
                                         Variant="Variant.Outlined"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Value="@_form.RatingCount"
                                         ValueChanged="OnRatingCountChangedAsync"
                                         Error="@HasError(nameof(InsertFormState.RatingCount))"
                                         ErrorText="@GetError(nameof(InsertFormState.RatingCount))" />
                    </MudItem>
                </MudGrid>

                <MudNumericField T="decimal?"
                                 Label="Average Rating"
                                 HelperText="0 – 10"
                                 Required="true"
                                 Min="0"
                                 Max="10"
                                 Step="@DecimalStep"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 HideSpinButtons="true"
                                 Value="@_form.AverageRating"
                                 ValueChanged="OnAverageRatingChangedAsync"
                                 Error="@HasError(nameof(InsertFormState.AverageRating))"
                                 ErrorText="@GetError(nameof(InsertFormState.AverageRating))" />

                <MudTextField T="string"
                              Label="Data Source Note"
                              Placeholder="e.g. Editorial Board report / spreadsheet source"
                              Lines="2"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Value="@_form.DataSourceNote"
                              ValueChanged="OnDataSourceNoteChangedAsync" />
            </MudStack>

            <MudDivider />

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="pa-4">
                <MudButton Variant="Variant.Outlined"
                           Disabled="@Saving"
                           OnClick="CloseAsync">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           Disabled="@Saving"
                           OnClick="SaveAsync">
                    @if (Saving)
                    {
                        <MudProgressCircular Size="Size.Small"
                                             Indeterminate="true"
                                             Class="me-2" />
                    }

                    Save
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private const decimal DecimalStep = 0.1m;

    private readonly Dictionary<string, string> _errors = [];

    private InsertFormState _form = new();
    private bool _wasOpen;

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public Guid SelectedPublicationPeriodId { get; set; }

    [Parameter]
    public IReadOnlyList<PublicationPeriodOption> PublicationPeriods { get; set; } = [];

    [Parameter]
    public Func<string?, CancellationToken, Task<IEnumerable<CatalogEntry>>>? SearchSeriesAsync { get; set; }

    [Parameter]
    public EventCallback<InsertFormState> Saved { get; set; }

    [Parameter]
    public bool Saving { get; set; }

    protected override void OnParametersSet()
    {
        if (Open && !_wasOpen)
        {
            ResetForm();
        }

        if (Open
            && _form.PublicationPeriodId == Guid.Empty
            && SelectedPublicationPeriodId != Guid.Empty)
        {
            _form.PublicationPeriodId = SelectedPublicationPeriodId;
        }

        _wasOpen = Open;
    }

    private void ResetForm()
    {
        _errors.Clear();

        _form = new InsertFormState
        {
            PublicationPeriodId = SelectedPublicationPeriodId
        };
    }

    private async Task CloseAsync()
    {
        if (Saving)
        {
            return;
        }

        _errors.Clear();
        await OpenChanged.InvokeAsync(false);
    }

    private Task OnPublicationPeriodChangedAsync(Guid value)
    {
        _form.PublicationPeriodId = value;
        _form.Series = null;

        ClearError(nameof(InsertFormState.PublicationPeriodId));
        ClearError(nameof(InsertFormState.Series));

        return Task.CompletedTask;
    }

    private Task OnSeriesChangedAsync(CatalogEntry? value)
    {
        _form.Series = value;
        ClearError(nameof(InsertFormState.Series));

        return Task.CompletedTask;
    }

    private Task OnReadingCountChangedAsync(int? value)
    {
        _form.ReadingCount = value;
        ClearError(nameof(InsertFormState.ReadingCount));
        ClearError(nameof(InsertFormState.RatingCount));

        return Task.CompletedTask;
    }

    private Task OnRatingCountChangedAsync(int? value)
    {
        _form.RatingCount = value;
        ClearError(nameof(InsertFormState.RatingCount));

        return Task.CompletedTask;
    }

    private Task OnAverageRatingChangedAsync(decimal? value)
    {
        _form.AverageRating = value;
        ClearError(nameof(InsertFormState.AverageRating));

        return Task.CompletedTask;
    }

    private Task OnDataSourceNoteChangedAsync(string value)
    {
        _form.DataSourceNote = value;
        return Task.CompletedTask;
    }

    private async Task<IEnumerable<CatalogEntry>> SearchSeriesInternalAsync(
        string? value,
        CancellationToken cancellationToken)
    {
        if (SearchSeriesAsync is null || _form.PublicationPeriodId == Guid.Empty)
        {
            return [];
        }

        var result = await SearchSeriesAsync.Invoke(value, cancellationToken);

        return result
            .OrderBy(series => series.Title)
            .ToList();
    }

    private async Task SaveAsync()
    {
        _errors.Clear();

        Validate();

        if (_errors.Count > 0)
        {
            return;
        }

        await Saved.InvokeAsync(_form);
    }

    private void Validate()
    {
        if (_form.PublicationPeriodId == Guid.Empty)
        {
            _errors[nameof(InsertFormState.PublicationPeriodId)] =
                "Publication week is required.";
        }

        if (_form.Series is null)
        {
            _errors[nameof(InsertFormState.Series)] =
                "Series is required.";
        }

        if (!_form.ReadingCount.HasValue || _form.ReadingCount.Value <= 0)
        {
            _errors[nameof(InsertFormState.ReadingCount)] =
                "Reading count must be greater than 0.";
        }

        if (!_form.RatingCount.HasValue || _form.RatingCount.Value <= 0)
        {
            _errors[nameof(InsertFormState.RatingCount)] =
                "Rating count must be greater than 0.";
        }

        if (_form.ReadingCount.HasValue
            && _form.RatingCount.HasValue
            && _form.RatingCount.Value > _form.ReadingCount.Value)
        {
            _errors[nameof(InsertFormState.RatingCount)] =
                "Rating count cannot exceed reading count.";
        }

        if (!_form.AverageRating.HasValue
            || _form.AverageRating.Value < 0
            || _form.AverageRating.Value > 10)
        {
            _errors[nameof(InsertFormState.AverageRating)] =
                "Average rating must be between 0 and 10.";
        }
    }

    private bool HasError(string fieldName)
    {
        return _errors.ContainsKey(fieldName);
    }

    private string GetError(string fieldName)
    {
        return _errors.TryGetValue(fieldName, out var error)
            ? error
            : string.Empty;
    }

    private void ClearError(string fieldName)
    {
        _errors.Remove(fieldName);
    }

    private static string FormatSeries(CatalogEntry? series)
    {
        return series?.Title ?? string.Empty;
    }
}