@using System.Globalization
@inject ISnackbar Snackbar

<MudPaper Class="section-card" Elevation="0">
    <MudStack Row="true" Class="pa-4 pb-2" Spacing="2">
        <MudIcon Icon="@Icons.Material.Filled.EditNote" Color="Color.Primary" />
        <div>
            <MudText Typo="Typo.h6" Class="fw-800">Series Vote Input</MudText>
            <MudText Typo="Typo.caption" Color="Color.Secondary">
                Data is loaded from <code>manga.SeriesVoteInput</code>. Ranking recalculates from the SQL view after save.
            </MudText>
        </div>
        <MudSpacer />
        @if (CanManageRankingInput)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="OnAddInputClickedAsync"
                       Disabled="Loading">
                Add Input
            </MudButton>
        }
    </MudStack>

    <MudDivider />

    <MudGrid Spacing="3" Class="pa-4">
        <MudItem xs="12" md="8">
            <MudTextField T="string"
                          Value="@Search"
                          ValueChanged="OnSearchChangedAsync"
                          Placeholder="Search"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Immediate="true"
                          Clearable="true"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>

        <MudItem xs="12" md="4">
            <MudSelect T="string"
                       Value="@Sort"
                       ValueChanged="OnSortChangedAsync"
                       Label="Sort"
                       Placeholder="Sort"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Dense="true">
                @foreach (var option in SortOptions)
                {
                    <MudSelectItem T="string" Value="@option.Value">
                        @option.Label
                    </MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @if (Loading)
    {
        <MudStack Class="pa-8" AlignItems="AlignItems.Center">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            <MudText Color="Color.Secondary">Loading vote input from database...</MudText>
        </MudStack>
    }
    else
    {
        <MudTable Items="@Rows"
                  Hover="true"
                  Dense="true"
                  Bordered="false"
                  Breakpoint="Breakpoint.Sm"
                  RowsPerPage="5"
                  Class="ranking-table">
            <HeaderContent>
                <MudTh>Series</MudTh>
                <MudTh Class="text-end">Reading Count</MudTh>
                <MudTh Class="text-end">Rating Count</MudTh>
                <MudTh Class="text-end">Average Rating</MudTh>
                <MudTh>Data Source</MudTh>
                <MudTh>Inserted At</MudTh>
                <MudTh>Last Updated</MudTh>
                @if (CanManageRankingInput)
                {
                    <MudTh Class="text-center">Actions</MudTh>
                }
            </HeaderContent>

            <RowTemplate>
                <MudTd DataLabel="Series">
                    <MudStack Row="true" Spacing="2">
                        <MudAvatar Image="@context.CoverUrl" Rounded="true" Class="cover-avatar" />
                        <div>
                            <MudText Typo="Typo.body2" Class="fw-700">@context.Title</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">@SelectedPublicationWeek</MudText>
                        </div>
                    </MudStack>
                </MudTd>

                <MudTd DataLabel="Reading Count" Class="text-end">
                    @if (IsEditing(context.SeriesVoteInputId))
                    {
                        <MudNumericField T="int?"
                                         Value="@_editRows[context.SeriesVoteInputId].ReadingCount"
                                         ValueChanged="@(value => OnEditReadingCountChanged(context.SeriesVoteInputId, value))"
                                         Min="1"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Error="@HasEditError(context.SeriesVoteInputId, nameof(EditRowState.ReadingCount))"
                                         ErrorText="@GetEditError(context.SeriesVoteInputId, nameof(EditRowState.ReadingCount))"
                                         Class="inline-number" />
                    }
                    else
                    {
                        <span class="mono">@RankingUiHelper.FormatNumber(context.ReadingCount)</span>
                    }
                </MudTd>

                <MudTd DataLabel="Rating Count" Class="text-end">
                    @if (IsEditing(context.SeriesVoteInputId))
                    {
                        <MudNumericField T="int?"
                                         Value="@_editRows[context.SeriesVoteInputId].RatingCount"
                                         ValueChanged="@(value => OnEditRatingCountChanged(context.SeriesVoteInputId, value))"
                                         Min="1"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Error="@HasEditError(context.SeriesVoteInputId, nameof(EditRowState.RatingCount))"
                                         ErrorText="@GetEditError(context.SeriesVoteInputId, nameof(EditRowState.RatingCount))"
                                         Class="inline-number" />
                    }
                    else
                    {
                        <span class="mono">@RankingUiHelper.FormatNumber(context.RatingCount)</span>
                    }
                </MudTd>

                <MudTd DataLabel="Average Rating" Class="text-end">
                    @if (IsEditing(context.SeriesVoteInputId))
                    {
                        <MudNumericField T="decimal?"
                                         Value="@_editRows[context.SeriesVoteInputId].AverageRating"
                                         ValueChanged="@(value => OnEditAverageRatingChanged(context.SeriesVoteInputId, value))"
                                         Min="0"
                                         Max="10"
                                         Step="@DecimalStep"
                                         Margin="Margin.Dense"
                                         HideSpinButtons="true"
                                         Error="@HasEditError(context.SeriesVoteInputId, nameof(EditRowState.AverageRating))"
                                         ErrorText="@GetEditError(context.SeriesVoteInputId, nameof(EditRowState.AverageRating))"
                                         Class="inline-number" />
                    }
                    else
                    {
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Color="Color.Warning"
                                 Variant="Variant.Text"
                                 Icon="@Icons.Material.Filled.Star">
                            @context.AverageRating.ToString("0.0", CultureInfo.InvariantCulture)
                        </MudChip>
                    }
                </MudTd>

                <MudTd DataLabel="Data Source">
                    <MudText Typo="Typo.caption">
                        @(string.IsNullOrWhiteSpace(context.DataSourceNote) ? "—" : context.DataSourceNote)
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Inserted At">
                    <MudText Typo="Typo.caption" Class="mono">
                        @context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Last Updated">
                    <MudText Typo="Typo.caption" Class="mono">
                        @context.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </MudText>
                </MudTd>

                @if (CanManageRankingInput)
                {
                    <MudTd DataLabel="Actions" Class="text-center">
                        @if (IsEditing(context.SeriesVoteInputId))
                        {
                            <MudButtonGroup Size="Size.Small" Variant="Variant.Outlined">
                                <MudButton Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Save"
                                           OnClick="@(() => SaveInlineEditAsync(context))">
                                    Save
                                </MudButton>

                                <MudButton Color="Color.Default"
                                           StartIcon="@Icons.Material.Filled.Close"
                                           OnClick="@(() => CancelInlineEdit(context.SeriesVoteInputId))">
                                    Cancel
                                </MudButton>
                            </MudButtonGroup>
                        }
                        else
                        {
                            <MudButton Size="Size.Small"
                                       Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Edit"
                                       OnClick="@(() => StartInlineEdit(context))">
                                Edit
                            </MudButton>
                        }
                    </MudTd>
                }
            </RowTemplate>

            <NoRecordsContent>
                <MudStack Justify="Justify.Center" Class="pa-8">
                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Color="Color.Secondary">No series vote input found for this period.</MudText>
                </MudStack>
            </NoRecordsContent>

            <PagerContent>
                <MudTablePager PageSizeOptions="@(new[] { 5, 10, 20 })" />
            </PagerContent>
        </MudTable>
    }
</MudPaper>

@code {
    private const decimal DecimalStep = 0.1m;

    private readonly Dictionary<Guid, EditRowState> _editRows = [];

    [Parameter]
    public IReadOnlyList<SeriesInputRow> Rows { get; set; } = [];

    [Parameter]
    public IReadOnlyList<SortOption> SortOptions { get; set; } = [];

    [Parameter]
    public string SelectedPublicationWeek { get; set; } = string.Empty;

    [Parameter]
    public string Search { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SearchChanged { get; set; }

    [Parameter]
    public string Sort { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<string> SortChanged { get; set; }

    [Parameter]
    public bool CanManageRankingInput { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public EventCallback AddInputClicked { get; set; }

    [Parameter]
    public EventCallback<SeriesVoteInputUpdateRequestUi> RowSaveRequested { get; set; }

    private Task OnAddInputClickedAsync()
    {
        return AddInputClicked.InvokeAsync();
    }

    private Task OnSearchChangedAsync(string value)
    {
        return SearchChanged.InvokeAsync(value ?? string.Empty);
    }

    private Task OnSortChangedAsync(string value)
    {
        return SortChanged.InvokeAsync(value ?? string.Empty);
    }

    private void StartInlineEdit(SeriesInputRow row)
    {
        _editRows[row.SeriesVoteInputId] = new EditRowState
        {
            ReadingCount = row.ReadingCount,
            RatingCount = row.RatingCount,
            AverageRating = row.AverageRating
        };
    }

    private void CancelInlineEdit(Guid seriesVoteInputId)
    {
        _editRows.Remove(seriesVoteInputId);
    }

    private bool IsEditing(Guid seriesVoteInputId)
    {
        return _editRows.ContainsKey(seriesVoteInputId);
    }

    private void OnEditReadingCountChanged(Guid seriesVoteInputId, int? value)
    {
        _editRows[seriesVoteInputId].ReadingCount = value;
        ClearEditError(seriesVoteInputId, nameof(EditRowState.ReadingCount));
    }

    private void OnEditRatingCountChanged(Guid seriesVoteInputId, int? value)
    {
        _editRows[seriesVoteInputId].RatingCount = value;
        ClearEditError(seriesVoteInputId, nameof(EditRowState.RatingCount));
    }

    private void OnEditAverageRatingChanged(Guid seriesVoteInputId, decimal? value)
    {
        _editRows[seriesVoteInputId].AverageRating = value;
        ClearEditError(seriesVoteInputId, nameof(EditRowState.AverageRating));
    }

    private async Task SaveInlineEditAsync(SeriesInputRow row)
    {
        if (!_editRows.TryGetValue(row.SeriesVoteInputId, out var state))
        {
            return;
        }

        state.Errors = ValidateEditState(state);

        if (state.Errors.Count > 0)
        {
            Snackbar.Add("Validation failed. Please fix the highlighted fields.", Severity.Error);
            return;
        }

        await RowSaveRequested.InvokeAsync(new SeriesVoteInputUpdateRequestUi(
            row.SeriesVoteInputId,
            state.ReadingCount!.Value,
            state.RatingCount!.Value,
            state.AverageRating!.Value,
            row.DataSourceNote));

        _editRows.Remove(row.SeriesVoteInputId);
    }

    private static Dictionary<string, string> ValidateEditState(EditRowState state)
    {
        var errors = new Dictionary<string, string>();

        if (!state.ReadingCount.HasValue || state.ReadingCount.Value <= 0)
        {
            errors[nameof(EditRowState.ReadingCount)] = "Reading count must be greater than 0.";
        }

        if (!state.RatingCount.HasValue || state.RatingCount.Value <= 0)
        {
            errors[nameof(EditRowState.RatingCount)] = "Rating count must be greater than 0.";
        }

        if (state.ReadingCount.HasValue
            && state.RatingCount.HasValue
            && state.RatingCount.Value > state.ReadingCount.Value)
        {
            errors[nameof(EditRowState.RatingCount)] = "Rating count cannot exceed reading count.";
        }

        if (!state.AverageRating.HasValue
            || state.AverageRating.Value < 0
            || state.AverageRating.Value > 10)
        {
            errors[nameof(EditRowState.AverageRating)] = "Average rating must be between 0 and 10.";
        }

        return errors;
    }

    private bool HasEditError(Guid seriesVoteInputId, string fieldName)
    {
        return _editRows.TryGetValue(seriesVoteInputId, out var state)
               && state.Errors.ContainsKey(fieldName);
    }

    private string GetEditError(Guid seriesVoteInputId, string fieldName)
    {
        if (!_editRows.TryGetValue(seriesVoteInputId, out var state))
        {
            return string.Empty;
        }

        return state.Errors.TryGetValue(fieldName, out var error)
            ? error
            : string.Empty;
    }

    private void ClearEditError(Guid seriesVoteInputId, string fieldName)
    {
        if (_editRows.TryGetValue(seriesVoteInputId, out var state))
        {
            state.Errors.Remove(fieldName);
        }
    }
}