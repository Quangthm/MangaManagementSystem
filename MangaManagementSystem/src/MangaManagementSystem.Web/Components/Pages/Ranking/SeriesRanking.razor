@page "/ranking"
@page "/demo/mangaflow/ranking"
@using System.Globalization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Mangaka,Tantou Editor,Editorial Board Member,Editorial Board Chief,Admin")]
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MangaManagementSystem.Web.Services.Api.ISeriesRankingApiClient RankingApiClient

<PageTitle>Series Ranking Management</PageTitle>

<RankingLayout>
    <RankingStyles />

    <div class="mf-page">
        <MudStack Spacing="4" Class="ranking-page">
            <RankingHero PublicationPeriods="@_publicationPeriods"
                         SelectedPublicationPeriodId="@_selectedPublicationPeriodId"
                         SelectedPublicationPeriodIdChanged="OnPublicationPeriodChangedAsync"
                         Loading="@_loadingPeriods" />

            @if (_usingSampleData)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Preview mode is using sample ranking data because database ranking data is not available yet.
                    When real weekly publication periods and vote inputs exist, this page will use database data automatically.
                </MudAlert>
            }

            @if (!string.IsNullOrWhiteSpace(_loadError) && !_usingSampleData)
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    @_loadError
                </MudAlert>
            }

            <RankingStatsGrid Items="@Stats" />

            @if (_canManageRankingInput)
            {
                <SeriesVoteInputSection Rows="@_inputRows"
                                        SortOptions="@_sortOptions"
                                        SelectedPublicationWeek="@SelectedPublicationPeriodLabel"
                                        Search="@_inputSearch"
                                        SearchChanged="OnInputSearchChangedAsync"
                                        Sort="@_inputSort"
                                        SortChanged="OnInputSortChangedAsync"
                                        CanManageRankingInput="@_canManageRankingInput"
                                        Loading="@_loadingRows"
                                        AddInputClicked="OpenInsertDialog"
                                        RowSaveRequested="OnUpdateVoteInputAsync" />
            }

            <RankingResultsSection Rows="@_rankingRows"
                                   SortOptions="@_sortOptions"
                                   SelectedPublicationWeek="@SelectedPublicationPeriodLabel"
                                   Search="@_rankingSearch"
                                   SearchChanged="OnRankingSearchChangedAsync"
                                   Sort="@_rankingSort"
                                   SortChanged="OnRankingSortChangedAsync" />

            <TopRankedSeriesSection Rows="@_rankingRows"
                                    SelectedPublicationWeek="@SelectedPublicationPeriodLabel" />
        </MudStack>

        @if (_canManageRankingInput)
        {
            <RankingInputDialog Open="@_insertDialogOpen"
                                OpenChanged="OnInsertDialogOpenChanged"
                                SelectedPublicationPeriodId="@_selectedPublicationPeriodId"
                                PublicationPeriods="@_publicationPeriods"
                                SearchSeriesAsync="SearchSeriesAsync"
                                Saved="OnCreateVoteInputAsync"
                                Saving="@_savingInput" />
        }
    </div>
</RankingLayout>

@code {
    private static readonly Guid SamplePeriodId = Guid.Parse("11111111-1111-1111-1111-111111111111");

    private readonly List<SortOption> _sortOptions =
    [
        new("rank_asc", "Rank (Ascending)"),
        new("rank_desc", "Rank (Descending)"),
        new("title_asc", "Series Title (A–Z)"),
        new("title_desc", "Series Title (Z–A)"),
        new("score_desc", "Ranking Score (Highest First)"),
        new("score_asc", "Ranking Score (Lowest First)"),
        new("average_rating_desc", "Average Rating (Highest First)"),
        new("average_rating_asc", "Average Rating (Lowest First)"),
        new("reading_count_desc", "Reading Count (Highest First)"),
        new("reading_count_asc", "Reading Count (Lowest First)"),
        new("rating_count_desc", "Rating Count (Highest First)"),
        new("rating_count_asc", "Rating Count (Lowest First)"),
        new("updated_desc", "Last Updated (Newest First)"),
        new("updated_asc", "Last Updated (Oldest First)")
    ];

    private readonly List<CatalogEntry> _sampleCatalog =
    [
        new(Guid.Parse("22222222-2222-2222-2222-222222222221"), "Moonlit Blade", "/images/placeholder-cover.png"),
        new(Guid.Parse("22222222-2222-2222-2222-222222222222"), "Crimson School Days", "/images/placeholder-cover.png"),
        new(Guid.Parse("22222222-2222-2222-2222-222222222223"), "Neon Yokai Files", "/images/placeholder-cover.png"),
        new(Guid.Parse("22222222-2222-2222-2222-222222222224"), "Garden of Ashes", "/images/placeholder-cover.png"),
        new(Guid.Parse("22222222-2222-2222-2222-222222222225"), "Starlight Courier", "/images/placeholder-cover.png"),
        new(Guid.Parse("22222222-2222-2222-2222-222222222226"), "Silent Dragon Café", "/images/placeholder-cover.png")
    ];

    private List<PublicationPeriodOption> _publicationPeriods = [];
    private List<SeriesInputRow> _allSampleInputRows = [];
    private List<SeriesInputRow> _inputRows = [];
    private List<RankingRow> _rankingRows = [];
    private Guid _selectedPublicationPeriodId;
    private string _inputSearch = string.Empty;
    private string _rankingSearch = string.Empty;
    private string _inputSort = "updated_desc";
    private string _rankingSort = "rank_asc";
    private bool _insertDialogOpen;
    private bool _canManageRankingInput;
    private bool _loadingPeriods;
    private bool _loadingRows;
    private bool _savingInput;
    private bool _usingSampleData;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _canManageRankingInput =
            user.IsInRole("Editorial Board Member")
            || user.IsInRole("Editorial Board Chief")
            || user.IsInRole("Board Member")
            || user.IsInRole("Board Chief");

        await LoadPeriodsAsync();
    }

    private string SelectedPublicationPeriodLabel =>
        _publicationPeriods.FirstOrDefault(period => period.PublicationPeriodId == _selectedPublicationPeriodId)?.Label
        ?? "No publication week selected";

    private IReadOnlyList<RankingStatItem> Stats =>
    [
        new("Total ranked series", _rankingRows.Count.ToString(CultureInfo.InvariantCulture), Icons.Material.Filled.BarChart, Color.Primary),
        new("Average rating", AverageRatingText, Icons.Material.Filled.Star, Color.Warning),
        new("Highest score", HighestScoreText, Icons.Material.Filled.EmojiEvents, Color.Secondary),
        new("Most read series", MostReadSeriesTitle, Icons.Material.Filled.MenuBook, Color.Success, "text-truncate")
    ];

    private string AverageRatingText => _rankingRows.Count == 0
        ? "0.00"
        : _rankingRows.Average(row => row.AverageRating).ToString("0.00", CultureInfo.InvariantCulture);

    private string HighestScoreText => _rankingRows.Count == 0
        ? "0.0"
        : _rankingRows.Max(row => row.Score).ToString("0.0", CultureInfo.InvariantCulture);

    private string MostReadSeriesTitle => _rankingRows.Count == 0
        ? "—"
        : _rankingRows.MaxBy(row => row.ReadingCount)?.Title ?? "—";

    private async Task LoadPeriodsAsync()
    {
        _loadingPeriods = true;
        _loadError = null;

        try
        {
            var periods = await RankingApiClient.GetWeeklyPeriodsAsync();
            _publicationPeriods = periods
                .Select(RankingUiHelper.ToOption)
                .ToList();

            if (_publicationPeriods.Count == 0)
            {
                LoadSampleData();
                return;
            }

            _usingSampleData = false;
            _selectedPublicationPeriodId = _publicationPeriods.First().PublicationPeriodId;
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            LoadSampleData();
        }
        finally
        {
            _loadingPeriods = false;
        }
    }

    private async Task LoadRowsAsync()
    {
        if (_usingSampleData)
        {
            RefreshSampleRankingRows();
            return;
        }

        if (_selectedPublicationPeriodId == Guid.Empty)
        {
            _inputRows = [];
            _rankingRows = [];
            return;
        }

        _loadingRows = true;
        _loadError = null;

        try
        {
            var inputRows = await RankingApiClient.GetVoteInputsAsync(
                _selectedPublicationPeriodId,
                _inputSearch,
                _inputSort);

            var rankingRows = await RankingApiClient.GetRankingAsync(
                _selectedPublicationPeriodId,
                _rankingSearch,
                _rankingSort);

            _inputRows = inputRows
                .Select(RankingUiHelper.ToInputRow)
                .ToList();

            _rankingRows = rankingRows
                .Select(RankingUiHelper.ToRankingRow)
                .ToList();

            if (_inputRows.Count == 0 && _rankingRows.Count == 0)
            {
                LoadSampleData();
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            LoadSampleData();
        }
        finally
        {
            _loadingRows = false;
        }
    }

    private async Task OnPublicationPeriodChangedAsync(Guid value)
    {
        _selectedPublicationPeriodId = value;
        await LoadRowsAsync();
    }

    private async Task OnInputSearchChangedAsync(string value)
    {
        _inputSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnRankingSearchChangedAsync(string value)
    {
        _rankingSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnInputSortChangedAsync(string value)
    {
        _inputSort = string.IsNullOrWhiteSpace(value) ? "updated_desc" : value;
        await LoadRowsAsync();
    }

    private async Task OnRankingSortChangedAsync(string value)
    {
        _rankingSort = string.IsNullOrWhiteSpace(value) ? "rank_asc" : value;
        await LoadRowsAsync();
    }

    private void OpenInsertDialog()
    {
        if (!_canManageRankingInput)
        {
            return;
        }

        _insertDialogOpen = true;
    }

    private void OnInsertDialogOpenChanged(bool value)
    {
        _insertDialogOpen = value;
    }

    private async Task<IEnumerable<CatalogEntry>> SearchSeriesAsync(
        string? searchText,
        CancellationToken cancellationToken)
    {
        if (_usingSampleData)
        {
            return SearchSampleCatalog(searchText);
        }

        if (_selectedPublicationPeriodId == Guid.Empty)
        {
            return [];
        }

        var result = await RankingApiClient.SearchSeriesAsync(
            _selectedPublicationPeriodId,
            searchText,
            maxResults: 10,
            cancellationToken);

        return result.Select(RankingUiHelper.ToCatalogEntry);
    }

    private async Task OnCreateVoteInputAsync(InsertFormState form)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add("Only Editorial Board Member and Editorial Board Chief can manage ranking input.", Severity.Error);
            return;
        }

        if (form.Series is null
            || !form.ReadingCount.HasValue
            || !form.RatingCount.HasValue
            || !form.AverageRating.HasValue)
        {
            return;
        }

        if (_usingSampleData)
        {
            CreateSampleVoteInput(form);
            _insertDialogOpen = false;
            Snackbar.Add($"{form.Series.Title} added to preview ranking.", Severity.Success);
            return;
        }

        _savingInput = true;

        try
        {
            await RankingApiClient.CreateVoteInputAsync(
                form.PublicationPeriodId,
                form.Series.SeriesId,
                form.RatingCount.Value,
                form.AverageRating.Value,
                form.ReadingCount.Value,
                form.DataSourceNote);

            _insertDialogOpen = false;
            Snackbar.Add($"{form.Series.Title} vote input saved to database.", Severity.Success);
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingInput = false;
        }
    }

    private async Task OnUpdateVoteInputAsync(SeriesVoteInputUpdateRequestUi request)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add("Only Editorial Board Member and Editorial Board Chief can manage ranking input.", Severity.Error);
            return;
        }

        if (_usingSampleData)
        {
            UpdateSampleVoteInput(request);
            Snackbar.Add("Preview vote input updated.", Severity.Success);
            return;
        }

        try
        {
            await RankingApiClient.UpdateVoteInputAsync(
                request.SeriesVoteInputId,
                request.RatingCount,
                request.AverageRating,
                request.ReadingCount,
                request.DataSourceNote);

            Snackbar.Add("Series vote input updated in database.", Severity.Success);
            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void LoadSampleData()
    {
        _usingSampleData = true;
        _loadError = null;

        var today = DateTime.Today;
        var startOfWeek = today.AddDays(-(int)today.DayOfWeek + 1);
        var endOfWeek = startOfWeek.AddDays(6);

        _publicationPeriods =
        [
            new PublicationPeriodOption(
                SamplePeriodId,
                "Week 28 2026",
                $"Week 28 2026 ({startOfWeek:MMM d} – {endOfWeek:MMM d})",
                startOfWeek,
                endOfWeek)
        ];

        _selectedPublicationPeriodId = SamplePeriodId;

        var now = DateTime.UtcNow;

        _allSampleInputRows =
        [
            new SeriesInputRow
            {
                SeriesVoteInputId = Guid.Parse("33333333-3333-3333-3333-333333333331"),
                PublicationPeriodId = SamplePeriodId,
                SeriesId = _sampleCatalog[0].SeriesId,
                Title = _sampleCatalog[0].Title,
                CoverUrl = _sampleCatalog[0].CoverUrl,
                ReadingCount = 24800,
                RatingCount = 4200,
                AverageRating = 9.2m,
                DataSourceNote = "Preview data",
                CreatedAt = now.AddHours(-10),
                UpdatedAt = now.AddHours(-2)
            },
            new SeriesInputRow
            {
                SeriesVoteInputId = Guid.Parse("33333333-3333-3333-3333-333333333332"),
                PublicationPeriodId = SamplePeriodId,
                SeriesId = _sampleCatalog[1].SeriesId,
                Title = _sampleCatalog[1].Title,
                CoverUrl = _sampleCatalog[1].CoverUrl,
                ReadingCount = 19200,
                RatingCount = 3500,
                AverageRating = 8.7m,
                DataSourceNote = "Preview data",
                CreatedAt = now.AddHours(-9),
                UpdatedAt = now.AddHours(-3)
            },
            new SeriesInputRow
            {
                SeriesVoteInputId = Guid.Parse("33333333-3333-3333-3333-333333333333"),
                PublicationPeriodId = SamplePeriodId,
                SeriesId = _sampleCatalog[2].SeriesId,
                Title = _sampleCatalog[2].Title,
                CoverUrl = _sampleCatalog[2].CoverUrl,
                ReadingCount = 17650,
                RatingCount = 2800,
                AverageRating = 8.9m,
                DataSourceNote = "Preview data",
                CreatedAt = now.AddHours(-8),
                UpdatedAt = now.AddHours(-1)
            },
            new SeriesInputRow
            {
                SeriesVoteInputId = Guid.Parse("33333333-3333-3333-3333-333333333334"),
                PublicationPeriodId = SamplePeriodId,
                SeriesId = _sampleCatalog[3].SeriesId,
                Title = _sampleCatalog[3].Title,
                CoverUrl = _sampleCatalog[3].CoverUrl,
                ReadingCount = 14300,
                RatingCount = 2100,
                AverageRating = 8.4m,
                DataSourceNote = "Preview data",
                CreatedAt = now.AddHours(-7),
                UpdatedAt = now.AddHours(-5)
            }
        ];

        RefreshSampleRankingRows();
    }

    private IEnumerable<CatalogEntry> SearchSampleCatalog(string? searchText)
    {
        var existingSeriesIds = _allSampleInputRows
            .Select(row => row.SeriesId)
            .ToHashSet();

        var query = _sampleCatalog
            .Where(series => !existingSeriesIds.Contains(series.SeriesId));

        if (!string.IsNullOrWhiteSpace(searchText))
        {
            query = query.Where(series =>
                series.Title.Contains(searchText.Trim(), StringComparison.OrdinalIgnoreCase));
        }

        return query
            .OrderBy(series => series.Title)
            .Take(10)
            .ToList();
    }

    private void CreateSampleVoteInput(InsertFormState form)
    {
        if (form.Series is null
            || !form.ReadingCount.HasValue
            || !form.RatingCount.HasValue
            || !form.AverageRating.HasValue)
        {
            return;
        }

        var now = DateTime.UtcNow;

        _allSampleInputRows.Add(new SeriesInputRow
        {
            SeriesVoteInputId = Guid.NewGuid(),
            PublicationPeriodId = SamplePeriodId,
            SeriesId = form.Series.SeriesId,
            Title = form.Series.Title,
            CoverUrl = form.Series.CoverUrl,
            ReadingCount = form.ReadingCount.Value,
            RatingCount = form.RatingCount.Value,
            AverageRating = form.AverageRating.Value,
            DataSourceNote = form.DataSourceNote,
            CreatedAt = now,
            UpdatedAt = now
        });

        RefreshSampleRankingRows();
    }

    private void UpdateSampleVoteInput(SeriesVoteInputUpdateRequestUi request)
    {
        var index = _allSampleInputRows.FindIndex(row => row.SeriesVoteInputId == request.SeriesVoteInputId);

        if (index < 0)
        {
            return;
        }

        var current = _allSampleInputRows[index];

        _allSampleInputRows[index] = new SeriesInputRow
        {
            SeriesVoteInputId = current.SeriesVoteInputId,
            PublicationPeriodId = current.PublicationPeriodId,
            SeriesId = current.SeriesId,
            Title = current.Title,
            CoverUrl = current.CoverUrl,
            ReadingCount = request.ReadingCount,
            RatingCount = request.RatingCount,
            AverageRating = request.AverageRating,
            DataSourceNote = request.DataSourceNote,
            CreatedAt = current.CreatedAt,
            UpdatedAt = DateTime.UtcNow
        };

        RefreshSampleRankingRows();
    }

    private void RefreshSampleRankingRows()
    {
        var filteredInputRows = FilterSampleInputs(_allSampleInputRows);
        _inputRows = SortSampleInputs(filteredInputRows).ToList();

        var ranked = _allSampleInputRows
            .Select(row => new
            {
                Row = row,
                Score = CalculateScore(row)
            })
            .OrderByDescending(item => item.Score)
            .ThenByDescending(item => item.Row.AverageRating)
            .ThenByDescending(item => item.Row.RatingCount)
            .ThenByDescending(item => item.Row.ReadingCount)
            .ToList();

        var rankingRows = new List<RankingRow>();

        for (var index = 0; index < ranked.Count; index++)
        {
            rankingRows.Add(new RankingRow
            {
                SeriesId = ranked[index].Row.SeriesId,
                Rank = index + 1,
                PreviousRank = index + 1,
                Title = ranked[index].Row.Title,
                CoverUrl = ranked[index].Row.CoverUrl,
                ReadingCount = ranked[index].Row.ReadingCount,
                RatingCount = ranked[index].Row.RatingCount,
                AverageRating = ranked[index].Row.AverageRating,
                Score = ranked[index].Score
            });
        }

        _rankingRows = SortSampleRankingRows(FilterSampleRankingRows(rankingRows)).ToList();
    }

    private IEnumerable<SeriesInputRow> FilterSampleInputs(IEnumerable<SeriesInputRow> rows)
    {
        if (string.IsNullOrWhiteSpace(_inputSearch))
        {
            return rows;
        }

        return rows.Where(row =>
            row.Title.Contains(_inputSearch.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<RankingRow> FilterSampleRankingRows(IEnumerable<RankingRow> rows)
    {
        if (string.IsNullOrWhiteSpace(_rankingSearch))
        {
            return rows;
        }

        return rows.Where(row =>
            row.Title.Contains(_rankingSearch.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private IEnumerable<SeriesInputRow> SortSampleInputs(IEnumerable<SeriesInputRow> rows)
    {
        return _inputSort switch
        {
            "title_desc" => rows.OrderByDescending(row => row.Title),
            "average_rating_desc" => rows.OrderByDescending(row => row.AverageRating),
            "average_rating_asc" => rows.OrderBy(row => row.AverageRating),
            "reading_count_desc" => rows.OrderByDescending(row => row.ReadingCount),
            "reading_count_asc" => rows.OrderBy(row => row.ReadingCount),
            "rating_count_desc" => rows.OrderByDescending(row => row.RatingCount),
            "rating_count_asc" => rows.OrderBy(row => row.RatingCount),
            "updated_asc" => rows.OrderBy(row => row.UpdatedAt),
            _ => rows.OrderByDescending(row => row.UpdatedAt)
        };
    }

    private IEnumerable<RankingRow> SortSampleRankingRows(IEnumerable<RankingRow> rows)
    {
        return _rankingSort switch
        {
            "rank_desc" => rows.OrderByDescending(row => row.Rank),
            "title_asc" => rows.OrderBy(row => row.Title),
            "title_desc" => rows.OrderByDescending(row => row.Title),
            "score_desc" => rows.OrderByDescending(row => row.Score),
            "score_asc" => rows.OrderBy(row => row.Score),
            "average_rating_desc" => rows.OrderByDescending(row => row.AverageRating),
            "average_rating_asc" => rows.OrderBy(row => row.AverageRating),
            "reading_count_desc" => rows.OrderByDescending(row => row.ReadingCount),
            "reading_count_asc" => rows.OrderBy(row => row.ReadingCount),
            "rating_count_desc" => rows.OrderByDescending(row => row.RatingCount),
            "rating_count_asc" => rows.OrderBy(row => row.RatingCount),
            _ => rows.OrderBy(row => row.Rank)
        };
    }

    private static decimal CalculateScore(SeriesInputRow row)
    {
        var weightedRating = row.AverageRating * (decimal)Math.Log10(1 + row.RatingCount);
        var readingBoost = row.ReadingCount * 0.001m;

        return Math.Round(weightedRating + readingBoost, 4);
    }
}