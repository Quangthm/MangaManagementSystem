@page "/ranking"
@page "/demo/mangaflow/ranking"
@using System.Globalization
@using System.Security.Claims
@using System.Security.Cryptography
@using System.Text
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Mangaka,Assistant,Tantou Editor,Editorial Board Member,Editorial Board Chief,EditorialBoardMember,EditorialBoardChief,Board Member,Board Chief,Admin")]
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MangaManagementSystem.Web.Services.Api.ISeriesRankingApiClient RankingApiClient

<PageTitle>Series Ranking Management</PageTitle>

<RankingPageFrame>
    <RankingStyles />

    <div class="mf-page">
        <MudStack Spacing="4" Class="ranking-page">

            <RankingHero RankingScope="@_rankingScope"
                         RankingScopeChanged="OnRankingScopeChangedAsync"
                         PeriodOptions="@_periodOptions"
                         SelectedPeriodId="@_selectedPeriodOptionId"
                         SelectedPeriodIdChanged="OnSelectedPeriodChangedAsync"
                         Loading="@_loadingPeriods" />

            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    @_loadError
                </MudAlert>
            }

            @if (!_loadingPeriods && _weeklyPublicationPeriods.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    No weekly publication periods were found in the database.
                    Please seed <code>manga.PublicationPeriod</code> first.
                </MudAlert>
            }

            @if (!_loadingRows && _rankingRows.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No ranking data exists for this filter yet.
                </MudAlert>
            }

            @if (_canManageRankingInput && _rankingScope != ScopeWeekly)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Series vote input is entered by week only. Monthly and all-time rankings are calculated from weekly input data.
                </MudAlert>
            }

            <RankingStatsGrid Items="@Stats" />

            @if (_canManageRankingInput)
            {
                <SeriesVoteInputSection Rows="@_inputRows"
                                        SortOptions="@_sortOptions"
                                        SelectedPublicationWeek="@InputSectionLabel"
                                        Search="@_inputSearch"
                                        SearchChanged="OnInputSearchChangedAsync"
                                        Sort="@_inputSort"
                                        SortChanged="OnInputSortChangedAsync"
                                        CanManageRankingInput="@_canManageRankingInput"
                                        Loading="@(_loadingRows || _loadingPeriods)"
                                        AddInputClicked="OpenInsertDialog"
                                        RowSaveRequested="OnUpdateVoteInputAsync" />
            }

            <RankingResultsSection Rows="@_rankingRows"
                                   SortOptions="@_sortOptions"
                                   SelectedPublicationWeek="@SelectedPeriodLabel"
                                   Search="@_rankingSearch"
                                   SearchChanged="OnRankingSearchChangedAsync"
                                   Sort="@_rankingSort"
                                   SortChanged="OnRankingSortChangedAsync" />

            <TopRankedSeriesSection Rows="@_rankingRows"
                                    SelectedPublicationWeek="@SelectedPeriodLabel" />
        </MudStack>

        @if (_canManageRankingInput)
        {
            <RankingInputDialog Open="@_insertDialogOpen"
                                OpenChanged="OnInsertDialogOpenChanged"
                                SelectedPublicationPeriodId="@SelectedInputPublicationPeriodId"
                                PublicationPeriods="@_weeklyPublicationPeriods"
                                SearchSeriesAsync="SearchSeriesAsync"
                                Saved="OnCreateVoteInputAsync"
                                Saving="@_savingInput" />
        }
    </div>
</RankingPageFrame>

@code {

    private const string ScopeWeekly = "WEEKLY";
    private const string ScopeMonthly = "MONTHLY";
    private const string ScopeAllTime = "ALL_TIME";

    private readonly List<SortOption> _sortOptions =
    [
        new("rank_asc", "Rank (Ascending)"),
        new("rank_desc", "Rank (Descending)"),
        new("title_asc", "Series Title (Aâ€“Z)"),
        new("title_desc", "Series Title (Zâ€“A)"),
        new("score_desc", "Ranking Score (Highest First)"),
        new("score_asc", "Ranking Score (Lowest First)"),
        new("average_rating_desc", "Average Rating (Highest First)"),
        new("average_rating_asc", "Average Rating (Lowest First)"),
        new("reading_count_desc", "Reading Count (Highest First)"),
        new("reading_count_asc", "Reading Count (Lowest First)"),
        new("rating_count_desc", "Rating Count (Highest First)"),
        new("rating_count_asc", "Rating Count (Lowest First)"),
        new("updated_desc", "Last Updated (Newest First)"),
        new("updated_asc", "Last Updated (Oldest First)")
    ];

    private readonly Dictionary<Guid, IReadOnlyList<Guid>> _monthWeekPeriodIds = [];
    private readonly Dictionary<Guid, IReadOnlyList<SeriesInputRow>> _weeklyVoteInputCache = [];

    private List<PublicationPeriodOption> _weeklyPublicationPeriods = [];
    private List<PublicationPeriodOption> _periodOptions = [];
    private List<SeriesInputRow> _inputRows = [];
    private List<RankingRow> _rankingRows = [];

    private Guid _selectedPeriodOptionId;
    private string _rankingScope = ScopeWeekly;
    private string _inputSearch = string.Empty;
    private string _rankingSearch = string.Empty;
    private string _inputSort = "updated_desc";
    private string _rankingSort = "rank_asc";

    private bool _insertDialogOpen;
    private bool _canManageRankingInput;
    private bool _loadingPeriods;
    private bool _loadingRows;
    private bool _savingInput;

    private string? _loadError;

    private bool HasSelectedPeriod =>
        _rankingScope == ScopeAllTime || _selectedPeriodOptionId != Guid.Empty;

    private Guid SelectedInputPublicationPeriodId
    {
        get
        {
            if (_rankingScope == ScopeWeekly && _selectedPeriodOptionId != Guid.Empty)
            {
                return _selectedPeriodOptionId;
            }

            if (_rankingScope == ScopeMonthly
                && _selectedPeriodOptionId != Guid.Empty
                && _monthWeekPeriodIds.TryGetValue(_selectedPeriodOptionId, out var weekIds))
            {
                return weekIds.FirstOrDefault();
            }

            return _weeklyPublicationPeriods.FirstOrDefault()?.PublicationPeriodId ?? Guid.Empty;
        }
    }

    private string InputSectionLabel => _rankingScope switch
    {
        ScopeWeekly => SelectedPeriodLabel,
        ScopeMonthly => $"Weekly inputs inside {SelectedPeriodLabel}",
        ScopeAllTime => "All weekly inputs",
        _ => SelectedPeriodLabel
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _canManageRankingInput = IsRankingInputRole(user);

        await LoadPeriodsAsync();
    }

    private string SelectedPeriodLabel
    {
        get
        {
            if (_rankingScope == ScopeAllTime)
            {
                return "All Time";
            }

            return _periodOptions
                .FirstOrDefault(period => period.PublicationPeriodId == _selectedPeriodOptionId)
                ?.Label
                ?? "No publication period selected";
        }
    }

    private IReadOnlyList<RankingStatItem> Stats =>
    [
        new(
            "Total ranked series",
            _rankingRows.Count.ToString(CultureInfo.InvariantCulture),
            Icons.Material.Filled.BarChart,
            Color.Primary),

        new(
            "Average rating",
            AverageRatingText,
            Icons.Material.Filled.Star,
            Color.Warning),

        new(
            "Highest score",
            HighestScoreText,
            Icons.Material.Filled.EmojiEvents,
            Color.Secondary),

        new(
            "Most read series",
            MostReadSeriesTitle,
            Icons.Material.Filled.MenuBook,
            Color.Success,
            "text-truncate")
    ];

    private string AverageRatingText => _rankingRows.Count == 0
        ? "0.00"
        : _rankingRows.Average(row => row.AverageRating).ToString("0.00", CultureInfo.InvariantCulture);

    private string HighestScoreText => _rankingRows.Count == 0
        ? "0.0"
        : _rankingRows.Max(row => row.Score).ToString("0.0", CultureInfo.InvariantCulture);

    private string MostReadSeriesTitle => _rankingRows.Count == 0
        ? "â€”"
        : _rankingRows.MaxBy(row => row.ReadingCount)?.Title ?? "â€”";

    private async Task LoadPeriodsAsync()
    {
        _loadingPeriods = true;
        _loadError = null;

        try
        {
            var periods = await RankingApiClient.GetWeeklyPeriodsAsync();

            _weeklyPublicationPeriods = periods
                .Select(RankingUiHelper.ToOption)
                .OrderByDescending(period => period.PeriodStartDate)
                .ToList();

            BuildPeriodOptions();

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"The ranking page could not load weekly publication periods from the database. {ex.Message}";
            _weeklyPublicationPeriods = [];
            _periodOptions = [];
            _selectedPeriodOptionId = Guid.Empty;
            _inputRows = [];
            _rankingRows = [];
        }
        finally
        {
            _loadingPeriods = false;
        }
    }

    private void BuildPeriodOptions()
    {
        _monthWeekPeriodIds.Clear();

        if (_rankingScope == ScopeWeekly)
        {
            _periodOptions = _weeklyPublicationPeriods.ToList();

            if (_selectedPeriodOptionId == Guid.Empty
                || !_periodOptions.Any(period => period.PublicationPeriodId == _selectedPeriodOptionId))
            {
                _selectedPeriodOptionId = _periodOptions.FirstOrDefault()?.PublicationPeriodId ?? Guid.Empty;
            }

            return;
        }

        if (_rankingScope == ScopeMonthly)
        {
            _periodOptions = BuildMonthlyOptions();

            if (_selectedPeriodOptionId == Guid.Empty
                || !_periodOptions.Any(period => period.PublicationPeriodId == _selectedPeriodOptionId))
            {
                _selectedPeriodOptionId = _periodOptions.FirstOrDefault()?.PublicationPeriodId ?? Guid.Empty;
            }

            return;
        }

        _periodOptions = [];
        _selectedPeriodOptionId = Guid.Empty;
    }

    private List<PublicationPeriodOption> BuildMonthlyOptions()
    {
        var groups = _weeklyPublicationPeriods
            .GroupBy(GetMonthBucketKey)
            .OrderByDescending(group => group.Max(period => period.PeriodEndDate));

        var result = new List<PublicationPeriodOption>();

        foreach (var group in groups)
        {
            var weeks = group
                .OrderBy(period => period.PeriodStartDate)
                .ToList();

            var startDate = weeks.Min(period => period.PeriodStartDate);
            var endDate = weeks.Max(period => period.PeriodEndDate);
            var id = CreateStableGuid($"MONTH:{group.Key}");

            _monthWeekPeriodIds[id] = weeks
                .Select(period => period.PublicationPeriodId)
                .ToList();

            result.Add(new PublicationPeriodOption(
                id,
                group.Key,
                $"{group.Key} ({startDate:dd/MM/yyyy} â€“ {endDate:dd/MM/yyyy})",
                startDate,
                endDate));
        }

        return result;
    }

    private async Task LoadRowsAsync()
    {
        _loadingRows = true;
        _loadError = null;

        try
        {
            await LoadInputRowsForCurrentScopeAsync();

            if (_rankingScope == ScopeWeekly)
            {
                await LoadWeeklyRowsAsync();
            }
            else if (_rankingScope == ScopeMonthly)
            {
                await LoadMonthlyRowsAsync();
            }
            else
            {
                await LoadAllTimeRowsAsync();
            }
        }
        catch (Exception ex)
        {
            _loadError = $"The ranking data could not be loaded from the database. {ex.Message}";
            _inputRows = [];
            _rankingRows = [];
        }
        finally
        {
            _loadingRows = false;
        }
    }

    private async Task LoadWeeklyRowsAsync()
    {
        if (_selectedPeriodOptionId == Guid.Empty)
        {
            _rankingRows = [];
            return;
        }

        var voteInputRows = await LoadVoteInputRowsForRankingAsync(
            [_selectedPeriodOptionId]);

        _rankingRows = BuildRankingRowsFromVoteInputs(voteInputRows);
    }

    private async Task LoadInputRowsForCurrentScopeAsync()
    {
        if (!_canManageRankingInput)
        {
            _inputRows = [];
            return;
        }

        var periodIds = GetInputPeriodIdsForCurrentScope();

        if (periodIds.Count == 0)
        {
            _inputRows = [];
            return;
        }

        var rows = new List<SeriesInputRow>();

        foreach (var periodId in periodIds)
        {
            var inputRows = await RankingApiClient.GetVoteInputsAsync(
                periodId,
                _inputSearch,
                _inputSort);

            rows.AddRange(inputRows.Select(RankingUiHelper.ToInputRow));
        }

        _inputRows = rows;
    }

    private IReadOnlyList<Guid> GetInputPeriodIdsForCurrentScope()
    {
        if (_rankingScope == ScopeWeekly)
        {
            return _selectedPeriodOptionId == Guid.Empty
                ? []
                : [_selectedPeriodOptionId];
        }

        if (_rankingScope == ScopeMonthly)
        {
            return _selectedPeriodOptionId != Guid.Empty
                   && _monthWeekPeriodIds.TryGetValue(_selectedPeriodOptionId, out var weekIds)
                ? weekIds
                : [];
        }

        return _weeklyPublicationPeriods
            .Select(period => period.PublicationPeriodId)
            .ToList();
    }

    private async Task LoadMonthlyRowsAsync()
    {
        if (_selectedPeriodOptionId == Guid.Empty
            || !_monthWeekPeriodIds.TryGetValue(_selectedPeriodOptionId, out var weekPeriodIds))
        {
            _rankingRows = [];
            return;
        }

        var voteInputRows = await LoadVoteInputRowsForRankingAsync(weekPeriodIds);

        _rankingRows = BuildRankingRowsFromVoteInputs(voteInputRows);
    }

    private async Task LoadAllTimeRowsAsync()
    {
        var weekPeriodIds = _weeklyPublicationPeriods
            .Select(period => period.PublicationPeriodId)
            .ToList();

        var voteInputRows = await LoadVoteInputRowsForRankingAsync(weekPeriodIds);

        _rankingRows = BuildRankingRowsFromVoteInputs(voteInputRows);
    }

    private async Task<List<SeriesInputRow>> LoadVoteInputRowsForRankingAsync(
        IEnumerable<Guid> weekPeriodIds)
    {
        var result = new List<SeriesInputRow>();

        foreach (var periodId in weekPeriodIds.Distinct())
        {
            if (!_weeklyVoteInputCache.TryGetValue(periodId, out var cachedRows))
            {
                var apiRows = await RankingApiClient.GetVoteInputsAsync(
                    periodId,
                    searchText: null,
                    sort: "updated_desc");

                cachedRows = apiRows
                    .Select(RankingUiHelper.ToInputRow)
                    .ToList();

                _weeklyVoteInputCache[periodId] = cachedRows;
            }

            result.AddRange(cachedRows);
        }

        return result;
    }

    private List<RankingRow> BuildRankingRowsFromVoteInputs(
        IEnumerable<SeriesInputRow> sourceRows)
    {
        var aggregatedRows = sourceRows
            .GroupBy(row => row.SeriesId)
            .Select(group =>
            {
                var first = group.First();

                var ratingCount = group.Sum(row => row.RatingCount);
                var readingCount = group.Sum(row => row.ReadingCount);

                var averageRating = ratingCount == 0
                    ? 0m
                    : group.Sum(row => row.AverageRating * row.RatingCount) / ratingCount;

                return new AggregatedRankingRow(
                    first.SeriesId,
                    first.Title,
                    first.CoverUrl,
                    ratingCount,
                    readingCount,
                    averageRating);
            })
            .ToList();

        if (aggregatedRows.Count == 0)
        {
            return [];
        }

        var scopeWeightedAverageRating = CalculateScopeWeightedAverageRating(aggregatedRows);
        var medianRatingCount = CalculateMedianRatingCount(aggregatedRows);

        var scoredRows = aggregatedRows
            .Select(row => new RankingRow
            {
                SeriesId = row.SeriesId,
                Rank = 0,
                PreviousRank = 0,
                Title = row.Title,
                CoverUrl = row.CoverUrl,
                ReadingCount = row.ReadingCount,
                RatingCount = row.RatingCount,
                AverageRating = Math.Round(row.AverageRating, 2),
                Score = CalculateRankingScore(
                    row.AverageRating,
                    row.RatingCount,
                    scopeWeightedAverageRating,
                    medianRatingCount)
            })
            .ToList();

        var officialSortedRows = scoredRows
            .OrderByDescending(row => row.Score)
            .ThenByDescending(row => row.AverageRating)
            .ThenByDescending(row => row.RatingCount)
            .ThenByDescending(row => row.ReadingCount)
            .ThenBy(row => row.SeriesId)
            .ToList();

        var rankedRows = ApplyDenseRanks(officialSortedRows);

        var normalizedSearch = _rankingSearch.Trim();

        IEnumerable<RankingRow> displayRows = rankedRows;

        if (!string.IsNullOrWhiteSpace(normalizedSearch))
        {
            displayRows = displayRows.Where(row =>
                row.Title.Contains(normalizedSearch, StringComparison.OrdinalIgnoreCase));
        }

        return ApplyRankingDisplaySort(displayRows).ToList();
    }

    private IEnumerable<RankingRow> ApplyRankingDisplaySort(
        IEnumerable<RankingRow> rows)
    {
        return _rankingSort switch
        {
            "rank_desc" => rows.OrderByDescending(row => row.Rank),
            "title_asc" => rows.OrderBy(row => row.Title),
            "title_desc" => rows.OrderByDescending(row => row.Title),
            "score_desc" => rows.OrderByDescending(row => row.Score),
            "score_asc" => rows.OrderBy(row => row.Score),
            "average_rating_desc" => rows.OrderByDescending(row => row.AverageRating),
            "average_rating_asc" => rows.OrderBy(row => row.AverageRating),
            "reading_count_desc" => rows.OrderByDescending(row => row.ReadingCount),
            "reading_count_asc" => rows.OrderBy(row => row.ReadingCount),
            "rating_count_desc" => rows.OrderByDescending(row => row.RatingCount),
            "rating_count_asc" => rows.OrderBy(row => row.RatingCount),
            _ => rows.OrderBy(row => row.Rank)
        };
    }

    private static List<RankingRow> ApplyDenseRanks(IReadOnlyList<RankingRow> sortedRows)
    {
        var result = new List<RankingRow>();
        var currentRank = 0;

        decimal? previousScore = null;

        foreach (var row in sortedRows)
        {
            /*
                Ranking rule:
                - Rank is DENSE_RANK by ranking_score DESC only.
                - average_rating, rating_count, reading_count, and series_id
                  are deterministic display ordering fields only.
                - Equal ranking_score values must share the same rank.
            */
            if (previousScore is null || row.Score != previousScore.Value)
            {
                currentRank++;
                previousScore = row.Score;
            }

            result.Add(new RankingRow
            {
                SeriesId = row.SeriesId,
                Rank = currentRank,
                PreviousRank = 0,
                Title = row.Title,
                CoverUrl = row.CoverUrl,
                ReadingCount = row.ReadingCount,
                RatingCount = row.RatingCount,
                AverageRating = row.AverageRating,
                Score = row.Score
            });
        }

        return result;
    }

    private static decimal CalculateRankingScore(
        decimal averageRating,
        int ratingCount,
        decimal scopeWeightedAverageRating,
        decimal medianRatingCount)
    {
        var denominator = ratingCount + medianRatingCount;

        if (denominator <= 0)
        {
            return 0m;
        }

        var score =
            (ratingCount * averageRating + medianRatingCount * scopeWeightedAverageRating)
            / denominator;

        return Math.Round(score, 4);
    }

    private static decimal CalculateScopeWeightedAverageRating(
        IReadOnlyList<AggregatedRankingRow> rows)
    {
        var totalRatingCount = rows.Sum(row => row.RatingCount);

        if (totalRatingCount <= 0)
        {
            return 0m;
        }

        return rows.Sum(row => row.AverageRating * row.RatingCount) / totalRatingCount;
    }

    private static decimal CalculateMedianRatingCount(
        IReadOnlyList<AggregatedRankingRow> rows)
    {
        if (rows.Count == 0)
        {
            return 0m;
        }

        var orderedCounts = rows
            .Select(row => row.RatingCount)
            .OrderBy(count => count)
            .ToList();

        var middleIndex = orderedCounts.Count / 2;

        if (orderedCounts.Count % 2 == 1)
        {
            return orderedCounts[middleIndex];
        }

        return (orderedCounts[middleIndex - 1] + orderedCounts[middleIndex]) / 2m;
    }

    private async Task OnRankingScopeChangedAsync(string value)
    {
        _rankingScope = string.IsNullOrWhiteSpace(value)
            ? ScopeWeekly
            : value;

        _rankingSearch = string.Empty;
        _inputSearch = string.Empty;
        _selectedPeriodOptionId = Guid.Empty;

        BuildPeriodOptions();

        await LoadRowsAsync();
    }

    private async Task OnSelectedPeriodChangedAsync(Guid value)
    {
        _selectedPeriodOptionId = value;
        _rankingSearch = string.Empty;
        _inputSearch = string.Empty;

        await LoadRowsAsync();
    }

    private async Task OnInputSearchChangedAsync(string value)
    {
        _inputSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnRankingSearchChangedAsync(string value)
    {
        _rankingSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnInputSortChangedAsync(string value)
    {
        _inputSort = string.IsNullOrWhiteSpace(value)
            ? "updated_desc"
            : value;

        await LoadRowsAsync();
    }

    private async Task OnRankingSortChangedAsync(string value)
    {
        _rankingSort = string.IsNullOrWhiteSpace(value)
            ? "rank_asc"
            : value;

        await LoadRowsAsync();
    }

    private void OpenInsertDialog()
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        if (_weeklyPublicationPeriods.Count == 0)
        {
            Snackbar.Add(
                "Please seed at least one weekly publication period before adding series vote input.",
                Severity.Warning);

            return;
        }

        _insertDialogOpen = true;
    }

    private void OnInsertDialogOpenChanged(bool value)
    {
        _insertDialogOpen = value;
    }

    private async Task<IEnumerable<CatalogEntry>> SearchSeriesAsync(
        Guid publicationPeriodId,
        string? searchText,
        CancellationToken cancellationToken)
    {
        if (!_canManageRankingInput || publicationPeriodId == Guid.Empty)
        {
            return [];
        }

        var result = await RankingApiClient.SearchSeriesAsync(
            publicationPeriodId,
            searchText,
            maxResults: 10,
            cancellationToken);

        return result.Select(RankingUiHelper.ToCatalogEntry);
    }

    private async Task OnCreateVoteInputAsync(InsertFormState form)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        if (form.Series is null
            || !form.ReadingCount.HasValue
            || !form.RatingCount.HasValue
            || !form.AverageRating.HasValue)
        {
            return;
        }

        _savingInput = true;

        try
        {
            await RankingApiClient.CreateVoteInputAsync(
                form.PublicationPeriodId,
                form.Series.SeriesId,
                form.RatingCount.Value,
                form.AverageRating.Value,
                form.ReadingCount.Value,
                form.DataSourceNote);

            _insertDialogOpen = false;

            _weeklyVoteInputCache.Clear();

            Snackbar.Add(
                $"{form.Series.Title} vote input saved to database.",
                Severity.Success);

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingInput = false;
        }
    }

    private async Task OnUpdateVoteInputAsync(SeriesVoteInputUpdateRequestUi request)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        try
        {
            await RankingApiClient.UpdateVoteInputAsync(
                request.SeriesVoteInputId,
                request.RatingCount,
                request.AverageRating,
                request.ReadingCount,
                request.DataSourceNote);

            _weeklyVoteInputCache.Clear();

            Snackbar.Add(
                "Series vote input updated in database.",
                Severity.Success);

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static string GetMonthBucketKey(PublicationPeriodOption period)
    {
        var weekIndex = period.PeriodName.IndexOf("_WEEK", StringComparison.OrdinalIgnoreCase);

        if (weekIndex > 0)
        {
            return period.PeriodName[..weekIndex];
        }

        return period.PeriodStartDate.ToString("yyyy_MMMM", CultureInfo.InvariantCulture).ToUpperInvariant();
    }

    private static Guid CreateStableGuid(string key)
    {
        var bytes = MD5.HashData(Encoding.UTF8.GetBytes(key));
        return new Guid(bytes);
    }

    private sealed record AggregatedRankingRow(
        Guid SeriesId,
        string Title,
        string? CoverUrl,
        int RatingCount,
        int ReadingCount,
        decimal AverageRating);

    private static bool IsRankingInputRole(ClaimsPrincipal user)
    {
        return HasAnyRole(
            user,
            "Editorial Board Member",
            "EditorialBoardMember",
            "Board Member",
            "Editorial Board Chief",
            "EditorialBoardChief",
            "Board Chief");
    }

    private static bool HasAnyRole(ClaimsPrincipal user, params string[] roleNames)
    {
        foreach (var roleName in roleNames)
        {
            if (user.IsInRole(roleName))
            {
                return true;
            }
        }

        var roleClaimValues = user.Claims
            .Where(claim =>
                claim.Type == ClaimTypes.Role
                || claim.Type == "role"
                || claim.Type == "role_name"
                || claim.Type == "Role"
                || claim.Type == "RoleName")
            .Select(claim => claim.Value)
            .ToList();

        return roleClaimValues.Any(value =>
            roleNames.Any(roleName =>
                string.Equals(value, roleName, StringComparison.OrdinalIgnoreCase)));
    }
}
