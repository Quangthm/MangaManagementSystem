@page "/ranking"
@page "/demo/mangaflow/ranking"
@using System.Globalization
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Mangaka,Assistant,Tantou Editor,Editorial Board Member,Editorial Board Chief,EditorialBoardMember,EditorialBoardChief,Board Member,Board Chief,Admin")]
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject MangaManagementSystem.Web.Services.Api.ISeriesRankingApiClient RankingApiClient

<PageTitle>Series Ranking Management</PageTitle>

<RankingPageFrame>
    <RankingStyles />

    <div class="mf-page">
        <MudStack Spacing="4" Class="ranking-page">
            <RankingHero PublicationPeriods="@_publicationPeriods"
                         SelectedPublicationPeriodId="@_selectedPublicationPeriodId"
                         SelectedPublicationPeriodIdChanged="OnPublicationPeriodChangedAsync"
                         Loading="@_loadingPeriods" />

            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                    @_loadError
                </MudAlert>
            }

            @if (!_loadingPeriods && _publicationPeriods.Count == 0)
            {
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                    No weekly publication periods were found in the database.
                    Please seed <code>manga.PublicationPeriod</code> first.
                </MudAlert>
            }

            @if (!_loadingRows && HasSelectedPublicationPeriod && _rankingRows.Count == 0)
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No ranking data exists for this publication week yet.
                    Board Chief or Board Member users can add series vote input to generate ranking results.
                </MudAlert>
            }

            <RankingStatsGrid Items="@Stats" />

            @if (_canManageRankingInput)
            {
                <SeriesVoteInputSection Rows="@_inputRows"
                                        SortOptions="@_sortOptions"
                                        SelectedPublicationWeek="@SelectedPublicationPeriodLabel"
                                        Search="@_inputSearch"
                                        SearchChanged="OnInputSearchChangedAsync"
                                        Sort="@_inputSort"
                                        SortChanged="OnInputSortChangedAsync"
                                        CanManageRankingInput="@_canManageRankingInput"
                                        Loading="@(_loadingRows || _loadingPeriods)"
                                        AddInputClicked="OpenInsertDialog"
                                        RowSaveRequested="OnUpdateVoteInputAsync" />
            }

            <RankingResultsSection Rows="@_rankingRows"
                                   SortOptions="@_sortOptions"
                                   SelectedPublicationWeek="@SelectedPublicationPeriodLabel"
                                   Search="@_rankingSearch"
                                   SearchChanged="OnRankingSearchChangedAsync"
                                   Sort="@_rankingSort"
                                   SortChanged="OnRankingSortChangedAsync" />

            <TopRankedSeriesSection Rows="@_rankingRows"
                                    SelectedPublicationWeek="@SelectedPublicationPeriodLabel" />
        </MudStack>

        @if (_canManageRankingInput)
        {
            <RankingInputDialog Open="@_insertDialogOpen"
                                OpenChanged="OnInsertDialogOpenChanged"
                                SelectedPublicationPeriodId="@_selectedPublicationPeriodId"
                                PublicationPeriods="@_publicationPeriods"
                                SearchSeriesAsync="SearchSeriesAsync"
                                Saved="OnCreateVoteInputAsync"
                                Saving="@_savingInput" />
        }
    </div>
</RankingPageFrame>

@code {
    private readonly List<SortOption> _sortOptions =
    [
        new("rank_asc", "Rank (Ascending)"),
        new("rank_desc", "Rank (Descending)"),
        new("title_asc", "Series Title (A–Z)"),
        new("title_desc", "Series Title (Z–A)"),
        new("score_desc", "Ranking Score (Highest First)"),
        new("score_asc", "Ranking Score (Lowest First)"),
        new("average_rating_desc", "Average Rating (Highest First)"),
        new("average_rating_asc", "Average Rating (Lowest First)"),
        new("reading_count_desc", "Reading Count (Highest First)"),
        new("reading_count_asc", "Reading Count (Lowest First)"),
        new("rating_count_desc", "Rating Count (Highest First)"),
        new("rating_count_asc", "Rating Count (Lowest First)"),
        new("updated_desc", "Last Updated (Newest First)"),
        new("updated_asc", "Last Updated (Oldest First)")
    ];

    private List<PublicationPeriodOption> _publicationPeriods = [];
    private List<SeriesInputRow> _inputRows = [];
    private List<RankingRow> _rankingRows = [];

    private Guid _selectedPublicationPeriodId;
    private string _inputSearch = string.Empty;
    private string _rankingSearch = string.Empty;
    private string _inputSort = "updated_desc";
    private string _rankingSort = "rank_asc";

    private bool _insertDialogOpen;
    private bool _canManageRankingInput;
    private bool _loadingPeriods;
    private bool _loadingRows;
    private bool _savingInput;

    private string? _loadError;

    private bool HasSelectedPublicationPeriod => _selectedPublicationPeriodId != Guid.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        _canManageRankingInput = IsRankingInputRole(user);

        await LoadPeriodsAsync();
    }

    private string SelectedPublicationPeriodLabel =>
        _publicationPeriods.FirstOrDefault(period => period.PublicationPeriodId == _selectedPublicationPeriodId)?.Label
        ?? "No publication week selected";

    private IReadOnlyList<RankingStatItem> Stats =>
    [
        new(
            "Total ranked series",
            _rankingRows.Count.ToString(CultureInfo.InvariantCulture),
            Icons.Material.Filled.BarChart,
            Color.Primary),

        new(
            "Average rating",
            AverageRatingText,
            Icons.Material.Filled.Star,
            Color.Warning),

        new(
            "Highest score",
            HighestScoreText,
            Icons.Material.Filled.EmojiEvents,
            Color.Secondary),

        new(
            "Most read series",
            MostReadSeriesTitle,
            Icons.Material.Filled.MenuBook,
            Color.Success,
            "text-truncate")
    ];

    private string AverageRatingText => _rankingRows.Count == 0
        ? "0.00"
        : _rankingRows.Average(row => row.AverageRating).ToString("0.00", CultureInfo.InvariantCulture);

    private string HighestScoreText => _rankingRows.Count == 0
        ? "0.0"
        : _rankingRows.Max(row => row.Score).ToString("0.0", CultureInfo.InvariantCulture);

    private string MostReadSeriesTitle => _rankingRows.Count == 0
        ? "—"
        : _rankingRows.MaxBy(row => row.ReadingCount)?.Title ?? "—";

    private async Task LoadPeriodsAsync()
    {
        _loadingPeriods = true;
        _loadError = null;

        try
        {
            var periods = await RankingApiClient.GetWeeklyPeriodsAsync();

            _publicationPeriods = periods
                .Select(RankingUiHelper.ToOption)
                .ToList();

            if (_publicationPeriods.Count == 0)
            {
                _selectedPublicationPeriodId = Guid.Empty;
                _inputRows = [];
                _rankingRows = [];
                return;
            }

            _selectedPublicationPeriodId = _publicationPeriods.First().PublicationPeriodId;

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            _loadError = $"The ranking page could not load weekly publication periods from the database. {ex.Message}";
            _selectedPublicationPeriodId = Guid.Empty;
            _publicationPeriods = [];
            _inputRows = [];
            _rankingRows = [];
        }
        finally
        {
            _loadingPeriods = false;
        }
    }

    private async Task LoadRowsAsync()
    {
        if (!HasSelectedPublicationPeriod)
        {
            _inputRows = [];
            _rankingRows = [];
            return;
        }

        _loadingRows = true;
        _loadError = null;

        try
        {
            if (_canManageRankingInput)
            {
                var inputRows = await RankingApiClient.GetVoteInputsAsync(
                    _selectedPublicationPeriodId,
                    _inputSearch,
                    _inputSort);

                _inputRows = inputRows
                    .Select(RankingUiHelper.ToInputRow)
                    .ToList();
            }
            else
            {
                _inputRows = [];
            }

            var rankingRows = await RankingApiClient.GetRankingAsync(
                _selectedPublicationPeriodId,
                _rankingSearch,
                _rankingSort);

            _rankingRows = rankingRows
                .Select(RankingUiHelper.ToRankingRow)
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = $"The ranking data could not be loaded from the database. {ex.Message}";
            _inputRows = [];
            _rankingRows = [];
        }
        finally
        {
            _loadingRows = false;
        }
    }

    private async Task OnPublicationPeriodChangedAsync(Guid value)
    {
        _selectedPublicationPeriodId = value;
        _inputSearch = string.Empty;
        _rankingSearch = string.Empty;

        await LoadRowsAsync();
    }

    private async Task OnInputSearchChangedAsync(string value)
    {
        _inputSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnRankingSearchChangedAsync(string value)
    {
        _rankingSearch = value ?? string.Empty;
        await LoadRowsAsync();
    }

    private async Task OnInputSortChangedAsync(string value)
    {
        _inputSort = string.IsNullOrWhiteSpace(value)
            ? "updated_desc"
            : value;

        await LoadRowsAsync();
    }

    private async Task OnRankingSortChangedAsync(string value)
    {
        _rankingSort = string.IsNullOrWhiteSpace(value)
            ? "rank_asc"
            : value;

        await LoadRowsAsync();
    }

    private void OpenInsertDialog()
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        if (!HasSelectedPublicationPeriod)
        {
            Snackbar.Add(
                "Please seed or select a weekly publication period before adding series vote input.",
                Severity.Warning);

            return;
        }

        _insertDialogOpen = true;
    }

    private void OnInsertDialogOpenChanged(bool value)
    {
        _insertDialogOpen = value;
    }

    private async Task<IEnumerable<CatalogEntry>> SearchSeriesAsync(
        string? searchText,
        CancellationToken cancellationToken)
    {
        if (!_canManageRankingInput || !HasSelectedPublicationPeriod)
        {
            return [];
        }

        var result = await RankingApiClient.SearchSeriesAsync(
            _selectedPublicationPeriodId,
            searchText,
            maxResults: 10,
            cancellationToken);

        return result.Select(RankingUiHelper.ToCatalogEntry);
    }

    private async Task OnCreateVoteInputAsync(InsertFormState form)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        if (!HasSelectedPublicationPeriod)
        {
            Snackbar.Add("Please select a publication week first.", Severity.Error);
            return;
        }

        if (form.Series is null
            || !form.ReadingCount.HasValue
            || !form.RatingCount.HasValue
            || !form.AverageRating.HasValue)
        {
            return;
        }

        _savingInput = true;

        try
        {
            await RankingApiClient.CreateVoteInputAsync(
                form.PublicationPeriodId,
                form.Series.SeriesId,
                form.RatingCount.Value,
                form.AverageRating.Value,
                form.ReadingCount.Value,
                form.DataSourceNote);

            _insertDialogOpen = false;

            Snackbar.Add(
                $"{form.Series.Title} vote input saved to database.",
                Severity.Success);

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _savingInput = false;
        }
    }

    private async Task OnUpdateVoteInputAsync(SeriesVoteInputUpdateRequestUi request)
    {
        if (!_canManageRankingInput)
        {
            Snackbar.Add(
                "Only Editorial Board Member and Editorial Board Chief can manage ranking input.",
                Severity.Error);

            return;
        }

        try
        {
            await RankingApiClient.UpdateVoteInputAsync(
                request.SeriesVoteInputId,
                request.RatingCount,
                request.AverageRating,
                request.ReadingCount,
                request.DataSourceNote);

            Snackbar.Add(
                "Series vote input updated in database.",
                Severity.Success);

            await LoadRowsAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private static bool IsRankingInputRole(ClaimsPrincipal user)
    {
        return HasAnyRole(
            user,
            "Editorial Board Member",
            "EditorialBoardMember",
            "Board Member",
            "Editorial Board Chief",
            "EditorialBoardChief",
            "Board Chief");
    }

    private static bool HasAnyRole(ClaimsPrincipal user, params string[] roleNames)
    {
        foreach (var roleName in roleNames)
        {
            if (user.IsInRole(roleName))
            {
                return true;
            }
        }

        var roleClaimValues = user.Claims
            .Where(claim =>
                claim.Type == ClaimTypes.Role
                || claim.Type == "role"
                || claim.Type == "role_name"
                || claim.Type == "Role"
                || claim.Type == "RoleName")
            .Select(claim => claim.Value)
            .ToList();

        return roleClaimValues.Any(value =>
            roleNames.Any(roleName =>
                string.Equals(value, roleName, StringComparison.OrdinalIgnoreCase)));
    }
}