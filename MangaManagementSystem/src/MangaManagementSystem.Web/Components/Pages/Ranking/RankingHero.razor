@using System.Globalization

<MudPaper Class="ranking-hero pa-5" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="7">
            <MudStack Row="true" Spacing="2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Rounded="true">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                </MudAvatar>

                <div>
                    <MudText Typo="Typo.h5" Class="fw-800">
                        Series Ranking Management
                    </MudText>

                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Weekly editorial ranking input and live database-calculated results
                    </MudText>
                </div>
            </MudStack>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudAutocomplete T="PublicationPeriodOption"
                             Label="Publication Week"
                             Placeholder="Type dd/mm/yyyy, month, year, or week name"
                             Value="@SelectedPublicationPeriod"
                             ValueChanged="OnPublicationPeriodSelectedAsync"
                             SearchFunc="SearchPublicationPeriodsAsync"
                             ToStringFunc="FormatPublicationPeriod"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             Dense="true"
                             Clearable="false"
                             CoerceText="false"
                             CoerceValue="false"
                             ResetValueOnEmptyText="false"
                             MinCharacters="0"
                             MaxItems="100"
                             Disabled="@(PublicationPeriods.Count == 0 || Loading)"
                             Adornment="Adornment.Start"
                             AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                             Class="ranking-period-select">
                <ItemTemplate>
                    <MudStack Spacing="0">
                        <MudText Typo="Typo.body2" Class="fw-700">
                            @context.PeriodName
                        </MudText>

                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @FormatPeriodDateRange(context)
                        </MudText>
                    </MudStack>
                </ItemTemplate>

                <NoItemsTemplate>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="pa-2">
                        No matching weekly publication period found.
                    </MudText>
                </NoItemsTemplate>
            </MudAutocomplete>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<PublicationPeriodOption> PublicationPeriods { get; set; } = [];

    [Parameter]
    public Guid SelectedPublicationPeriodId { get; set; }

    [Parameter]
    public EventCallback<Guid> SelectedPublicationPeriodIdChanged { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    private PublicationPeriodOption? SelectedPublicationPeriod =>
        PublicationPeriods.FirstOrDefault(period =>
            period.PublicationPeriodId == SelectedPublicationPeriodId);

    private async Task OnPublicationPeriodSelectedAsync(PublicationPeriodOption? value)
    {
        if (value is null)
        {
            return;
        }

        await SelectedPublicationPeriodIdChanged.InvokeAsync(value.PublicationPeriodId);
    }

    private Task<IEnumerable<PublicationPeriodOption>> SearchPublicationPeriodsAsync(
        string? searchText,
        CancellationToken cancellationToken)
    {
        var normalizedSearch = searchText?.Trim();

        if (string.IsNullOrWhiteSpace(normalizedSearch))
        {
            return Task.FromResult(
                PublicationPeriods
                    .OrderByDescending(period => period.PeriodStartDate)
                    .AsEnumerable());
        }

        if (TryParseSearchDate(normalizedSearch, out var parsedDate))
        {
            var date = parsedDate.Date;

            var result = PublicationPeriods
                .Select(period => new
                {
                    Period = period,
                    ContainsDate = IsDateInsidePeriod(period, date),
                    DistanceDays = GetDistanceDaysFromPeriod(period, date)
                })
                .Where(item => item.ContainsDate || item.DistanceDays <= 28)
                .OrderByDescending(item => item.ContainsDate)
                .ThenBy(item => item.DistanceDays)
                .ThenBy(item => item.Period.PeriodStartDate)
                .Select(item => item.Period)
                .AsEnumerable();

            return Task.FromResult(result);
        }

        var textResult = PublicationPeriods
            .Where(period => MatchesPeriodText(period, normalizedSearch))
            .OrderByDescending(period => period.PeriodStartDate)
            .AsEnumerable();

        return Task.FromResult(textResult);
    }

    private static bool MatchesPeriodText(
        PublicationPeriodOption period,
        string searchText)
    {
        return period.PeriodName.Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.Label.Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodStartDate.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodEndDate.ToString("dd/MM/yyyy", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodStartDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodEndDate.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodStartDate.ToString("MM/yyyy", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodEndDate.ToString("MM/yyyy", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodStartDate.ToString("MMMM", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodEndDate.ToString("MMMM", CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase)
               || period.PeriodStartDate.Year.ToString(CultureInfo.InvariantCulture).Contains(searchText, StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDateInsidePeriod(
        PublicationPeriodOption period,
        DateTime date)
    {
        return date >= period.PeriodStartDate.Date
               && date <= period.PeriodEndDate.Date;
    }

    private static int GetDistanceDaysFromPeriod(
        PublicationPeriodOption period,
        DateTime date)
    {
        if (IsDateInsidePeriod(period, date))
        {
            return 0;
        }

        if (date < period.PeriodStartDate.Date)
        {
            return Math.Abs((period.PeriodStartDate.Date - date).Days);
        }

        return Math.Abs((date - period.PeriodEndDate.Date).Days);
    }

    private static bool TryParseSearchDate(
        string searchText,
        out DateTime date)
    {
        var formats = new[]
        {
            "dd/MM/yyyy",
            "d/MM/yyyy",
            "dd/M/yyyy",
            "d/M/yyyy",

            "dd-MM-yyyy",
            "d-MM-yyyy",
            "dd-M-yyyy",
            "d-M-yyyy",

            "yyyy-MM-dd",
            "yyyy-M-dd",
            "yyyy-MM-d",
            "yyyy-M-d",

            "yyyy/MM/dd",
            "yyyy/M/dd",
            "yyyy/MM/d",
            "yyyy/M/d"
        };

        return DateTime.TryParseExact(
            searchText,
            formats,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out date);
    }

    private static string FormatPublicationPeriod(
        PublicationPeriodOption? period)
    {
        return period is null
            ? string.Empty
            : $"{period.PeriodName} ({FormatPeriodDateRange(period)})";
    }

    private static string FormatPeriodDateRange(
        PublicationPeriodOption period)
    {
        return $"{period.PeriodStartDate:dd/MM/yyyy} – {period.PeriodEndDate:dd/MM/yyyy}";
    }
}