<MudPaper Class="ranking-hero pa-5" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="7">
            <MudStack Row="true" Spacing="2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Rounded="true">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                </MudAvatar>

                <div>
                    <MudText Typo="Typo.h5" Class="fw-800">Series Ranking Management</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Weekly editorial ranking input and live database-calculated results
                    </MudText>
                </div>
            </MudStack>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudStack Spacing="1">
                <MudDatePicker Label="Publication Date"
                               Date="@SelectedPublicationDate"
                               DateChanged="OnPublicationDateChangedAsync"
                               DateFormat="yyyy-MM-dd"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Disabled="@(PublicationPeriods.Count == 0 || Loading)"
                               Adornment="Adornment.Start"
                               AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                               Class="ranking-period-select"
                               Error="@(!string.IsNullOrWhiteSpace(_dateError))"
                               ErrorText="@_dateError" />

                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @SelectedPublicationPeriodLabel
                </MudText>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    private string? _dateError;

    [Parameter]
    public IReadOnlyList<PublicationPeriodOption> PublicationPeriods { get; set; } = [];

    [Parameter]
    public Guid SelectedPublicationPeriodId { get; set; }

    [Parameter]
    public EventCallback<Guid> SelectedPublicationPeriodIdChanged { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    private DateTime? SelectedPublicationDate
    {
        get
        {
            var selectedPeriod = PublicationPeriods.FirstOrDefault(period =>
                period.PublicationPeriodId == SelectedPublicationPeriodId);

            return selectedPeriod?.PeriodStartDate;
        }
    }

    private string SelectedPublicationPeriodLabel
    {
        get
        {
            var selectedPeriod = PublicationPeriods.FirstOrDefault(period =>
                period.PublicationPeriodId == SelectedPublicationPeriodId);

            return selectedPeriod is null
                ? "No publication week selected"
                : selectedPeriod.Label;
        }
    }

    private async Task OnPublicationDateChangedAsync(DateTime? value)
    {
        if (!value.HasValue)
        {
            return;
        }

        var selectedDate = value.Value.Date;

        var matchedPeriod = PublicationPeriods.FirstOrDefault(period =>
            selectedDate >= period.PeriodStartDate.Date
            && selectedDate <= period.PeriodEndDate.Date);

        if (matchedPeriod is null)
        {
            _dateError = "No weekly publication period contains this date.";
            return;
        }

        _dateError = null;

        await SelectedPublicationPeriodIdChanged.InvokeAsync(
            matchedPeriod.PublicationPeriodId);
    }
}