<MudPaper Class="ranking-hero pa-5" Elevation="0">
    <MudGrid>
        <MudItem xs="12" md="7">
            <MudStack Row="true" Spacing="2">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Rounded="true">
                    <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h5" Class="fw-800">Series Ranking Management</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Weekly editorial ranking input and live database-calculated results
                    </MudText>
                </div>
            </MudStack>
        </MudItem>

        <MudItem xs="12" md="5">
            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudSelect T="Guid"
                           Label="Publication Week"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Margin="Margin.Dense"
                           Value="SelectedPublicationPeriodId"
                           ValueChanged="OnSelectedPublicationPeriodChanged"
                           Disabled="PublicationPeriods.Count == 0 || Loading"
                           Adornment="Adornment.Start"
                           AdornmentIcon="@Icons.Material.Filled.CalendarMonth"
                           Class="ranking-period-select">
                    @foreach (var period in PublicationPeriods)
                    {
                        <MudSelectItem T="Guid" Value="@period.PublicationPeriodId">@period.Label</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>
        </MudItem>
    </MudGrid>
</MudPaper>

@code {
    [Parameter]
    public IReadOnlyList<PublicationPeriodOption> PublicationPeriods { get; set; } = [];

    [Parameter]
    public Guid SelectedPublicationPeriodId { get; set; }

    [Parameter]
    public EventCallback<Guid> SelectedPublicationPeriodIdChanged { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    private Task OnSelectedPublicationPeriodChanged(Guid value)
    {
        return SelectedPublicationPeriodIdChanged.InvokeAsync(value);
    }
}
