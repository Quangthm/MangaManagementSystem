@code {
    private const string AllFilter = "ALL";

    private static readonly string[] StatusOptions =
    {
        "PENDING_APPROVAL",
        "ACTIVE",
        "DISABLED",
        "REJECTED"
    };

    private static readonly string[] RoleOptions =
    {
        "Admin",
        "Mangaka",
        "Assistant",
        "Tantou Editor",
        "Editorial Board Member",
        "Editorial Board Chief"
    };

    [SupplyParameterFromQuery(Name = "status")]
    public string? StatusQuery { get; set; }

    private IReadOnlyList<AdminUserListItemDto> _users =
        Array.Empty<AdminUserListItemDto>();

    private string? _search;
    private string _statusFilter = AllFilter;
    private string _roleFilter = AllFilter;
    private int _pageNumber = 1;
    private int _pageSize = 20;
    private int _totalCount;
    private int _totalPages;
    private bool _isLoading;
    private string? _loadError;
    private Guid? _processingUserId;
    private Guid? _currentUserId;
    private bool _initialized;

    private bool _showReasonDialog;
    private AdminUserListItemDto? _reasonTarget;
    private ReasonAction _reasonAction;
    private string? _reason;

    protected override async Task OnInitializedAsync()
    {
        var authState =
            await AuthStateProvider.GetAuthenticationStateAsync();

        var userIdValue =
            authState.User.FindFirst(
                ClaimTypes.NameIdentifier)?.Value;

        if (Guid.TryParse(
                userIdValue,
                out var userId))
        {
            _currentUserId = userId;
        }

        if (!string.IsNullOrWhiteSpace(StatusQuery)
            && StatusOptions.Contains(
                StatusQuery.Trim(),
                StringComparer.OrdinalIgnoreCase))
        {
            _statusFilter =
                StatusQuery.Trim().ToUpperInvariant();
        }

        _initialized = true;
        await LoadUsersAsync();
    }

    private bool IsBusy(Guid userId) =>
        _isLoading
        || _processingUserId == userId;

    private bool IsCurrentUser(Guid userId) =>
        _currentUserId == userId;

    private async Task HandleSearchKeyDownAsync(
        KeyboardEventArgs args)
    {
        if (args.Key == "Enter"
            && !_isLoading)
        {
            await ApplyFiltersAsync();
        }
    }
    private async Task ApplyFiltersAsync()
    {
        _pageNumber = 1;
        await LoadUsersAsync();
    }

    private async Task OnPageSizeChanged(int pageSize)
    {
        _pageSize = pageSize;
        _pageNumber = 1;

        if (_initialized)
        {
            await LoadUsersAsync();
        }
    }

    private async Task PreviousPageAsync()
    {
        if (_pageNumber <= 1)
        {
            return;
        }

        _pageNumber--;
        await LoadUsersAsync();
    }

    private async Task NextPageAsync()
    {
        if (_totalPages == 0
            || _pageNumber >= _totalPages)
        {
            return;
        }

        _pageNumber++;
        await LoadUsersAsync();
    }

    private async Task LoadUsersAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var page =
                await AdminUserApiClient.SearchUsersAsync(
                    _search,
                    NormalizeFilter(_statusFilter),
                    NormalizeFilter(_roleFilter),
                    _pageNumber,
                    _pageSize);

            _users = page.Items;
            _totalCount = page.TotalCount;
            _totalPages = page.TotalPages;

            if (_totalPages > 0
                && _pageNumber > _totalPages)
            {
                _pageNumber = _totalPages;
                await LoadUsersAsync();
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _users =
                Array.Empty<AdminUserListItemDto>();
            _totalCount = 0;
            _totalPages = 0;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static string? NormalizeFilter(
        string value)
    {
        return string.Equals(
            value,
            AllFilter,
            StringComparison.OrdinalIgnoreCase)
            ? null
            : value;
    }

    private async Task ApproveAsync(
        AdminUserListItemDto user)
    {
        await RunActionAsync(
            user,
            async () =>
                await AdminUserApiClient
                    .ApproveUserAsync(user.UserId),
            user.StatusCode == "REJECTED"
                ? $"Approved {user.Username} again."
                : $"Approved {user.Username}.");
    }

    private async Task ActivateAsync(
        AdminUserListItemDto user)
    {
        await RunActionAsync(
            user,
            async () =>
                await AdminUserApiClient
                    .ActivateUserAsync(user.UserId),
            $"Activated {user.Username}.");
    }

    private void OpenReasonDialog(
        AdminUserListItemDto user,
        ReasonAction action)
    {
        _reasonTarget = user;
        _reasonAction = action;
        _reason = null;
        _showReasonDialog = true;
    }

    private void CloseReasonDialog()
    {
        _showReasonDialog = false;
        _reasonTarget = null;
        _reason = null;
    }

    private async Task SubmitReasonActionAsync()
    {
        if (_reasonTarget is null
            || string.IsNullOrWhiteSpace(_reason))
        {
            Snackbar.Add(
                "A reason is required.",
                Severity.Error);

            return;
        }

        var user = _reasonTarget;
        var reason = _reason.Trim();
        var action = _reasonAction;

        CloseReasonDialog();

        await InvokeAsync(StateHasChanged);
        await Task.Yield();

        if (action == ReasonAction.Reject)
        {
            await RunActionAsync(
                user,
                async () =>
                    await AdminUserApiClient
                        .RejectUserAsync(
                            user.UserId,
                            reason),
                $"Rejected {user.Username}.");
        }
        else
        {
            await RunActionAsync(
                user,
                async () =>
                    await AdminUserApiClient
                        .DisableUserAsync(
                            user.UserId,
                            reason),
                $"Disabled {user.Username}.");
        }
    }

    private async Task RunActionAsync(
        AdminUserListItemDto user,
        Func<Task> action,
        string successMessage)
    {
        if (_processingUserId.HasValue)
        {
            return;
        }

        _processingUserId = user.UserId;

        try
        {
            await action();
            Snackbar.Add(
                successMessage,
                Severity.Success);

            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                ex.Message,
                Severity.Error);
        }
        finally
        {
            _processingUserId = null;
        }
    }

    private enum ReasonAction
    {
        Reject,
        Disable
    }
}
