@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAdminUserApiClient AdminUserApiClient
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>User Accounts - MangaFlow</PageTitle>

<AdminLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">User Accounts</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Manage and review all user accounts</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-4" />
            }
            else
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText Typo="Typo.h6">Accounts</MudText>
                    <MudStack Row="true">
                        <MudButton Variant="Variant.Outlined" OnClick="ReloadUsers">Refresh</MudButton>
                    </MudStack>
                </MudStack>

                @if (_loadError != null)
                {
                    <MudAlert Severity="Severity.Error">Failed to load users: @_loadError</MudAlert>
                }
                else if (!_users.Any())
                {
                    <MudPaper Class="pa-6 text-center mf-card"><MudText>No users found.</MudText></MudPaper>
                }
                else
                {
                    <MudTable Items="_users" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Avatar</MudTh>
                            <MudTh>Display Name</MudTh>
                            <MudTh>Username</MudTh>
                            <MudTh>Email</MudTh>
                            <MudTh>Role</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                @if (context.AvatarFileId.HasValue)
                                {
                                    <MudIcon Icon="mdi-image" />
                                }
                                else
                                {
                                    var initial = "?";
                                    if (!string.IsNullOrWhiteSpace(context.DisplayName))
                                        initial = context.DisplayName.Substring(0, 1).ToUpperInvariant();
                                    else if (!string.IsNullOrWhiteSpace(context.Username))
                                        initial = context.Username.Substring(0, 1).ToUpperInvariant();
                                    <MudAvatar Size="Size.Small">@initial</MudAvatar>
                                }
                            </MudTd>
                            <MudTd>@(context.DisplayName ?? "-")</MudTd>
                            <MudTd>@context.Username</MudTd>
                            <MudTd>@context.Email</MudTd>
                            <MudTd>@context.RoleName</MudTd>
                            <MudTd>
                                @switch (context.StatusCode)
                                {
                                    case "PENDING_APPROVAL":<MudChip T="string" Color="Color.Info" Size="Size.Small">PENDING_APPROVAL</MudChip>;break;
                                    case "ACTIVE":<MudChip T="string" Color="Color.Success" Size="Size.Small">ACTIVE</MudChip>;break;
                                    case "REJECTED":<MudChip T="string" Color="Color.Warning" Size="Size.Small">REJECTED</MudChip>;break;
                                    case "DISABLED":<MudChip T="string" Color="Color.Error" Size="Size.Small">DISABLED</MudChip>;break;
                                    default:<MudChip T="string" Size="Size.Small">@context.StatusCode</MudChip>;break;
                                }
                            </MudTd>
                            <MudTd>@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
                            <MudTd>
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Text"
                                               Href="/admin/user-approval">
                                        View
                                    </MudButton>

                                    @if (IsRejected(context))
                                    {
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   Disabled="@(IsActionDisabled(context))"
                                                   OnClick="@(() => OpenRestoreConfirmation(context, RestoreAction.ApproveAgain))">
                                            Approve Again
                                        </MudButton>
                                    }
                                    else if (IsDisabled(context))
                                    {
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   Disabled="@(IsActionDisabled(context))"
                                                   OnClick="@(() => OpenRestoreConfirmation(context, RestoreAction.Activate))">
                                            Activate
                                        </MudButton>
                                    }
                                    else if (CanDisable(context))
                                    {
                                        <MudButton Size="Size.Small"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   Disabled="@(IsActionDisabled(context))"
                                                   OnClick="@(() => ConfirmDisable(context))">
                                            Disable
                                        </MudButton>
                                    }
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            }

            @if (_deleteTarget != null && !_deleteTarget.Username.Equals(_currentUserUsername, StringComparison.OrdinalIgnoreCase))
            {
                <MudDialog @bind-Visible="_showDeleteConfirm">
                    <DialogContent>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Confirm Disable Account</MudText>
                        <MudText Class="mt-2">Are you sure you want to disable this account? The account will be marked as DISABLED and cannot log in.</MudText>
                        <MudText Class="mt-2">Current status: <MudChip T="string" Size="Size.Small">@_deleteTarget.StatusCode</MudChip></MudText>
                        <MudAlert Severity="Severity.Warning" Class="mt-3">Disabled accounts are retained in the system for audit purposes.</MudAlert>
                    </DialogContent>
                    <DialogActions>
                        <MudButton Variant="Variant.Text" OnClick="CancelDisable">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ConfirmDisableAsync">Disable Account</MudButton>
                    </DialogActions>
                </MudDialog>
            }

            @if (_restoreTarget != null)
            {
                <MudDialog @bind-Visible="_showRestoreConfirm">
                    <DialogContent>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">
                            @GetRestoreDialogTitle()
                        </MudText>
                        <MudText Class="mt-2">
                            @GetRestoreDialogMessage()
                        </MudText>
                        <MudText Class="mt-2">
                            Current status:
                            <MudChip T="string" Size="Size.Small">@_restoreTarget.StatusCode</MudChip>
                        </MudText>
                        <MudAlert Severity="Severity.Info" Class="mt-3">
                            The account will become ACTIVE and will be able to sign in.
                        </MudAlert>
                    </DialogContent>
                    <DialogActions>
                        <MudButton Variant="Variant.Text" OnClick="CancelRestore">Cancel</MudButton>
                        @if (_restoreAction == RestoreAction.ApproveAgain)
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       OnClick="ConfirmRestoreAsync">
                                Approve Again
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       OnClick="ConfirmRestoreAsync">
                                Activate Account
                            </MudButton>
                        }
                    </DialogActions>
                </MudDialog>
            }
        </MudPaper>
    </div>
</AdminLayout>

@code {
    private List<MangaManagementSystem.Application.DTOs.Auth.UserDto> _users = new();
    private bool _isLoading;
    private string? _loadError;
    private Guid? _processingUserId;

    private bool _showDeleteConfirm;
    private MangaManagementSystem.Application.DTOs.Auth.UserDto? _deleteTarget;
    private string? _currentUserUsername;

    private bool _showRestoreConfirm;
    private MangaManagementSystem.Application.DTOs.Auth.UserDto? _restoreTarget;
    private RestoreAction _restoreAction;
    private async Task<AuthenticationState> GetAuthenticationStateAsync()
    {
        return await AuthStateProvider.GetAuthenticationStateAsync();
    }

    private async Task ReloadUsers()
    {
        await LoadAllUsersAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            _currentUserUsername = user.Identity.Name;
        }
        await LoadAllUsersAsync();
    }

    private async Task LoadAllUsersAsync()
    {
        _isLoading = true;
        _loadError = null;
        _users.Clear();
        try
        {
            _users =
                (await AdminUserApiClient
                    .GetUsersAsync())
                .OrderByDescending(
                    user =>
                        user.CreatedAtUtc)
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ConfirmDisable(MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        _deleteTarget = user;
        _showDeleteConfirm = true;
    }

    private void CancelDisable()
    {
        _showDeleteConfirm = false;
        _deleteTarget = null;
    }

    private async Task ConfirmDisableAsync()
    {
        if (_deleteTarget == null) return;
        var user = _deleteTarget;
        if (_processingUserId.HasValue) return;

        _processingUserId = user.UserId;
        _showDeleteConfirm = false;
        try
        {
            await AdminUserApiClient
                .DisableUserAsync(
                    user.UserId);
            Snackbar.Add($"Disabled {user.Username}.", Severity.Success);
            await LoadAllUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to disable {user.Username}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingUserId = null;
            _deleteTarget = null;
        }
    }
    private bool IsCurrentUser(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        return !string.IsNullOrWhiteSpace(_currentUserUsername)
            && string.Equals(
                user.Username,
                _currentUserUsername,
                StringComparison.OrdinalIgnoreCase);
    }

    private bool IsActionDisabled(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        return _processingUserId.HasValue
            || IsCurrentUser(user);
    }

    private static bool IsRejected(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        return string.Equals(
            user.StatusCode,
            "REJECTED",
            StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsDisabled(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        return string.Equals(
            user.StatusCode,
            "DISABLED",
            StringComparison.OrdinalIgnoreCase);
    }

    private static bool CanDisable(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user)
    {
        return string.Equals(
                   user.StatusCode,
                   "ACTIVE",
                   StringComparison.OrdinalIgnoreCase)
            || string.Equals(
                   user.StatusCode,
                   "PENDING_APPROVAL",
                   StringComparison.OrdinalIgnoreCase);
    }

    private void OpenRestoreConfirmation(
        MangaManagementSystem.Application.DTOs.Auth.UserDto user,
        RestoreAction action)
    {
        if (IsActionDisabled(user))
        {
            return;
        }

        _restoreTarget = user;
        _restoreAction = action;
        _showRestoreConfirm = true;
    }

    private void CancelRestore()
    {
        _showRestoreConfirm = false;
        _restoreTarget = null;
    }

    private string GetRestoreDialogTitle()
    {
        return _restoreAction == RestoreAction.ApproveAgain
            ? "Confirm Approve Account Again"
            : "Confirm Activate Account";
    }

    private string GetRestoreDialogMessage()
    {
        if (_restoreTarget == null)
        {
            return string.Empty;
        }

        return _restoreAction == RestoreAction.ApproveAgain
            ? $"Approve the previously rejected registration for '{_restoreTarget.Username}'?"
            : $"Activate the disabled account '{_restoreTarget.Username}'?";
    }

    private async Task ConfirmRestoreAsync()
    {
        if (_restoreTarget == null || _processingUserId.HasValue)
        {
            return;
        }

        var user = _restoreTarget;
        var action = _restoreAction;

        _processingUserId = user.UserId;
        _showRestoreConfirm = false;

        try
        {
            if (action == RestoreAction.ApproveAgain)
            {
                await AdminUserApiClient.ApproveUserAsync(user.UserId);
                Snackbar.Add($"Approved {user.Username} again.", Severity.Success);
            }
            else
            {
                await AdminUserApiClient.ActivateUserAsync(user.UserId);
                Snackbar.Add($"Activated {user.Username}.", Severity.Success);
            }

            await LoadAllUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                $"Failed to update {user.Username}: {ex.Message}",
                Severity.Error);
        }
        finally
        {
            _processingUserId = null;
            _restoreTarget = null;
        }
    }

    private enum RestoreAction
    {
        ApproveAgain,
        Activate
    }
}