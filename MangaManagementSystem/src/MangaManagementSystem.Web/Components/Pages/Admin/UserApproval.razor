@page "/admin/user-approval"
@attribute [Authorize(Roles = "Admin")]
@inject IUserService UserService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Approval - MangaFlow</PageTitle>

<AdminLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">User Approval</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review and approve accounts pending admin activation</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-4" />
            }

            <MudTable Items="_pendingUsers" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="mf-muted pa-4">No users are waiting for approval.</MudText>
                </NoRecordsContent>
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Created At</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Username">@context.Username</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Role">@MapRoleName(context.RoleId)</MudTd>
                    <MudTd DataLabel="Created At">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Size="Size.Small"
                                       Color="Color.Success"
                                       Variant="Variant.Filled"
                                       Disabled="@IsRowBusy(context.UserId)"
                                       OnClick="@(() => ApproveAsync(context))">
                                Approve
                            </MudButton>
                            <MudButton Size="Size.Small"
                                       Color="Color.Error"
                                       Variant="Variant.Outlined"
                                       Disabled="@IsRowBusy(context.UserId)"
                                       OnClick="@(() => RejectAsync(context))">
                                Reject
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </div>
</AdminLayout>

@code {
    private const string PendingStatus = "PENDING_APPROVAL";

    private readonly List<UserDto> _pendingUsers = new();
    private Dictionary<Guid, Guid> _selectedRolesByUserId = new();
    private bool _isLoading;
    private Guid? _processingUserId;

    private string MapRoleName(Guid roleId) => roleId == Guid.Empty ? "Unknown" : "Member";

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingUsersAsync();
    }

    private async Task LoadPendingUsersAsync()
    {
        _isLoading = true;
        try
        {
            var users = await UserService.GetUsersByStatusAsync(PendingStatus);
            _pendingUsers.Clear();
            _pendingUsers.AddRange(users);
                _selectedRolesByUserId = users.ToDictionary(u => u.UserId, u => u.RoleId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load pending users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Guid GetSelectedRole(Guid userId)
    {
        if (_selectedRolesByUserId.TryGetValue(userId, out var roleId))
        {
            return roleId;
        }

        return _pendingUsers.FirstOrDefault(u => u.UserId == userId)?.RoleId ?? Guid.Empty;
    }

    private void SetSelectedRole(Guid userId, Guid roleId)
    {
        _selectedRolesByUserId[userId] = roleId;
    }

    private bool IsRowBusy(Guid userId) => _isLoading || _processingUserId == userId;

    private async Task<Guid> GetCurrentAdminUserIdAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!Guid.TryParse(userIdClaim, out var adminUserId))
        {
            throw new InvalidOperationException("Current admin user id is not available.");
        }

        return adminUserId;
    }

    private async Task ApproveAsync(UserDto user)
    {
        if (_processingUserId.HasValue)
        {
            return;
        }

        _processingUserId = user.UserId;
        try
        {
            var adminUserId = await GetCurrentAdminUserIdAsync();
            await UserService.ApproveUserAsync(adminUserId, user.UserId);
            Snackbar.Add($"Approved {user.Username}.", Severity.Success);
            await LoadPendingUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to approve {user.Username}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingUserId = null;
        }
    }

    private async Task RejectAsync(UserDto user)
    {
        if (_processingUserId.HasValue)
        {
            return;
        }

        _processingUserId = user.UserId;
        try
        {
            var adminUserId = await GetCurrentAdminUserIdAsync();
            await UserService.RejectUserAsync(adminUserId, user.UserId);
            Snackbar.Add($"Rejected {user.Username}.", Severity.Warning);
            await LoadPendingUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to reject {user.Username}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingUserId = null;
        }
    }
}
