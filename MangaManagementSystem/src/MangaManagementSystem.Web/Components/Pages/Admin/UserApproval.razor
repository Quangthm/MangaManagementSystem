@page "/admin/user-approval"
@attribute [Authorize(Roles = "Admin")]
@inject IUserService UserService
@inject IFileResourceService _fileResourceService
@inject ISnackbar Snackbar

<PageTitle>User Approval - MangaFlow</PageTitle>

<AdminLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">User Approval</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review and approve accounts pending admin activation</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-4" />
            }

            @if (_showRejectConfirm && _rejectTarget != null)
            {
                <MudDialog Open="true">
                    <DialogContent>
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Confirm Reject User</MudText>
                        <MudText Class="mt-2">Are you sure you want to reject registration for <strong>@_rejectTarget.Username</strong> (@_rejectTarget.DisplayName)?</MudText>
                        <MudText Class="mt-2">Current status: <MudChip T="string" Size="Size.Small">@_rejectTarget.StatusCode</MudChip></MudText>
                        <MudAlert Severity="Severity.Warning" Class="mt-3">Rejected accounts cannot log in. This action can be reviewed in the audit logs.</MudAlert>
                    </DialogContent>
                    <DialogActions>
                        <MudButton Variant="Variant.Text" OnClick="CancelReject">Cancel</MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ConfirmRejectAsync">Confirm Reject</MudButton>
                    </DialogActions>
                </MudDialog>
            }

            <MudTable Items="_pendingUsers" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm">
                <NoRecordsContent>
                    <MudText Typo="Typo.body2" Class="mf-muted pa-4">No users are waiting for approval.</MudText>
                </NoRecordsContent>
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Username</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Portfolio</MudTh>
                    <MudTh>Created At</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Username">@context.Username</MudTd>
                    <MudTd DataLabel="Email">@context.Email</MudTd>
                    <MudTd DataLabel="Portfolio">
                        @if (context.PortfolioFileId.HasValue)
                        {
                            <MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="@(()=>ViewPortfolioAsync(context.PortfolioFileId.Value))">View Portfolio</MudButton>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="mf-muted">No portfolio</MudText>
                        }
                    </MudTd>
                    <MudTd DataLabel="Role">@MapRoleName(context.RoleId)</MudTd>
                    <MudTd DataLabel="Created At">@context.CreatedAtUtc.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudButton Size="Size.Small"
                                       Color="Color.Success"
                                       Variant="Variant.Filled"
                                       Disabled="@IsRowBusy(context.UserId)"
                                       OnClick="@(() => ApproveAsync(context))">
                                Approve
                            </MudButton>
                            <MudButton Size="Size.Small"
                                       Color="Color.Error"
                                       Variant="Variant.Outlined"
                                       Disabled="@IsRowBusy(context.UserId)"
                                       OnClick="@(() => RejectAsync(context))">
                                Reject
                            </MudButton>
                        </MudStack>
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (_showPortfolioPreview && _currentPortfolio != null)
            {
                <MudDialog Open="true" MaxWidth="MaxWidth.Medium" KeepContentMounted="true">
                    <DialogContent>
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Portfolio Preview</MudText>
                        @if (_isImagePreview)
                        {
                            <ImageWithFallback Src="@_currentPortfolio.CloudinarySecureUrl" Alt="Portfolio Image" />
                        }
                        else if (!string.IsNullOrWhiteSpace(_currentPortfolio.CloudinarySecureUrl))
                        {
                            <MudText Class="mb-2">File: @_currentPortfolio.OriginalFileName</MudText>
                            <MudButton Href="@_currentPortfolio.CloudinarySecureUrl" Target="_blank">Open file</MudButton>
                        }
                        else
                        {
                            <MudText class="mf-muted">File unavailable or has been removed.</MudText>
                        }
                    </DialogContent>
                    <DialogActions>
                        <MudButton Variant="Variant.Text" OnClick="ClosePortfolioPreview">Close</MudButton>
                    </DialogActions>
                </MudDialog>
            }
        </MudPaper>
    </div>
</AdminLayout>

@code {
    private const string PendingStatus = "PENDING_APPROVAL";

    private readonly List<UserDto> _pendingUsers = new();
    private Dictionary<int, short> _selectedRolesByUserId = new();
    private bool _isLoading;
    private int? _processingUserId;

    private static readonly (short Id, string Label)[] RoleOptions =
    {
        (1, "Mangaka"),
        (2, "Assistant"),
        (3, "Tantou Editor"),
        (4, "Editorial Board Member"),
        (5, "Admin")
    };

    private string MapRoleName(short roleId) => roleId switch
    {
        1 => "Mangaka",
        2 => "Assistant",
        3 => "Tantou Editor",
        4 => "Editorial Board Member",
        5 => "Admin",
        _ => "Unknown"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingUsersAsync();
    }

    private async Task LoadPendingUsersAsync()
    {
        _isLoading = true;
        try
        {
            var users = await UserService.GetUsersByStatusAsync(PendingStatus);
            _pendingUsers.Clear();
            _pendingUsers.AddRange(users);
                _selectedRolesByUserId = users.ToDictionary(u => u.UserId, u => u.RoleId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load pending users: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private short GetSelectedRole(int userId)
    {
        if (_selectedRolesByUserId.TryGetValue(userId, out var roleId))
        {
            return roleId;
        }

        return _pendingUsers.FirstOrDefault(u => u.UserId == userId)?.RoleId ?? 1;
    }

    private void SetSelectedRole(int userId, short roleId)
    {
        _selectedRolesByUserId[userId] = roleId;
    }

    private bool IsRowBusy(int userId) => _isLoading || _processingUserId == userId;

    private MangaManagementSystem.Application.DTOs.Manga.FileResourceDto? _currentPortfolio;
    private bool _showPortfolioPreview;
    private bool _isImagePreview;

    private async Task ViewPortfolioAsync(long fileResourceId)
    {
        try
        {
            var file = await _fileResourceService.GetFileResourceByIdAsync(fileResourceId);
            if (file == null)
            {
                Snackbar.Add("Portfolio file not found.", Severity.Error);
                return;
            }

            _currentPortfolio = file;
            _isImagePreview = file.ContentType?.StartsWith("image/") == true;
            _showPortfolioPreview = true;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load portfolio: {ex.Message}", Severity.Error);
        }
    }

    private void ClosePortfolioPreview()
    {
        _showPortfolioPreview = false;
        _currentPortfolio = null;
    }

    private async Task ApproveAsync(UserDto user)
    {
        if (_processingUserId.HasValue)
        {
            return;
        }

        _processingUserId = user.UserId;
        try
        {
            await UserService.ApproveUserAsync(user.UserId);
            Snackbar.Add($"Approved {user.Username}.", Severity.Success);
            await LoadPendingUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to approve {user.Username}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingUserId = null;
        }
    }

    // Confirmation dialog state
    private bool _showRejectConfirm;
    private UserDto? _rejectTarget;

    private async Task RejectAsync(UserDto user)
    {
        // Open confirmation dialog
        _rejectTarget = user;
        _showRejectConfirm = true;
    }

    private async Task ConfirmRejectAsync()
    {
        if (_rejectTarget == null) return;
        var user = _rejectTarget;
        if (_processingUserId.HasValue) return;

        _processingUserId = user.UserId;
        _showRejectConfirm = false;
        try
        {
            await UserService.RejectUserAsync(user.UserId);
            Snackbar.Add($"Rejected {user.Username}.", Severity.Warning);
            await LoadPendingUsersAsync();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to reject {user.Username}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _processingUserId = null;
            _rejectTarget = null;
        }
    }

    private void CancelReject()
    {
        _showRejectConfirm = false;
        _rejectTarget = null;
    }
}
