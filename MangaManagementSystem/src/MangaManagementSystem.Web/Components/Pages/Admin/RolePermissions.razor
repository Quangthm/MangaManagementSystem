@page "/admin/roles"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager Nav

<AdminLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Role & Permission Management</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Configure role-based access control and permissions</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Permission Management</MudText>
            <MudTable Items="Roles" Hover="true">
                <HeaderContent><MudTh>Role</MudTh><MudTh>Dashboard</MudTh><MudTh>Review</MudTh><MudTh>Admin</MudTh><MudTh>Ranking</MudTh></HeaderContent>
                <RowTemplate><MudTd>@context.Role</MudTd><MudTd>@context.Dashboard</MudTd><MudTd>@context.Review</MudTd><MudTd>@context.Admin</MudTd><MudTd>@context.Ranking</MudTd></RowTemplate>
            </MudTable>
        </MudPaper>

    </div>
</AdminLayout>

@code {

    private readonly List<RoleRow> Roles = new()
    {
        new("Mangaka", "View", "Submit", "No", "View"),
        new("Assistant", "View", "Task Only", "No", "No"),
        new("Tantou Editor", "View", "Approve", "No", "View"),
        new("System Administrator", "Full", "Full", "Full", "Full")
    };
    private record RoleRow(string Role, string Dashboard, string Review, string Admin, string Ranking);

}
