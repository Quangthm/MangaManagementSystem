@page "/admin/files"
@using MangaManagementSystem.Application.DTOs.Manga
@using Microsoft.AspNetCore.Authorization
@inject IJSRuntime JSRuntime
@attribute [Authorize(Roles = "Admin")]
@inject IFileResourceService FileResourceService
@inject ISnackbar Snackbar

<PageTitle>File Management - MangaFlow</PageTitle>

<style>
    .phase7-file-dialog-backdrop {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
        background: rgba(0, 0, 0, 0.45);
    }

    .phase7-file-dialog-card {
        width: min(720px, 100%);
        max-height: calc(100vh - 32px);
        overflow-y: auto;
    }

    .phase7-file-name {
        overflow-wrap: anywhere;
    }

    .phase7-file-hash {
        overflow-wrap: anywhere;
        font-family: monospace;
        font-size: 0.78rem;
    }

    .phase7-action-row {
        gap: 8px;
        flex-wrap: wrap;
    }
</style>

<AdminLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">File Management</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">
                Review file resources, preview/download active files, soft-delete records,
                and clean up storage for soft-deleted files.
            </MudText>
        </div>

        <MudAlert Severity="Severity.Info" Class="mb-4">
            This page only reads database records when loading or filtering files.
            Cloudinary is called only when Cleanup or Cleanup All is clicked.
        </MudAlert>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="5">
                    <MudTextField T="string"
                                  Label="Search"
                                  Placeholder="File name, public id, URL, content type..."
                                  @bind-Value="_keyword"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Label="Purpose Code"
                                  Placeholder="Example: USER_AVATAR"
                                  @bind-Value="_purposeCode"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudNumericField T="int"
                                     Label="Page Size"
                                     @bind-Value="_pageSize"
                                     Min="1"
                                     Max="100"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Spacing="2" Class="mb-4 phase7-action-row">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Disabled="_isLoading"
                           OnClick="ReloadFilesAsync">
                    Refresh
                </MudButton>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           Disabled="@(_isLoading || _isCleaningAll)"
                           OnClick="OpenCleanupAllDialog">
                    Cleanup All
                </MudButton>
            </MudStack>

            @if (_isLoading)
            {
                <MudProgressLinear Indeterminate="true" Class="mb-4" />
            }

            @if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_loadError</MudAlert>
            }

            <MudText Typo="Typo.body2" Class="mf-muted mb-2">
                Showing @_files.Count file(s). Total: @_totalCount. Page: @_page.
            </MudText>

            @if (!_files.Any() && !_isLoading)
            {
                <MudPaper Class="pa-6 text-center mf-card">
                    <MudText>No file resources found.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_files" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>File</MudTh>
                        <MudTh>Purpose</MudTh>
                        <MudTh>Content Type</MudTh>
                        <MudTh>Size</MudTh>
                        <MudTh>Uploaded</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>

                    <RowTemplate>
                        <MudTd>
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.body2" Class="phase7-file-name">@context.OriginalFileName</MudText>
                                <MudText Typo="Typo.caption" Class="mf-muted">@context.CloudinaryPublicId</MudText>
                            </MudStack>
                        </MudTd>

                        <MudTd>@context.FilePurposeCode</MudTd>
                        <MudTd>@context.ContentType</MudTd>
                        <MudTd>@FormatFileSize(context.FileSizeBytes)</MudTd>
                        <MudTd>@context.UploadedAtUtc.ToLocalTime().ToString("g")</MudTd>

                        <MudTd>
                            @if (context.IsDeleted)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small">Deleted</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip>
                            }
                        </MudTd>

                        <MudTd>
                            <MudStack Row="true" Spacing="1" Class="phase7-action-row">
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Disabled="_isLoading"
                                           OnClick="@(() => OpenDetailDialog(context))">
                                    Details
                                </MudButton>

                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Disabled="@(_isLoading || !CanPreview(context))"
                                           OnClick="@(() => PreviewAsync(context))">
                                    Preview
                                </MudButton>

                                <MudButton Size="Size.Small"
                                           Variant="Variant.Outlined"
                                           Disabled="@(_isLoading || !CanDownload(context))"
                                           OnClick="@(() => DownloadAsync(context))">
                                    Download
                                </MudButton>

                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Disabled="@(_isLoading || context.IsDeleted)"
                                           OnClick="@(() => OpenSoftDeleteDialog(context))">
                                    Soft Delete
                                </MudButton>

                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Warning"
                                           Disabled="@(_isLoading || !CanCleanup(context))"
                                           OnClick="@(() => OpenCleanupDialog(context))">
                                    Cleanup
                                </MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>

                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-4">
                    <MudButton Variant="Variant.Text"
                               Disabled="@(_page <= 1 || _isLoading)"
                               OnClick="PreviousPageAsync">
                        Previous
                    </MudButton>

                    <MudText Typo="Typo.body2">Page @_page</MudText>

                    <MudButton Variant="Variant.Text"
                               Disabled="@(!HasNextPage || _isLoading)"
                               OnClick="NextPageAsync">
                        Next
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </div>
</AdminLayout>

@if (_selectedDetail is not null)
{
    <div class="phase7-file-dialog-backdrop">
        <MudPaper Class="phase7-file-dialog-card pa-5 mf-card" Elevation="12">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h5">File Details</MudText>

                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           OnClick="CloseDetailDialog">
                    Close
                </MudButton>
            </div>

            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mf-muted">File name</MudText>
                    <MudText Class="phase7-file-name">@_selectedDetail.OriginalFileName</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Purpose</MudText>
                    <MudText>@_selectedDetail.FilePurposeCode</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Content type</MudText>
                    <MudText>@_selectedDetail.ContentType</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Size</MudText>
                    <MudText>@FormatFileSize(_selectedDetail.FileSizeBytes)</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Status</MudText>
                    <MudText>@(_selectedDetail.IsDeleted ? "Deleted" : "Active")</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Uploaded at</MudText>
                    <MudText>@_selectedDetail.UploadedAtUtc.ToLocalTime().ToString("g")</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Deleted at</MudText>
                    <MudText>@FormatNullableDate(_selectedDetail.DeletedAtUtc)</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mf-muted">Secure URL</MudText>
                    <MudText Class="phase7-file-name">@_selectedDetail.CloudinarySecureUrl</MudText>
                </MudItem>

                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mf-muted">SHA-256</MudText>
                    <div class="phase7-file-hash">@(_selectedDetail.Sha256Hash ?? "-")</div>
                </MudItem>
            </MudGrid>
        </MudPaper>
    </div>
}

@if (_softDeleteTarget is not null)
{
    <div class="phase7-file-dialog-backdrop">
        <MudPaper Class="phase7-file-dialog-card pa-5 mf-card" Elevation="12">
            <MudText Typo="Typo.h5" Class="mb-2">Soft Delete File</MudText>

            <MudAlert Severity="Severity.Warning" Class="mb-4">
                This action marks the database record as deleted.
                It does not delete the physical storage asset.
            </MudAlert>

            <MudText Typo="Typo.body2" Class="mb-4 phase7-file-name">
                @_softDeleteTarget.OriginalFileName
            </MudText>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Disabled="_isSoftDeleting"
                           OnClick="CloseSoftDeleteDialog">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Error"
                           Disabled="_isSoftDeleting"
                           OnClick="ConfirmSoftDeleteAsync">
                    @(_isSoftDeleting ? "Deleting..." : "Confirm Soft Delete")
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@if (_cleanupTarget is not null)
{
    <div class="phase7-file-dialog-backdrop">
        <MudPaper Class="phase7-file-dialog-card pa-5 mf-card" Elevation="12">
            <MudText Typo="Typo.h5" Class="mb-2">Cleanup File</MudText>

            <MudAlert Severity="Severity.Warning" Class="mb-4">
                This action calls Cloudinary and permanently deletes the physical file if it still exists.
                The database record is preserved.
            </MudAlert>

            <MudGrid Class="mb-4">
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="mf-muted">File</MudText>
                    <MudText Class="phase7-file-name">@_cleanupTarget.OriginalFileName</MudText>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudText Typo="Typo.caption" Class="mf-muted">Status</MudText>
                    <MudText>Deleted</MudText>
                </MudItem>
            </MudGrid>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Disabled="_isCleaning"
                           OnClick="CloseCleanupDialog">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Disabled="_isCleaning"
                           OnClick="ConfirmCleanupAsync">
                    @(_isCleaning ? "Cleaning..." : "Confirm Cleanup")
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@if (_isCleanupAllDialogOpen)
{
    <div class="phase7-file-dialog-backdrop">
        <MudPaper Class="phase7-file-dialog-card pa-5 mf-card" Elevation="12">
            <MudText Typo="Typo.h5" Class="mb-2">Cleanup All Deleted Files</MudText>

            <MudAlert Severity="Severity.Warning" Class="mb-4">
                This action calls Cloudinary for soft-deleted file records only.
                Database records are preserved.
            </MudAlert>

            <MudText Typo="Typo.body2" Class="mb-2">
                Deleted files visible on this page:
                @_cleanupAllVisibleCandidateCount
            </MudText>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-4">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Default"
                           Disabled="_isCleaningAll"
                           OnClick="CloseCleanupAllDialog">
                    Cancel
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Warning"
                           Disabled="_isCleaningAll"
                           OnClick="ConfirmCleanupAllAsync">
                    @(_isCleaningAll ? "Cleaning..." : "Confirm Cleanup All")
                </MudButton>
            </MudStack>
        </MudPaper>
    </div>
}

@code {
    private List<FileResourceDto> _files = new();

    private string? _keyword;
    private string? _purposeCode;

    private int _page = 1;
    private int _pageSize = 20;
    private int _totalCount;

    private bool _isLoading;
    private bool _isSoftDeleting;
    private bool _isCleaning;
    private bool _isCleaningAll;
    private bool _isCleanupAllDialogOpen;
    private int _cleanupAllVisibleCandidateCount;

    private string? _loadError;

    private FileResourceDto? _selectedDetail;
    private FileResourceDto? _softDeleteTarget;
    private FileResourceDto? _cleanupTarget;

    private bool HasNextPage => _page * _pageSize < _totalCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadFilesAsync();
    }

    private async Task ReloadFilesAsync()
    {
        _page = 1;
        await LoadFilesAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_page <= 1)
        {
            return;
        }

        _page--;
        await LoadFilesAsync();
    }

    private async Task NextPageAsync()
    {
        if (!HasNextPage)
        {
            return;
        }

        _page++;
        await LoadFilesAsync();
    }

    private async Task LoadFilesAsync()
    {
        _isLoading = true;
        _loadError = null;

        try
        {
            var result = await FileResourceService.SearchAdminFilesAsync(
                NormalizeFilter(_keyword),
                NormalizeFilter(_purposeCode),
                page: _page,
                pageSize: _pageSize);

            _files = result.Items.ToList();
            _totalCount = result.TotalCount;
            _page = result.Page;
            _pageSize = result.PageSize;
        }
        catch (Exception ex)
        {
            _loadError = $"Failed to load file resources: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenDetailDialog(FileResourceDto file)
    {
        _selectedDetail = file;
    }

    private void CloseDetailDialog()
    {
        _selectedDetail = null;
    }

    private async Task PreviewAsync(FileResourceDto file)
    {
        await OpenExternalUrlAsync(file.CloudinarySecureUrl);
    }

    private async Task DownloadAsync(FileResourceDto file)
    {
        await OpenExternalUrlAsync(file.CloudinarySecureUrl);
    }

    private async Task OpenExternalUrlAsync(string? secureUrl)
    {
        if (string.IsNullOrWhiteSpace(secureUrl))
        {
            Snackbar.Add("File URL is empty.", Severity.Warning);
            return;
        }

        await JSRuntime.InvokeVoidAsync("open", secureUrl, "_blank");
    }

    private void OpenSoftDeleteDialog(FileResourceDto file)
    {
        if (file.IsDeleted)
        {
            Snackbar.Add("This file is already soft-deleted.", Severity.Info);
            return;
        }

        _softDeleteTarget = file;
    }

    private void CloseSoftDeleteDialog()
    {
        if (_isSoftDeleting)
        {
            return;
        }

        _softDeleteTarget = null;
    }

    private async Task ConfirmSoftDeleteAsync()
    {
        if (_softDeleteTarget is null)
        {
            return;
        }

        _isSoftDeleting = true;

        try
        {
            var deleted = await FileResourceService.DeleteFileResourceAsync(_softDeleteTarget.FileResourceId);

            Snackbar.Add(
                deleted
                    ? "The file was soft-deleted."
                    : "The file could not be soft-deleted.",
                deleted ? Severity.Success : Severity.Warning);

            _softDeleteTarget = null;

            await LoadFilesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Soft delete failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSoftDeleting = false;
        }
    }

    private void OpenCleanupDialog(FileResourceDto file)
    {
        if (!CanCleanup(file))
        {
            Snackbar.Add("Only soft-deleted files can be cleaned up.", Severity.Warning);
            return;
        }

        _cleanupTarget = file;
    }

    private void CloseCleanupDialog()
    {
        if (_isCleaning)
        {
            return;
        }

        _cleanupTarget = null;
    }

    private async Task ConfirmCleanupAsync()
    {
        if (_cleanupTarget is null)
        {
            return;
        }

        _isCleaning = true;

        try
        {
            var result = await FileResourceService.CleanupStorageAsync(_cleanupTarget.FileResourceId);

            Snackbar.Add(result.Message, result.Succeeded ? Severity.Success : Severity.Error);

            _cleanupTarget = null;

            await LoadFilesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cleanup failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCleaning = false;
        }
    }

    private void OpenCleanupAllDialog()
    {
        _cleanupAllVisibleCandidateCount = _files.Count(CanCleanup);

        if (_cleanupAllVisibleCandidateCount <= 0)
        {
            Snackbar.Add("No soft-deleted file is visible on the current page.", Severity.Info);
            return;
        }

        _isCleanupAllDialogOpen = true;
    }

    private void CloseCleanupAllDialog()
    {
        if (_isCleaningAll)
        {
            return;
        }

        _isCleanupAllDialogOpen = false;
        _cleanupAllVisibleCandidateCount = 0;
    }

    private async Task ConfirmCleanupAllAsync()
    {
        _isCleaningAll = true;

        try
        {
            var results = await FileResourceService.CleanupDeletedStorageBatchAsync(100);

            var successCount = results.Count(r => r.Succeeded);
            var failedCount = results.Count - successCount;

            Snackbar.Add(
                $"Cleanup completed. Success: {successCount}, Failed: {failedCount}.",
                failedCount == 0 ? Severity.Success : Severity.Warning);

            _isCleanupAllDialogOpen = false;
            _cleanupAllVisibleCandidateCount = 0;

            await LoadFilesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Cleanup all failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCleaningAll = false;
        }
    }

    private static bool CanPreview(FileResourceDto file)
    {
        if (file.IsDeleted || string.IsNullOrWhiteSpace(file.CloudinarySecureUrl))
        {
            return false;
        }

        return IsImageContentType(file.ContentType)
            || string.Equals(
                file.ContentType,
                "application/pdf",
                StringComparison.OrdinalIgnoreCase);
    }

    private static bool CanDownload(FileResourceDto file)
    {
        return !file.IsDeleted
            && !string.IsNullOrWhiteSpace(file.CloudinarySecureUrl);
    }

    private static bool CanCleanup(FileResourceDto file)
    {
        return file.IsDeleted;
    }

    private static bool IsImageContentType(string contentType)
    {
        return contentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase)
            || string.Equals(
                contentType,
                "image/svg+xml",
                StringComparison.OrdinalIgnoreCase);
    }

    private static string? NormalizeFilter(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

    private static string FormatNullableDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "-";
    }

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        if (bytes < 1024 * 1024)
        {
            return $"{bytes / 1024d:0.##} KB";
        }

        return $"{bytes / 1024d / 1024d:0.##} MB";
    }
}
