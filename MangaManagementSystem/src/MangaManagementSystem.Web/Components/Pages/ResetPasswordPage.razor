@page "/reset-password"
@using Microsoft.AspNetCore.WebUtilities
@using MangaManagementSystem.Application.DTOs.Auth
@using MangaManagementSystem.Web.Services.Api
@inject IPasswordResetApiClient PasswordResetApiClient
@inject NavigationManager NavigationManager

<PageTitle>Reset Password - MangaFlow</PageTitle>

<HeadContent>
    <meta name="referrer" content="no-referrer" />
</HeadContent>

<div class="mf-gradient-bg d-flex align-center justify-center pa-4">
    <MudContainer MaxWidth="MaxWidth.Small">
        <MudPaper Class="pa-8 mf-card" Elevation="8">
            <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">
                Reset Password
            </MudText>

            @if (_completed)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Your password has been reset. You can now sign in with the new password.
                </MudAlert>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="/login">
                    Go to Login
                </MudButton>
            }
            else if (!_hasValidLink)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    This password reset link is invalid or incomplete. Request a new link and try again.
                </MudAlert>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Href="/forgot-password">
                    Request New Link
                </MudButton>
            }
            else
            {
                <MudText Class="mf-muted mb-6">
                    Choose a new password with at least 8 characters.
                </MudText>

                <MudStack Spacing="3">
                    <MudTextField Label="New Password"
                                  @bind-Value="_newPassword"
                                  Variant="Variant.Outlined"
                                  InputType="@ResetNewPasswordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@ResetNewPasswordIcon"
                                  OnAdornmentClick="ToggleResetNewPasswordVisibility"
                                  Required="true"
                                  Disabled="_busy" />

                    <MudTextField Label="Confirm New Password"
                                  @bind-Value="_confirmPassword"
                                  Variant="Variant.Outlined"
                                  InputType="@ResetConfirmPasswordInputType"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@ResetConfirmPasswordIcon"
                                  OnAdornmentClick="ToggleResetConfirmPasswordVisibility"
                                  Required="true"
                                  Disabled="_busy" />

                    @if (!string.IsNullOrWhiteSpace(_message))
                    {
                        <MudAlert Severity="Severity.Error">
                            @_message
                        </MudAlert>
                    }

                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               Disabled="_busy"
                               OnClick="ResetAsync">
                        @if (_busy)
                        {
                            <MudProgressCircular Size="Size.Small"
                                                 Indeterminate="true"
                                                 Class="mr-2" />
                        }
                        Reset Password
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </MudContainer>
</div>

@code {
    private string _token = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private bool _showResetNewPassword;
    private bool _showResetConfirmPassword;

    private InputType ResetNewPasswordInputType =>
        _showResetNewPassword
            ? InputType.Text
            : InputType.Password;

    private InputType ResetConfirmPasswordInputType =>
        _showResetConfirmPassword
            ? InputType.Text
            : InputType.Password;

    private string ResetNewPasswordIcon =>
        _showResetNewPassword
            ? Icons.Material.Filled.VisibilityOff
            : Icons.Material.Filled.Visibility;

    private string ResetConfirmPasswordIcon =>
        _showResetConfirmPassword
            ? Icons.Material.Filled.VisibilityOff
            : Icons.Material.Filled.Visibility;

    private void ToggleResetNewPasswordVisibility()
    {
        _showResetNewPassword =
            !_showResetNewPassword;
    }

    private void ToggleResetConfirmPasswordVisibility()
    {
        _showResetConfirmPassword =
            !_showResetConfirmPassword;
    }
    private string? _message;
    private bool _hasValidLink;
    private bool _busy;
    private bool _completed;

    protected override void OnInitialized()
    {
        var uri =
            NavigationManager.ToAbsoluteUri(
                NavigationManager.Uri);

        var query =
            QueryHelpers.ParseQuery(
                uri.Query);

        if (query.TryGetValue(
                "token",
                out var token)
            && !string.IsNullOrWhiteSpace(token))
        {
            _token = token.ToString().Trim();
            _hasValidLink =
                _token.Length is >= 32 and <= 200;
        }
    }

    private async Task ResetAsync()
    {
        if (_busy)
        {
            return;
        }

        _message = null;

        if (_newPassword.Length < 8
            || _newPassword.Length > 255)
        {
            _message =
                "New password must contain between 8 and 255 characters.";

            return;
        }

        if (!string.Equals(
                _newPassword,
                _confirmPassword,
                StringComparison.Ordinal))
        {
            _message =
                "The password confirmation does not match.";

            return;
        }

        _busy = true;

        try
        {
            await PasswordResetApiClient
                .ResetPasswordAsync(
                    _token,
                    _newPassword);

            _completed = true;
            _token = string.Empty;
            _showResetNewPassword = false;
            _showResetConfirmPassword = false;
        }
        catch (ApiClientException ex)
            when (ex.Code ==
                AuthErrorCodes.InvalidPasswordResetToken)
        {
            _message =
                "This password reset link is invalid, expired, or has already been used.";
        }
        catch
        {
            _message =
                "The password could not be reset. Request a new link and try again.";
        }
        finally
        {
            _busy = false;
        }
    }
}
