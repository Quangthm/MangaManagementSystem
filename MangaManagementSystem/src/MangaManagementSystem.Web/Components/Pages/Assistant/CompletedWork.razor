@page "/assistant/completed-work"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IAssistantTaskApiClient AssistantTaskClient

<AssistantLayout>
    <div style="display: flex; flex-direction: column; height: 100%; background: #f8fafc;">
        @* ── Header ── *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; flex-shrink: 0;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    Completed Work
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">Track approved assistant tasks and estimated work summary.</div>
                <div style="color: #94a3b8; font-size: 0.75rem; margin-top: 2px;">Estimated from approved completed tasks only. MangaFlow does not process real payments.</div>
            </div>
        </div>

        @* ── Scrollable Content ── *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem;">Failed to load completed work: @_error</div>
            }
            else if (_summary == null)
            {
                <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 12px 16px; color: #1e40af; font-size: 0.85rem;">No completed work data available.</div>
            }
            else
            {
                @* ── Stat Cards ── *@
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
                    <StatCard Label="Completed Tasks" Value="@_summary.CompletedTaskCount.ToString()" Description="Approved tasks" />
                    <StatCard Label="Approved Regions" Value="@_summary.ApprovedRegionCount.ToString()" Description="Regions completed" />
                    <StatCard Label="Estimated Total" Value="@_summary.TotalEstimatedAmount.ToString("N0")" Description="All completed work" />
                    <StatCard Label="This Month" Value="@_summary.ThisMonthEstimatedAmount.ToString("N0")" Description="Current month" />
                </div>

                @* ── Breakdown by Task Type ── *@
                <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); margin-bottom: 24px; overflow: hidden;">
                    <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9;">
                        <div style="font-weight: 700; font-size: 1rem; color: #111827;">Breakdown by Task Type</div>
                    </div>
                    @if (_summary.Breakdown.Count == 0)
                    {
                        <div style="padding: 24px; color: #94a3b8; font-size: 0.85rem;">No breakdown data available.</div>
                    }
                    else
                    {
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                <thead>
                                    <tr style="border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
                                        <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Task Type</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Completed Tasks</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Regions</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Estimated Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _summary.Breakdown)
                                    {
                                        <tr style="border-bottom: 1px solid #f1f5f9;">
                                            <td style="padding: 12px 16px;">
                                                <span style="background: #eef2ff; color: #4f46e5; font-size: 0.72rem; padding: 2px 8px; border-radius: 8px; font-weight: 500;">@item.TaskType</span>
                                            </td>
                                            <td style="padding: 12px 16px; text-align: right; color: #374151;">@item.CompletedTaskCount</td>
                                            <td style="padding: 12px 16px; text-align: right; color: #374151;">@item.RegionCount</td>
                                            <td style="padding: 12px 16px; text-align: right; font-weight: 700; color: #111827;">@item.EstimatedAmount.ToString("N0")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                @* ── Recent Completed Tasks ── *@
                <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); overflow: hidden;">
                    <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9;">
                        <div style="font-weight: 700; font-size: 1rem; color: #111827;">Recent Completed Tasks</div>
                    </div>
                    @if (_summary.RecentItems.Count == 0)
                    {
                        <div style="padding: 24px; color: #94a3b8; font-size: 0.85rem;">No recently completed tasks.</div>
                    }
                    else
                    {
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                <thead>
                                    <tr style="border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
                                        <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Task</th>
                                        <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Series</th>
                                        <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Chapter / Page</th>
                                        <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Completed</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Regions</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Estimated Amount</th>
                                        <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in _summary.RecentItems)
                                    {
                                        <tr style="border-bottom: 1px solid #f1f5f9;">
                                            <td style="padding: 12px 16px;">
                                                <span style="background: #f0fdf4; color: #166534; font-size: 0.72rem; padding: 2px 8px; border-radius: 8px; font-weight: 500;">@item.TaskType</span>
                                            </td>
                                            <td style="padding: 12px 16px; color: #374151;">@item.SeriesTitle</td>
                                            <td style="padding: 12px 16px; color: #64748b;">
                                                @item.ChapterTitle
                                                @if (item.PageNumber > 0)
                                                {
                                                    <span> &bull; P.@item.PageNumber</span>
                                                }
                                            </td>
                                            <td style="padding: 12px 16px; color: #64748b;">@(item.CompletedAt?.ToLocalTime().ToString("MMM dd, yyyy") ?? "-")</td>
                                            <td style="padding: 12px 16px; text-align: right; color: #374151;">@item.RegionCount</td>
                                            <td style="padding: 12px 16px; text-align: right; font-weight: 700; color: #111827;">@item.EstimatedAmount.ToString("N0")</td>
                                            <td style="padding: 12px 16px; text-align: right;">
                                                <a href="@($"/assistant/task/{item.TaskId}")" style="color: #4f46e5; font-size: 0.78rem; text-decoration: none; font-weight: 500;">View</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</AssistantLayout>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _error;
    private AssistantCompletedWorkSummaryDto? _summary;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadCompletedWorkAsync();
    }

    private async Task LoadCompletedWorkAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _summary = await AssistantTaskClient.GetCompletedWorkAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
