@page "/assistant/studio/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Studio Workspace</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Work on assigned page regions and submit task output</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">Failed to load task: @_error</MudAlert>
        }
        else if (_task is null)
        {
            <MudAlert Severity="Severity.Warning">Task not found or not assigned to you.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <div>
                                <MudText Typo="Typo.h6">Page Review Canvas</MudText>
                                <MudText Class="mf-muted">@_task.TypeCode — Task @_task.ChapterPageTaskId</MudText>
                            </div>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <StatusBadge Status="@_task.StatusCode" />
                                <MudChip T="string" Color="Color.Info" Size="Size.Small">@Zoom%</MudChip>
                            </MudStack>
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                        {
                            <div class="mf-canvas" style="min-height:400px">
                                <MudImage Src="@_task.PageImageUrl" Class="mf-page-image" MaxHeight="400" Aspect="Aspect.Fill" />
                            </div>
                        }
                        else
                        {
                            <div class="mf-canvas" style="min-height:400px">
                                <MudStack AlignItems="AlignItems.Center" Spacing="2">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Color="Color.Secondary" />
                                    <MudText Typo="Typo.h6" Class="mf-muted">Page Image</MudText>
                                    <MudText Class="mf-muted">Page image data not available.</MudText>
                                </MudStack>
                            </div>
                        }

                        <MudStack Row="true" Class="mt-4" Spacing="2">
                            <MudButton Variant="Variant.Outlined" OnClick="@(() => Zoom = Math.Max(50, Zoom - 10))">- Zoom</MudButton>
                            <MudButton Variant="Variant.Outlined" OnClick="@(() => Zoom = Math.Min(200, Zoom + 10))">+ Zoom</MudButton>
                        </MudStack>
                    </MudPaper>

                    @if (_task.PageRegions.Any())
                    {
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Assigned Page Regions</MudText>
                            <MudTable Items="@_task.PageRegions" Hover="true" RowsPerPage="5" Elevation="0">
                                <Columns>
                                    <MudColumn><MudText>Label</MudText></MudColumn>
                                    <MudColumn><MudText>Type</MudText></MudColumn>
                                    <MudColumn><MudText>X</MudText></MudColumn>
                                    <MudColumn><MudText>Y</MudText></MudColumn>
                                    <MudColumn><MudText>Width</MudText></MudColumn>
                                    <MudColumn><MudText>Height</MudText></MudColumn>
                                </Columns>
                                <RowTemplate>
                                    <MudTd>@context.RegionLabel</MudTd>
                                    <MudTd>@context.TypeCode</MudTd>
                                    <MudTd>@context.X</MudTd>
                                    <MudTd>@context.Y</MudTd>
                                    <MudTd>@context.Width</MudTd>
                                    <MudTd>@context.Height</MudTd>
                                </RowTemplate>
                            </MudTable>
                            <MudText Typo="Typo.caption" Class="mf-muted mt-2">
                                Highlighted regions show the page areas you need to work on.
                            </MudText>
                        </MudPaper>
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Current Task</MudText>
                        <MudStack Spacing="1">
                            <MudText><strong>Type:</strong> @_task.TypeCode</MudText>
                            <MudText><strong>Priority:</strong> @_task.PriorityLevel</MudText>
                            <MudText><strong>Due:</strong> <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" /></MudText>
                            @if (_task.CompensationAmount.HasValue)
                            {
                                <MudText><strong>Compensation:</strong> @_task.CompensationAmount.Value.ToString("C2")</MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(_task.AssignedToDisplayName))
                            {
                                <MudText><strong>Assigned To:</strong> @_task.AssignedToDisplayName</MudText>
                            }
                            @if (_task.CompletedPageVersionId.HasValue)
                            {
                                <MudText><strong>Completed Version:</strong> @_task.CompletedPageVersionId</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Actions</MudText>
                        <MudText Class="mf-muted mb-3">Once your work is complete, submit it for editor review.</MudText>
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/assistant/task/{_task.ChapterPageTaskId}/submit")">Submit Work</MudButton>
                            <MudButton Variant="Variant.Outlined" Href="@($"/assistant/task/{_task.ChapterPageTaskId}")">Back to Task Detail</MudButton>
                            <MudButton Variant="Variant.Text" Href="/assistant/tasks">All Tasks</MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private bool _loading = true;
    private string? _error;
    private ChapterPageTaskDto? _task;
    private int Zoom { get; set; } = 100;

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(TaskId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
