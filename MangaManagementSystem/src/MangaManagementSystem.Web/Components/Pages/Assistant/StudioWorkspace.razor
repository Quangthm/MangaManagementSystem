@page "/assistant/studio/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav

@code {
    [Parameter] public Guid TaskId { get; set; }
    [SupplyParameterFromQuery] public string? returnUrl { get; set; }

    protected override void OnInitialized()
    {
        var redirect = $"/workspace/tasks/{TaskId}";
        if (!string.IsNullOrWhiteSpace(returnUrl))
        {
            redirect += $"?returnUrl={Uri.EscapeDataString(returnUrl)}";
        }
        else
        {
            redirect += "?returnUrl=/assistant/tasks";
        }
        Nav.NavigateTo(redirect, replace: true);
    }
}
