@page "/assistant/task/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient
@inject AuthenticationStateProvider AuthStateProvider

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Task Detail</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review assignment details and reference material</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">Failed to load task: @_error</MudAlert>
        }
        else if (_task is null)
        {
            <MudAlert Severity="Severity.Warning">Task not found or not assigned to you.</MudAlert>
        }
        else
        {
            @* Status Banner *@
            <MudAlert Severity="GetStatusSeverity()" Class="mb-6">
                <MudStack Row="true" AlignItems="AlignItems.Center">
                    <MudIcon Icon="@GetStatusIcon()" Size="Size.Small" />
                    <MudText Typo="Typo.body2">@GetStatusMessage()</MudText>
                </MudStack>
            </MudAlert>

            <MudGrid>
                <MudItem xs="12" md="8">
                    @* Header Card *@
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                            <div>
                                <MudText Typo="Typo.h4" Class="font-weight-bold">@_task.TypeCode Task</MudText>
                                @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle) || !string.IsNullOrWhiteSpace(_task.ChapterNumberLabel) || _task.PageNo.HasValue)
                                {
                                    <MudText Typo="Typo.body1" Class="mt-1">
                                        @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle))
                                        {
                                            <span>@_task.SeriesTitle</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(_task.ChapterNumberLabel))
                                        {
                                            <span class="mf-muted"> › @_task.ChapterNumberLabel</span>
                                        }
                                        @if (_task.PageNo.HasValue)
                                        {
                                            <span class="mf-muted"> › Page @_task.PageNo.Value</span>
                                        }
                                    </MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(_task.TaskTitle))
                                {
                                    <MudText Typo="Typo.body2" Class="mf-muted mt-1">@_task.TaskTitle</MudText>
                                }
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-2">
                                    <MudText Typo="Typo.caption" Class="mf-muted">
                                        Assigned: <TimestampDisplay Value="@_task.CreatedAtUtc" EmptyText="-" ShowTime="false" />
                                    </MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Class="mf-muted" Style="font-size: 6px;" />
                                    <MudText Typo="Typo.caption" Class="mf-muted">
                                        Due: <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline" ShowTime="false" />
                                    </MudText>
                                    <MudIcon Icon="@Icons.Material.Filled.FiberManualRecord" Size="Size.Small" Class="mf-muted" Style="font-size: 6px;" />
                                    <MudText Typo="Typo.caption" Class="mf-muted">Priority @_task.PriorityLevel</MudText>
                                </MudStack>
                            </div>
                            <StatusBadge Status="@_task.StatusCode" Size="Size.Medium" />
                        </MudStack>
                    </MudPaper>

                    @* Description *@
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Description</MudText>
                        @if (!string.IsNullOrWhiteSpace(_task.TaskDescription))
                        {
                            <MudText Class="mf-muted" Style="white-space: pre-line;">@_task.TaskDescription</MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mf-muted">No description available.</MudText>
                        }
                    </MudPaper>

                    @* Assigned Page Regions *@
                    @if (_task.PageRegions.Any())
                    {
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Assigned Page Regions</MudText>
                            <MudTable Items="@_task.PageRegions" Hover="true" RowsPerPage="10" Elevation="0" Dense="true">
                                <HeaderContent>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Label</MudTh>
                                    <MudTh>X</MudTh>
                                    <MudTh>Y</MudTh>
                                    <MudTh>W</MudTh>
                                    <MudTh>H</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@context.TypeCode</MudChip></MudTd>
                                    <MudTd>@context.RegionLabel</MudTd>
                                    <MudTd>@context.X</MudTd>
                                    <MudTd>@context.Y</MudTd>
                                    <MudTd>@context.Width</MudTd>
                                    <MudTd>@context.Height</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    }

                    @* Annotations *@
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Annotations</MudText>
                        @if (_annotations == null)
                        {
                            <MudText Typo="Typo.body2" Class="mf-muted">Loading annotations...</MudText>
                        }
                        else if (!_annotations.Any())
                        {
                            <MudText Typo="Typo.body2" Class="mf-muted">No annotations for the assigned regions.</MudText>
                        }
                        else
                        {
                            <MudTable Items="@_annotations" Hover="true" RowsPerPage="10" Elevation="0" Dense="true">
                                <HeaderContent>
                                    <MudTh>Issue Type</MudTh>
                                    <MudTh>Annotation</MudTh>
                                    <MudTh>By</MudTh>
                                    <MudTh>Created</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh>Regions</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">@context.IssueTypeCode</MudChip></MudTd>
                                    <MudTd Style="max-width:300px;overflow:hidden;text-overflow:ellipsis;">@context.AnnotationText</MudTd>
                                    <MudTd>@(context.AnnotatedByDisplayName ?? "\u2014")</MudTd>
                                    <MudTd><TimestampDisplay Value="@context.CreatedAtUtc" EmptyText="\u2014" /></MudTd>
                                    <MudTd>
                                        @if (context.ResolvedAtUtc.HasValue)
                                        {
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Resolved</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Open</MudChip>
                                        }
                                    </MudTd>
                                    <MudTd>@context.PageRegions.Count</MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <div style="position: sticky; top: 24px;">
                        @* Actions Card *@
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Actions</MudText>
                            <MudStack Spacing="2">
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Href="@($"/assistant/studio/{_task.ChapterPageTaskId}")">
                                    Open Studio Workspace
                                </MudButton>
                                @if (_task.StatusCode == "ASSIGNED")
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Href="@($"/assistant/task/{_task.ChapterPageTaskId}/submit")">
                                        Submit Work
                                    </MudButton>
                                }
                                else if (_task.StatusCode == "UNDER_REVIEW")
                                {
                                    <div class="text-center">
                                        <MudChip T="string" Color="Color.Warning" Size="Size.Medium" Variant="Variant.Outlined">
                                            Submitted for Review
                                        </MudChip>
                                    </div>
                                }
                                else if (_task.StatusCode == "COMPLETED")
                                {
                                    <div class="text-center">
                                        <MudChip T="string" Color="Color.Success" Size="Size.Medium">
                                            Approved ✓
                                        </MudChip>
                                    </div>
                                }
                                else if (_task.StatusCode == "CANCELLED")
                                {
                                    <div class="text-center">
                                        <MudChip T="string" Color="Color.Error" Size="Size.Medium" Variant="Variant.Outlined">
                                            Task Cancelled
                                        </MudChip>
                                    </div>
                                }
                                <MudButton Variant="Variant.Text" FullWidth="true" Href="/assistant/tasks">Back to Tasks</MudButton>
                            </MudStack>
                        </MudPaper>

                        @* Metadata Card *@
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Metadata</MudText>
                            <MudStack Spacing="1">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Type</MudText>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">@_task.TypeCode</MudChip>
                                </MudStack>
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Status</MudText>
                                    <StatusBadge Status="@_task.StatusCode" />
                                </MudStack>
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Assigned</MudText>
                                    <TimestampDisplay Value="@_task.CreatedAtUtc" EmptyText="-" ShowTime="false" />
                                </MudStack>
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Priority</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@_task.PriorityLevel</MudText>
                                </MudStack>
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Due</MudText>
                                    <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline" ShowTime="false" />
                                </MudStack>
                                <MudDivider Class="my-1" />
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body2" Class="mf-muted">Regions</MudText>
                                    <MudText Typo="Typo.body2" Class="font-weight-bold">@_task.PageRegions.Count</MudText>
                                </MudStack>
                            </MudStack>
                        </MudPaper>

                        @* Source Page Card *@
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Source Page</MudText>
                            @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                            {
                                <MudImage Src="@_task.PageImageUrl" MaxHeight="150" ObjectFit="ObjectFit.Contain" Class="rounded w-100" />
                                <div class="mt-2 text-center">
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Href="@_task.PageImageUrl" Target="_blank">Download Source</MudButton>
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mf-muted pa-4 text-center">Source image not available.</MudText>
                            }
                        </MudPaper>

                        @* Submitted Output Card *@
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Submitted Output</MudText>
                            @if (!string.IsNullOrWhiteSpace(_task.CompletedOutputUrl))
                            {
                                <div class="text-center pa-4">
                                    <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Large" Class="mf-muted mb-2" />
                                    <MudText Typo="Typo.body2" Class="mf-muted">Submitted output is available</MudText>
                                    @if (_task.CompletedPageVersionId.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Class="mf-muted">Version: @_task.CompletedPageVersionId.Value.ToString("N")[..8]</MudText>
                                    }
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Class="mt-3"
                                               OnClick="() => _showOutputPreview = true">
                                        View Submitted Output
                                    </MudButton>
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mf-muted pa-4 text-center">No submitted output yet.</MudText>
                            }
                        </MudPaper>

                        @* Submitted Output Preview Overlay *@
                        <MudOverlay Visible="_showOutputPreview" AutoClose="false">
                            <div style="display: flex; align-items: center; justify-content: center; height: 100%; padding: 24px;">
                                <MudPaper Elevation="0" Class="mf-card"
                                          Style="max-width: 800px; width: 100%; max-height: 85vh; overflow: hidden; display: flex; flex-direction: column;">
                                    <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; border-bottom: 1px solid var(--mf-slate-200);">
                                        <MudText Typo="Typo.h6" Class="font-weight-bold">Submitted Output Preview</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseOutputPreview" Size="Size.Small" />
                                    </div>
                                    <div style="flex: 1; overflow: auto; padding: 24px; text-align: center;">
                                        @if (!string.IsNullOrWhiteSpace(_task?.CompletedOutputUrl))
                                        {
                                            <img src="@_task.CompletedOutputUrl"
                                                 style="max-width: 100%; max-height: 72vh; object-fit: contain; border-radius: 8px;" />
                                        }
                                    </div>
                                    <div style="padding: 12px 24px; border-top: 1px solid var(--mf-slate-200); text-align: right;">
                                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CloseOutputPreview">Close</MudButton>
                                    </div>
                                </MudPaper>
                            </div>
                        </MudOverlay>
                    </div>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private Guid _currentUserId;
    private bool _loading = true;
    private bool _showOutputPreview;
    private string? _error;
    private ChapterPageTaskDto? _task;
    private IReadOnlyList<ChapterPageAnnotationDto>? _annotations;

    private Severity GetStatusSeverity()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => Severity.Info,
            "UNDER_REVIEW" => Severity.Warning,
            "COMPLETED" => Severity.Success,
            "CANCELLED" => Severity.Error,
            _ => Severity.Normal
        };
    }

    private string GetStatusIcon()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => Icons.Material.Filled.Assignment,
            "UNDER_REVIEW" => Icons.Material.Filled.RateReview,
            "COMPLETED" => Icons.Material.Filled.CheckCircle,
            "CANCELLED" => Icons.Material.Filled.Cancel,
            _ => Icons.Material.Filled.Info
        };
    }

    private string GetStatusMessage()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => "This task is assigned to you and ready to work on.",
            "UNDER_REVIEW" => "Your work has been submitted. Waiting for Mangaka review.",
            "COMPLETED" => "This task has been approved and completed.",
            "CANCELLED" => "This task has been cancelled.",
            _ => ""
        };
    }

    private void CloseOutputPreview()
    {
        _showOutputPreview = false;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(_currentUserId, TaskId);

            if (_task != null)
            {
                _annotations = await AssistantTaskClient.GetTaskAnnotationsAsync(_currentUserId, TaskId);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
