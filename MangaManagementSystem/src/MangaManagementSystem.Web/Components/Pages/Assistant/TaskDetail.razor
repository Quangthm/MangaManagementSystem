@page "/assistant/task/{TaskId:guid}"
@layout AssistantLayout

<style>
    @@media (max-width: 1024px) { .as-grid-main { grid-template-columns: 1fr !important; } }
</style>

@using System.Security.Claims
@using MangaManagementSystem.Web.Services.Api
@using System.Threading
@attribute [Authorize(Roles = "Assistant")]
@implements IDisposable
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient
@inject AuthenticationStateProvider AuthStateProvider

    <div style="display: flex; flex-direction: column; height: 100%; background: #f8fafc;">
        @* ── Header ── *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; flex-shrink: 0;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    Task Detail
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">Review assignment details and reference material</div>
            </div>
        </div>

        @* ── Scrollable Content ── *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem;">Failed to load task: @_error</div>
            }
            else if (_task is null)
            {
                <div style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 12px 16px; color: #92400e; font-size: 0.85rem;">Task not found or not assigned to you.</div>
            }
            else
            {
                @* Status Banner *@
                <div style="padding: 12px 16px; border-radius: 8px; margin-bottom: 24px; display: flex; align-items: center; gap: 8px; font-size: 0.85rem; background: @GetStatusBg(); border: 1px solid @GetStatusBorder(); color: @GetStatusTextColor();">
                    <span style="font-size: 1.1rem;">@GetStatusIcon()</span>
                    <span>@GetStatusMessage()</span>
                </div>

                <div class="as-grid-main" style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        @* Header Card *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 24px;">
                            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                                <div>
                                    <div style="font-weight: 800; font-size: 1.3rem; color: #111827; letter-spacing: -0.02em;">@_task.TypeCode Task</div>
                                    @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle) || !string.IsNullOrWhiteSpace(_task.ChapterNumberLabel) || _task.PageNo.HasValue)
                                    {
                                        <div style="font-size: 0.9rem; color: #64748b; margin-top: 4px;">
                                            @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle))
                                            {
                                                <span>@_task.SeriesTitle</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(_task.ChapterNumberLabel))
                                            {
                                                <span style="color: #94a3b8;"> › @_task.ChapterNumberLabel</span>
                                            }
                                            @if (_task.PageNo.HasValue)
                                            {
                                                <span style="color: #94a3b8;"> › Page @_task.PageNo.Value</span>
                                            }
                                        </div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_task.TaskTitle))
                                    {
                                        <div style="color: #94a3b8; font-size: 0.85rem; margin-top: 4px;">@_task.TaskTitle</div>
                                    }
                                    <div style="display: flex; align-items: center; gap: 8px; margin-top: 12px; font-size: 0.78rem;">
                                        <span style="color: #94a3b8;">
                                            Assigned: <TimestampDisplay Value="@_task.CreatedAtUtc" EmptyText="-" ShowTime="false" />
                                        </span>
                                        <span style="color: #cbd5e1;">&bull;</span>
                                        <span style="color: #94a3b8;">
                                            Due: <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline" ShowTime="false" />
                                        </span>
                                        <span style="color: #cbd5e1;">&bull;</span>
                                        <span style="color: #94a3b8;">Priority @_task.PriorityLevel</span>
                                    </div>
                                </div>
                                <StatusBadge Status="@_task.StatusCode" Size="Size.Medium" />
                            </div>
                        </div>

                    @* Description *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                            <div style="font-weight: 700; font-size: 1rem; color: #111827; margin-bottom: 8px;">Description</div>
                            @if (!string.IsNullOrWhiteSpace(_task.TaskDescription))
                            {
                                <div style="color: #64748b; font-size: 0.85rem; white-space: pre-line;">@_task.TaskDescription</div>
                            }
                            else
                            {
                                <div style="color: #94a3b8; font-size: 0.85rem;">No description available.</div>
                            }
                        </div>

                        @* Assigned Page Regions *@
                        @if (_task.PageRegions.Any())
                        {
                            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); overflow: hidden;">
                                <div style="padding: 16px 24px; border-bottom: 1px solid #f1f5f9;">
                                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">Assigned Page Regions</div>
                                </div>
                                <div style="overflow-x: auto;">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                        <thead>
                                            <tr style="border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Type</th>
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Label</th>
                                                <th style="padding: 10px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">X</th>
                                                <th style="padding: 10px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Y</th>
                                                <th style="padding: 10px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">W</th>
                                                <th style="padding: 10px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">H</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var region in _task.PageRegions)
                                            {
                                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                                    <td style="padding: 10px 16px;">
                                                        <span style="background: #eef2ff; color: #4f46e5; font-size: 0.72rem; padding: 2px 8px; border-radius: 6px; font-weight: 500;">@region.TypeCode</span>
                                                    </td>
                                                    <td style="padding: 10px 16px; color: #374151;">@region.RegionLabel</td>
                                                    <td style="padding: 10px 16px; text-align: right; color: #64748b;">@region.X</td>
                                                    <td style="padding: 10px 16px; text-align: right; color: #64748b;">@region.Y</td>
                                                    <td style="padding: 10px 16px; text-align: right; color: #64748b;">@region.Width</td>
                                                    <td style="padding: 10px 16px; text-align: right; color: #64748b;">@region.Height</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        }

                        @* Review Activity *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); overflow: hidden;">
                            <div style="padding: 16px 24px; border-bottom: 1px solid #f1f5f9;">
                                <div style="font-weight: 700; font-size: 1rem; color: #111827;">Review Activity</div>
                            </div>
                            <div style="padding: 20px 24px;">
                                @* Timeline items *@
                                <div style="display: flex; flex-direction: column; gap: 16px;">
                                    @* Task created *@
                                    <div style="display: flex; gap: 12px;">
                                        <div style="display: flex; flex-direction: column; align-items: center;">
                                            <div style="width: 10px; height: 10px; border-radius: 50%; background: #4f46e5; flex-shrink: 0;"></div>
                                            <div style="width: 2px; flex: 1; background: #e2e8f0; min-height: 24px;"></div>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; font-size: 0.85rem; color: #111827;">Task Assigned</div>
                                            <div style="color: #94a3b8; font-size: 0.78rem;"><TimestampDisplay Value="@_task.CreatedAtUtc" EmptyText="-" ShowTime="true" /></div>
                                        </div>
                                    </div>

                                    @* Submitted *@
                                    <div style="display: flex; gap: 12px;">
                                        <div style="display: flex; flex-direction: column; align-items: center;">
                                            <div style="width: 10px; height: 10px; border-radius: 50%; background: @(_task.StatusCode == "UNDER_REVIEW" || _task.StatusCode == "COMPLETED" ? "#d97706" : "#e2e8f0"); flex-shrink: 0;"></div>
                                            <div style="width: 2px; flex: 1; background: @(_task.StatusCode == "COMPLETED" ? "#e2e8f0" : "#e2e8f0"); min-height: 24px;"></div>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; font-size: 0.85rem; color: @(_task.StatusCode == "UNDER_REVIEW" || _task.StatusCode == "COMPLETED" ? "#111827" : "#94a3b8");">Work Submitted</div>
                                            @if (!string.IsNullOrWhiteSpace(_task.CompletedOutputUrl))
                                            {
                                                <div style="color: #94a3b8; font-size: 0.78rem;">Awaiting Mangaka review</div>
                                            }
                                            else
                                            {
                                                <div style="color: #94a3b8; font-size: 0.78rem;">Not yet submitted</div>
                                            }
                                        </div>
                                    </div>

                                    @* Approved *@
                                    <div style="display: flex; gap: 12px;">
                                        <div style="display: flex; flex-direction: column; align-items: center;">
                                            <div style="width: 10px; height: 10px; border-radius: 50%; background: @(_task.StatusCode == "COMPLETED" ? "#166534" : "#e2e8f0"); flex-shrink: 0;"></div>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; font-size: 0.85rem; color: @(_task.StatusCode == "COMPLETED" ? "#111827" : "#94a3b8");">Approved</div>
                                            @if (_task.StatusCode == "COMPLETED")
                                            {
                                                <div style="color: #94a3b8; font-size: 0.78rem;">Task completed and approved</div>
                                            }
                                            else if (_task.StatusCode == "UNDER_REVIEW")
                                            {
                                                <div style="color: #94a3b8; font-size: 0.78rem;">Waiting for Mangaka approval</div>
                                            }
                                            else
                                            {
                                                <div style="color: #94a3b8; font-size: 0.78rem;">Pending submission</div>
                                            }
                                        </div>
                                    </div>
                                </div>

                                @if (_task.StatusCode == "ASSIGNED")
                                {
                                    <div style="margin-top: 16px; padding: 12px; background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; font-size: 0.82rem; color: #1e40af;">
                                        <strong>Next step:</strong> Open the workspace to start working on this task, then submit your work for review.
                                    </div>
                                }
                                else if (_task.StatusCode == "UNDER_REVIEW")
                                {
                                    <div style="margin-top: 16px; padding: 12px; background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; font-size: 0.82rem; color: #92400e;">
                                        <strong>Currently under review:</strong> A Mangaka is reviewing your submission. You will be notified when it's approved or if changes are requested.
                                    </div>
                                }
                                else if (_task.StatusCode == "COMPLETED")
                                {
                                    <div style="margin-top: 16px; padding: 12px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px; font-size: 0.82rem; color: #166534;">
                                        ✓ This task has been approved. Good work!
                                    </div>
                                }
                            </div>
                        </div>

                        @* Annotations (Feedback from reviewers) *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); overflow: hidden;">
                            <div style="padding: 16px 24px; border-bottom: 1px solid #f1f5f9;">
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <span style="font-weight: 700; font-size: 1rem; color: #111827;">Feedback & Annotations</span>
                                    @if (_annotations?.Count > 0)
                                    {
                                        <span style="background: #fef3c7; color: #92400e; font-size: 0.68rem; padding: 1px 8px; border-radius: 8px; font-weight: 600;">@_annotations.Count</span>
                                    }
                                </div>
                            </div>
                            @if (_annotations == null)
                            {
                                <div style="padding: 24px; color: #94a3b8; font-size: 0.85rem;">Loading annotations...</div>
                            }
                            else if (!_annotations.Any())
                            {
                                <div style="padding: 24px; color: #94a3b8; font-size: 0.85rem;">No annotations for the assigned regions.</div>
                            }
                            else
                            {
                                <div style="overflow-x: auto;">
                                    <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                        <thead>
                                            <tr style="border-bottom: 1px solid #f1f5f9; background: #f8fafc;">
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Issue Type</th>
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Annotation</th>
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">By</th>
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Created</th>
                                                <th style="padding: 10px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Status</th>
                                                <th style="padding: 10px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Regions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ann in _annotations)
                                            {
                                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                                    <td style="padding: 10px 16px;">
                                                        <span style="background: #fef3c7; color: #92400e; font-size: 0.72rem; padding: 2px 8px; border-radius: 6px; font-weight: 500;">@ann.IssueTypeCode</span>
                                                    </td>
                                                    <td style="padding: 10px 16px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; color: #374151;">@ann.AnnotationText</td>
                                                    <td style="padding: 10px 16px; color: #64748b;">@(ann.AnnotatedByDisplayName ?? "—")</td>
                                                    <td style="padding: 10px 16px; color: #64748b;"><TimestampDisplay Value="@ann.CreatedAtUtc" EmptyText="—" /></td>
                                                    <td style="padding: 10px 16px;">
                                                        @if (ann.ResolvedAtUtc.HasValue)
                                                        {
                                                            <span style="background: #f0fdf4; color: #166534; font-size: 0.68rem; padding: 2px 8px; border-radius: 6px; font-weight: 500;">Resolved</span>
                                                        }
                                                        else
                                                        {
                                                            <span style="background: #fef3c7; color: #92400e; font-size: 0.68rem; padding: 2px 8px; border-radius: 6px; font-weight: 500;">Open</span>
                                                        }
                                                    </td>
                                                    <td style="padding: 10px 16px; text-align: right; color: #64748b;">@ann.PageRegions.Count</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

                    @* ── Right Sidebar ── *@
                    <div>
                        <div style="position: sticky; top: 24px; display: flex; flex-direction: column; gap: 16px;">
                            @* Actions Card *@
                            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                                <div style="font-weight: 700; font-size: 0.9rem; color: #111827; margin-bottom: 12px;">Actions</div>
                                <div style="display: flex; flex-direction: column; gap: 8px;">
                                    <a href="@($"/workspace/tasks/{_task.ChapterPageTaskId}?returnUrl=/assistant/task/{_task.ChapterPageTaskId}")" style="background: #4f46e5; color: #fff; padding: 10px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 500; text-align: center;">Open Workspace</a>
                                    @if (_task.StatusCode == "ASSIGNED")
                                    {
                                        <a href="@($"/assistant/task/{_task.ChapterPageTaskId}/submit")" style="border: 1px solid #e2e8f0; color: #374151; padding: 10px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 500; text-align: center;">Submit Work</a>
                                    }
                                    else if (_task.StatusCode == "UNDER_REVIEW")
                                    {
                                        <div style="text-align: center;">
                                            <span style="background: #fef3c7; color: #92400e; font-size: 0.78rem; padding: 6px 12px; border-radius: 8px; font-weight: 500; display: inline-block;">Submitted for Review</span>
                                        </div>
                                    }
                                    else if (_task.StatusCode == "COMPLETED")
                                    {
                                        <div style="text-align: center;">
                                            <span style="background: #f0fdf4; color: #166534; font-size: 0.78rem; padding: 6px 12px; border-radius: 8px; font-weight: 500; display: inline-block;">Approved ✓</span>
                                        </div>
                                    }
                                    else if (_task.StatusCode == "CANCELLED")
                                    {
                                        <div style="text-align: center;">
                                            <span style="background: #fef2f2; color: #dc2626; font-size: 0.78rem; padding: 6px 12px; border-radius: 8px; font-weight: 500; display: inline-block;">Task Cancelled</span>
                                        </div>
                                    }
                                    <a href="/assistant/tasks" style="color: #4f46e5; font-size: 0.85rem; text-decoration: none; font-weight: 500; text-align: center; padding: 6px;">Back to Tasks</a>
                                </div>
                            </div>

                            @* Metadata Card *@
                            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                                <div style="font-weight: 700; font-size: 0.9rem; color: #111827; margin-bottom: 12px;">Metadata</div>
                                <div style="display: flex; flex-direction: column;">
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Type</span>
                                        <span style="background: #eef2ff; color: #4f46e5; font-size: 0.72rem; padding: 2px 8px; border-radius: 6px; font-weight: 500;">@_task.TypeCode</span>
                                    </div>
                                    <div style="height: 1px; background: #f1f5f9; margin: 2px 0;"></div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Status</span>
                                        <StatusBadge Status="@_task.StatusCode" />
                                    </div>
                                    <div style="height: 1px; background: #f1f5f9; margin: 2px 0;"></div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Assigned</span>
                                        <span style="color: #64748b; font-size: 0.85rem;"><TimestampDisplay Value="@_task.CreatedAtUtc" EmptyText="-" ShowTime="false" /></span>
                                    </div>
                                    <div style="height: 1px; background: #f1f5f9; margin: 2px 0;"></div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Priority</span>
                                        <span style="color: #111827; font-weight: 700; font-size: 0.85rem;">@_task.PriorityLevel</span>
                                    </div>
                                    <div style="height: 1px; background: #f1f5f9; margin: 2px 0;"></div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Due</span>
                                        <span style="color: #64748b; font-size: 0.85rem;"><TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline" ShowTime="false" /></span>
                                    </div>
                                    <div style="height: 1px; background: #f1f5f9; margin: 2px 0;"></div>
                                    <div style="display: flex; align-items: center; justify-content: space-between; padding: 6px 0;">
                                        <span style="color: #94a3b8; font-size: 0.85rem;">Regions</span>
                                        <span style="color: #111827; font-weight: 700; font-size: 0.85rem;">@_task.PageRegions.Count</span>
                                    </div>
                                </div>
                            </div>

                            @* Source Page Card *@
                            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                                <div style="font-weight: 700; font-size: 0.9rem; color: #111827; margin-bottom: 12px;">Source Page</div>
                                @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                                {
                                    <MudImage Src="@_task.PageImageUrl" MaxHeight="150" ObjectFit="ObjectFit.Contain" Class="rounded w-100" />
                                    <div style="text-align: center; margin-top: 8px;">
                                        <a href="@_task.PageImageUrl" target="_blank" style="color: #4f46e5; font-size: 0.85rem; text-decoration: none; font-weight: 500;">Download Source</a>
                                    </div>
                                }
                                else
                                {
                                    <div style="color: #94a3b8; font-size: 0.85rem; text-align: center; padding: 16px;">Source image not available.</div>
                                }
                            </div>

                            @* Submitted Output Card *@
                            <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                                <div style="font-weight: 700; font-size: 0.9rem; color: #111827; margin-bottom: 12px;">Submitted Output</div>
                                @if (!string.IsNullOrWhiteSpace(_task.CompletedOutputUrl))
                                {
                                    <div style="text-align: center; padding: 16px;">
                                        <div style="color: #94a3b8;">
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Style="font-size: 32px;" Class="mb-2" />
                                        </div>
                                        <div style="color: #94a3b8; font-size: 0.85rem;">Submitted output is available</div>
                                        @if (_task.CompletedPageVersionId.HasValue)
                                        {
                                            <div style="color: #94a3b8; font-size: 0.72rem;">Version: @_task.CompletedPageVersionId.Value.ToString("N")[..8]</div>
                                        }
                                        <button @onclick="() => _showOutputPreview = true" style="border: 1px solid #e2e8f0; color: #374151; padding: 8px 16px; border-radius: 8px; background: none; cursor: pointer; font-size: 0.85rem; font-weight: 500; margin-top: 12px; width: 100%;">View Submitted Output</button>
                                    </div>
                                }
                                else
                                {
                                    <div style="color: #94a3b8; font-size: 0.85rem; text-align: center; padding: 16px;">No submitted output yet.</div>
                                }
                            </div>

                            @* Submitted Output Preview Overlay *@
                            <MudOverlay Visible="_showOutputPreview" AutoClose="false">
                                <div style="display: flex; align-items: center; justify-content: center; height: 100%; padding: 24px;">
                                    <div style="max-width: 800px; width: 100%; max-height: 85vh; background: #fff; border: 1px solid #e2e8f0; border-radius: 14px; box-shadow: 0 10px 40px rgba(0,0,0,0.2); overflow: hidden; display: flex; flex-direction: column;">
                                        <div style="display: flex; justify-content: space-between; align-items: center; padding: 16px 24px; border-bottom: 1px solid #e2e8f0;">
                                            <div style="font-weight: 700; font-size: 1rem; color: #111827;">Submitted Output Preview</div>
                                            <button @onclick="CloseOutputPreview" style="background: none; border: none; cursor: pointer; color: #94a3b8;">
                                                <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                                            </button>
                                        </div>
                                        <div style="flex: 1; overflow: auto; padding: 24px; text-align: center;">
                                            @if (!string.IsNullOrWhiteSpace(_task?.CompletedOutputUrl))
                                            {
                                                <img src="@_task.CompletedOutputUrl" style="max-width: 100%; max-height: 72vh; object-fit: contain; border-radius: 8px;" />
                                            }
                                        </div>
                                        <div style="padding: 12px 24px; border-top: 1px solid #e2e8f0; text-align: right;">
                                            <button @onclick="CloseOutputPreview" style="background: #4f46e5; color: #fff; padding: 8px 20px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.85rem; font-weight: 500;">Close</button>
                                        </div>
                                    </div>
                                </div>
                            </MudOverlay>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private Guid _currentUserId;
    private bool _loading = true;
    private bool _showOutputPreview;
    private string? _error;
    private ChapterPageTaskDto? _task;
    private IReadOnlyList<ChapterPageAnnotationDto>? _annotations;

    private string GetStatusBg()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => "#eff6ff",
            "UNDER_REVIEW" => "#fffbeb",
            "COMPLETED" => "#f0fdf4",
            "CANCELLED" => "#fef2f2",
            _ => "#f8fafc"
        };
    }

    private string GetStatusBorder()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => "#bfdbfe",
            "UNDER_REVIEW" => "#fde68a",
            "COMPLETED" => "#bbf7d0",
            "CANCELLED" => "#fecaca",
            _ => "#e2e8f0"
        };
    }

    private string GetStatusTextColor()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => "#1e40af",
            "UNDER_REVIEW" => "#92400e",
            "COMPLETED" => "#166534",
            "CANCELLED" => "#dc2626",
            _ => "#64748b"
        };
    }

    private string GetStatusMessage()
    {
        return _task?.StatusCode switch
        {
            "ASSIGNED" => "This task is assigned to you and ready to work on.",
            "UNDER_REVIEW" => "Your work has been submitted and is awaiting Mangaka review. You will be notified of the outcome.",
            "COMPLETED" => "This task has been approved and completed. Great work!",
            "CANCELLED" => "This task has been cancelled.",
            _ => ""
        };
    }

    private string GetStatusIcon() => _task?.StatusCode switch
    {
        "ASSIGNED" => "📋",
        "UNDER_REVIEW" => "⏳",
        "COMPLETED" => "✅",
        "CANCELLED" => "❌",
        _ => ""
    };

    private void CloseOutputPreview()
    {
        _showOutputPreview = false;
    }

    private readonly TimeSpan _refreshInterval = TimeSpan.FromSeconds(30);
    private bool _disposed;
    private PeriodicTimer? _timer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTaskAsync();

        _timer = new PeriodicTimer(_refreshInterval);
        _ = PollForUpdatesAsync();
    }

    private async Task PollForUpdatesAsync()
    {
        while (!_disposed && _timer is not null)
        {
            try
            {
                await _timer.WaitForNextTickAsync();
                if (!_disposed)
                {
                    await LoadTaskAsync();
                    if (!_disposed)
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch
            {
                break;
            }
        }
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(_currentUserId, TaskId);

            if (_task != null)
            {
                _annotations = await AssistantTaskClient.GetTaskAnnotationsAsync(_currentUserId, TaskId);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    public void Dispose()
    {
        _disposed = true;
        _timer?.Dispose();
    }
}
