@page "/assistant/task/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Task Detail</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review assignment details and reference material</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">Failed to load task: @_error</MudAlert>
        }
        else if (_task is null)
        {
            <MudAlert Severity="Severity.Warning">Task not found or not assigned to you.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">@_task.TypeCode</MudText>
                                <MudText Typo="Typo.body2" Class="mf-muted">Task Id: @_task.ChapterPageTaskId</MudText>
                            </div>
                            <StatusBadge Status="@_task.StatusCode" />
                        </MudStack>

                        <MudPaper Class="pa-4 mb-3" Elevation="0" Style="background-color:#f5f5f5;">
                            @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle) || !string.IsNullOrWhiteSpace(_task.ChapterNumberLabel) || _task.PageNo.HasValue)
                            {
                                <MudStack Spacing="1">
                                    @if (!string.IsNullOrWhiteSpace(_task.SeriesTitle))
                                    {
                                        <MudText Typo="Typo.body2"><strong>Series:</strong> @_task.SeriesTitle</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_task.ChapterNumberLabel))
                                    {
                                        <MudText Typo="Typo.body2"><strong>Chapter:</strong> @_task.ChapterNumberLabel</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_task.ChapterTitle))
                                    {
                                        <MudText Typo="Typo.body2"><strong>Chapter Title:</strong> @_task.ChapterTitle</MudText>
                                    }
                                    @if (_task.PageNo.HasValue)
                                    {
                                        <MudText Typo="Typo.body2"><strong>Page:</strong> @_task.PageNo.Value</MudText>
                                    }
                                </MudStack>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mf-muted">Series/Chapter information not available.</MudText>
                            }
                        </MudPaper>

                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Task Description</MudText>
                            @if (!string.IsNullOrWhiteSpace(_task.TaskDescription))
                            {
                                <MudText Class="mf-muted"> @_task.TaskDescription</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Class="mf-muted">No description available.</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    @if (_task.PageRegions.Any())
                    {
                        <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Page Regions</MudText>
                            <MudTable Items="@_task.PageRegions" Hover="true" RowsPerPage="10" Elevation="0">
                                <Columns>
                                    <MudColumn><MudText>Region Type</MudText></MudColumn>
                                    <MudColumn><MudText>Label</MudText></MudColumn>
                                    <MudColumn><MudText>X</MudText></MudColumn>
                                    <MudColumn><MudText>Y</MudText></MudColumn>
                                    <MudColumn><MudText>Width</MudText></MudColumn>
                                    <MudColumn><MudText>Height</MudText></MudColumn>
                                </Columns>
                                <RowTemplate>
                                    <MudTd>@context.TypeCode</MudTd>
                                    <MudTd>@context.RegionLabel</MudTd>
                                    <MudTd>@context.X</MudTd>
                                    <MudTd>@context.Y</MudTd>
                                    <MudTd>@context.Width</MudTd>
                                    <MudTd>@context.Height</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    }

                    @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                    {
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Page Image</MudText>
                            <MudImage Src="@_task.PageImageUrl" Class="mf-page-image" MaxHeight="400" Aspect="Aspect.Fill" />
                        </MudPaper>
                    }
                    else
                    {
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Page Image</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">Page image data not available.</MudText>
                        </MudPaper>
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Task Metadata</MudText>
                        <MudStack Spacing="1">
                            <MudText><strong>Type:</strong> @_task.TypeCode</MudText>
                            <MudText><strong>Status:</strong> @_task.StatusCode</MudText>
                            <MudText><strong>Priority:</strong> @_task.PriorityLevel</MudText>
                            <MudText><strong>Due:</strong> <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" /></MudText>
                            @if (_task.CompensationAmount.HasValue)
                            {
                                <MudText><strong>Compensation:</strong> @_task.CompensationAmount.Value.ToString("C2")</MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(_task.AssignedToDisplayName))
                            {
                                <MudText><strong>Assigned To:</strong> @_task.AssignedToDisplayName</MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(_task.AssignedUsername))
                            {
                                <MudText><strong>Username:</strong> @_task.AssignedUsername</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Actions</MudText>
                        <MudStack Spacing="2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/assistant/studio/{_task.ChapterPageTaskId}")">Open Studio Workspace</MudButton>
                            <MudButton Variant="Variant.Outlined" Href="@($"/assistant/task/{_task.ChapterPageTaskId}/submit")">Submit Work</MudButton>
                            <MudButton Variant="Variant.Text" Href="/assistant/tasks">Back to Tasks</MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private bool _loading = true;
    private string? _error;
    private ChapterPageTaskDto? _task;

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(TaskId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
