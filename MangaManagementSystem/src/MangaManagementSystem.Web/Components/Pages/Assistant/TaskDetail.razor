@page "/assistant/task/{TaskId:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Task Detail</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review assignment details and reference material</MudText>
        </div>

        <MudGrid>
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mf-card" Elevation="0"><MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Page Preview - @TaskId</MudText><div class="mf-canvas">AI-assisted region suggestion preview</div></MudPaper>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card mb-4" Elevation="0"><MudText Typo="Typo.h6">Task Description</MudText><MudText class="mf-muted">Apply tone shading to the highlighted regions. Please review AI-suggested areas and adjust as needed.</MudText></MudPaper>
                <MudPaper Class="pa-5 mf-card mb-4" Elevation="0"><MudText Typo="Typo.h6">Task Notes</MudText><MudText>Assigned: Takahashi Yuki</MudText><MudText>Due: May 22, 2026</MudText><MudText>Estimated: 3 hours</MudText></MudPaper>
                <MudPaper Class="pa-5 mf-card" Elevation="0"><MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText><MudStack><MudButton Variant="Variant.Outlined">Download Reference Files</MudButton><MudButton Variant="Variant.Outlined">View Previous Chapter</MudButton><MudButton Variant="Variant.Outlined">Message Lead Artist</MudButton><MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/assistant/studio/{TaskId}")">Open Studio Workspace</MudButton></MudStack></MudPaper>
            </MudItem>
        </MudGrid>

    </div>
</AssistantLayout>

@code {

    [Parameter] public Guid TaskId { get; set; }

}
