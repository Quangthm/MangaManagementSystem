@page "/assistant/tasks"
@inject NavigationManager Nav

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Assigned Tasks</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">5 tasks requiring your attention</MudText>
        </div>

        <MudGrid Class="mb-6"><MudItem xs="12" md="3"><StatCard Label="In Progress" Value="2" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Not Started" Value="2" /></MudItem><MudItem xs="12" md="3"><StatCard Label="In Review" Value="1" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Overdue" Value="1" /></MudItem></MudGrid>
        <MudGrid>
            @foreach (var task in Tasks)
            {
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.h6" Class="font-weight-bold">@task.Title</MudText><MudChip T="string" Color="@task.Color" Size="Size.Small">@task.Status</MudChip></MudStack>
                        <MudText class="mf-muted">@task.Series • @task.Chapter</MudText>
                        <MudText Typo="Typo.body2" Class="mt-2">Due: @task.Due • Priority: @task.Priority</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/assistant/task/{task.Id}")" Class="mt-3">Open Task</MudButton>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

    </div>
</AssistantLayout>

@code {

    private readonly List<TaskCard> Tasks = new()
    {
        new("T1", "Tone Shading", "Shadow Blade Chronicles", "Ch. 12 · Page 8", "May 22", "High", "In Progress", Color.Info),
        new("T2", "Background Drawing", "Lunar Eclipse Academy", "Ch. 24 · Page 15", "May 23", "Medium", "Not Started", Color.Warning),
        new("T3", "Cleanup", "Star Runner Protocol", "Ch. 15 · Page 11", "May 22", "High", "In Review", Color.Secondary)
    };
    private record TaskCard(string Id, string Title, string Series, string Chapter, string Due, string Priority, string Status, Color Color);

}
