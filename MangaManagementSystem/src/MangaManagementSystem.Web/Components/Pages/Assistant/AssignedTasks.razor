@page "/assistant/tasks"
@layout AssistantLayout

<style>
    @@media (max-width: 1024px) { .as-grid-stats { grid-template-columns: repeat(2, 1fr) !important; } .as-grid-cards { grid-template-columns: 1fr !important; } }
    @@media (max-width: 640px) { .as-grid-stats { grid-template-columns: 1fr !important; } }
</style>

@using System.Security.Claims
@using MangaManagementSystem.Web.Services.Api
@using System.Threading
@attribute [Authorize(Roles = "Assistant")]
@implements IDisposable
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject IAssistantTaskApiClient AssistantTaskClient

    <div style="display: flex; flex-direction: column; height: 100%; background: #f8fafc;">
        @* ── Header ── *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; flex-shrink: 0;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    Assigned Tasks
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">
                    Tasks assigned to you
                    <span style="color: #94a3b8; font-size: 0.72rem; margin-left: 8px;">auto-refreshes every 30s</span>
                </div>
            </div>
        </div>

        @* ── Scrollable Content ── *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem;">Failed to load tasks: @_error</div>
            }
            else
            {
                @* ── Stat Cards ── *@
                <div class="as-grid-stats" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
                    <StatCard Label="Assigned" Value="@_assignedCount.ToString()" Description="Awaiting your work" />
                    <StatCard Label="Under Review" Value="@_underReviewCount.ToString()" Description="Submitted for review" />
                    <StatCard Label="Completed" Value="@_completedCount.ToString()" Description="Approved tasks" />
                    <StatCard Label="Overdue" Value="@_overdueCount.ToString()" Description="Past due date" />
                </div>

                @if (_overdueCount > 0)
                {
                    <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px;">
                        <span style="color: #dc2626; font-weight: 600; font-size: 0.85rem;">@_overdueCount task(s) are overdue!</span>
                        <button @onclick="@(() => _filter = "overdue")" style="background: none; border: none; color: #dc2626; font-weight: 600; font-size: 0.85rem; cursor: pointer;">Show Overdue &rarr;</button>
                    </div>
                }

                @* ── Search + Filter Tabs ── *@
                <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 12px 16px; margin-bottom: 24px; display: flex; flex-direction: column; gap: 12px;">
                    <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
                        <div style="flex: 1; min-width: 200px; position: relative;">
                            <input @bind="_searchQuery" @bind:event="oninput" placeholder="Search tasks..." style="width: 100%; padding: 8px 12px 8px 36px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.85rem; color: #111827; outline: none; background: #f8fafc;" />
                            <span style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #94a3b8; font-size: 0.9rem;">🔍</span>
                        </div>
                        <div style="display: flex; gap: 4px; flex-wrap: wrap;">
                            <button @onclick="@(() => { _filter = "all"; _currentPage = 1; })" style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(_filter == "all" ? 600 : 500); cursor: pointer; background: @(_filter == "all" ? "#4f46e5" : "#f1f5f9"); color: @(_filter == "all" ? "#fff" : "#475569"); border: 1px solid @(_filter == "all" ? "#4f46e5" : "#e2e8f0");">All</button>
                            <button @onclick="@(() => { _filter = "assigned"; _currentPage = 1; })" style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(_filter == "assigned" ? 600 : 500); cursor: pointer; background: @(_filter == "assigned" ? "#4f46e5" : "#f1f5f9"); color: @(_filter == "assigned" ? "#fff" : "#475569"); border: 1px solid @(_filter == "assigned" ? "#4f46e5" : "#e2e8f0");">Assigned</button>
                            <button @onclick="@(() => { _filter = "under_review"; _currentPage = 1; })" style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(_filter == "under_review" ? 600 : 500); cursor: pointer; background: @(_filter == "under_review" ? "#4f46e5" : "#f1f5f9"); color: @(_filter == "under_review" ? "#fff" : "#475569"); border: 1px solid @(_filter == "under_review" ? "#4f46e5" : "#e2e8f0");">Under Review</button>
                            <button @onclick="@(() => { _filter = "completed"; _currentPage = 1; })" style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(_filter == "completed" ? 600 : 500); cursor: pointer; background: @(_filter == "completed" ? "#166534" : "#f1f5f9"); color: @(_filter == "completed" ? "#fff" : "#475569"); border: 1px solid @(_filter == "completed" ? "#166534" : "#e2e8f0");">Completed</button>
                            <button @onclick="@(() => { _filter = "overdue"; _currentPage = 1; })" style="padding: 6px 14px; border-radius: 20px; font-size: 0.78rem; font-weight: @(_filter == "overdue" ? 600 : 500); cursor: pointer; background: @(_filter == "overdue" ? "#dc2626" : "#f1f5f9"); color: @(_filter == "overdue" ? "#fff" : "#475569"); border: 1px solid @(_filter == "overdue" ? "#dc2626" : "#e2e8f0");">Overdue</button>
                        </div>
                    </div>
                    <div style="display: flex; align-items: center; justify-content: space-between;">
                        <div style="color: #94a3b8; font-size: 0.78rem;">
                            @_filteredTasks.Count task(s)
                            @if (_filter != "all" || !string.IsNullOrWhiteSpace(_searchQuery))
                            {
                                <a href="javascript:void(0)" @onclick="ClearFilters" style="margin-left: 8px; color: #4f46e5;">Clear filters</a>
                            }
                        </div>
                    </div>
                </div>

                @if (!_filteredTasks.Any())
                {
                    <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 48px 24px; text-align: center; color: #94a3b8; font-size: 0.95rem;">
                        @if (!string.IsNullOrWhiteSpace(_searchQuery))
                        {
                            <span>No tasks match "<strong>@_searchQuery</strong>".</span>
                        }
                        else
                        {
                            <span>No tasks match the current filter.</span>
                        }
                    </div>
                }
                else
                {
                    var pageItems = _paginatedTasks;
                    var totalPages = _totalPages;
                    <div class="as-grid-cards" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;">
                        @foreach (var t in pageItems)
                        {
                            var isOverdue = IsOverdue(t);
                            var isDueSoon = IsDueSoon(t);
                            var borderStyle = isOverdue ? "border-left: 4px solid #dc2626;" : isDueSoon ? "border-left: 4px solid #d97706;" : "";

                            <div @key="t.ChapterPageTaskId" style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px; @borderStyle">
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px;">
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <div style="font-weight: 700; font-size: 0.95rem; color: @(isOverdue ? "#dc2626" : "#111827");">@t.TypeCode</div>
                                        @if (isOverdue)
                                        {
                                            <span style="background: #dc2626; color: #fff; font-size: 0.62rem; padding: 1px 6px; border-radius: 8px; font-weight: 600;">OVERDUE</span>
                                        }
                                        else if (isDueSoon)
                                        {
                                            <span style="background: #fef3c7; color: #92400e; font-size: 0.62rem; padding: 1px 6px; border-radius: 8px; font-weight: 600;">DUE SOON</span>
                                        }
                                    </div>
                                    <span style="display: inline-block; background: @GetStatusBg(t.StatusCode); color: @GetStatusText(t.StatusCode); font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; font-weight: 600;">@t.StatusCode</span>
                                </div>

                                <div style="color: #64748b; font-size: 0.85rem; margin-bottom: 8px;">
                                    @if (!string.IsNullOrWhiteSpace(t.SeriesTitle))
                                    {
                                        <span>@t.SeriesTitle</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(t.ChapterNumberLabel))
                                    {
                                        <span> &bull; @t.ChapterNumberLabel</span>
                                    }
                                    @if (t.PageNo.HasValue)
                                    {
                                        <span> &bull; Page @t.PageNo.Value</span>
                                    }
                                </div>

                                <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 0.78rem;">
                                    <span style="color: #94a3b8;">
                                        Assigned: <TimestampDisplay Value="@t.CreatedAtUtc" EmptyText="-" ShowTime="false" />
                                    </span>
                                    <span style="color: #cbd5e1;">&bull;</span>
                                    <span style="color: @(isOverdue ? "#dc2626" : "#64748b"); font-weight: @(isOverdue ? "600" : "normal");">
                                        Due: <TimestampDisplay Value="@t.DueAtUtc" EmptyText="No deadline set" />
                                    </span>
                                </div>

                                @if (t.PageRegions.Any())
                                {
                                    <div style="color: #94a3b8; font-size: 0.78rem; margin-bottom: 8px;">Regions: @t.PageRegions.Count</div>
                                }

                                <a href="@($"/workspace/tasks/{t.ChapterPageTaskId}?returnUrl=/assistant/tasks")" style="background: #4f46e5; color: #fff; display: inline-block; padding: 6px 16px; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: 500;">Open Workspace</a>
                            </div>
                        }
                    </div>

                    @* ── Pagination ── *@
                    @if (totalPages > 1)
                    {
                        <div style="display: flex; align-items: center; justify-content: center; gap: 8px; margin-top: 24px;">
                            <button @onclick="@(() => _currentPage = 1)" disabled="@(_currentPage == 1)" style="padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; background: @(_currentPage == 1 ? "#f1f5f9" : "#fff"); color: @(_currentPage == 1 ? "#94a3b8" : "#374151"); border: 1px solid #e2e8f0; @(_currentPage == 1 ? "cursor: default;" : "")">««</button>
                            <button @onclick="@(() => _currentPage = Math.Max(1, _currentPage - 1))" disabled="@(_currentPage == 1)" style="padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; background: @(_currentPage == 1 ? "#f1f5f9" : "#fff"); color: @(_currentPage == 1 ? "#94a3b8" : "#374151"); border: 1px solid #e2e8f0; @(_currentPage == 1 ? "cursor: default;" : "")">«</button>
                            @for (int p = Math.Max(1, _currentPage - 2); p <= Math.Min(totalPages, _currentPage + 2); p++)
                            {
                                <button @onclick="@(() => _currentPage = p)" style="padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; background: @(p == _currentPage ? "#4f46e5" : "#fff"); color: @(p == _currentPage ? "#fff" : "#374151"); border: 1px solid @(p == _currentPage ? "#4f46e5" : "#e2e8f0"); font-weight: @(p == _currentPage ? "600" : "normal");">@p</button>
                            }
                            <button @onclick="@(() => _currentPage = Math.Min(totalPages, _currentPage + 1))" disabled="@(_currentPage == totalPages)" style="padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; background: @(_currentPage == totalPages ? "#f1f5f9" : "#fff"); color: @(_currentPage == totalPages ? "#94a3b8" : "#374151"); border: 1px solid #e2e8f0; @(_currentPage == totalPages ? "cursor: default;" : "")">»</button>
                            <button @onclick="@(() => _currentPage = totalPages)" disabled="@(_currentPage == totalPages)" style="padding: 6px 12px; border-radius: 6px; font-size: 0.78rem; cursor: pointer; background: @(_currentPage == totalPages ? "#f1f5f9" : "#fff"); color: @(_currentPage == totalPages ? "#94a3b8" : "#374151"); border: 1px solid #e2e8f0; @(_currentPage == totalPages ? "cursor: default;" : "")">»»</button>
                            <span style="color: #94a3b8; font-size: 0.78rem; margin-left: 8px;">Page @_currentPage of @totalPages (@_filteredTasks.Count items)</span>
                        </div>
                    }
                }
            }
        </div>
    </div>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<ChapterPageTaskDto>? _tasks;
    private string _filter = "all";
    private string _searchQuery = string.Empty;
    private int _currentPage = 1;
    private const int PageSize = 12;

    private int _assignedCount;
    private int _underReviewCount;
    private int _completedCount;
    private int _overdueCount;

    private List<ChapterPageTaskDto> _filteredTasks
    {
        get
        {
            if (_tasks == null) return [];
            var now = DateTime.UtcNow;
            IEnumerable<ChapterPageTaskDto> query = _tasks;

            query = _filter switch
            {
                "assigned" => query.Where(t => t.StatusCode == "ASSIGNED"),
                "under_review" => query.Where(t => t.StatusCode == "UNDER_REVIEW"),
                "completed" => query.Where(t => t.StatusCode == "COMPLETED"),
                "overdue" => query.Where(t => t.DueAtUtc.HasValue && t.DueAtUtc.Value < now &&
                                                t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED"),
                _ => query
            };

            // Apply search filter
            if (!string.IsNullOrWhiteSpace(_searchQuery))
            {
                var q = _searchQuery.Trim().ToLowerInvariant();
                query = query.Where(t =>
                    (t.TaskTitle?.ToLowerInvariant().Contains(q) ?? false) ||
                    (t.SeriesTitle?.ToLowerInvariant().Contains(q) ?? false) ||
                    (t.TypeCode?.ToLowerInvariant().Contains(q) ?? false) ||
                    (t.ChapterNumberLabel?.ToLowerInvariant().Contains(q) ?? false));
            }

            return [.. query.OrderBy(t =>
            {
                if (t.DueAtUtc.HasValue && t.DueAtUtc.Value < now &&
                    t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED") return 0;
                if (t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3)) return 1;
                return 2;
            }).ThenBy(t => t.DueAtUtc ?? DateTime.MaxValue)];
        }
    }

    private List<ChapterPageTaskDto> _paginatedTasks
    {
        get
        {
            var filtered = _filteredTasks;
            return filtered.Skip((_currentPage - 1) * PageSize).Take(PageSize).ToList();
        }
    }

    private int _totalPages => Math.Max(1, (int)Math.Ceiling((double)_filteredTasks.Count / PageSize));

    private readonly TimeSpan _refreshInterval = TimeSpan.FromSeconds(30);
    private bool _disposed;
    private PeriodicTimer? _timer;
    private DateTime _lastRefresh = DateTime.MinValue;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTasksAsync();
        _lastRefresh = DateTime.UtcNow;

        _timer = new PeriodicTimer(_refreshInterval);
        _ = PollForUpdatesAsync();
    }

    private async Task PollForUpdatesAsync()
    {
        while (!_disposed && _timer is not null)
        {
            try
            {
                await _timer.WaitForNextTickAsync();
                if (!_disposed)
                {
                    await LoadTasksAsync();
                    _lastRefresh = DateTime.UtcNow;
                    if (!_disposed)
                    {
                        await InvokeAsync(StateHasChanged);
                    }
                }
            }
            catch
            {
                break;
            }
        }
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _tasks = await AssistantTaskClient.GetAssignedTasksAsync(_currentUserId);

            var now = DateTime.UtcNow;
            _assignedCount = _tasks.Count(t => t.StatusCode == "ASSIGNED");
            _underReviewCount = _tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
            _completedCount = _tasks.Count(t => t.StatusCode == "COMPLETED");
            _overdueCount = _tasks.Count(t =>
                t.DueAtUtc.HasValue && t.DueAtUtc.Value < now &&
                t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsOverdue(ChapterPageTaskDto t) =>
        t.DueAtUtc.HasValue && t.DueAtUtc.Value < DateTime.UtcNow &&
        t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED";

    private bool IsDueSoon(ChapterPageTaskDto t)
    {
        if (IsOverdue(t)) return false;
        var now = DateTime.UtcNow;
        return t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3);
    }

    private void ClearFilters()
    {
        _filter = "all";
        _searchQuery = string.Empty;
        _currentPage = 1;
    }

    private string GetStatusBg(string status) => status switch
    {
        "ASSIGNED" => "#eef2ff",
        "UNDER_REVIEW" => "#fef3c7",
        "COMPLETED" => "#f0fdf4",
        "CANCELLED" => "#f1f5f9",
        _ => "#f1f5f9"
    };

    private string GetStatusText(string status) => status switch
    {
        "ASSIGNED" => "#4f46e5",
        "UNDER_REVIEW" => "#92400e",
        "COMPLETED" => "#166534",
        "CANCELLED" => "#64748b",
        _ => "#64748b"
    };

    public void Dispose()
    {
        _disposed = true;
        _timer?.Dispose();
    }
}
