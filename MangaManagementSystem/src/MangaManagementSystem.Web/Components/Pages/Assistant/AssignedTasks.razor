@page "/assistant/tasks"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject MangaManagementSystem.Application.Interfaces.IChapterPageTaskService TaskService

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Assigned Tasks</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">@_subtitle</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">Failed to load tasks: @_error</MudAlert>
        }
        else if (_tasks == null || !_tasks.Any())
        {
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Class="pa-6 text-center mf-card"><MudText>No assigned tasks found.</MudText></MudPaper>
                </MudItem>
            </MudGrid>
        }
        else
        {
            <MudGrid Class="mb-6"><MudItem xs="12" md="3"><StatCard Label="Assigned" Value="@_assignedCount.ToString()" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Under Review" Value="@_underReviewCount.ToString()" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Completed" Value="@_completedCount.ToString()" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Overdue" Value="@_overdueCount.ToString()" /></MudItem></MudGrid>
            <MudGrid>
                @foreach (var t in _tasks)
                {
                    <MudItem xs="12" md="6">
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudStack Row="true" Justify="Justify.SpaceBetween"><MudText Typo="Typo.h6" Class="font-weight-bold">@t.TypeCode</MudText><MudChip T="string" Color="Color.Info" Size="Size.Small">@t.StatusCode</MudChip></MudStack>
                            <MudText class="mf-muted">Task Id: @t.ChapterPageTaskId</MudText>
                            <MudText Typo="Typo.body2" Class="mt-2">Priority: @t.PriorityLevel • Due: @FormatDate(t.DueAtUtc)</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@($"/assistant/task/{t.ChapterPageTaskId}")" Class="mt-3">Open Task</MudButton>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }

    </div>
</AssistantLayout>

@code {

    private bool _loading = true;
    private string? _error;
    private IEnumerable<MangaManagementSystem.Application.DTOs.Manga.ChapterPageTaskDto>? _tasks;
    private int _assignedCount;
    private int _underReviewCount;
    private int _completedCount;
    private int _overdueCount;
    private string _subtitle = "Loading tasks…";

    protected override async Task OnInitializedAsync()
    {
        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user?.Identity?.IsAuthenticated != true)
            {
                _tasks = Array.Empty<MangaManagementSystem.Application.DTOs.Manga.ChapterPageTaskDto>();
                return;
            }

            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (!Guid.TryParse(idClaim?.Value, out var uid))
            {
                _tasks = Array.Empty<MangaManagementSystem.Application.DTOs.Manga.ChapterPageTaskDto>();
                return;
            }

            var tasks = (await TaskService.GetChapterPageTasksByAssignedUserIdAsync(uid)).ToList();
            _tasks = tasks;

            var now = DateTime.UtcNow;
            _assignedCount = tasks.Count(t => t.StatusCode == "ASSIGNED");
            _underReviewCount = tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
            _completedCount = tasks.Count(t => t.StatusCode == "COMPLETED");
            _overdueCount = tasks.Count(t =>
                t.DueAtUtc.HasValue
                && t.DueAtUtc.Value < now
                && t.StatusCode != "COMPLETED"
                && t.StatusCode != "CANCELLED");
            _subtitle = $"{tasks.Count} task{(tasks.Count == 1 ? "" : "s")} requiring your attention";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private string FormatDate(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("g") : "—";

}
