@page "/assistant"
@page "/assistant/notifications"
@page "/assistant/approved-work-history"
@page "/assistant/settings"
@inject NavigationManager Nav

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Assistant Dashboard</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Today's assigned production work</MudText>
        </div>

        <MudChip T="string" Color="Color.Warning" Class="mb-4">2 tasks due today</MudChip>
        <MudGrid Class="mb-6"><MudItem xs="12" md="3"><StatCard Label="Total Tasks" Value="5" Description="All assigned work" /></MudItem><MudItem xs="12" md="3"><StatCard Label="In Progress" Value="2" Description="Currently active" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Pending Review" Value="2" Description="Awaiting start" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Completed" Value="1" Description="This cycle" /></MudItem></MudGrid>
        <MudGrid>
            <MudItem xs="12" md="8"><MudPaper Class="pa-5 mf-card" Elevation="0"><MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Recent Assigned Tasks</MudText><MudTable Items="Tasks" Hover="true"><HeaderContent><MudTh>Title / Task</MudTh><MudTh>Chapter</MudTh><MudTh>Deadline</MudTh><MudTh>Status</MudTh></HeaderContent><RowTemplate><MudTd>@context.Title</MudTd><MudTd>@context.Chapter</MudTd><MudTd>@context.Deadline</MudTd><MudTd><MudChip T="string" Color="@context.Color" Size="Size.Small">@context.Status</MudChip></MudTd></RowTemplate></MudTable></MudPaper></MudItem>
            <MudItem xs="12" md="4"><MudPaper Class="pa-5 mf-card" Elevation="0"><MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Deadline Alerts</MudText><MudAlert Severity="Severity.Warning">2 tasks require immediate attention.</MudAlert><MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/assistant/tasks" Class="mt-3">View All Tasks</MudButton></MudPaper></MudItem>
        </MudGrid>

    </div>
</AssistantLayout>

@code {

    private readonly List<AssistantTask> Tasks = new()
    {
        new("Shadow Blade Chronicles · Tone Shading", "Ch. 12 · Pg. 8", "May 22 — 6:00 PM", "In Progress", Color.Info),
        new("Lunar Eclipse Academy · Background Drawing", "Ch. 24 · Pg. 15", "May 23", "Pending", Color.Warning),
        new("Star Runner Protocol · Cleanup", "Ch. 15 · Pg. 11", "May 22", "Pending Review", Color.Secondary)
    };
    private record AssistantTask(string Title, string Chapter, string Deadline, string Status, Color Color);

}
