@page "/assistant"

@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject IAssistantTaskApiClient AssistantTaskClient
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<AssistantLayout>
    <div style="display: flex; flex-direction: column; height: 100%; background: #f8fafc;">
        @* ── Header ── *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; flex-shrink: 0;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    Assistant Workspace
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">View assigned page tasks and track task progress.</div>
            </div>
        </div>

        @* ── Scrollable Content ── *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_loadError != null)
            {
                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem;">Failed to load tasks: @_loadError</div>
            }
            else
            {
                @* ── Stat Cards ── *@
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px;">
                    <StatCard Label="Assigned" Value="@_assignedCount.ToString()" Description="Tasks assigned to you" />
                    <StatCard Label="Due Soon" Value="@_dueSoonCount.ToString()" Description="Within 3 days" />
                    <StatCard Label="Under Review" Value="@_underReviewCount.ToString()" Description="Awaiting feedback" />
                    <StatCard Label="Completed" Value="@_completedCount.ToString()" Description="Finished tasks" />
                </div>

                @if (_overdueCount > 0)
                {
                    <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; display: flex; align-items: center; gap: 8px; margin-bottom: 24px;">
                        <span style="color: #dc2626; font-weight: 600; font-size: 0.85rem;">@_overdueCount overdue task(s)! Please check the task list.</span>
                    </div>
                }

                @* ── Main Content Grid ── *@
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
                    @* ── Tasks Table Card ── *@
                    <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); overflow: hidden;">
                        <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                            <div style="font-weight: 700; font-size: 1rem; color: #111827;">My Assigned Tasks</div>
                            <a href="/assistant/tasks" style="color: #4f46e5; font-size: 0.85rem; text-decoration: none; font-weight: 500;">View All &rarr;</a>
                        </div>
                        @if (_tasks == null || !_tasks.Any())
                        {
                            <div style="padding: 48px 24px; text-align: center;">
                                <div style="font-size: 40px; color: #cbd5e1; margin-bottom: 12px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Assignment" Style="font-size: 40px;" />
                                </div>
                                <div style="font-weight: 600; font-size: 0.95rem; color: #64748b; margin-bottom: 4px;">No assigned tasks.</div>
                                <div style="color: #94a3b8; font-size: 0.85rem;">Tasks assigned to you will appear here.</div>
                            </div>
                        }
                        else
                        {
                            <div style="overflow-x: auto;">
                                <table style="width: 100%; border-collapse: collapse; font-size: 0.85rem;">
                                    <thead>
                                        <tr style="border-bottom: 1px solid #f1f5f9;">
                                            <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Type</th>
                                            <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Series / Chapter</th>
                                            <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Due</th>
                                            <th style="padding: 12px 16px; text-align: left; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;">Status</th>
                                            <th style="padding: 12px 16px; text-align: right; color: #94a3b8; font-weight: 600; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em;"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var t in _orderedTasks)
                                        {
                                            var isOverdue = IsOverdue(t);
                                            var isDueSoon = IsDueSoon(t);
                                            var rowColor = isOverdue ? "#fef2f2" : (isDueSoon ? "#fffbeb" : "transparent");
                                            <tr style="border-bottom: 1px solid #f1f5f9; background: @rowColor; cursor: pointer;" @onclick="@(() => OpenTask(t.ChapterPageTaskId))">
                                                <td style="padding: 12px 16px; font-weight: 600; color: @(isOverdue ? "#dc2626" : "#111827");">@t.TypeCode</td>
                                                <td style="padding: 12px 16px; color: @(isOverdue ? "#dc2626" : "#374151");">
                                                    @(t.SeriesTitle ?? "—") @(t.ChapterNumberLabel != null ? $"• {t.ChapterNumberLabel}" : "")
                                                </td>
                                                <td style="padding: 12px 16px;">
                                                    <span style="color: @(isOverdue ? "#dc2626" : (isDueSoon ? "#d97706" : "#64748b")); font-weight: @(isOverdue || isDueSoon ? "600" : "normal");">
                                                        @FormatDate(t.DueAtUtc)
                                                    </span>
                                                    @if (isOverdue)
                                                    {
                                                        <span style="background: #dc2626; color: #fff; font-size: 0.62rem; padding: 1px 6px; border-radius: 8px; font-weight: 600; margin-left: 6px;">OVERDUE</span>
                                                    }
                                                    else if (isDueSoon)
                                                    {
                                                        <span style="background: #fef3c7; color: #92400e; font-size: 0.62rem; padding: 1px 6px; border-radius: 8px; font-weight: 600; margin-left: 6px;">SOON</span>
                                                    }
                                                </td>
                                                <td style="padding: 12px 16px;">
                                                    <span style="display: inline-block; background: @GetStatusBg(t.StatusCode); color: @GetStatusText(t.StatusCode); font-size: 0.68rem; padding: 2px 8px; border-radius: 10px; font-weight: 600;">@t.StatusCode</span>
                                                </td>
                                                <td style="padding: 12px 16px; text-align: right;">
                                                    <a href="@($"/workspace/tasks/{t.ChapterPageTaskId}?returnUrl=/assistant")" style="background: #4f46e5; color: #fff; padding: 4px 14px; border-radius: 6px; text-decoration: none; font-size: 0.78rem; font-weight: 500;">Open Workspace</a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>

                    @* ── Right Sidebar ── *@
                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        @* Due Soon Card *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                <div style="font-weight: 700; font-size: 0.9rem; color: #111827;">Due Soon</div>
                                @if (_dueSoonCount > 0)
                                {
                                    <span style="background: #fef3c7; color: #92400e; font-size: 0.68rem; padding: 1px 8px; border-radius: 8px; font-weight: 600;">@_dueSoonCount</span>
                                }
                            </div>
                            @if (_dueSoon == null || !_dueSoon.Any())
                            {
                                <div style="color: #94a3b8; font-size: 0.85rem;">No tasks due soon.</div>
                            }
                            else
                            {
                                <div style="display: flex; flex-direction: column;">
                                    @foreach (var t in _dueSoon.Take(5))
                                    {
                                        <div @onclick="@(() => OpenTask(t.ChapterPageTaskId))" style="padding: 8px 0; border-bottom: 1px solid #f1f5f9; cursor: pointer; display: flex; align-items: center; justify-content: space-between;">
                                            <div>
                                                <div style="font-weight: 600; font-size: 0.85rem; color: #111827;">@t.TypeCode</div>
                                                <div style="color: #94a3b8; font-size: 0.75rem;">@(t.SeriesTitle ?? "—") @(t.ChapterNumberLabel != null ? $"• {t.ChapterNumberLabel}" : "")</div>
                                            </div>
                                            <div style="font-size: 0.75rem; color: #d97706; font-weight: 600; white-space: nowrap;">@FormatDate(t.DueAtUtc)</div>
                                        </div>
                                    }
                                </div>
                                @if (_dueSoon.Count() > 5)
                                {
                                    <div style="color: #94a3b8; font-size: 0.75rem; margin-top: 8px;">+ @(_dueSoon.Count() - 5) more</div>
                                }
                            }
                            <div style="border-top: 1px solid #f1f5f9; margin-top: 12px; padding-top: 12px;">
                                <a href="/assistant/tasks" style="background: #4f46e5; color: #fff; display: block; text-align: center; padding: 8px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 500;">View All Tasks</a>
                            </div>
                        </div>

                        @if (_overdueCount > 0)
                        {
                            @* Overdue Card *@
                            <div style="background: #fff; border: 1px solid #fecaca; border-left: 4px solid #dc2626; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px;">
                                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px;">
                                    <div style="font-weight: 700; font-size: 0.9rem; color: #dc2626;">Overdue</div>
                                    <span style="background: #dc2626; color: #fff; font-size: 0.68rem; padding: 1px 8px; border-radius: 8px; font-weight: 600;">@_overdueCount</span>
                                </div>
                                <div style="display: flex; flex-direction: column;">
                                    @foreach (var t in _overdueTasks.Take(3))
                                    {
                                        <div @onclick="@(() => OpenTask(t.ChapterPageTaskId))" style="padding: 8px 0; border-bottom: 1px solid #fef2f2; cursor: pointer; display: flex; align-items: center; justify-content: space-between;">
                                            <div>
                                                <div style="font-weight: 600; font-size: 0.85rem; color: #dc2626;">@t.TypeCode</div>
                                                <div style="color: #94a3b8; font-size: 0.75rem;">@(t.SeriesTitle ?? "—") @(t.ChapterNumberLabel != null ? $"• {t.ChapterNumberLabel}" : "")</div>
                                            </div>
                                            <div style="font-size: 0.75rem; color: #dc2626; font-weight: 700; white-space: nowrap;">@FormatDate(t.DueAtUtc)</div>
                                        </div>
                                    }
                                </div>
                                @if (_overdueTasks.Count > 3)
                                {
                                    <div style="color: #94a3b8; font-size: 0.75rem; margin-top: 8px;">+ @(_overdueTasks.Count - 3) more</div>
                                }
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</AssistantLayout>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _loadError;
    private IReadOnlyList<ChapterPageTaskDto>? _tasks;
    private IEnumerable<ChapterPageTaskDto>? _dueSoon;
    private List<ChapterPageTaskDto> _overdueTasks = [];
    private int _assignedCount;
    private int _dueSoonCount;
    private int _underReviewCount;
    private int _completedCount;
    private int _overdueCount;
    private string _sortOrder = "due_asc";

    private IReadOnlyList<ChapterPageTaskDto> _orderedTasks
    {
        get
        {
            if (_tasks == null) return [];
            var sorted = _sortOrder == "due_asc"
                ? _tasks.OrderBy(t => t.DueAtUtc ?? DateTime.MaxValue)
                : _tasks.OrderBy(t => t.StatusCode == "ASSIGNED" ? 0 : 1)
                        .ThenBy(t => t.DueAtUtc ?? DateTime.MaxValue);
            if (_overdueCount > 0)
            {
                sorted = sorted.OrderBy(t => IsOverdue(t) ? 0 : 1);
            }
            return sorted.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            _assignedCount = _tasks.Count(t => t.StatusCode == "ASSIGNED");
            var now = DateTime.UtcNow;
            _assignedCount = _tasks.Count(t => t.StatusCode == "ASSIGNED");
            _dueSoon = _tasks.Where(t => !IsOverdue(t) && t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3) && t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED").ToList();
            _dueSoonCount = _dueSoon.Count();
            _underReviewCount = _tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
            _completedCount = _tasks.Count(t => t.StatusCode == "COMPLETED");
            _overdueTasks = _tasks.Where(t => IsOverdue(t)).ToList();
            _overdueCount = _overdueTasks.Count;
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private bool IsOverdue(ChapterPageTaskDto t) =>
        t.DueAtUtc.HasValue && t.DueAtUtc.Value < DateTime.UtcNow &&
        t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED";

    private bool IsDueSoon(ChapterPageTaskDto t)
    {
        if (IsOverdue(t)) return false;
        var now = DateTime.UtcNow;
        return t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3);
    }

    private string GetOverdueStyle(ChapterPageTaskDto t)
    {
        if (IsOverdue(t))
            return "color: var(--mud-palette-error); font-weight: 600;";
        if (IsDueSoon(t))
            return "color: var(--mud-palette-warning); font-weight: 600;";
        return "";
    }

    private void OpenTask(Guid id) => Nav.NavigateTo($"/assistant/task/{id}");

    private string FormatDate(DateTime? value)
    {
        if (!value.HasValue) return "—";
        var local = value.Value.ToLocalTime();
        var now = DateTime.Now;
        if (local.Date == now.Date) return $"Today {local:t}";
        if (local.Date == now.Date.AddDays(1)) return $"Tomorrow {local:t}";
        if (local.Date == now.Date.AddDays(-1)) return $"Yesterday {local:t}";
        return local.ToString("MMM dd");
    }

    private string GetStatusBg(string status) => status switch
    {
        "ASSIGNED" => "#eef2ff",
        "UNDER_REVIEW" => "#fef3c7",
        "COMPLETED" => "#f0fdf4",
        "CANCELLED" => "#f1f5f9",
        _ => "#f1f5f9"
    };

    private string GetStatusText(string status) => status switch
    {
        "ASSIGNED" => "#4f46e5",
        "UNDER_REVIEW" => "#92400e",
        "COMPLETED" => "#166534",
        "CANCELLED" => "#64748b",
        _ => "#64748b"
    };
}
