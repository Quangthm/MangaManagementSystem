@page "/assistant"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@attribute [Authorize(Roles = "Assistant")]
@inject MangaManagementSystem.Application.Interfaces.IChapterPageTaskService TaskService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Assistant Workspace</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">View assigned page tasks and track task progress.</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_loadError != null)
        {
            <MudAlert Severity="Severity.Error">Failed to load tasks: @_loadError</MudAlert>
        }
        else
        {
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="3"><StatCard Label="Assigned" Value="@(_assignedCount?.ToString() ?? "—")" Description="Tasks assigned to you" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Due Soon" Value="@(_dueSoonCount?.ToString() ?? "—")" Description="Near due date" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Under Review" Value="@(_underReviewCount?.ToString() ?? "—")" Description="Awaiting feedback" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Completed" Value="@(_completedCount?.ToString() ?? "—")" Description="Finished tasks" /></MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">My Assigned Tasks</MudText>
                        @if (_tasks == null || !_tasks.Any())
                        {
                            <MudPaper Class="pa-6 text-center mf-card"><MudText>No assigned tasks found.</MudText></MudPaper>
                        }
                        else
                        {
                            <MudTable Items="_tasks" Hover="true">
                                <HeaderContent>
                                    <MudTh>Task Id</MudTh>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Due</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.ChapterPageTaskId</MudTd>
                                    <MudTd>@(context.TypeCode)</MudTd>
                                    <MudTd>@FormatDate(context.DueAtUtc)</MudTd>
                                    <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                                    <MudTd><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=>OpenTask(context.ChapterPageTaskId))">View</MudButton></MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Due Soon</MudText>
                        @if (_dueSoon == null || !_dueSoon.Any())
                        {
                            <MudText class="mf-muted">No tasks due soon.</MudText>
                        }
                        else
                        {
                            <MudList T="ChapterPageTaskDto">
                                @foreach (var t in _dueSoon)
                                {
                                    <MudListItem T="ChapterPageTaskDto" Value="@t">
                                        <MudText>@t.TypeCode — Id: @t.ChapterPageTaskId</MudText>
                                        <MudText class="mf-muted">@FormatDate(t.DueAtUtc)</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }

                        <MudDivider Class="my-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/assistant/tasks">View All Tasks</MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mt-4 mf-card">
                <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Task Detail Preview</MudText>
                @if (_selectedTask == null)
                {
                    <MudText class="mf-muted">Select a task to view details.</MudText>
                }
                else
                {
                    <MudGrid>
                        <MudItem xs="12" md="8">
                            <MudText Typo="Typo.subtitle1">Task Id: @_selectedTask.ChapterPageTaskId</MudText>
                            <MudText class="mf-muted">Type: @_selectedTask.TypeCode</MudText>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudText class="mf-muted">Due: @FormatDate(_selectedTask.DueAtUtc)</MudText>
                            <MudChip T="string" Color="@GetStatusColor(_selectedTask.StatusCode)">@_selectedTask.StatusCode</MudChip>
                        </MudItem>
                    </MudGrid>
                }
            </MudPaper>
        }
    </div>
</AssistantLayout>

@code {
    private bool _loading = true;
    private string? _loadError;
    private IEnumerable<ChapterPageTaskDto>? _tasks;
    private IEnumerable<ChapterPageTaskDto>? _dueSoon;
    private ChapterPageTaskDto? _selectedTask;
    private int? _assignedCount;
    private int? _dueSoonCount;
    private int? _underReviewCount;
    private int? _completedCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (user?.Identity?.IsAuthenticated != true)
            {
                _tasks = Array.Empty<ChapterPageTaskDto>();
                return;
            }

            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
            if (!Guid.TryParse(idClaim?.Value, out var uid))
            {
                _tasks = Array.Empty<ChapterPageTaskDto>();
                return;
            }

            var tasks = (await TaskService.GetChapterPageTasksByAssignedUserIdAsync(uid)).ToList();
            _tasks = tasks;
            _assignedCount = tasks.Count;
            var now = DateTime.UtcNow;
            _dueSoon = tasks.Where(t => t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3) && t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED").ToList();
            _dueSoonCount = _dueSoon.Count();
            _underReviewCount = tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
            _completedCount = tasks.Count(t => t.StatusCode == "COMPLETED");
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenTask(Guid id)
    {
        // route exists: /assistant/task/{TaskId}
        Nav.NavigateTo($"/assistant/task/{id}");
    }

    private string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "—";
    }

    private Color GetStatusColor(string status) => status switch
    {
        "ASSIGNED" => Color.Info,
        "UNDER_REVIEW" => Color.Secondary,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Default,
        _ => Color.Default
    };
}
