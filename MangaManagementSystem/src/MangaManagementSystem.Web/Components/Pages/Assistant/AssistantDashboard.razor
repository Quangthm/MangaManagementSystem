@page "/assistant"

@inject NavigationManager Nav
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject MangaManagementSystem.Application.Interfaces.IChapterPageTaskService TaskService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Assistant Workspace</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">View assigned page tasks and track task progress.</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_loadError != null)
        {
            <MudAlert Severity="Severity.Error">Failed to load tasks: @_loadError</MudAlert>
        }
        else
        {
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="3"><StatCard Label="Assigned" Value="@_assignedCount.ToString()" Description="Tasks assigned to you" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Due Soon" Value="@_dueSoonCount.ToString()" Description="Within 3 days" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Under Review" Value="@_underReviewCount.ToString()" Description="Awaiting feedback" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Completed" Value="@_completedCount.ToString()" Description="Finished tasks" /></MudItem>
            </MudGrid>

            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">My Assigned Tasks</MudText>
                        @if (_tasks == null || !_tasks.Any())
                        {
                            <MudPaper Class="pa-6 text-center mf-card">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" Color="Color.Secondary" />
                                <MudText Typo="Typo.h6" Class="mt-2">No assigned tasks.</MudText>
                                <MudText Class="mf-muted">Tasks assigned to you will appear here.</MudText>
                            </MudPaper>
                        }
                        else
                        {
                            <MudTable Items="_tasks" Hover="true">
                                <HeaderContent>
                                    <MudTh>Type</MudTh>
                                    <MudTh>Series / Chapter</MudTh>
                                    <MudTh>Due</MudTh>
                                    <MudTh>Status</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.TypeCode</MudTd>
                                    <MudTd>@(context.SeriesTitle ?? "—") @(context.ChapterNumberLabel != null ? $"• {context.ChapterNumberLabel}" : "")</MudTd>
                                    <MudTd>@FormatDate(context.DueAtUtc)</MudTd>
                                    <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                                    <MudTd><MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(()=>OpenTask(context.ChapterPageTaskId))">View</MudButton></MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Due Soon</MudText>
                        @if (_dueSoon == null || !_dueSoon.Any())
                        {
                            <MudText Class="mf-muted">No tasks due soon.</MudText>
                        }
                        else
                        {
                            <MudList T="ChapterPageTaskDto">
                                @foreach (var t in _dueSoon)
                                {
                                    <MudListItem T="ChapterPageTaskDto" Value="@t">
                                        <MudText>@t.TypeCode â€” Id: @t.ChapterPageTaskId</MudText>
                                        <MudText class="mf-muted">@FormatDate(t.DueAtUtc)</MudText>
                                    </MudListItem>
                                }
                            </MudList>
                        }

                        <MudDivider Class="my-4" />
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/assistant/tasks">View All Tasks</MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _loadError;
    private IReadOnlyList<ChapterPageTaskDto>? _tasks;
    private IEnumerable<ChapterPageTaskDto>? _dueSoon;
    private int _assignedCount;
    private int _dueSoonCount;
    private int _underReviewCount;
    private int _completedCount;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _loadError = null;
        try
        {
            _tasks = await AssistantTaskClient.GetAssignedTasksAsync(_currentUserId);
            _assignedCount = _tasks.Count(t => t.StatusCode == "ASSIGNED");
            var now = DateTime.UtcNow;
            _dueSoon = _tasks.Where(t => t.DueAtUtc.HasValue && t.DueAtUtc.Value >= now && t.DueAtUtc.Value <= now.AddDays(3) && t.StatusCode != "COMPLETED" && t.StatusCode != "CANCELLED").ToList();
            _dueSoonCount = _dueSoon.Count();
            _underReviewCount = _tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
            _completedCount = _tasks.Count(t => t.StatusCode == "COMPLETED");
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OpenTask(Guid id) => Nav.NavigateTo($"/assistant/task/{id}");

    private string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("g") : "â€”";
    }

    private Color GetStatusColor(string status) => status switch
    {
        "ASSIGNED" => Color.Info,
        "UNDER_REVIEW" => Color.Secondary,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Default,
        _ => Color.Default
    };
}

