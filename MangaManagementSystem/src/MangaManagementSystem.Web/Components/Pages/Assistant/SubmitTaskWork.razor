@page "/assistant/task/{TaskId:guid}/submit"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IChapterPageTaskService TaskService
@inject ISnackbar Snackbar

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Submit Work</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Send completed work for editor review</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_task is null)
        {
            <MudAlert Severity="Severity.Warning">Task not found.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Submit Your Work</MudText>
                                <MudText Class="mf-muted">@_task.TypeCode — Task @_task.ChapterPageTaskId</MudText>
                            </div>
                            <StatusBadge Status="@_task.StatusCode" />
                        </MudStack>

                        <MudAlert Severity="Severity.Info" Class="mb-4">
                            File/page-version upload is not integrated in this commit. Submitting this form will only move an assigned task to UNDER_REVIEW using the existing task update service.
                        </MudAlert>

                        <div class="mf-canvas" style="min-height:260px">
                            Submission file upload placeholder<br />
                            Full file → FileResource → ChapterPageVersion integration is pending.
                        </div>

                        <MudText Typo="Typo.caption" Class="mf-muted mt-4 d-block">
                            Current due date: <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" />
                        </MudText>
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Task Summary</MudText>
                        <MudStack Spacing="1">
                            <MudText><strong>Type:</strong> @_task.TypeCode</MudText>
                            <MudText><strong>Priority:</strong> @_task.PriorityLevel</MudText>
                            <MudText><strong>Status:</strong> @_task.StatusCode</MudText>
                            <MudText><strong>Due:</strong> <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" /></MudText>
                            @if (_task.CompletedPageVersionId.HasValue)
                            {
                                <MudText><strong>Completed Version:</strong> @_task.CompletedPageVersionId</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Submission Notes</MudText>
                        <MudText Class="mf-muted mb-3">Notes are captured in the UI only in this commit. They are not persisted by the current backend contract.</MudText>
                        <MudTextField Lines="6" Label="Notes" @bind-Value="Notes" Variant="Variant.Outlined" />

                        @if (!CanSubmit)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mt-3">
                                Only tasks in ASSIGNED status can be submitted for review.
                            </MudAlert>
                        }

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Class="mt-3"
                                   Disabled="@(!CanSubmit || _submitting)"
                                   OnClick="SubmitAsync">
                            @(_submitting ? "Submitting..." : "Submit Final Work")
                        </MudButton>
                        <MudButton Variant="Variant.Text" FullWidth="true" Class="mt-2" Disabled="true">
                            Save Draft (Not Available)
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Class="mt-2" Href="@($"/assistant/task/{TaskId}")">
                            Back to Task Detail
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private string Notes { get; set; } = string.Empty;
    private bool _loading = true;
    private bool _submitting;
    private string? _error;
    private ChapterPageTaskDto? _task;

    private bool CanSubmit => _task is not null && string.Equals(_task.StatusCode, "ASSIGNED", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await TaskService.GetChapterPageTaskByIdAsync(TaskId);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load task: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task SubmitAsync()
    {
        if (_task is null)
        {
            _error = "Task not found.";
            return;
        }

        if (!CanSubmit)
        {
            _error = "Only tasks in ASSIGNED status can be submitted for review.";
            return;
        }

        _submitting = true;
        _error = null;

        try
        {
            var dto = new UpdateChapterPageTaskDto(
                _task.ChapterPageTaskId,
                _task.AssignedToUserId,
                _task.TypeCode,
                "UNDER_REVIEW",
                _task.PriorityLevel,
                _task.DueAtUtc,
                _task.CompletedPageVersionId,
                _task.PageRegions.Select(r => r.PageRegionId).ToList());

            var updated = await TaskService.UpdateChapterPageTaskAsync(dto);
            if (updated is null)
            {
                _error = "Task could not be updated. Please try again.";
                return;
            }

            Snackbar.Add("Task submitted for review.", Severity.Success);
            Nav.NavigateTo("/assistant/tasks");
        }
        catch (Exception ex)
        {
            _error = $"Failed to submit task for review: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
