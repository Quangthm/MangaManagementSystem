@page "/assistant/task/{TaskId:guid}/submit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<AssistantLayout>
    <div style="display: flex; flex-direction: column; height: 100%; background: #f8fafc;">
        @* ── Header ── *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; flex-shrink: 0;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    Submit Work
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">Upload completed work for Mangaka review</div>
            </div>
        </div>

        @* ── Scrollable Content ── *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (!string.IsNullOrWhiteSpace(_error))
            {
                <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem;">@_error</div>
            }
            else if (_task is null)
            {
                <div style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 12px 16px; color: #92400e; font-size: 0.85rem;">Task not found or not assigned to you.</div>
            }
            else
            {
                <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px;">
                    <div>
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 24px;">
                            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                                <div>
                                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">Submit Your Work</div>
                                    <div style="color: #94a3b8; font-size: 0.85rem;">@_task.TypeCode @(!string.IsNullOrWhiteSpace(_task.TaskTitle) ? $"— {_task.TaskTitle}" : "")</div>
                                </div>
                                <StatusBadge Status="@_task.StatusCode" />
                            </div>

                            @if (!CanSubmit)
                            {
                                <div style="background: #fffbeb; border: 1px solid #fde68a; border-radius: 8px; padding: 12px 16px; color: #92400e; font-size: 0.85rem; margin-bottom: 16px;">
                                    Only tasks in ASSIGNED status can be submitted for review. Current status: @_task.StatusCode
                                </div>
                            }
                            else
                            {
                                <div style="background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 12px 16px; color: #1e40af; font-size: 0.85rem; margin-bottom: 16px;">
                                    Upload your completed page image. Allowed: PNG, JPEG, WebP (max 10 MB).
                                </div>
                            }

                            <div style="margin-bottom: 16px;">
                                <InputFile OnChange="HandleFileSelected" disabled="@(!CanSubmit)" />
                                <div style="color: #94a3b8; font-size: 0.78rem; margin-top: 8px;">
                                    @if (_selectedFile != null)
                                    {
                                        <span>Selected: @_selectedFile.Name (@_fileSizeDisplay)</span>
                                    }
                                    else
                                    {
                                        <span>Click to select a file</span>
                                    }
                                </div>
                                @if (!string.IsNullOrWhiteSpace(_fileValidationError))
                                {
                                    <div style="background: #fef2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 12px 16px; color: #dc2626; font-size: 0.85rem; margin-top: 8px;">@_fileValidationError</div>
                                }
                            </div>

                            @* Source page reference *@
                            @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                            {
                                <div style="font-weight: 600; font-size: 0.85rem; color: #374151; margin-bottom: 8px;">Source Page Reference:</div>
                                <MudImage Src="@_task.PageImageUrl" MaxHeight="250" ObjectFit="ObjectFit.Contain" Class="rounded" />
                                <div style="margin-top: 4px;">
                                    <a href="@_task.PageImageUrl" target="_blank" style="color: #4f46e5; font-size: 0.85rem; text-decoration: none; font-weight: 500;">Download Source</a>
                                </div>
                            }
                        </div>
                    </div>

                    <div style="display: flex; flex-direction: column; gap: 16px;">
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                            <div style="font-weight: 700; font-size: 0.9rem; color: #111827; margin-bottom: 12px;">Task Summary</div>
                            <div style="display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem;">
                                <div><span style="color: #64748b;">Type:</span> <span style="color: #111827; font-weight: 500;">@_task.TypeCode</span></div>
                                <div><span style="color: #64748b;">Priority:</span> <span style="color: #111827; font-weight: 500;">@_task.PriorityLevel</span></div>
                                <div><span style="color: #64748b;">Status:</span> <span style="color: #111827; font-weight: 500;">@_task.StatusCode</span></div>
                                <div><span style="color: #64748b;">Due:</span> <span style="color: #111827; font-weight: 500;"><TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" /></span></div>
                            </div>
                        </div>

                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); padding: 20px 24px;">
                            <div class="mb-3">
                                <label style="display: block; font-size: 0.85rem; color: #374151; font-weight: 500; margin-bottom: 4px;">Submission Notes (optional)</label>
                                <textarea @bind="Notes" style="width: 100%; padding: 10px 12px; border: 1px solid #e2e8f0; border-radius: 8px; font-size: 0.85rem; color: #111827; resize: vertical; min-height: 80px; outline: none;" placeholder="Add notes..."></textarea>
                            </div>

                            <button @onclick="SubmitAsync" disabled="@(!CanSubmit || _selectedFile == null || _submitting)" style="background: #4f46e5; color: #fff; padding: 10px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.85rem; font-weight: 500; width: 100%; @(!CanSubmit || _selectedFile == null || _submitting ? "opacity: 0.5;" : "")">
                                @(_submitting ? "Submitting..." : "Submit Final Work")
                            </button>
                            <a href="@($"/assistant/task/{TaskId}")" style="border: 1px solid #e2e8f0; color: #374151; padding: 10px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; font-weight: 500; display: block; text-align: center; margin-top: 8px;">Back to Task Detail</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private const long MaxFileSizeBytes = 10 * 1024 * 1024;
    private readonly string[] AllowedFileTypes = new[] { "image/png", "image/jpeg", "image/jpg", "image/webp" };

    private Guid _currentUserId;
    private string Notes { get; set; } = string.Empty;
    private bool _loading = true;
    private bool _submitting;
    private string? _error;
    private ChapterPageTaskDto? _task;

    private IBrowserFile? _selectedFile;
    private string _fileSizeDisplay = string.Empty;
    private string _fileValidationError = string.Empty;

    private bool CanSubmit => _task is not null && string.Equals(_task.StatusCode, "ASSIGNED", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(_currentUserId, TaskId);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load task: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _fileValidationError = string.Empty;

        if (_selectedFile == null)
        {
            _fileSizeDisplay = string.Empty;
            return;
        }

        if (_selectedFile.Size > MaxFileSizeBytes)
        {
            _fileValidationError = $"File is too large. Maximum allowed is {MaxFileSizeBytes / (1024 * 1024)} MB.";
            _selectedFile = null;
            _fileSizeDisplay = string.Empty;
            return;
        }

        if (!AllowedFileTypes.Contains(_selectedFile.ContentType.ToLowerInvariant()))
        {
            _fileValidationError = "Unsupported file type. Allowed: PNG, JPEG, WebP.";
            _selectedFile = null;
            _fileSizeDisplay = string.Empty;
            return;
        }

        _fileSizeDisplay = $"{_selectedFile.Size / 1024} KB";
    }

    private async Task SubmitAsync()
    {
        if (_task is null || !CanSubmit || _selectedFile == null)
        {
            return;
        }

        _submitting = true;
        _error = null;

        try
        {
            var result = await AssistantTaskClient.SubmitTaskWorkAsync(_currentUserId, TaskId, _selectedFile, Notes);

            if (result != null)
            {
                Snackbar.Add("Task submitted for review.", Severity.Success);
                Nav.NavigateTo($"/assistant/task/{TaskId}");
            }
            else
            {
                _error = "Task submission failed. Please try again.";
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Submission failed: {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = $"Failed to submit: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
