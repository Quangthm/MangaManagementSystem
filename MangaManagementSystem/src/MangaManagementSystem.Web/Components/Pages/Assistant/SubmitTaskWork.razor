@page "/assistant/task/{TaskId:guid}/submit"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Forms
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Assistant")]
@inject NavigationManager Nav
@inject IAssistantTaskApiClient AssistantTaskClient
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<AssistantLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Submit Work</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Upload completed work for Mangaka review</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_task is null)
        {
            <MudAlert Severity="Severity.Warning">Task not found or not assigned to you.</MudAlert>
        }
        else
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <div>
                                <MudText Typo="Typo.h6" Class="font-weight-bold">Submit Your Work</MudText>
                                <MudText Class="mf-muted">@_task.TypeCode @(!string.IsNullOrWhiteSpace(_task.TaskTitle) ? $"— {_task.TaskTitle}" : "")</MudText>
                            </div>
                            <StatusBadge Status="@_task.StatusCode" />
                        </MudStack>

                        @if (!CanSubmit)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4">
                                Only tasks in ASSIGNED status can be submitted for review. Current status: @_task.StatusCode
                            </MudAlert>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Class="mb-4">
                                Upload your completed page image. Allowed: PNG, JPEG, WebP (max 10 MB).
                            </MudAlert>
                        }

                        <div class="mb-4">
                            <InputFile OnChange="HandleFileSelected" disabled="@(!CanSubmit)" />
                            <MudText Typo="Typo.caption" Class="mf-muted mt-2 d-block">
                                @if (_selectedFile != null)
                                {
                                    <span>Selected: @_selectedFile.Name (@_fileSizeDisplay)</span>
                                }
                                else
                                {
                                    <span>Click to select a file</span>
                                }
                            </MudText>
                            @if (!string.IsNullOrWhiteSpace(_fileValidationError))
                            {
                                <MudAlert Severity="Severity.Error" Class="mt-2">@_fileValidationError</MudAlert>
                            }
                        </div>

                        @* Source page reference *@
                        @if (!string.IsNullOrWhiteSpace(_task.PageImageUrl))
                        {
                            <MudText Typo="Typo.body2" Class="mb-2"><strong>Source Page Reference:</strong></MudText>
                            <MudImage Src="@_task.PageImageUrl" MaxHeight="250" ObjectFit="ObjectFit.Contain" Class="rounded" />
                            <MudButton Variant="Variant.Text" Size="Size.Small" Href="@_task.PageImageUrl" Target="_blank" Class="mt-1">Download Source</MudButton>
                        }
                    </MudPaper>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-4" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Task Summary</MudText>
                        <MudStack Spacing="1">
                            <MudText><strong>Type:</strong> @_task.TypeCode</MudText>
                            <MudText><strong>Priority:</strong> @_task.PriorityLevel</MudText>
                            <MudText><strong>Status:</strong> @_task.StatusCode</MudText>
                            <MudText><strong>Due:</strong> <TimestampDisplay Value="@_task.DueAtUtc" EmptyText="No deadline set" /></MudText>
                            @if (_task.CompensationAmount.HasValue)
                            {
                                <MudText><strong>Compensation:</strong> @_task.CompensationAmount.Value.ToString("C2")</MudText>
                            }
                        </MudStack>
                    </MudPaper>

                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudTextField Lines="4" Label="Submission Notes (optional)" @bind-Value="Notes" Variant="Variant.Outlined" Class="mb-3" />

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Disabled="@(!CanSubmit || _selectedFile == null || _submitting)"
                                   OnClick="SubmitAsync">
                            @(_submitting ? "Submitting..." : "Submit Final Work")
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" FullWidth="true" Class="mt-2" Href="@($"/assistant/task/{TaskId}")">
                            Back to Task Detail
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }
    </div>
</AssistantLayout>

@code {
    [Parameter] public Guid TaskId { get; set; }

    private const long MaxFileSizeBytes = 10 * 1024 * 1024;
    private readonly string[] AllowedFileTypes = new[] { "image/png", "image/jpeg", "image/jpg", "image/webp" };

    private Guid _currentUserId;
    private string Notes { get; set; } = string.Empty;
    private bool _loading = true;
    private bool _submitting;
    private string? _error;
    private ChapterPageTaskDto? _task;

    private IBrowserFile? _selectedFile;
    private string _fileSizeDisplay = string.Empty;
    private string _fileValidationError = string.Empty;

    private bool CanSubmit => _task is not null && string.Equals(_task.StatusCode, "ASSIGNED", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTaskAsync();
    }

    private async Task LoadTaskAsync()
    {
        _loading = true;
        _error = null;

        try
        {
            _task = await AssistantTaskClient.GetTaskDetailAsync(_currentUserId, TaskId);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load task: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _fileValidationError = string.Empty;

        if (_selectedFile == null)
        {
            _fileSizeDisplay = string.Empty;
            return;
        }

        if (_selectedFile.Size > MaxFileSizeBytes)
        {
            _fileValidationError = $"File is too large. Maximum allowed is {MaxFileSizeBytes / (1024 * 1024)} MB.";
            _selectedFile = null;
            _fileSizeDisplay = string.Empty;
            return;
        }

        if (!AllowedFileTypes.Contains(_selectedFile.ContentType.ToLowerInvariant()))
        {
            _fileValidationError = "Unsupported file type. Allowed: PNG, JPEG, WebP.";
            _selectedFile = null;
            _fileSizeDisplay = string.Empty;
            return;
        }

        _fileSizeDisplay = $"{_selectedFile.Size / 1024} KB";
    }

    private async Task SubmitAsync()
    {
        if (_task is null || !CanSubmit || _selectedFile == null)
        {
            return;
        }

        _submitting = true;
        _error = null;

        try
        {
            var result = await AssistantTaskClient.SubmitTaskWorkAsync(_currentUserId, TaskId, _selectedFile, Notes);

            if (result != null)
            {
                Snackbar.Add("Task submitted for review.", Severity.Success);
                Nav.NavigateTo($"/assistant/task/{TaskId}");
            }
            else
            {
                _error = "Task submission failed. Please try again.";
            }
        }
        catch (HttpRequestException ex)
        {
            _error = $"Submission failed: {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = $"Failed to submit: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
