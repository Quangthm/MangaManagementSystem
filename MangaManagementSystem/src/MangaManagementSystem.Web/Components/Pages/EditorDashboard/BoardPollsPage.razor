            Status = "Open"
        },
        new()
        {
            Id = "poll-001",
            Code = "MNG-001",
            Name = "Serialization Vote — Celestial Blade Chronicles",
            Type = "START_SERIALIZATION",
            Deadline = new DateTime(2026, 6, 1),
            Approve = 8,
