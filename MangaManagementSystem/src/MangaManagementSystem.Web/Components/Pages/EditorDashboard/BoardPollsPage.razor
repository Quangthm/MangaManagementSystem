            Status = "Open"
        },
        new()
        {
            Id = "poll-015",
            Code = "MNG-015",
            Name = "Cancellation Review — Velocity Kings",
            Type = "CANCEL_SERIALIZATION",
            Deadline = new DateTime(2026, 6, 12),
            Approve = 4,
