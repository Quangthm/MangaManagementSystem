    // Chapter logic
    public class ChapterModel
    {
        public int Id { get; set; }
        public int PageCount { get; set; }
        public bool IsCompleted { get; set; }
        public List<PageModel> Pages { get; set; } = new();
    }

    private List<ChapterModel> Chapters = new();
    private string SeriesTitle = "The Supreme Cultivation Manual";
    private string SeriesSubtitle = "Σ┐«Σ╗Öτºÿτ▒ì - Ti├¬n hiß╗çp";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        // Resolve actor user ID from auth state.
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var uid))
                _currentUserId = uid;
        }
        catch { }

        // Workspace access guard: resolve slug → SeriesId and verify series-specific access.
        if (string.IsNullOrWhiteSpace(Slug) || !_currentUserId.HasValue)
        {
            _accessDenied = true;
            return;
        }

        try
        {
            var entry = await SeriesApiClient.GetWorkspaceEntryAsync(_currentUserId.Value, Slug);
            if (entry is null || !entry.CanAccess)
            {
                _accessDenied = true;
                return;
            }

            SeriesId = entry.SeriesId.ToString();
        }
        catch
        {
            _accessDenied = true;
            return;
        }

        await LoadSeriesDataAsync();
    }

    private async Task LoadSeriesDataAsync()
    {
        if (!string.IsNullOrWhiteSpace(SeriesId) && Guid.TryParse(SeriesId, out Guid id))
        {
            var series = await SeriesService.GetSeriesByIdAsync(id);
            if (series != null)
            {
                SeriesTitle = series.Title;
                SeriesSubtitle = series.Genre;
                
                var chapters = await ChapterService.GetChaptersBySeriesIdAsync(id);
                if (chapters != null && chapters.Any())
                {
                    Chapters = chapters.Select((c, i) => new ChapterModel 
                    { 
                        Id = int.TryParse(c.ChapterNumberLabel, out int num) ? num : (i + 1), 
                        PageCount = 0, // Placeholder, update if you have page counts
                        IsCompleted = c.StatusCode == "PUBLISHED"
                    }).OrderBy(c => c.Id).ToList();
                    
                    if (Chapters.Any())
                    {
                        SelectedChapter = Chapters.First().Id;
                    }
                }
                else
                {
                    Chapters = new List<ChapterModel>();
                }
                return;
            }
        }
        
        SetupDefaultSeries();
    }

    private void SetupDefaultSeries()
    {
        SeriesTitle = "The Supreme Cultivation Manual";
        SeriesSubtitle = "Σ┐«Σ╗Öτºÿτ▒ì - Ti├¬n hiß╗çp";
        Chapters = new List<ChapterModel>
        {
            new ChapterModel { Id = 40, PageCount = 11, IsCompleted = true },
            new ChapterModel { Id = 41, PageCount = 9, IsCompleted = true },
            new ChapterModel { Id = 42, PageCount = 12, IsCompleted = false },
            new ChapterModel { Id = 43, PageCount = 8, IsCompleted = false },
            new ChapterModel { Id = 44, PageCount = 6, IsCompleted = false }
        };
        SelectedChapter = 42;
    }

    private async Task SelectChapter(int chapterId)
