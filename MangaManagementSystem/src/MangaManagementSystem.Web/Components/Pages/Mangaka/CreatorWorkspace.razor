    private DotNetObjectReference<CreatorWorkspace>? _objRef;

    private void SaveProgress()
    {
        Snackbar.Add("Progress saved successfully!", Severity.Success);
    }

    private void ExportCurrentPage()
    {
        Snackbar.Add("Page exported successfully!", Severity.Info);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var version = DateTime.Now.Ticks;
            _module = await JS.InvokeAsync<IJSObjectReference>("import", $"/js/mangaAiCanvas.js?v={version}");
            _objRef = DotNetObjectReference.Create(this);
            await _module.InvokeVoidAsync("initCanvas", "ai-canvas", "ai-canvas-container", _objRef);
            
            // Wait for user to upload an image.
            Snackbar.Add("Please upload an image to begin.", Severity.Info);
        }
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        try
        {
            if (SelectedChapter == 0)
            {
                if (!Chapters.Any())
                {
                    await AddNewChapter();
                }
                else
                {
                    Snackbar.Add("Please select a chapter first.", Severity.Warning);
                    return;
                }
            }

            var files = e.GetMultipleFiles(100);
            if (files.Any())
            {
                foreach (var file in files)
                {
                    using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 20);
                    using var memoryStream = new MemoryStream();
                    await stream.CopyToAsync(memoryStream);
                    var base64 = Convert.ToBase64String(memoryStream.ToArray());
                    var dataUrl = $"data:{file.ContentType};base64,{base64}";
                    
                    var activeChap = Chapters.FirstOrDefault(c => c.Id == SelectedChapter);
                    if (activeChap != null)
                    {
                        var newPage = new PageModel();
                        newPage.Versions.Add(new PageVersionModel { VersionNo = 1, DataUrl = dataUrl, Note = "Original Upload" });
                        activeChap.Pages.Add(newPage);
                    }
                }
                
                var chap = Chapters.FirstOrDefault(c => c.Id == SelectedChapter);
                if (chap != null) chap.PageCount = chap.Pages.Count;

                await LoadPage(ActivePageIndex == 0 ? 0 : ActivePageIndex);
                Snackbar.Add($"Loaded {files.Count} page(s) successfully!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error uploading: {ex.Message}", Severity.Error);
        }
    }

    private void OnPageChanged(int pageNumber)
    {
        // MudPagination pageNumber is 1-indexed
        _ = LoadPage(pageNumber - 1);
    }

    private async Task LoadPage(int index)
    {
        if (index >= 0 && index < UploadedPages.Count)
        {
            var page = UploadedPages[index];
            
            ActivePageIndex = index;
            SelectedPage = index + 1; // update the header number
            
            if (page.Versions.Any())
            {
                var activeVersion = page.Versions[page.ActiveVersionIndex];
                await _module.InvokeVoidAsync("loadImage", activeVersion.DataUrl);
                if (!string.IsNullOrEmpty(activeVersion.Regions))
                {
                    await _module.InvokeVoidAsync("loadRegions", activeVersion.Regions);
                }
                else
                {
                    await _module.InvokeVoidAsync("loadRegions", "[]");
                }
            }
            
            await SyncAnnotationsToJS();
            StateHasChanged();
        }
    }

    private async Task DeleteCurrentPage()
    {
        if (UploadedPages.Any())
        {
            bool? result = await DialogService.ShowMessageBox(
                "Delete Page", 
                "Are you sure you want to delete this page?", 
                yesText: "Delete", cancelText: "Cancel");

            if (result == true)
            {
                UploadedPages.RemoveAt(ActivePageIndex);
                
                var activeChap = Chapters.FirstOrDefault(c => c.Id == SelectedChapter);
                if (activeChap != null) activeChap.PageCount = UploadedPages.Count;

                if (UploadedPages.Count == 0)
                {
                    ActivePageIndex = 0;
                    if (_module != null)
                        await _module.InvokeVoidAsync("loadImage", ""); // clear canvas
                    Snackbar.Add("All pages deleted.", Severity.Info);
                }
                else
                {
                    if (ActivePageIndex >= UploadedPages.Count)
                        ActivePageIndex = UploadedPages.Count - 1;
                    await LoadPage(ActivePageIndex);
                }
                StateHasChanged();
            }
        }
    }

    private async Task SwitchVersion(int versionIndex, bool isDeleting = false)
    {
        if (UploadedPages.Count > ActivePageIndex)
        {
            var page = UploadedPages[ActivePageIndex];
            
            // Auto-save the current canvas background before switching
            if (!isDeleting && page.Versions.Any() && _module != null)
            {
                page.Versions[page.ActiveVersionIndex].DataUrl = await _module.InvokeAsync<string>("exportImage");
            }

            if (versionIndex >= 0 && versionIndex < page.Versions.Count)
            {
                page.ActiveVersionIndex = versionIndex;
                var activeVersion = page.Versions[versionIndex];
                if (_module != null)
                {
                    await _module.InvokeVoidAsync("loadImage", activeVersion.DataUrl);
                    if (!string.IsNullOrEmpty(activeVersion.Regions))
                    {
                        await _module.InvokeVoidAsync("loadRegions", activeVersion.Regions);
                    }
                    else
                    {
                        await _module.InvokeVoidAsync("loadRegions", "[]");
                    }
                }
                StateHasChanged();
            }
        }
    }

    private async Task SaveAsNewVersion()
    {
        if (UploadedPages.Any() && _module != null)
        {
            var dataUrl = await _module.InvokeAsync<string>("exportImage");
            var page = UploadedPages[ActivePageIndex];
            
            int nextVersionNo = page.Versions.Any() ? page.Versions.Max(v => v.VersionNo) + 1 : 1;
            
            page.Versions.Add(new PageVersionModel 
            {
                VersionNo = nextVersionNo,
                Regions = "[]", // DO NOT CLONE REGIONS!
                DataUrl = dataUrl,
                Note = $"New Version {nextVersionNo}"
            });
            page.ActiveVersionIndex = page.Versions.Count - 1;
            await SwitchVersion(page.ActiveVersionIndex);
            
            Snackbar.Add($"Created New Version {nextVersionNo}", Severity.Success);
            StateHasChanged();
        }
    }

    private async Task UploadNewVersion(IBrowserFile file)
    {
        if (file != null && UploadedPages.Any())
        {
            try
            {
                using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 20);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                var base64 = Convert.ToBase64String(memoryStream.ToArray());
                var dataUrl = $"data:{file.ContentType};base64,{base64}";
                
                var page = UploadedPages[ActivePageIndex];
                int nextVersionNo = page.Versions.Any() ? page.Versions.Max(v => v.VersionNo) + 1 : 1;
                
                page.Versions.Add(new PageVersionModel
                {
                    VersionNo = nextVersionNo,
                    Regions = "[]",
                    DataUrl = dataUrl,
                    Note = $"Uploaded Revision {nextVersionNo}"
                });
                
                page.ActiveVersionIndex = page.Versions.Count - 1;
                await SwitchVersion(page.ActiveVersionIndex);
                Snackbar.Add($"Uploaded Revision {nextVersionNo}", Severity.Success);
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to upload revision: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteCurrentVersion()
    {
        if (UploadedPages.Any())
        {
            var page = UploadedPages[ActivePageIndex];
            if (page.Versions.Count > 1)
            {
                bool? result = await DialogService.ShowMessageBox(
                    "Delete Version", 
                    $"Are you sure you want to delete Version {page.Versions[page.ActiveVersionIndex].VersionNo}?", 
                    yesText: "Delete", cancelText: "Cancel");

                if (result == true)
                {
                    page.Versions.RemoveAt(page.ActiveVersionIndex);
                    // Switch to the previous version
                    int nextIndex = Math.Max(0, page.Versions.Count - 1);
                    await SwitchVersion(nextIndex, isDeleting: true);
                    Snackbar.Add("Version deleted.", Severity.Info);
                }
            }
        }
    }

    private async Task SetTool(string tool)
    {
        CurrentTool = tool;
        await _module.InvokeVoidAsync("setTool", tool);
    }

    private async Task ZoomIn() => await _module.InvokeVoidAsync("zoom", 1.2);
    private async Task ZoomOut() => await _module.InvokeVoidAsync("zoom", 0.8);

    private async Task ApproveSelectedRegions() => await _module.InvokeVoidAsync("approveSelectedRegions");
    private async Task DeleteSelectedRegions() => await _module.InvokeVoidAsync("deleteSelectedRegions");

    private async Task Undo() => await _module.InvokeVoidAsync("undo");
    private async Task Redo() => await _module.InvokeVoidAsync("redo");

    private async Task RunSegmentAI()
    {
        IsProcessing = true;
        StateHasChanged();
        
        Snackbar.Add("Running Segmentation...", Severity.Info);
        var successSegment = await _module.InvokeAsync<bool>("callSegmentAPI");
        
        IsProcessing = false;
        StateHasChanged();
        
        if (successSegment) {
            Snackbar.Add("Segmentation complete.", Severity.Success);
        } else {
            Snackbar.Add("Segmentation failed.", Severity.Error);
        }
    }

    private async Task RunTranslateAI()
    {
        IsProcessing = true;
        StateHasChanged();
        
        Snackbar.Add("Running Translation...", Severity.Info);
        var successTranslate = await _module.InvokeAsync<bool>("callTranslateAPI");
        
        IsProcessing = false;
        StateHasChanged();
        
        if (successTranslate) {
            Snackbar.Add("Translation complete.", Severity.Success);
            if (UploadedPages.Any())
            {
                var page = UploadedPages[ActivePageIndex];
                if (page.Versions.Any())
                {
                    page.Versions[page.ActiveVersionIndex].DataUrl = await _module.InvokeAsync<string>("exportImage");
                }
            }
        } else {
            Snackbar.Add("Translation failed.", Severity.Error);
        }
    }

    [JSInvokable]
    public void OnRegionsUpdated(string newRegionsStr, bool canUndo, bool canRedo)
    {
        CanUndo = canUndo;
        CanRedo = canRedo;
        
        if (UploadedPages.Count > ActivePageIndex)
        {
            var page = UploadedPages[ActivePageIndex];
            if (page.Versions.Any())
            {
                page.Versions[page.ActiveVersionIndex].Regions = newRegionsStr;
            }
        }
        
        SelectedRegions.Clear();
        if (!string.IsNullOrEmpty(newRegionsStr))
        {
            try
            {
                var options = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var allRegions = System.Text.Json.JsonSerializer.Deserialize<List<RegionModel>>(newRegionsStr, options);
                if (allRegions != null)
                {
                    SelectedRegions = allRegions.Where(r => r.Selected).ToList();
                }
            }
            catch { }
        }
        StateHasChanged();
    }

    public void Dispose()
    {
        _objRef?.Dispose();
    }

    public class RegionModel
    {
        public int Id { get; set; }
        public double X { get; set; }
        public double Y { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
        public bool Selected { get; set; }
        public string? OriginalText { get; set; }
        public string? TranslatedText { get; set; }
    }
}
