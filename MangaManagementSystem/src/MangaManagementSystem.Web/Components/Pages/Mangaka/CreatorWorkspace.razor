    // ── New chapter ──

    private void OnNewChapterFileSelected(IBrowserFile file)
    {
        if (file == null) return;
        _newChapterFileName = file.Name;
        _newChapterFileSize = file.Size;
        using var s = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
        using var ms = new MemoryStream();
        s.CopyTo(ms);
        _newChapterFileBytes = ms.ToArray();
        StateHasChanged();
    }

    private async Task ConfirmNewChapter()
    {
        if (string.IsNullOrWhiteSpace(_newChapterName)) return;

        var newNo = _newChapterNo ?? (_chapters.MaxBy(c => c.Number)?.Number ?? 0) + 1;

        if (!_demoMode)
        {
            try
            {
                var dto = new CreateChapterDto(
                    SeriesId: SeriesId,
                    ChapterNumberLabel: newNo.ToString(),
                    ChapterTitle: _newChapterName.Trim(),
                    StatusCode: "DRAFT",
                    PlannedReleaseDate: null
                );
                var created = await ChapterService.CreateChapterAsync(dto);

                for (int p = 1; p <= _newChapterPages; p++)
                {
                    await ChapterPageService.CreateChapterPageAsync(
                        new CreateChapterPageDto(
                            ChapterId: created.ChapterId,
                            PageNo: p,
                            PageNotes: null
                        )
                    );
                }

                Snackbar.Add($"Chapter {newNo} created with {_newChapterPages} pages", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to create chapter on server: {ex.Message}", Severity.Warning);
            }
        }

        _chapters.Add(new ChapterInfo(newNo, _newChapterName.Trim(), _newChapterPages));
        _newChapterDialogOpen = false;
        _newChapterNo = null;
        _newChapterName = "";
        _newChapterPages = 20;
        _newChapterFileBytes = null;
        _newChapterFileName = null;
        _newChapterFileSize = 0;
        StateHasChanged();
    }

