@page "/mangaka/workspace/{SeriesId}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Mangaka")]
@inject NavigationManager Nav

<MangakaLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">@CurrentSeries.Title</MudText>
                    <MudText Typo="Typo.body1" Class="mf-muted">@CurrentSeries.Subtitle</MudText>
                </div>
                <MudButton Variant="@(_taskPanelOpen ? Variant.Filled : Variant.Outlined)"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Assignment"
                           OnClick="@(() => _taskPanelOpen = !_taskPanelOpen)">
                    @(_taskPanelOpen ? "Close Task" : "Assign Task")
                </MudButton>
            </MudStack>
        </div>

        <!-- Hierarchy breadcrumb -->
        <MudBreadcrumbs Items="BreadcrumbItems" Class="px-0 mb-3" />

        <MudGrid>
            <!-- LEFT: Compact navigator card -->
            <MudItem xs="12" md="3">
                <MudPaper Class="pa-4 mf-card" Elevation="0">
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mf-muted mb-3">Navigator</MudText>

                    <!-- Chapter prev/next + dropdown -->
                    <MudText Typo="Typo.caption" Class="mf-muted mb-1 d-block">Chapter</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-4">
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Size="Size.Small"
                                       Disabled="@(CurrentChapterIndex <= 0)"
                                       OnClick="PrevChapter" />
                        <MudSelect T="int" Value="SelectedChapterNo" ValueChanged="OnChapterSelected"
                                   Variant="Variant.Outlined" Dense="true"
                                   Style="flex:1; min-width:0;">
                            @foreach (var chapter in CurrentSeries.Chapters)
                            {
                                <MudSelectItem Value="@chapter.Number">Ch. @chapter.Number</MudSelectItem>
                            }
                        </MudSelect>
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Size="Size.Small"
                                       Disabled="@(CurrentChapterIndex >= CurrentSeries.Chapters.Count - 1)"
                                       OnClick="NextChapter" />
                    </MudStack>

                    <!-- Page prev/next navigator -->
                    <MudText Typo="Typo.caption" Class="mf-muted mb-1 d-block">Page</MudText>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Spacing="1">
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                       Size="Size.Small"
                                       Disabled="@(SelectedPage <= 1)"
                                       OnClick="PrevPage" />
                        <MudText Typo="Typo.body2" Class="font-weight-bold" Style="white-space:nowrap;">
                            @SelectedPage / @SelectedChapterPageCount
                        </MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                       Size="Size.Small"
                                       Disabled="@(SelectedPage >= SelectedChapterPageCount || SelectedChapterPageCount == 0)"
                                       OnClick="NextPage" />
                    </MudStack>

                    <MudDivider Class="my-3" />
                    <MudText Typo="Typo.caption" Class="mf-muted">
                        Ch. @SelectedChapterNo &nbsp;·&nbsp; Pg. @SelectedPage of @SelectedChapterPageCount
                    </MudText>
                </MudPaper>
            </MudItem>

            <!-- CENTER: Page preview canvas -->
            <MudItem xs="12" md="9">
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6">
                            Chapter @SelectedChapterNo · Page @SelectedPage of @SelectedChapterPageCount
                        </MudText>
                        <MudChip T="string" Color="Color.Primary">Draft</MudChip>
                    </MudStack>

                    <div class="mf-canvas">
                        Manga page preview canvas<br />
                        Chapter @SelectedChapterNo — Page @SelectedPage / @SelectedChapterPageCount<br />
                        Example dialogue text / More dialogue here...
                    </div>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </div>

    <!-- Right-side Task Assignment drawer — overlays viewport, no scroll needed -->
    <MudDrawer @bind-Open="_taskPanelOpen"
               Anchor="Anchor.End"
               Variant="DrawerVariant.Temporary"
               Elevation="4"
               Width="400px"
               ClipMode="DrawerClipMode.Never">
        <MudDrawerHeader>
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Style="width:100%">
                <div>
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Assign Task</MudText>
                    <MudText Typo="Typo.caption" Class="mf-muted">
                        Chapter @SelectedChapterNo, Page @SelectedPage
                    </MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _taskPanelOpen = false)" />
            </MudStack>
        </MudDrawerHeader>

        <div class="pa-4">
            <MudSelect T="string" Label="Task Type" @bind-Value="TaskType"
                       Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem Value="@("Tone Shading")">Tone Shading</MudSelectItem>
                <MudSelectItem Value="@("Background Drawing")">Background Drawing</MudSelectItem>
                <MudSelectItem Value="@("Cleanup")">Cleanup</MudSelectItem>
            </MudSelect>

            <MudTextField Label="Assign to" @bind-Value="AssistantName"
                          Variant="Variant.Outlined" Class="mb-3" />

            <MudTextField Label="Instructions" Lines="4" @bind-Value="Instructions"
                          Variant="Variant.Outlined" Class="mb-3" />

            <MudAlert Severity="Severity.Warning" Class="mb-3">
                <MudText Typo="Typo.caption" Class="font-weight-bold">Coming Soon</MudText>
                <MudText Class="mt-1">Task assignment requires backend implementation.</MudText>
            </MudAlert>

            <MudButton FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                       Class="mb-2" Disabled="true">Assign Task (Disabled)</MudButton>
            <MudButton FullWidth="true" Variant="Variant.Text" Disabled="true">Save Draft (Disabled)</MudButton>
        </div>
    </MudDrawer>
</MangakaLayout>

@code {

    [Parameter] public string? SeriesId { get; set; }

    private int SelectedChapterNo { get; set; }
    private int SelectedPage { get; set; } = 1;
    private bool _taskPanelOpen = false;
    private string TaskType { get; set; } = "Tone Shading";
    private string AssistantName { get; set; } = "";
    private string Instructions { get; set; } = "";

    private SeriesDetail CurrentSeries { get; set; } = new();

    private int CurrentChapterIndex =>
        CurrentSeries.Chapters.FindIndex(c => c.Number == SelectedChapterNo);

    private int SelectedChapterPageCount =>
        CurrentSeries.Chapters.FirstOrDefault(c => c.Number == SelectedChapterNo)?.PageCount ?? 0;

    private List<BreadcrumbItem> BreadcrumbItems => new()
    {
        new BreadcrumbItem(CurrentSeries.Title, href: null, disabled: true),
        new BreadcrumbItem($"Chapter {SelectedChapterNo}", href: null, disabled: true),
        new BreadcrumbItem($"Page {SelectedPage}", href: null, disabled: true)
    };

    protected override void OnInitialized()
    {
        CurrentSeries = LoadSeries(SeriesId);
        SelectedChapterNo = CurrentSeries.Chapters.FirstOrDefault()?.Number ?? 1;
        SelectedPage = 1;
    }

    private void OnChapterSelected(int chapterNo)
    {
        SelectedChapterNo = chapterNo;
        SelectedPage = 1;
    }

    private void PrevChapter()
    {
        var idx = CurrentChapterIndex;
        if (idx > 0)
            OnChapterSelected(CurrentSeries.Chapters[idx - 1].Number);
    }

    private void NextChapter()
    {
        var idx = CurrentChapterIndex;
        if (idx < CurrentSeries.Chapters.Count - 1)
            OnChapterSelected(CurrentSeries.Chapters[idx + 1].Number);
    }

    private void PrevPage() { if (SelectedPage > 1) SelectedPage--; }
    private void NextPage() { if (SelectedPage < SelectedChapterPageCount) SelectedPage++; }

    private static SeriesDetail LoadSeries(string? seriesId) => new()
    {
        Title = "Crimson Moon Academy",
        Subtitle = "紅月学院",
        Chapters = new()
        {
            new ChapterInfo(10, 20),
            new ChapterInfo(11, 22),
            new ChapterInfo(12, 24),
            new ChapterInfo(13, 18)
        }
    };

    private class SeriesDetail
    {
        public string Title { get; set; } = "";
        public string Subtitle { get; set; } = "";
        public List<ChapterInfo> Chapters { get; set; } = new();
    }

    private record ChapterInfo(int Number, int PageCount);
}
