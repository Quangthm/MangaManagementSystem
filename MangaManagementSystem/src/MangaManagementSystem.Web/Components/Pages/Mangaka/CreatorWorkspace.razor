            chapter.IsCompleted = !chapter.IsCompleted;
            StateHasChanged();
        }
    }

    private async Task AddNewChapter()
    {
        int newId = Chapters.Any() ? Chapters.Max(c => c.Id) + 1 : 1;
        Chapters.Add(new ChapterModel { Id = newId, PageCount = 0, IsCompleted = false });
        await SelectChapter(newId);
