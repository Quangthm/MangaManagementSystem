    private async Task DeleteCurrentPage()
    {
        if (IsChapterLocked) return;
        if (UploadedPages.Any())
        {
            var pageToDelete = UploadedPages[ActivePageIndex];
            bool? result = await DialogService.ShowMessageBox(
                "Delete Page", 
                "Are you sure you want to delete this page?", 
                yesText: "Delete", cancelText: "Cancel");

            if (result == true)
            {
                try
                {
                    if (pageToDelete.ChapterPageId != Guid.Empty)
                    {
                        var success = await PageService.DeleteChapterPageAsync(pageToDelete.ChapterPageId, _currentUserId.Value);
                        if (!success)
                        {
                            Snackbar.Add("Failed to delete page from database.", Severity.Error);
                            return;
                        }
                    }

                    UploadedPages.RemoveAt(ActivePageIndex);
                    
                    var activeChap = Chapters.FirstOrDefault(c => c.Id == SelectedChapter);
                    if (activeChap != null) activeChap.PageCount = UploadedPages.Count;

                    if (UploadedPages.Count == 0)
                    {
                        ActivePageIndex = 0;
                        if (_leftCanvasRef != null)
                            await _leftCanvasRef.InvokeVoidAsync("loadImage", ""); // clear canvas
                        Snackbar.Add("All pages deleted.", Severity.Info);
                    }
                    else
                    {
                        if (ActivePageIndex >= UploadedPages.Count)
                            ActivePageIndex = UploadedPages.Count - 1;
                        await LoadPage(ActivePageIndex);
                        Snackbar.Add("Page deleted.", Severity.Success);
                    }
                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error deleting page: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private async Task SwitchVersion(string pane, int versionIndex, bool isDeleting = false)
    {
        var page = pane == "Left" ? UploadedPages.ElementAtOrDefault(ActivePageIndex) : _splitUploadedPages.ElementAtOrDefault(_splitPageIndex);
        var canvas = pane == "Left" ? _leftCanvasRef : _rightCanvasRef;

        if (page == null) return;
        
        // Auto-save the current canvas background before switching
        if (!isDeleting && page.Versions.Any() && canvas != null && page.ActiveVersionIndex >= 0 && page.ActiveVersionIndex < page.Versions.Count && page.ActiveVersionIndex != versionIndex)
        {
            page.Versions[page.ActiveVersionIndex].DataUrl = await canvas.InvokeAsync<string>("exportImage");
        }

        if (versionIndex >= 0 && versionIndex < page.Versions.Count)
        {
            page.ActiveVersionIndex = versionIndex;
            var activeVersion = page.Versions[versionIndex];
            if (canvas != null)
            {
                await canvas.InvokeVoidAsync("loadImage", activeVersion.DataUrl);
                if (!string.IsNullOrEmpty(activeVersion.Regions))
                {
                    await canvas.InvokeVoidAsync("loadRegions", activeVersion.Regions);
                }
                else
                {
                    await canvas.InvokeVoidAsync("loadRegions", "[]");
                }
            }
            StateHasChanged();
        }
    }

    private async Task SaveAsNewVersion(string pane)
    {
        var page = pane == "Left" ? UploadedPages.ElementAtOrDefault(ActivePageIndex) : _splitUploadedPages.ElementAtOrDefault(_splitPageIndex);
        var canvas = pane == "Left" ? _leftCanvasRef : _rightCanvasRef;

        if (page != null && canvas != null)
        {
            IsProcessing = true;
            StateHasChanged();
            Snackbar.Add("Saving new version to cloud...", Severity.Info);

            try
            {
                var dataUrl = await canvas.InvokeAsync<string>("exportImage");
                
                int nextVersionNo = page.Versions.Any() ? page.Versions.Max(v => v.VersionNo) + 1 : 1;
                
                var commaIndex = dataUrl.IndexOf(',');
                var base64Data = dataUrl.Substring(commaIndex + 1);
                var bytes = Convert.FromBase64String(base64Data);

                var uploadResult = await FileStorageService.UploadFileAsync(bytes, $"page_{SelectedPage}_v{nextVersionNo}.png", "image/png", "CHAPTER_PAGE_VERSION");
                
                var fileResourceDto = await FileResourceService.CreateFileResourceAsync(new CreateFileResourceDto(
                    FilePurposeCode: "CHAPTER_PAGE_VERSION",
                    OriginalFileName: uploadResult.OriginalFileName,
                    CloudinaryPublicId: uploadResult.PublicId,
                    CloudinarySecureUrl: uploadResult.SecureUrl,
                    ContentType: uploadResult.ContentType,
                    FileSizeBytes: uploadResult.FileSizeBytes,
                    Sha256Hash: uploadResult.Sha256Hash,
                    UploadedByUserId: _currentUserId
                ));

                var versionDto = await VersionService.CreateChapterPageVersionAsync(new CreateChapterPageVersionDto(
                    ChapterPageId: page.ChapterPageId,
                    VersionNo: (short)nextVersionNo,
                    PageFileId: fileResourceDto.FileResourceId,
                    VersionNote: $"New Version {nextVersionNo}"
                ));
                
                var newVersionModel = new PageVersionModel 
                {
                    ChapterPageVersionId = versionDto.ChapterPageVersionId,
                    VersionNo = nextVersionNo,
                    Regions = "[]", // DO NOT CLONE REGIONS!
                    DataUrl = dataUrl,
                    Note = $"New Version {nextVersionNo}"
                };
                page.Versions.Add(newVersionModel);
                
                await SetActiveVersion(pane, newVersionModel);
                
                await SwitchVersion(pane, page.Versions.Count - 1);
                
                Snackbar.Add($"Created New Version {nextVersionNo}", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Failed to save version: {ex.Message}", Severity.Error);
            }
            finally
            {
                IsProcessing = false;
                StateHasChanged();
            }
        }
    }

    private async Task SetActiveVersion(string pane, PageVersionModel version)
    {
        if (IsChapterLocked) return;
        if (version.IsCurrentVersion) return;

        var page = pane == "Left" ? UploadedPages.ElementAtOrDefault(ActivePageIndex) : _splitUploadedPages.ElementAtOrDefault(_splitPageIndex);
        if (page == null) return;

        IsProcessing = true;
        StateHasChanged();
        Snackbar.Add("Setting active version...", Severity.Info);

        try
        {
            await VersionService.SetCurrentVersionAsync(page.ChapterPageId, version.ChapterPageVersionId);
            
            // Update UI state
            foreach (var v in page.Versions)
            {
                v.IsCurrentVersion = v.ChapterPageVersionId == version.ChapterPageVersionId;
            }

            Snackbar.Add("Active version updated successfully.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to set active version: {ex.Message}", Severity.Error);
        }
        finally
        {
            IsProcessing = false;
            StateHasChanged();
        }
    }

    private async Task DeleteCurrentVersion(string pane)
    {
        if (IsChapterLocked) return;

        var page = pane == "Left" ? UploadedPages.ElementAtOrDefault(ActivePageIndex) : _splitUploadedPages.ElementAtOrDefault(_splitPageIndex);
        if (page != null)
        {
            if (page.Versions.Count > 1)
            {
                var versionToDelete = page.Versions[page.ActiveVersionIndex];
                bool? result = await DialogService.ShowMessageBox(
                    "Delete Version", 
                    $"Are you sure you want to delete Version {versionToDelete.VersionNo}?", 
                    yesText: "Delete", cancelText: "Cancel");

                if (result == true)
                {
                    IsProcessing = true;
                    StateHasChanged();
                    Snackbar.Add("Deleting version...", Severity.Info);

                    try
                    {
                        if (versionToDelete.ChapterPageVersionId != Guid.Empty)
                        {
                            var versionDetails = await VersionService.GetChapterPageVersionByIdAsync(versionToDelete.ChapterPageVersionId);
                            if (versionDetails != null)
                            {
                                var fileResourceDetails = await FileResourceService.GetFileResourceByIdAsync(versionDetails.PageFileId);
                                if (fileResourceDetails != null && !string.IsNullOrEmpty(fileResourceDetails.CloudinaryPublicId))
                                {
                                    await FileStorageService.DeleteFileAsync(fileResourceDetails.CloudinaryPublicId, "image");
                                    await FileResourceService.DeleteFileResourceAsync(fileResourceDetails.FileResourceId, _currentUserId);
                                }
                                await VersionService.DeleteChapterPageVersionAsync(versionToDelete.ChapterPageVersionId);
                            }
                        }

                        page.Versions.RemoveAt(page.ActiveVersionIndex);
                        int nextIndex = Math.Max(0, page.Versions.Count - 1);
                        await SwitchVersion(pane, nextIndex, isDeleting: true);
                        Snackbar.Add("Version deleted successfully.", Severity.Success);
                    }
                    catch (Exception ex)
                    {
                        Snackbar.Add($"Failed to delete version: {ex.Message}", Severity.Error);
                    }
                    finally
                    {
                        IsProcessing = false;
                        StateHasChanged();
                    }
                }
            }
        }
    }

