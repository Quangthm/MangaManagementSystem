@page "/series/{Slug}/workspace"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Text.Json
@using MangaManagementSystem.Application.Interfaces
@using MangaManagementSystem.Web.Services.Api
@using MangaManagementSystem.Web.Services
@attribute [Authorize(Roles = "Mangaka,Tantou Editor,Assistant")]
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ISeriesService SeriesService
@inject IChapterService ChapterService
@inject ISeriesApiClient SeriesApiClient
@inject IChapterPageService PageService
@inject IChapterPageVersionService VersionService
@inject IPageRegionService RegionService
@inject IChapterPageTaskService TaskService
@inject IChapterPageAnnotationService AnnotationService
@inject AuthenticationStateProvider AuthStateProvider
@inject IUserService UserService
@inject IFileStorageService FileStorageService
@inject IFileResourceService FileResourceService
@inject IAiService AiService

@if (_accessDenied)
{
    <div style="min-height: 100vh; background: #f8fafc; display: flex; align-items: center; justify-content: center;">
        <div style="max-width: 480px; text-align: center; padding: 40px 24px;">
            <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 56px; color: #cbd5e1; margin-bottom: 16px;" />
            <div style="font-weight: 700; font-size: 1.2rem; color: #111827; margin-bottom: 8px;">Workspace Access Denied</div>
            <div style="color: #64748b; font-size: 0.9rem; margin-bottom: 24px;">
                You are not an active contributor for this series, or the series was not found.
            </div>
            <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo(BackHref))">
                Back to Series
            </MudButton>
        </div>
    </div>
}
else
{
<div class="mf-workspace-container">
    <!-- Header -->
    <header class="mf-workspace-header px-4 py-2 d-flex justify-space-between align-center" style="position: relative;">
        <div class="d-flex align-center">
            <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Href="@BackHref" Class="mr-2" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@SeriesTitle</MudText>
            <MudText Typo="Typo.caption" Class="mf-muted ml-2 mt-1">@SeriesSubtitle</MudText>
        </div>
        
        <div class="d-flex align-center text-center mx-auto" style="position: absolute; left: 50%; transform: translateX(-50%);">
            @if (SelectedChapter > 0 && SelectedPage > 0 && UploadedPages != null && ActivePageIndex >= 0 && ActivePageIndex < UploadedPages.Count)
            {
                <MudText Typo="Typo.h6" Class="font-weight-bold mr-4">Chapter @SelectedChapter - Page @SelectedPage</MudText>
                <MudText Typo="Typo.caption" Class="mf-muted">Last saved @GetRelativeTime(UploadedPages[ActivePageIndex].Versions[UploadedPages[ActivePageIndex].ActiveVersionIndex].CreatedAtUtc)</MudText>
            }
            else if (SelectedChapter > 0)
            {
                <MudText Typo="Typo.h6" Class="font-weight-bold mf-muted">Chapter @SelectedChapter - No Pages Selected</MudText>
            }
            else
            {
                <MudText Typo="Typo.h6" Class="font-weight-bold mf-muted">No Pages Selected</MudText>
            }
        </div>

        <div class="d-flex align-center gap-2">
            @if (_isAutoSaving)
            {
                <MudText Typo="Typo.caption" Class="mf-muted mr-1" Style="font-size: 0.7rem; display: flex; align-items: center; gap: 4px;">
                    <MudIcon Icon="@Icons.Material.Filled.Sync" Style="font-size: 13px; animation: mf-spin 1s linear infinite;" /> Auto-saving...
                </MudText>
            }
            @{
                var _headerChap = Chapters.FirstOrDefault(c => c.Id == SelectedChapter);
            }
            @if (_headerChap != null)
            {
                @if (_currentRoleName == "Tantou Editor" || _currentRoleName == "Admin")
                {
                    @if (_headerChap.StatusCode == "UNDER_REVIEW")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" StartIcon="@Icons.Material.Filled.Lock" Class="mr-2" DisableElevation="true" OnClick="@(() => ApproveAndLockChapter(_headerChap.ChapterId))">Approve &amp; Lock</MudButton>
                    }
                    else if (_headerChap.StatusCode == "APPROVED" || _headerChap.StatusCode == "PUBLISHED" || _headerChap.StatusCode == "RELEASED")
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" StartIcon="@Icons.Material.Filled.LockOpen" Class="mr-2" OnClick="@(() => UnlockChapter(_headerChap.ChapterId))">Unlock</MudButton>
                    }
                }
                else if (_currentRoleName == "Mangaka")
                {
                    @if (_headerChap.StatusCode == "DRAFT" || _headerChap.StatusCode == "REVISION_REQUESTED")
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Send" Class="mr-2" DisableElevation="true" OnClick="@(() => SubmitChapterForReview(_headerChap.ChapterId))">Submit for Review</MudButton>
                    }
                    else if (_headerChap.StatusCode == "UNDER_REVIEW")
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small" StartIcon="@Icons.Material.Filled.Undo" Class="mr-2" OnClick="@(() => CancelSubmission(_headerChap.ChapterId))">Cancel Submission</MudButton>
                    }
                }
            }
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.FileDownload" DisableElevation="true" OnClick="ExportCurrentPage">Export</MudButton>
        </div>
    </header>

    <div class="mf-workspace-body d-flex flex-grow-1 overflow-hidden">
        
        <!-- Left Sidebar -->
        <aside class="mf-workspace-sidebar py-4 d-flex flex-column border-r-1 mud-border-lines-default" style="width: 250px; flex-shrink: 0; background-color: white; height: 100%; overflow: hidden;">
            <MudNavMenu Class="mud-width-full flex-grow-1" Style="overflow-y: auto;">
                    <div class="px-4 mt-6 mb-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" Class="rounded-lg" OnClick="AddNewChapter" Disabled="@_isAddingChapter">
                            @if (_isAddingChapter) { <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/> } else { <span>New Chapter</span> }
                        </MudButton>
                    </div>
                    
                    <MudText Typo="Typo.caption" Class="mf-muted px-4 font-weight-bold mt-4 mb-2 d-block">CHAPTERS</MudText>
                    
                    <MudList T="int" Class="px-2">
                        @foreach (var chapter in Chapters)
                        {
                            var isCurrent = (chapter.Id == SelectedChapter);
                            var bgClass = isCurrent ? "background-color: #f3f4f6;" : "";
                            var textColor = isCurrent ? Color.Primary : Color.Default;
                            
                            <MudListItem Class="rounded-lg" Style="@bgClass" OnClick="@(async () => await SelectChapter(chapter.Id))">
                                @if (chapter.IsRenaming)
                                {
                                    <div class="d-flex align-center w-100" @onclick:stopPropagation="true">
                                        <MudTextField @bind-Value="chapter.Title" Placeholder="Chapter Title" 
                                                     Variant="Variant.Outlined" Margin="Margin.Dense" 
                                                     OnKeyDown="@(async e => await HandleRenameKeyDown(e, chapter))"
                                                     Immediate="true" AutoFocus="true" Class="flex-grow-1 mr-1" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Default" OnClick="@(() => CancelRenameChapter(chapter))" />
                                    </div>
                                }
                                else
                                {
                                    <div class="d-flex justify-space-between align-center w-100">
                                        <div class="d-flex align-center" style="min-width: 0;">
                                            <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Class="mr-3 mf-muted flex-shrink-0" />
                                            <div style="min-width: 0;">
                                                <MudText Typo="Typo.body2" Class="font-weight-bold" Color="@textColor" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">Chapter @chapter.Id</MudText>
                                                @if (!string.IsNullOrWhiteSpace(chapter.Title))
                                                {
                                                    <MudText Typo="Typo.caption" Class="mf-muted" Style="display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">@chapter.Title</MudText>
                                                }
                                                <MudText Typo="Typo.caption" Class="mf-muted" Style="display: block;">@chapter.PageCount pages</MudText>
                                            </div>
                                        </div>
                                        <div class="d-flex align-center flex-shrink-0">
                                            @if (isCurrent)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Class="mr-2">Active</MudChip>
                                            }
                                            else
                                            {
                                                var statusLabel = chapter.StatusCode == "UNDER_REVIEW" ? "Review" : (chapter.StatusCode == "APPROVED" ? "Approved" : (chapter.StatusCode == "REVISION_REQUESTED" ? "Revision" : "Draft"));
                                                <MudText Typo="Typo.caption" Class="mf-muted mr-2">@statusLabel</MudText>
                                            }

                                            <div @onclick:stopPropagation="true">
                                                @if (chapter.StatusCode == "APPROVED" || chapter.StatusCode == "PUBLISHED" || chapter.StatusCode == "RELEASED" || chapter.StatusCode == "SCHEDULED")
                                                {
                                                    <MudTooltip Text="Chapter is locked and approved">
                                                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Success" Class="pa-1" />
                                                    </MudTooltip>
                                                }
                                                else
                                                {
                                                    <MudMenu Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Dense="true" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                                                        @if (chapter.StatusCode == "DRAFT" || chapter.StatusCode == "REVISION_REQUESTED")
                                                        {
                                                            <MudMenuItem OnClick="@(() => SubmitChapterForReview(chapter.ChapterId))">
                                                                <div class="d-flex align-center">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Send" Size="Size.Small" Color="Color.Primary" Class="mr-2" />
                                                                    <MudText Typo="Typo.body2">Submit for Review</MudText>
                                                                </div>
                                                            </MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => PromptRenameChapter(chapter))">
                                                                <div class="d-flex align-center">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Default" Class="mr-2" />
                                                                    <MudText Typo="Typo.body2">Rename</MudText>
                                                                </div>
                                                            </MudMenuItem>
                                                            <MudMenuItem OnClick="@(() => DeleteChapter(chapter.Id))">
                                                                <div class="d-flex align-center">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" Class="mr-2" />
                                                                    <MudText Typo="Typo.body2" Color="Color.Error">Delete</MudText>
                                                                </div>
                                                            </MudMenuItem>
                                                        }
                                                        else if (chapter.StatusCode == "UNDER_REVIEW")
                                                        {
                                                            <MudMenuItem OnClick="@(() => CancelSubmission(chapter.ChapterId))">
                                                                <div class="d-flex align-center">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Undo" Size="Size.Small" Color="Color.Warning" Class="mr-2" />
                                                                    <MudText Typo="Typo.body2">Cancel Submission</MudText>
                                                                </div>
                                                            </MudMenuItem>
                                                        }
                                                    </MudMenu>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </MudListItem>
                        }
                    </MudList>
            </MudNavMenu>
        </aside>

        <!-- Main Canvas Area -->
        <main class="flex-grow-1 d-flex flex-column" style="min-width: 0; background-color: #f8fafc; position: relative;">
            
            <!-- Canvas Toolbar -->
            <div class="d-flex justify-center mt-4" style="position: absolute; left: 50%; transform: translateX(-50%); z-index: 100;">
                <MudPaper Elevation="2" Class="d-flex align-center rounded-pill px-2 py-1 gap-1" Style="background: white;">
                    <InputFile id="fileInput" OnChange="HandleFileUpload" hidden accept="image/*" multiple disabled="@IsChapterLocked" />
                    <MudButton HtmlTag="label" for="fileInput" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.CloudUpload" Class="rounded-pill px-3 mr-1" Style="background: linear-gradient(90deg, #7c3aed, #c026d3); color: white; font-weight: bold; font-size: 0.65rem; letter-spacing: 0.5px; height: 28px;" Disabled="@IsChapterLocked">UPLOAD PAGES</MudButton>
                    <MudDivider Vertical="true" FlexItem="true" Class="mx-1" />
                    <MudTooltip Text="@(_isSplitView ? "Exit Split View" : "Split View")">
                        <MudIconButton Icon="@(_isSplitView ? Icons.Material.Filled.VerticalSplit : Icons.Material.Filled.VerticalSplit)" Color="@(_isSplitView ? Color.Primary : Color.Default)" OnClick="ToggleSplitView" Size="Size.Small" />
                    </MudTooltip>

                    <!-- Drawing Tools -->
                    <MudTooltip Text="Select Tool"><MudIconButton Icon="@Icons.Material.Filled.NearMe" Color="@(CurrentTool == "select" ? Color.Primary : Color.Default)" OnClick="@(() => SetTool("select"))" Size="Size.Small" Disabled="@IsChapterLocked" /></MudTooltip>
                    <MudTooltip Text="Region Tool"><MudIconButton Icon="@Icons.Material.Filled.Crop" Color="@(CurrentTool == "draw" ? Color.Primary : Color.Default)" OnClick="@(() => SetTool("draw"))" Size="Size.Small" Disabled="@IsChapterLocked" /></MudTooltip>
                    <MudTooltip Text="Brush Tool"><MudIconButton Icon="@Icons.Material.Filled.Brush" Color="@(CurrentTool == "brush" ? Color.Primary : Color.Default)" OnClick="@(() => SetTool("brush"))" Size="Size.Small" Disabled="@IsChapterLocked" /></MudTooltip>
                    <MudTooltip Text="Pin Tool"><MudIconButton Icon="@Icons.Material.Filled.PushPin" Color="@(CurrentTool == "pin" ? Color.Primary : Color.Default)" OnClick="@(() => SetTool("pin"))" Size="Size.Small" Disabled="@IsChapterLocked" /></MudTooltip>
                    
                    @if (CurrentTool == "brush")
                    {
                        <div class="d-flex align-center mx-2">
                            <input type="color" value="@BrushColor" @onchange="OnBrushColorChanged" style="width: 24px; height: 24px; border: none; padding: 0; cursor: pointer; border-radius: 4px;" disabled="@IsChapterLocked" />
                            <input type="range" min="1" max="100" value="@BrushSize" @onchange="OnBrushSizeChanged" style="width: 80px; margin-left: 8px;" disabled="@IsChapterLocked" />
                        </div>
                    }

                    <MudTooltip Text="Auto Segment Panels"><MudIconButton Icon="@Icons.Material.Filled.DashboardCustomize" Color="Color.Secondary" OnClick="RunSegmentAI" Disabled="@(IsProcessing || IsChapterLocked)" Size="Size.Small" /></MudTooltip>
                    <MudTooltip Text="Translate Selected"><MudIconButton Icon="@Icons.Material.Filled.Translate" Color="Color.Info" OnClick="RunTranslateAI" Disabled="@(IsProcessing || IsChapterLocked)" Size="Size.Small" /></MudTooltip>
                    <MudTooltip Text="Delete Selected"><MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" OnClick="DeleteSelectedRegions" Size="Size.Small" Disabled="@IsChapterLocked" /></MudTooltip>
                    
                    <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                    
                    <MudTooltip Text="Zoom In"><MudIconButton Icon="@Icons.Material.Filled.ZoomIn" OnClick="ZoomIn" Size="Size.Small" /></MudTooltip>
                    <MudTooltip Text="Zoom Out"><MudIconButton Icon="@Icons.Material.Filled.ZoomOut" OnClick="ZoomOut" Size="Size.Small" /></MudTooltip>
                    <MudTooltip Text="Undo"><MudIconButton Icon="@Icons.Material.Filled.Undo" OnClick="Undo" Disabled="@(!CanUndo)" Size="Size.Small" /></MudTooltip>
                    <MudTooltip Text="Redo"><MudIconButton Icon="@Icons.Material.Filled.Redo" OnClick="Redo" Disabled="@(!CanRedo)" Size="Size.Small" /></MudTooltip>
                </MudPaper>
            </div>

            <!-- Canvas Container -->
            <div class="flex-grow-1 d-flex" style="overflow: hidden; background-color: #e5e5e5; min-height: 0;">
                <!-- Editor Pane Left -->
                <div style="flex: 1; position: relative; overflow: hidden; min-width: 0; border-top: @(_activePane == "Left" ? "4px solid var(--mud-palette-primary)" : "4px solid transparent") ; transition: border-color 0.2s ease;" @onmousedown='() => SetActivePane("Left")'>
                    @if (UploadedPages.Any())
                    {
                        var currentPage = UploadedPages[ActivePageIndex];
                        if (currentPage.Versions.Count > 0)
                        {
                              <div style="position: absolute; top: 16px; left: 16px; z-index: 10;">
                                  <MudPaper Class="pa-2 rounded-lg" Elevation="2" Style="background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); width: 210px; border: 1px solid var(--mud-palette-lines-default);">
                                      <div class="d-flex align-center justify-space-between mb-2">
                                          <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Versions</MudText>
                                          <div class="d-flex gap-1">
                                              <MudTooltip Text="Create Canvas as New Version">
                                                  <MudIconButton Icon="@Icons.Material.Filled.AddPhotoAlternate" Color="Color.Secondary" Size="Size.Small" OnClick='() => SaveAsNewVersion("Left")' Disabled="@IsChapterLocked" />
                                              </MudTooltip>
                                              <MudTooltip Text="Delete Selected Version">
                                                  <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick='() => DeleteCurrentVersion("Left")' Disabled="@(currentPage.Versions.Count <= 1 || IsChapterLocked)" />
                                              </MudTooltip>
                                          </div>
                                      </div>
                                      <MudDivider Class="mb-2" />
                                      <div class="d-flex flex-column gap-1" style="max-height: 200px; overflow-y: auto;">
                                          @for (int i = 0; i < currentPage.Versions.Count; i++)
                                          {
                                              var idx = i;
                                              var ver = currentPage.Versions[idx];
                                              bool isSelected = idx == currentPage.ActiveVersionIndex;
                                              <MudPaper Elevation="0" Class="px-2 py-1 rounded" Style="@($"cursor: pointer; background-color: {(isSelected ? "var(--mud-palette-action-default-hover)" : "transparent")};")" @onclick='() => SwitchVersion("Left", idx)'>
                                                  <div class="d-flex align-center justify-space-between">
                                                      <div class="d-flex align-center gap-2">
                                                          <MudIcon Icon="@(ver.IsCurrentVersion ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)" Color="@(ver.IsCurrentVersion ? Color.Success : Color.Default)" Size="Size.Small" />
                                                          <MudText Typo="Typo.body2" Class="@(isSelected ? "font-weight-bold text-primary" : "")">v@(ver.VersionNo)</MudText>
                                                      </div>
                                                      @if (!ver.IsCurrentVersion && isSelected)
                                                      {
                                                          <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick='() => SetActiveVersion("Left", ver)' Disabled="@IsChapterLocked" Class="pa-0 px-2" Style="min-width: unset; text-transform: none; font-size: 0.75rem;">Set Active</MudButton>
                                                      }
                                                  </div>
                                              </MudPaper>
                                          }
                                      </div>
                                  </MudPaper>
                              </div>
                        }
                    }
                    <div id="ai-canvas-container-left" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                        <canvas id="ai-canvas-left" style="position: absolute; left: 0; top: 0; background: white; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); transform-origin: top left;"></canvas>
                    </div>
                </div>
                
                <!-- Split View Pane Right -->
                <div style="display: @(_isSplitView ? "block" : "none"); width: 1px; background: var(--mud-palette-lines-default); flex-shrink: 0;"></div>
                <div style="display: @(_isSplitView ? "flex" : "none") ; flex: 1; position: relative; overflow: hidden; background: #efefef; min-width: 0; border-top: @(_activePane == "Right" ? "4px solid var(--mud-palette-primary)" : "4px solid transparent") ; transition: border-color 0.2s ease;" @onmousedown='() => SetActivePane("Right")'>
                        @if (_splitUploadedPages.Any())
                        {
                            var splitPage = _splitUploadedPages[_splitPageIndex];
                            if (splitPage.Versions.Count > 0)
                            {
                                <div style="position: absolute; top: 16px; right: 16px; z-index: 10;">
                                  <MudPaper Class="pa-2 rounded-lg" Elevation="2" Style="background: rgba(255,255,255,0.95); backdrop-filter: blur(8px); width: 210px; border: 1px solid var(--mud-palette-lines-default);">
                                      <div class="d-flex align-center justify-space-between mb-2">
                                          <MudText Typo="Typo.subtitle2" Class="font-weight-bold">Versions</MudText>
                                          <div class="d-flex gap-1">
                                              <MudTooltip Text="Create Canvas as New Version">
                                                  <MudIconButton Icon="@Icons.Material.Filled.AddPhotoAlternate" Color="Color.Secondary" Size="Size.Small" OnClick='() => SaveAsNewVersion("Right")' Disabled="@IsChapterLocked" />
                                              </MudTooltip>
                                              <MudTooltip Text="Delete Selected Version">
                                                  <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick='() => DeleteCurrentVersion("Right")' Disabled="@(splitPage.Versions.Count <= 1 || IsChapterLocked)" />
                                              </MudTooltip>
                                          </div>
                                      </div>
                                      <MudDivider Class="mb-2" />
                                      <div class="d-flex flex-column gap-1" style="max-height: 200px; overflow-y: auto;">
                                          @for (int i = 0; i < splitPage.Versions.Count; i++)
                                          {
                                              var idx = i;
                                              var ver = splitPage.Versions[idx];
                                              bool isSelected = idx == splitPage.ActiveVersionIndex;
                                              <MudPaper Elevation="0" Class="px-2 py-1 rounded" Style="@($"cursor: pointer; background-color: {(isSelected ? "var(--mud-palette-action-default-hover)" : "transparent")};")" @onclick='() => SwitchVersion("Right", idx)'>
                                                  <div class="d-flex align-center justify-space-between">
                                                      <div class="d-flex align-center gap-2">
                                                          <MudIcon Icon="@(ver.IsCurrentVersion ? Icons.Material.Filled.CheckCircle : Icons.Material.Outlined.Circle)" Color="@(ver.IsCurrentVersion ? Color.Success : Color.Default)" Size="Size.Small" />
                                                          <MudText Typo="Typo.body2" Class="@(isSelected ? "font-weight-bold text-primary" : "")">v@(ver.VersionNo)</MudText>
                                                      </div>
                                                      @if (!ver.IsCurrentVersion && isSelected)
                                                      {
                                                          <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick='() => SetActiveVersion("Right", ver)' Disabled="@IsChapterLocked" Class="pa-0 px-2" Style="min-width: unset; text-transform: none; font-size: 0.75rem;">Set Active</MudButton>
                                                      }
                                                  </div>
                                              </MudPaper>
                                          }
                                      </div>
                                  </MudPaper>
                                </div>
                            }
                        }
                        <div id="ai-canvas-container-right" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0;">
                            <canvas id="ai-canvas-right" style="position: absolute; left: 0; top: 0; background: white; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); transform-origin: top left;"></canvas>
                        </div>
                    </div>
            </div>

            <!-- Bottom Pagination -->
            <div class="d-flex justify-center align-center py-2 bg-white border-t-1 mud-border-lines-default" style="gap: 16px;">
                <!-- Left Pane Pagination -->
                <div class="d-flex align-center">
                    @if (_isSplitView)
                    {
                        <MudText Typo="Typo.caption" Class="mf-muted font-weight-bold mr-2">Left Pane:</MudText>
                    }
                    @if (UploadedPages.Any())
                    {
                        <MudPagination Count="@UploadedPages.Count" Selected="@(ActivePageIndex + 1)" SelectedChanged="OnPageChanged" Variant="Variant.Filled" Color="Color.Primary" ShowFirstButton="@false" ShowLastButton="@false" />
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Class="mf-muted">0 / 0</MudText>
                    }
                </div>
                
                @if (_isSplitView)
                {
                    <MudDivider Vertical="true" FlexItem="true" />
                    <!-- Right Pane Pagination -->
                    <div class="d-flex align-center">
                        <MudText Typo="Typo.caption" Class="mf-muted font-weight-bold mr-2">Right Pane:</MudText>
                        @if (_splitUploadedPages.Any())
                        {
                            <MudPagination Count="@_splitUploadedPages.Count" Selected="@(_splitPageIndex + 1)" SelectedChanged="OnSplitPageChanged" Variant="Variant.Filled" Color="Color.Primary" ShowFirstButton="@false" ShowLastButton="@false" />
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Class="mf-muted">0 / 0</MudText>
                        }
                    </div>
                }
                
                <MudDivider Vertical="true" FlexItem="true" />
                <MudTooltip Text="Delete Current Page (Left)">
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="DeleteCurrentPage" Disabled="@IsChapterLocked" />
                </MudTooltip>
            </div>

            <!-- Right Panel Toggle Button -->
            <MudTooltip Text="@(_isRightPanelOpen ? "Collapse Task Panel" : "Expand Task Panel")" Placement="Placement.Left">
                <MudIconButton 
                    Icon="@(_isRightPanelOpen ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                    OnClick="ToggleRightPanel"
                    Color="Color.Default"
                    Variant="Variant.Filled"
                    Size="Size.Small"
                    Style="position: absolute; right: 0; top: 50%; transform: translateY(-50%); z-index: 50; border-radius: 16px 0 0 16px; border: 1px solid var(--mud-palette-lines-default); border-right: none; padding-right: 2px; background-color: white;" />
            </MudTooltip>
        </main>

        <!-- Right Panel (Tasks) -->
        <aside class="mf-workspace-right-panel border-l-1 mud-border-lines-default d-flex flex-column" style="width: @(_isRightPanelOpen ? "320px" : "0px"); flex-shrink: 0; background-color: white; height: 100%; overflow: hidden; transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1); position: relative;">
            <div class="py-4 d-flex flex-column" style="width: 320px; height: 100%;">
                <div class="px-4 mb-4" style="flex-shrink: 0;">
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Task Panel</MudText>
                <MudText Typo="Typo.body2" Class="mf-muted">Create and assign production tasks</MudText>
            </div>

            <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4" Color="Color.Transparent" Class="workspace-tabs">
                <MudTabPanel Text="Tasks">
                    <div class="px-4 mb-6" style="flex-shrink: 0;">
                <MudPaper Elevation="0" Class="pa-4 border-1 mud-border-lines-default rounded-lg">
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3">NEW TASK</MudText>
                    
                    <MudSelect T="string" Label="Task Type" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" Value="@TaskType" ValueChanged="OnTaskTypeChanged">
                        <MudSelectItem Value="@("BACKGROUND")">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Color="Color.Info" Class="mr-2"/> Background</div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("SHADING")">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Texture" Size="Size.Small" Color="Color.Warning" Class="mr-2"/> Tone Shading</div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("EFFECTS")">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Small" Color="Color.Success" Class="mr-2"/> SFX</div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("CLEANUP")">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Brush" Size="Size.Small" Color="Color.Secondary" Class="mr-2"/> Cleanup</div>
                        </MudSelectItem>
                        <MudSelectItem Value="@("OTHER")">
                            <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Small" Color="Color.Default" Class="mr-2"/> Other</div>
                        </MudSelectItem>
                    </MudSelect>

                    <MudSelect T="Guid?" Label="Assign to Assistant" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" Value="@AssignedAssistantId" ValueChanged="OnAssistantChanged">
                        @foreach(var user in _assistantUsers)
                        {
                            <MudSelectItem T="Guid?" Value="user.UserId">
                                <div class="d-flex align-center">
                                    <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-2" Style="width:24px; height:24px; font-size:10px;">
                                        @(string.IsNullOrWhiteSpace(user.Username) ? "?" : user.Username[0].ToString().ToUpper())
                                    </MudAvatar> 
                                    @user.Username
                                </div>
                            </MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField T="string" Label="Task description..." @bind-Value="TaskDescription" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" Class="mb-3" />

                    <div class="d-flex flex-column mb-3">
                        <MudText Typo="Typo.caption" Class="mf-muted mb-1">Panel Target (Hold Shift to select multiple)</MudText>
                        <div class="d-flex flex-wrap gap-1">
                            @if (SelectedRegions.Any())
                            {
                                @foreach (var reg in SelectedRegions)
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">Panel @reg.Id (X:@Math.Round(reg.X) Y:@Math.Round(reg.Y) W:@Math.Round(reg.Width) H:@Math.Round(reg.Height))</MudChip>
                                }
                            }
                            else if (SelectedPage > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Page @SelectedPage</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">No Page Selected</MudChip>
                            }
                        </div>
                    </div>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" OnClick="CreateTask" Disabled="@IsChapterLocked">Create Task</MudButton>
                </MudPaper>
            </div>

            <div class="px-4" style="flex-grow: 1; overflow-y: auto;">
                  <div class="d-flex justify-space-between align-center mb-3">
                      <MudText Typo="Typo.subtitle2" Class="font-weight-bold">ACTIVE TASKS</MudText>
                      <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">@ActiveTasks.Count</MudChip>
                  </div>

                  <MudStack Spacing="2">
                      @foreach (var task in ActiveTasks)
                      {
                          var icon = task.Type switch {
                              "Background" => Icons.Material.Filled.Image,
                              "Tone Shading" => Icons.Material.Filled.Texture,
                              "SFX" => Icons.Material.Filled.CheckCircle,
                              _ => Icons.Material.Filled.Assignment
                          };
                          var iconColor = task.Status == "Done" ? Color.Success : Color.Info;
                          var chipColor = task.Status switch {
                              "Done" => Color.Success,
                              "Review" => Color.Warning,
                              "In Progress" => Color.Info,
                              _ => Color.Default
                          };
                          var initials = string.Join("", task.Assistant.Split(' ').Select(n => n[0]));
                          
                          <MudPaper Elevation="0" Class="pa-3 border-1 mud-border-lines-default rounded-lg">
                              <div class="d-flex justify-space-between">
                                  <div class="d-flex">
                                      <MudIcon Icon="@icon" Size="Size.Small" Color="@iconColor" Class="mr-2 mt-1" />
                                      <div>
                                          <MudText Typo="Typo.body2" Class="@(task.Status == "Done" ? "font-weight-bold text-decoration-line-through" : "font-weight-bold")">@task.Type &bull; @task.Target</MudText>
                                          <MudText Typo="Typo.caption" Class="mf-muted d-flex align-center mt-1">
                                              <MudAvatar Size="Size.Small" Color="Color.Primary" Class="mr-1" Style="width:16px; height:16px; font-size:8px;">@initials</MudAvatar> @task.Assistant
                                          </MudText>
                                      </div>
                                  </div>
                                  <div class="d-flex align-center" @onclick:stopPropagation="true">
                                      <MudChip T="string" Size="Size.Small" Color="@chipColor" Variant="Variant.Outlined" OnClick="@(() => CycleTaskStatus(task))" Style="cursor: pointer;">@task.Status</MudChip>
                                      <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Default" Class="ml-1" OnClick="@(() => DeleteTask(task.Id))" Disabled="@IsChapterLocked" />
                                  </div>
                              </div>
                          </MudPaper>
                      }
                  </MudStack>
            </div>
                </MudTabPanel>
                
                <MudTabPanel Text="Annotations">
                    <div class="px-4 mb-6" style="flex-shrink: 0;">
                        <MudPaper Elevation="0" Class="pa-4 border-1 mud-border-lines-default rounded-lg">
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3">NEW ANNOTATION</MudText>
                            
                            <MudSelect T="string" Label="Issue Type" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-3" @bind-Value="AnnotationType">
                                <MudSelectItem Value="@("TYPESETTING_ERROR")">Typo / Typesetting</MudSelectItem>
                                <MudSelectItem Value="@("TRANSLATION_ERROR")">Translation Error</MudSelectItem>
                                <MudSelectItem Value="@("CLEANUP_REQUIRED")">Redraw Needed</MudSelectItem>
                                <MudSelectItem Value="@("BACKGROUND_INCONSISTENCY")">Background Issue</MudSelectItem>
                                <MudSelectItem Value="@("OTHER")">Other</MudSelectItem>
                            </MudSelect>

                            <MudTextField T="string" Label="Comment..." @bind-Value="AnnotationComment" Variant="Variant.Outlined" Lines="3" Margin="Margin.Dense" Class="mb-3" />
                            <div class="d-flex flex-column mt-3">
                                <MudText Typo="Typo.caption" Class="mf-muted mb-1">Target</MudText>
                                <div class="d-flex flex-wrap gap-1">
                                    @if (PendingPinX.HasValue && PendingPinY.HasValue)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Filled">Pin at (@Math.Round(PendingPinX.Value), @Math.Round(PendingPinY.Value))</MudChip>
                                    }
                                    else if (SelectedRegions.Any())
                                    {
                                        @foreach(var reg in SelectedRegions)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled">Panel @reg.Id</MudChip>
                                        }
                                    }
                                    else if (SelectedPage > 0)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Error" Variant="Variant.Outlined">Page @SelectedPage</MudChip>
                                    }
                                    else
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">No Page Selected</MudChip>
                                    }
                                </div>
                            </div>

                            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true" StartIcon="@Icons.Material.Filled.AddComment" OnClick="CreateAnnotation" Disabled="@IsChapterLocked">Add Annotation</MudButton>
                        </MudPaper>
                    </div>

                    <div class="px-4" style="flex-grow: 1; overflow-y: auto;">
                        <div class="d-flex justify-space-between align-center mb-3">
                            <MudText Typo="Typo.subtitle2" Class="font-weight-bold">PAGE ISSUES</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text">@ActiveAnnotations.Count(a => a.PageNumber == SelectedPage)</MudChip>
                        </div>

                        <MudStack Spacing="2">
                            @foreach (var ann in ActiveAnnotations.Where(a => a.PageNumber == SelectedPage))
                            {
                                var annColor = ann.IsResolved ? Color.Success : Color.Error;
                                <MudPaper Elevation="0" Class="pa-3 border-1 mud-border-lines-default rounded-lg">
                                    <div class="d-flex justify-space-between align-start">
                                        <div class="d-flex flex-column">
                                            <div class="d-flex align-center mb-1">
                                                @{
                                                    var annLabel = ann.Type switch {
                                                        "TYPESETTING_ERROR" => "Typo / Typesetting",
                                                        "TRANSLATION_ERROR" => "Translation Error",
                                                        "CLEANUP_REQUIRED" => "Redraw Needed",
                                                        "BACKGROUND_INCONSISTENCY" => "Background Issue",
                                                        "OTHER" => "Other",
                                                        _ => ann.Type
                                                    };
                                                }
                                                <MudChip T="string" Size="Size.Small" Color="@annColor" Variant="Variant.Outlined" Class="mr-2 mt-0">@annLabel</MudChip>
                                                <MudText Typo="Typo.caption" Class="font-weight-bold">@ann.Target</MudText>
                                            </div>
                                            <MudText Typo="Typo.body2" Class="mb-2">@ann.Comment</MudText>
                                            <MudText Typo="Typo.caption" Class="mf-muted d-flex align-center">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" Style="font-size: 12px;"/> @ann.Author
                                            </MudText>
                                        </div>
                                        <div>
                                            @if (!ann.IsResolved)
                                            {
                                                <MudTooltip Text="Resolve Issue"><MudIconButton Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Success" OnClick="@(() => ResolveAnnotation(ann.Id))" Disabled="@IsChapterLocked" /></MudTooltip>
                                            }
                                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" Color="Color.Default" Class="ml-1" OnClick="@(() => DeleteAnnotation(ann.Id))" Disabled="@IsChapterLocked" />
                                        </div>
                                    </div>
                                </MudPaper>
                            }
                        </MudStack>
                    </div>
                </MudTabPanel>
            </MudTabs>
            </div>
        </aside>

    </div>
</div>
}

<style>
    body { margin: 0; padding: 0; overflow: hidden; }
    @@keyframes mf-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
