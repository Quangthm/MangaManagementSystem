@page "/mangaka/review-submissions"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Mangaka")]
@inject IMangakaTaskApiClient MangakaTaskClient
@inject IMangakaSeriesApiClient MangakaSeriesClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@using MangaManagementSystem.Web.Services

<MangakaLayout>
    <div class="mf-page">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="color: #64748b; margin-bottom: 16px;"
                   OnClick="@(() => Nav.NavigateTo("/mangaka"))">
            Back to Mangaka Dashboard
        </MudButton>

        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Review Assistant Submissions</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review and approve completed tasks from your assistants</MudText>
        </div>

        @if (!_loading)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.FlashOn"
                       OnClick="OpenQuickSelect" Class="mb-4">
                Quick Select
            </MudButton>
        }

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            <MudGrid Class="mb-4">
                <MudItem xs="12" md="3"><StatCard Label="Under Review" Value="@_underReviewCount.ToString()" Description="Awaiting your decision" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Assigned" Value="@_assignedCount.ToString()" Description="Active tasks" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Completed" Value="@_completedCount.ToString()" Description="Approved tasks" /></MudItem>
                <MudItem xs="12" md="3"><StatCard Label="Cancelled" Value="@_cancelledCount.ToString()" Description="Cancelled tasks" /></MudItem>
            </MudGrid>

            <MudPaper Class="pa-4 mb-4 mf-card" Elevation="0">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="_searchText" Label="Search by series or chapter"
                                       Variant="Variant.Outlined" Immediate="true"
                                       Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" Label="Task Type" Value="@_typeFilter" ValueChanged="OnTypeFilterChanged"
                                    Variant="Variant.Outlined" Clearable="true">
                            <MudSelectItem Value="@("BACKGROUND")">Background</MudSelectItem>
                            <MudSelectItem Value="@("SHADING")">Shading</MudSelectItem>
                            <MudSelectItem Value="@("EFFECTS")">Effects</MudSelectItem>
                            <MudSelectItem Value="@("CLEANUP")">Cleanup</MudSelectItem>
                            <MudSelectItem Value="@("DIALOGUE")">Dialogue</MudSelectItem>
                            <MudSelectItem Value="@("TYPESETTING")">Typesetting</MudSelectItem>
                            <MudSelectItem Value="@("REVIEW")">Review</MudSelectItem>
                            <MudSelectItem Value="@("OTHER")">Other</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudAutocomplete T="string" Label="Assistant" Value="@_assistantFilter"
                                          Variant="Variant.Outlined" Clearable="true"
                                          SearchFunc="@SearchAssistants" ResetValueOnEmptyText="false"
                                          CoerceText="true" CoerceValue="false" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="string" Label="Status" Value="@_statusFilter" ValueChanged="OnFilterChanged"
                                    Variant="Variant.Outlined">
                            <MudSelectItem Value="@("ALL")">All Tasks</MudSelectItem>
                            <MudSelectItem Value="@("UNDER_REVIEW")">Under Review</MudSelectItem>
                            <MudSelectItem Value="@("ASSIGNED")">Assigned</MudSelectItem>
                            <MudSelectItem Value="@("COMPLETED")">Completed</MudSelectItem>
                            <MudSelectItem Value="@("CANCELLED")">Cancelled</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            @if (!_filteredTasks.Any())
            {
                <MudPaper Class="pa-8 mf-card text-center" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.h5" Class="mt-2">All Caught Up!</MudText>
                    <MudText Class="mf-muted">No tasks match the current filter.</MudText>
                </MudPaper>
            }
            else
            {
                <MudGrid>
                    @foreach (var task in _filteredTasks)
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-5 mf-card" Elevation="0">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">@task.TypeCode</MudChip>
                                    <StatusBadge Status="@task.StatusCode" />
                                </MudStack>

                                @if (!string.IsNullOrWhiteSpace(task.TaskTitle))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1"><strong>@task.TaskTitle</strong></MudText>
                                }

                                @if (!string.IsNullOrWhiteSpace(task.SeriesTitle))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1 mf-muted">
                                        <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Class="mr-1" />
                                        @task.SeriesTitle
                                    </MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(task.ChapterNumberLabel) || task.PageNo.HasValue || task.PageVersionNo.HasValue)
                                {
                                    <MudText Typo="Typo.body2" Class="mt-1 mf-muted">
                                        <MudIcon Icon="@Icons.Material.Filled.Article" Size="Size.Small" Class="mr-1" />
                                        @if (!string.IsNullOrWhiteSpace(task.ChapterNumberLabel))
                                        {
                                            <span>@task.ChapterNumberLabel</span>
                                        }
                                        @if (task.PageNo.HasValue)
                                        {
                                            <span> • Pg. @task.PageNo.Value</span>
                                        }
                                        @if (task.PageVersionNo.HasValue)
                                        {
                                            <span> • v@(task.PageVersionNo.Value)</span>
                                        }
                                    </MudText>
                                }

                                <MudText Typo="Typo.body2" Class="mt-1 mf-muted">
                                    <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                    @(task.AssignedToDisplayName ?? task.AssignedUsername ?? "Unknown")
                                </MudText>

                                <MudStack Row="true" Class="mt-1" Spacing="3">
                                    <MudText Typo="Typo.body2" Class="mf-muted">
                                        Priority: @task.PriorityLevel
                                    </MudText>
                                    <MudText Typo="Typo.body2" Class="mf-muted">
                                        Due: <TimestampDisplay Value="@task.DueAtUtc" EmptyText="No deadline" />
                                    </MudText>
                                </MudStack>

                                @if (task.PageRegions.Any())
                                {
                                    <MudText Typo="Typo.caption" Class="mt-1 mf-muted">
                                        Regions: @task.PageRegions.Count
                                    </MudText>
                                }

                                @if (task.CompensationAmount.HasValue)
                                {
                                    <MudText Typo="Typo.caption" Class="mt-1 mf-muted">
                                        Compensation: @task.CompensationAmount.Value.ToString("C2")
                                    </MudText>
                                }

                                @if (task.StatusCode == "UNDER_REVIEW" && !string.IsNullOrWhiteSpace(task.CompletedOutputUrl))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-2"><strong>Submitted Output:</strong></MudText>
                                    <MudImage Src="@task.CompletedOutputUrl" Alt="Submitted output" MaxHeight="200" Class="mt-1 rounded" ObjectFit="ObjectFit.Contain" />
                                    @if (!string.IsNullOrWhiteSpace(task.SeriesSlug) && task.ChapterId.HasValue)
                                    {
                                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.OpenInNew" Class="mt-1"
                                                   OnClick="@(() => Nav.NavigateTo(BuildWorkspaceLink(task)))">
                                            View in Workspace
                                        </MudButton>
                                    }
                                }

                                @if (!string.IsNullOrWhiteSpace(task.PageImageUrl))
                                {
                                    <MudText Typo="Typo.body2" Class="mt-2"><strong>Original Page:</strong></MudText>
                                    <MudImage Src="@task.PageImageUrl" Alt="Original page" MaxHeight="150" Class="mt-1 rounded" ObjectFit="ObjectFit.Contain" />
                                    @if (!string.IsNullOrWhiteSpace(task.SeriesSlug) && task.ChapterId.HasValue)
                                    {
                                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary"
                                                   StartIcon="@Icons.Material.Filled.OpenInNew" Class="mt-1"
                                                   OnClick="@(() => Nav.NavigateTo(BuildWorkspaceLink(task)))">
                                            View in Workspace
                                        </MudButton>
                                    }
                                }

                                @if (task.StatusCode == "UNDER_REVIEW")
                                {
                                    <MudStack Row="true" Class="mt-3" Spacing="2">
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => ApproveTask(task.ChapterPageTaskId))">
                                            Approve
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => OpenReturnDialog(task))">
                                            Return for Rework
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => OpenReassignDialog(task))">
                                            Reassign
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => OpenCancelDialog(task))">
                                            Cancel Task
                                        </MudButton>
                                    </MudStack>
                                }
                                else if (task.StatusCode == "ASSIGNED")
                                {
                                    <MudStack Row="true" Class="mt-3" Spacing="2">
                                        <MudButton Variant="Variant.Outlined" Color="Color.Info" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => OpenReassignDialog(task))">
                                            Reassign
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => OpenCancelDialog(task))">
                                            Cancel Task
                                        </MudButton>
                                    </MudStack>
                                }
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            }
        }

        @* Return for Rework Dialog *@
        <MudDialog @bind-Visible="_showReturnDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Return for Rework</TitleContent>
            <DialogContent>
                @if (_returnDialogTask != null)
                {
                    <MudText Class="mb-2">
                        <strong>Current Assistant:</strong> @(_returnDialogTask.AssignedToDisplayName ?? _returnDialogTask.AssignedUsername ?? "Unknown")
                    </MudText>
                }
                <MudTextField @bind-Value="_returnReason" Label="Updated task instructions" Lines="4"
                              Variant="Variant.Outlined" Required="true"
                              HelperText="Explain what the Assistant should revise before resubmitting." />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showReturnDialog = false)">Cancel</MudButton>
                <MudButton Color="Color.Warning" Variant="Variant.Filled" Disabled="@(string.IsNullOrWhiteSpace(_returnReason) || _actionInProgress)" OnClick="ConfirmReturn">Return for Rework</MudButton>
            </DialogActions>
        </MudDialog>

        @* Cancel Dialog *@
        <MudDialog @bind-Visible="_showCancelDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Cancel Task</TitleContent>
            <DialogContent>
                <MudText Class="mb-3">Provide a reason for cancellation:</MudText>
                <MudTextField @bind-Value="_cancelReason" Label="Cancellation Reason" Lines="4" Variant="Variant.Outlined" Required="true" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showCancelDialog = false)">Close</MudButton>
                <MudButton Color="Color.Error" Variant="Variant.Filled" Disabled="@(string.IsNullOrWhiteSpace(_cancelReason) || _actionInProgress)" OnClick="ConfirmCancel">Cancel Task</MudButton>
            </DialogActions>
        </MudDialog>

        @* Reassign Dialog *@
        <MudDialog @bind-Visible="_showReassignDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Reassign Task</TitleContent>
            <DialogContent>
                @if (_reassignDialogTask != null)
                {
                    <MudText Class="mb-2">
                        <strong>Current Assignee:</strong> @(_reassignDialogTask.AssignedToDisplayName ?? _reassignDialogTask.AssignedUsername ?? "Unknown")
                    </MudText>
                }
                @if (_loadingAssistants)
                {
                    <MudProgressLinear Indeterminate="true" Class="mb-3" />
                }
                else if (!_eligibleAssistants.Any())
                {
                    <MudAlert Severity="Severity.Warning" Class="mb-3">No eligible assistants found for this series.</MudAlert>
                }
                else
                {
                    <MudSelect T="Guid?" Label="New Assistant" @bind-Value="_selectedNewAssistantUserId"
                               Variant="Variant.Outlined" Required="true" Class="mb-3">
                        @foreach (var assistant in _eligibleAssistants)
                        {
                            <MudSelectItem T="Guid?" Value="@assistant.UserId">
                                @assistant.DisplayName @(assistant.Username != null ? $"(@{assistant.Username})" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
                <MudTextField @bind-Value="_reassignReason" Label="Reason for Reassignment" Lines="3"
                              Variant="Variant.Outlined" Required="true" Counter="500" MaxLength="500"
                              HelperText="Required. Max 500 characters." />
                <MudTextField @bind-Value="_reassignDescription" Label="Updated Task Description (optional)" Lines="3"
                              Variant="Variant.Outlined" Class="mt-3"
                              HelperText="Leave empty to keep the original description." />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showReassignDialog = false)">Cancel</MudButton>
                <MudButton Color="Color.Info" Variant="Variant.Filled"
                           Disabled="@(!_selectedNewAssistantUserId.HasValue || string.IsNullOrWhiteSpace(_reassignReason) || _actionInProgress || _loadingAssistants)"
                           OnClick="ConfirmReassign">
                    Reassign
                </MudButton>
            </DialogActions>
        </MudDialog>

        @* Quick Select Dialog *@
        <MudDialog @bind-Visible="_showQuickSelect" Options="new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true }">
            <TitleContent>Quick Select Task Assignment</TitleContent>
            <DialogContent>
                @if (_quickSelectLoadingSeries)
                {
                    <MudProgressLinear Indeterminate="true" />
                }
                else
                {
                    <MudSelect T="Guid?" Label="Series" Value="_quickSelectSelectedSeriesId"
                               ValueChanged="OnQuickSelectSeriesChanged"
                               Variant="Variant.Outlined" Required="true" Class="mb-3"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var s in _quickSelectSeries)
                        {
                            <MudSelectItem T="Guid?" Value="@s.SeriesId">@s.Title</MudSelectItem>
                        }
                    </MudSelect>
                }

                @if (_quickSelectSelectedSeriesId.HasValue)
                {
                    if (_quickSelectLoadingChapters)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-3" />
                    }
                    else if (!_quickSelectChapters.Any())
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3">No chapters found for this series.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="Guid?" Label="Chapter" Value="_quickSelectSelectedChapterId"
                                   ValueChanged="OnQuickSelectChapterChanged"
                                   Variant="Variant.Outlined" Required="true" Class="mb-3"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var ch in _quickSelectChapters)
                            {
                                <MudSelectItem T="Guid?" Value="@ch.ChapterId">
                                    Ch. @ch.ChapterNumber @(ch.Title ?? "") @(ch.PageCount.HasValue ? $"({ch.PageCount} pages)" : "")
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                }

                @if (_quickSelectSelectedChapterId.HasValue)
                {
                    if (_quickSelectLoadingPages)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-3" />
                    }
                    else if (!_quickSelectPages.Any())
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3">No pages found for this chapter.</MudAlert>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Select Pages</MudText>
                        <MudPaper Class="pa-2 mb-3" Elevation="0" Style="max-height:200px;overflow-y:auto;">
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="SelectAllPages" Class="mb-1">Select All</MudButton>
                            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="ClearAllPages" Class="mb-1 ml-2">Clear</MudButton>
                            @foreach (var pg in _quickSelectPages)
                            {
                                <div class="d-flex align-center py-1">
                                    <MudCheckBox T="bool"
                                                 Checked="@_quickSelectPageSelections[pg.ChapterPageId]"
                                                 CheckedChanged="@((bool v) => { _quickSelectPageSelections[pg.ChapterPageId] = v; })" />
                                    <MudText Typo="Typo.body2" Class="ml-2">Page @pg.PageNo &mdash; v@(pg.VersionNo)</MudText>
                                </div>
                            }
                        </MudPaper>
                    }
                }

                @if (_quickSelectSelectedChapterId.HasValue && _quickSelectSelectedPages.Any())
                {
                    if (_quickSelectLoadingAssistants)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mb-3" />
                    }
                    else if (!_quickSelectAssistants.Any())
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3">No active Assistant contributors found for this series.</MudAlert>
                    }
                    else
                    {
                        <MudSelect T="Guid?" Label="Assistant" @bind-Value="_quickSelectSelectedAssistantId"
                                   Variant="Variant.Outlined" Required="true" Class="mb-3"
                                   AnchorOrigin="Origin.BottomCenter">
                            @foreach (var a in _quickSelectAssistants)
                            {
                                <MudSelectItem T="Guid?" Value="@a.UserId">
                                    @a.DisplayName @(a.Username != null ? $"(@{a.Username})" : "")
                                </MudSelectItem>
                            }
                        </MudSelect>
                    }
                }

                @if (_quickSelectSelectedAssistantId.HasValue && _quickSelectSelectedPages.Any())
                {
                    <MudText Typo="Typo.subtitle2" Class="mt-2 mb-2">Task Details</MudText>
                    <MudGrid>
                        <MudItem xs="12" md="6">
                            <MudSelect T="string" Label="Task Type" @bind-Value="_quickSelectTypeCode"
                                       Variant="Variant.Outlined" Required="true" Class="mb-3">
                                <MudSelectItem Value="@("BACKGROUND")">Background</MudSelectItem>
                                <MudSelectItem Value="@("SHADING")">Shading</MudSelectItem>
                                <MudSelectItem Value="@("EFFECTS")">Effects</MudSelectItem>
                                <MudSelectItem Value="@("CLEANUP")">Cleanup</MudSelectItem>
                                <MudSelectItem Value="@("DIALOGUE")">Dialogue</MudSelectItem>
                                <MudSelectItem Value="@("TYPESETTING")">Typesetting</MudSelectItem>
                                <MudSelectItem Value="@("REVIEW")">Review</MudSelectItem>
                                <MudSelectItem Value="@("OTHER")">Other</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="_quickSelectTitlePrefix" Label="Task Title Prefix"
                                          Variant="Variant.Outlined" Required="true" Class="mb-3"
                                          HelperText="e.g. 'Cleanup' → tasks named 'Cleanup - Page 1'" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="_quickSelectPriority" Label="Priority (1-5)"
                                             Variant="Variant.Outlined" Min="1" Max="5" Required="true" Class="mb-3" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudDatePicker @bind-Date="_quickSelectDueDate" Label="Due Date"
                                           Class="mb-3" />
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <MudNumericField @bind-Value="_quickSelectCompensation" Label="Compensation"
                                             Variant="Variant.Outlined" Min="0" Class="mb-3"
                                             Format="F2" />
                        </MudItem>
                    </MudGrid>

                    <MudTextField @bind-Value="_quickSelectDefaultDescription" Label="Default Task Description"
                                  Variant="Variant.Outlined" Lines="4" Required="true" Class="mb-3"
                                  HelperText="Applied to all selected pages unless overridden." />

                    @if (_quickSelectSelectedPages.Any())
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            Per-Page Description Overrides <MudText Typo="Typo.caption" Class="mf-muted">(optional)</MudText>
                        </MudText>
                        <MudPaper Class="pa-2 mb-3" Elevation="0" Style="max-height:240px;overflow-y:auto;">
                            @foreach (var pg in _quickSelectSelectedPages)
                            {
                                <MudExpansionPanels Class="mb-1" Style="box-shadow:none;">
                                    <MudExpansionPanel Text="@($"Page {pg.PageNo} — v{pg.VersionNo}")">
                                        <MudTextField @bind-Value="_quickSelectPageOverrides[pg.ChapterPageId]"
                                                      Label="@($"Override for Page {pg.PageNo}")"
                                                      Variant="Variant.Outlined" Lines="3"
                                                      HelperText="Leave empty to use default description." />
                                    </MudExpansionPanel>
                                </MudExpansionPanels>
                            }
                        </MudPaper>
                    }
                }
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="CloseQuickSelect" Disabled="@_quickSelectSubmitting">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           Disabled="@(!CanQuickSelectSubmit() || _quickSelectSubmitting)"
                           OnClick="ConfirmQuickSelect">
                    @(_quickSelectSubmitting ? "Creating..." : "Create Tasks")
                </MudButton>
            </DialogActions>
        </MudDialog>

    </div>
</MangakaLayout>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<ChapterPageTaskDto> _tasks = Array.Empty<ChapterPageTaskDto>();
    private string _searchText = string.Empty;
    private string _typeFilter = string.Empty;
    private string _assistantFilter = string.Empty;
    private string _statusFilter = "ALL";
    private bool _actionInProgress;

    // Dialog state
    private bool _showReturnDialog;
    private bool _showCancelDialog;
    private string _returnReason = string.Empty;
    private string _cancelReason = string.Empty;
    private Guid _dialogTaskId;
    private ChapterPageTaskDto? _returnDialogTask;

    // Reassign dialog state
    private bool _showReassignDialog;
    private bool _loadingAssistants;
    private ChapterPageTaskDto? _reassignDialogTask;
    private string _reassignReason = string.Empty;
    private string _reassignDescription = string.Empty;
    private Guid? _selectedNewAssistantUserId;
    private IReadOnlyList<EligibleAssistantDto> _eligibleAssistants = Array.Empty<EligibleAssistantDto>();

    private IEnumerable<ChapterPageTaskDto> _filteredTasks =>
        ApplyFilters(_tasks);

    private IEnumerable<ChapterPageTaskDto> ApplyFilters(IEnumerable<ChapterPageTaskDto> source)
    {
        var query = source.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            var search = _searchText.Trim();
            query = query.Where(t =>
                (t.SeriesTitle != null && t.SeriesTitle.Contains(search, StringComparison.OrdinalIgnoreCase)) ||
                (t.ChapterNumberLabel != null && t.ChapterNumberLabel.Contains(search, StringComparison.OrdinalIgnoreCase)) ||
                (t.ChapterTitle != null && t.ChapterTitle.Contains(search, StringComparison.OrdinalIgnoreCase)) ||
                (t.TaskTitle != null && t.TaskTitle.Contains(search, StringComparison.OrdinalIgnoreCase)));
        }

        if (!string.IsNullOrWhiteSpace(_typeFilter))
        {
            query = query.Where(t => t.TypeCode == _typeFilter);
        }

        if (!string.IsNullOrWhiteSpace(_assistantFilter))
        {
            query = query.Where(t =>
                (t.AssignedToDisplayName != null && t.AssignedToDisplayName.Equals(_assistantFilter, StringComparison.OrdinalIgnoreCase)) ||
                (t.AssignedUsername != null && t.AssignedUsername.Equals(_assistantFilter, StringComparison.OrdinalIgnoreCase)));
        }

        if (_statusFilter != "ALL")
        {
            query = query.Where(t => t.StatusCode == _statusFilter);
        }

        return query;
    }

    private int _underReviewCount => _tasks.Count(t => t.StatusCode == "UNDER_REVIEW");
    private int _assignedCount => _tasks.Count(t => t.StatusCode == "ASSIGNED");
    private int _completedCount => _tasks.Count(t => t.StatusCode == "COMPLETED");
    private int _cancelledCount => _tasks.Count(t => t.StatusCode == "CANCELLED");

    private IEnumerable<string> _availableAssistants =>
        _tasks
            .Select(t => t.AssignedToDisplayName ?? t.AssignedUsername ?? "")
            .Where(n => !string.IsNullOrWhiteSpace(n))
            .Distinct()
            .OrderBy(n => n)
            .ToList();

    // Quick Select state
    private bool _showQuickSelect;
    private bool _quickSelectSubmitting;
    private bool _quickSelectLoadingSeries;
    private bool _quickSelectLoadingChapters;
    private bool _quickSelectLoadingPages;
    private bool _quickSelectLoadingAssistants;
    private Guid? _quickSelectSelectedSeriesId;
    private Guid? _quickSelectSelectedChapterId;
    private Guid? _quickSelectSelectedAssistantId;
    private string _quickSelectTypeCode = string.Empty;
    private string _quickSelectTitlePrefix = string.Empty;
    private int _quickSelectPriority = 3;
    private DateTime? _quickSelectDueDate = DateTime.Today.AddDays(7);
    private decimal _quickSelectCompensation;
    private string _quickSelectDefaultDescription = string.Empty;
    private IReadOnlyList<SeriesDto> _quickSelectSeries = Array.Empty<SeriesDto>();
    private IReadOnlyList<QuickSelectChapterDto> _quickSelectChapters = Array.Empty<QuickSelectChapterDto>();
    private IReadOnlyList<QuickSelectPageDto> _quickSelectPages = Array.Empty<QuickSelectPageDto>();
    private IReadOnlyList<QuickSelectAssistantDto> _quickSelectAssistants = Array.Empty<QuickSelectAssistantDto>();
    private Dictionary<Guid, bool> _quickSelectPageSelections = new();
    private Dictionary<Guid, string> _quickSelectPageOverrides = new();

    private IReadOnlyList<QuickSelectPageDto> _quickSelectSelectedPages =>
        _quickSelectPages.Where(p => _quickSelectPageSelections.TryGetValue(p.ChapterPageId, out var sel) && sel).ToList();

    private bool CanQuickSelectSubmit()
    {
        return _quickSelectSelectedSeriesId.HasValue
            && _quickSelectSelectedChapterId.HasValue
            && _quickSelectSelectedAssistantId.HasValue
            && _quickSelectSelectedPages.Any()
            && !string.IsNullOrWhiteSpace(_quickSelectTypeCode)
            && !string.IsNullOrWhiteSpace(_quickSelectTitlePrefix)
            && _quickSelectDueDate.HasValue
            && _quickSelectPriority is >= 1 and <= 5
            && _quickSelectCompensation >= 0
            && !string.IsNullOrWhiteSpace(_quickSelectDefaultDescription);
    }

    private void OpenQuickSelect()
    {
        _showQuickSelect = true;
        _quickSelectSelectedSeriesId = null;
        _quickSelectSelectedChapterId = null;
        _quickSelectSelectedAssistantId = null;
        _quickSelectTypeCode = string.Empty;
        _quickSelectTitlePrefix = string.Empty;
        _quickSelectPriority = 3;
        _quickSelectDueDate = DateTime.Today.AddDays(7);
        _quickSelectCompensation = 0;
        _quickSelectDefaultDescription = string.Empty;
        _quickSelectSeries = Array.Empty<SeriesDto>();
        _quickSelectChapters = Array.Empty<QuickSelectChapterDto>();
        _quickSelectPages = Array.Empty<QuickSelectPageDto>();
        _quickSelectAssistants = Array.Empty<QuickSelectAssistantDto>();
        _quickSelectPageSelections = new();
        _quickSelectPageOverrides = new();
        _quickSelectSubmitting = false;

        _ = LoadQuickSelectSeriesAsync();
    }

    private void CloseQuickSelect()
    {
        _showQuickSelect = false;
    }

    private async Task LoadQuickSelectSeriesAsync()
    {
        _quickSelectLoadingSeries = true;
        try
        {
            _quickSelectSeries = await MangakaSeriesClient.GetMySeriesAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load series: {ex.Message}", Severity.Error);
        }
        finally
        {
            _quickSelectLoadingSeries = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnQuickSelectSeriesChanged(Guid? seriesId)
    {
        _quickSelectSelectedChapterId = null;
        _quickSelectChapters = Array.Empty<QuickSelectChapterDto>();
        _quickSelectPages = Array.Empty<QuickSelectPageDto>();
        _quickSelectPageSelections = new();
        _quickSelectPageOverrides = new();
        _quickSelectSelectedAssistantId = null;
        _quickSelectAssistants = Array.Empty<QuickSelectAssistantDto>();

        if (!seriesId.HasValue)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        var loadChapters = LoadQuickSelectChaptersAsync(seriesId.Value);
        var loadAssistants = LoadQuickSelectAssistantsInternalAsync(seriesId.Value);
        await Task.WhenAll(loadChapters, loadAssistants);
    }

    private async Task LoadQuickSelectChaptersAsync(Guid seriesId)
    {
        _quickSelectLoadingChapters = true;
        try
        {
            _quickSelectChapters = await MangakaTaskClient.GetQuickSelectChaptersAsync(_currentUserId, seriesId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load chapters: {ex.Message}", Severity.Error);
        }
        finally
        {
            _quickSelectLoadingChapters = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnQuickSelectChapterChanged(Guid? chapterId)
    {
        _quickSelectPages = Array.Empty<QuickSelectPageDto>();
        _quickSelectPageSelections = new();
        _quickSelectPageOverrides = new();

        if (!chapterId.HasValue)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        _quickSelectLoadingPages = true;
        try
        {
            _quickSelectPages = await MangakaTaskClient.GetQuickSelectPagesAsync(chapterId.Value);
            _quickSelectPageSelections = _quickSelectPages.ToDictionary(p => p.ChapterPageId, _ => false);
            _quickSelectPageOverrides = _quickSelectPages.ToDictionary(p => p.ChapterPageId, _ => string.Empty);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load pages: {ex.Message}", Severity.Error);
        }
        finally
        {
            _quickSelectLoadingPages = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task LoadQuickSelectAssistantsInternalAsync(Guid seriesId)
    {
        _quickSelectLoadingAssistants = true;
        try
        {
            _quickSelectAssistants = await MangakaTaskClient.GetQuickSelectAssistantsAsync(_currentUserId, seriesId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load assistants: {ex.Message}", Severity.Error);
        }
        finally
        {
            _quickSelectLoadingAssistants = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void SelectAllPages()
    {
        foreach (var key in _quickSelectPageSelections.Keys.ToList())
            _quickSelectPageSelections[key] = true;
    }

    private void ClearAllPages()
    {
        foreach (var key in _quickSelectPageSelections.Keys.ToList())
            _quickSelectPageSelections[key] = false;
    }

    private async Task ConfirmQuickSelect()
    {
        if (!CanQuickSelectSubmit()) return;

        var selectedPages = _quickSelectSelectedPages;
        if (!selectedPages.Any())
        {
            Snackbar.Add("No pages selected.", Severity.Warning);
            return;
        }

        _quickSelectSubmitting = true;
        try
        {
            var pageRequests = selectedPages.Select(p =>
            {
                var overrideText = _quickSelectPageOverrides.TryGetValue(p.ChapterPageId, out var o) ? o?.Trim() : null;
                return new QuickSelectPageTaskRequest(
                    p.ChapterPageId,
                    p.CurrentChapterPageVersionId,
                    string.IsNullOrWhiteSpace(overrideText) ? null : overrideText);
            }).ToList();

            var request = new QuickSelectTaskAssignmentRequest(
                _quickSelectSelectedSeriesId!.Value,
                _quickSelectSelectedChapterId!.Value,
                _quickSelectSelectedAssistantId!.Value,
                _quickSelectTypeCode.Trim(),
                _quickSelectTitlePrefix.Trim(),
                _quickSelectDefaultDescription.Trim(),
                (byte)_quickSelectPriority,
                _quickSelectDueDate!.Value,
                _quickSelectCompensation,
                pageRequests);

            var result = await MangakaTaskClient.QuickSelectAssignAsync(_currentUserId, request);

            _showQuickSelect = false;
            Snackbar.Add($"Created {result.CreatedTaskCount} task(s).", Severity.Success);
            await RefreshTasksAfterMutationAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{ex.Message}", Severity.Error);
        }
        finally
        {
            _quickSelectSubmitting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadTasksAsync();
    }

    private async Task LoadTasksAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _tasks = await MangakaTaskClient.GetTasksForReviewAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    /// <summary>
    /// Shared post-mutation refresh: reloads full task list, clears dialog/action state,
    /// and invokes StateHasChanged to guarantee UI re-render.
    /// </summary>
    private async Task RefreshTasksAfterMutationAsync()
    {
        _showReturnDialog = false;
        _showCancelDialog = false;
        _showReassignDialog = false;
        _returnReason = string.Empty;
        _returnDialogTask = null;
        _cancelReason = string.Empty;
        _reassignReason = string.Empty;
        _reassignDescription = string.Empty;
        _selectedNewAssistantUserId = null;
        _eligibleAssistants = Array.Empty<EligibleAssistantDto>();
        _dialogTaskId = Guid.Empty;

        await LoadTasksAsync();
        await InvokeAsync(StateHasChanged);
    }

    // StoredProc: usp_ChapterPageTask_MarkCompleted
    private async Task ApproveTask(Guid taskId)
    {
        _actionInProgress = true;
        try
        {
            await MangakaTaskClient.ApproveTaskAsync(_currentUserId, taskId);
            Snackbar.Add("Task approved successfully.", Severity.Success);
            await RefreshTasksAfterMutationAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to approve: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private void OpenReturnDialog(ChapterPageTaskDto task)
    {
        _dialogTaskId = task.ChapterPageTaskId;
        _returnDialogTask = task;
        _returnReason = string.Empty;
        _showReturnDialog = true;
    }

    private async Task ConfirmReturn()
    {
        _actionInProgress = true;
        _showReturnDialog = false;
        try
        {
            await MangakaTaskClient.ReturnTaskForReworkAsync(_currentUserId, _dialogTaskId, _returnReason.Trim());
            Snackbar.Add("Task returned for rework.", Severity.Success);
            await RefreshTasksAfterMutationAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to return for rework: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private void OpenCancelDialog(ChapterPageTaskDto task)
    {
        _dialogTaskId = task.ChapterPageTaskId;
        _cancelReason = string.Empty;
        _showCancelDialog = true;
    }

    private async Task ConfirmCancel()
    {
        _actionInProgress = true;
        _showCancelDialog = false;
        try
        {
            await MangakaTaskClient.CancelTaskAsync(_currentUserId, _dialogTaskId, _cancelReason.Trim());
            Snackbar.Add("Task cancelled.", Severity.Success);
            await RefreshTasksAfterMutationAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to cancel: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    // --- Reassign ---

    private async Task OpenReassignDialog(ChapterPageTaskDto task)
    {
        _dialogTaskId = task.ChapterPageTaskId;
        _reassignDialogTask = task;
        _reassignReason = string.Empty;
        _reassignDescription = string.Empty;
        _selectedNewAssistantUserId = null;
        _eligibleAssistants = Array.Empty<EligibleAssistantDto>();
        _showReassignDialog = true;
        _loadingAssistants = true;

        try
        {
            _eligibleAssistants = await MangakaTaskClient.GetEligibleAssistantsAsync(_currentUserId, task.ChapterPageTaskId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load eligible assistants: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loadingAssistants = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConfirmReassign()
    {
        if (!_selectedNewAssistantUserId.HasValue || string.IsNullOrWhiteSpace(_reassignReason))
            return;

        _actionInProgress = true;
        _showReassignDialog = false;
        try
        {
            var request = new ReassignChapterPageTaskRequest(
                _selectedNewAssistantUserId.Value,
                _reassignReason.Trim(),
                string.IsNullOrWhiteSpace(_reassignDescription) ? null : _reassignDescription.Trim());

            await MangakaTaskClient.ReassignTaskAsync(_currentUserId, _dialogTaskId, request);
            Snackbar.Add("Task reassigned successfully.", Severity.Success);
            await RefreshTasksAfterMutationAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to reassign: {ex.Message}", Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private void OnFilterChanged(string newFilter)
    {
        _statusFilter = newFilter;
    }

    private void OnTypeFilterChanged(string newFilter)
    {
        _typeFilter = newFilter ?? string.Empty;
    }

    private async Task<IEnumerable<string>> SearchAssistants(string searchText, CancellationToken cancellationToken)
    {
        if (string.IsNullOrWhiteSpace(searchText))
            return _availableAssistants;

        return _availableAssistants
            .Where(n => n.Contains(searchText, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    /// <summary>
    /// Builds a workspace link for a task card, including returnUrl back to this page.
    /// Route: /series/{slug}/workspace?chapterId={id}&amp;returnUrl=/mangaka/review-submissions
    /// </summary>
    private static string BuildWorkspaceLink(ChapterPageTaskDto task)
    {
        var baseUrl = $"/series/{task.SeriesSlug}/workspace?chapterId={task.ChapterId}";
        return SafeReturnUrl.AppendReturnUrl(baseUrl, "/mangaka/review-submissions");
    }
}
