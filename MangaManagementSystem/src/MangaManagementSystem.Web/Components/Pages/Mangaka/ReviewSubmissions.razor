    private static string ChToString(QuickSelectChapterDto? ch)
        => ch == null ? "" : $"Ch. {ch.ChapterNumber}{(ch.Title != null ? $" {ch.Title}" : "")}{(ch.PageCount.HasValue ? $" ({ch.PageCount} pages)" : "")}";

    private static string AsstToString(QuickSelectAssistantDto? a)
        => a == null ? "" : $"{a.DisplayName}{(a.Username != null ? $" (@{a.Username})" : "")}";

