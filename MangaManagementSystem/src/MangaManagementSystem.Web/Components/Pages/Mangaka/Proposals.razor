@page "/mangaka/proposals"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Components.Layouts
@using MangaManagementSystem.Web.Services.Api
@using MangaManagementSystem.Web.Components.Shared
@attribute [Authorize(Roles = "Mangaka")]
@inject IMangakaSeriesApiClient MangakaSeriesApiClient
@inject IReferenceDataApiClient ReferenceDataApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MangakaLayout>
    <div class="mf-page" style="padding: 24px;">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="color: #64748b; margin-bottom: 16px;"
                   OnClick="@(() => Nav.NavigateTo("/mangaka"))">
            Back to Mangaka Dashboard
        </MudButton>

        <div class="mf-page-header" style="margin-bottom: 24px;">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Series Proposals</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Track submitted proposal versions and review progress</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else
        {
            <SeriesProposalTable Items="@_mappedItems"
                                 DefaultStatusFilter="All"
                                 ShowGenreFilter="true"
                                 ShowTagFilter="true"
                                 ShowReviewerColumns="false"
                                 AvailableGenres="_availableGenres"
                                 AvailableTags="_availableTags"
                                 RowClicked="OnRowClicked" />
        }
    </div>
</MangakaLayout>

@code {
    private bool _loading = true;
    private Guid? _currentUserId;

    private IReadOnlyList<MangakaSeriesProposalDto>? _proposalData;
    private IReadOnlyList<SeriesProposalListItemModel> _mappedItems = Array.Empty<SeriesProposalListItemModel>();
    private IReadOnlyList<GenreDto> _availableGenres = Array.Empty<GenreDto>();
    private IReadOnlyList<TagDto> _availableTags = Array.Empty<TagDto>();

    private void OnRowClicked(Guid seriesProposalId)
    {
        Nav.NavigateTo($"/mangaka/proposals/{seriesProposalId}");
    }

    private async Task LoadProposalTrackingAsync()
    {
        if (_currentUserId is null || _currentUserId == Guid.Empty)
        {
            _proposalData = Array.Empty<MangakaSeriesProposalDto>();
            return;
        }

        try
        {
            _proposalData = await MangakaSeriesApiClient.GetMySeriesProposalsAsync(_currentUserId.Value);
            _mappedItems = _proposalData.Select(MapToListItem).ToList().AsReadOnly();
            _availableGenres = _proposalData
                .SelectMany(p => p.Genres)
                .DistinctBy(g => g.GenreId)
                .OrderBy(g => g.GenreName)
                .ToList()
                .AsReadOnly();
            _availableTags = _proposalData
                .SelectMany(p => p.Tags)
                .DistinctBy(t => t.TagId)
                .OrderBy(t => t.TagName)
                .ToList()
                .AsReadOnly();
        }
        catch
        {
            _proposalData = Array.Empty<MangakaSeriesProposalDto>();
            _mappedItems = Array.Empty<SeriesProposalListItemModel>();
        }
    }

    private static SeriesProposalListItemModel MapToListItem(MangakaSeriesProposalDto p) => new(
        SeriesProposalId: p.SeriesProposalId,
        SeriesTitle: p.SeriesTitle,
        ProposalTitle: p.ProposalTitle,
        ProposalVersionNo: p.ProposalVersionNo,
        SubmittedByDisplayName: p.SubmittedByDisplayName,
        SubmittedAtUtc: p.SubmittedAtUtc,
        ReviewerDisplayName: p.ReviewedByDisplayName,
        ReviewedAtUtc: p.ReviewedAtUtc,
        StatusCode: p.StatusCode,
        HasMarkup: p.MarkupFile is not null,
        Genres: p.Genres,
        Tags: p.Tags
    );

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var uid))
                _currentUserId = uid;
        }
        catch { }

        await LoadProposalTrackingAsync();
        _loading = false;
    }
}
