@page "/mangaka"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Globalization
@attribute [Authorize(Roles = "Mangaka")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ISeriesService SeriesService
@inject IChapterPageTaskService TaskService
@inject IMangakaSeriesApiClient MangakaSeriesApiClient
@inject IProfileApiClient ProfileApiClient
@inject AuthenticationStateProvider AuthStateProvider
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api

@* ── Full-page layout matching React SeriesListPage.tsx ── *@
<div class="mf-dashboard-shell" style="display: flex; height: 100vh; overflow: hidden; background: #f8fafc;">
    @* ── Left Sidebar (260px) ── *@
    <aside style="width: 260px; flex-shrink: 0; background: #fff; border-right: 1px solid #e2e8f0; display: flex; flex-direction: column;">
        @* Profile Header *@
        <div style="padding: 16px; border-bottom: 1px solid #f1f5f9;">
            <MudMenu FullWidth="true" Style="cursor: pointer;">
                <ActivatorContent>
                    <div style="display: flex; align-items: center; gap: 12px; padding: 4px; border-radius: 8px; width: 100%; min-width: 0;">
                        @if (!string.IsNullOrWhiteSpace(_currentAvatarUrl))
                        {
                            <img src="@_currentAvatarUrl"
                                 alt="User avatar"
                                 style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
                        }
                        else
                        {
                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                @_currentAvatarInitial
                            </MudAvatar>
                        }

                        <div style="flex: 1; min-width: 0;">
                            <div title="@_currentDisplayName"
     style="font-weight: 600;
            font-size: 0.85rem;
            color: #111827;
            line-height: 1.2;
            width: 145px;
            max-width: 145px;
            min-width: 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            cursor: help;">
    @_currentDisplayName
</div>

                            <div style="color: #64748b; font-size: 0.7rem;">
                                @_currentRoleName
                            </div>
                        </div>
                        <MudIcon Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small" Style="font-size: 18px; color: #94a3b8;" />
                    </div>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="@(() => Nav.NavigateTo("/profile/settings"))">
                        <MudIcon Icon="@Icons.Material.Filled.Settings" Size="Size.Small" Style="margin-right: 8px;" />
                        Account Settings
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem Style="color: #dc2626;" OnClick="@(() => Nav.NavigateTo("/signout", true))">
                        <MudIcon Icon="@Icons.Material.Filled.Logout" Size="Size.Small" Style="margin-right: 8px; color: #dc2626;" />
                        Logout
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
        </div>

        @* Navigation Tabs *@
        <div style="flex: 1; overflow: auto; padding: 16px 12px;">
            <div style="color: #94a3b8; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; font-size: 0.65rem; padding: 0 12px; margin-bottom: 8px;">Main Menu</div>
            <div style="display: flex; flex-direction: column; gap: 4px;">
                @foreach (var nav in _navItems)
                {
                    var isActive = _activeTab == nav.Id;
                    <button @onclick="() => _activeTab = nav.Id"
                            style="display: flex; align-items: center; gap: 12px; padding: 8px 12px; border: none; border-radius: 8px; cursor: pointer; width: 100%; text-align: left; font-size: 0.85rem; font-weight: @(isActive ? 600 : 500); background: @(isActive ? "#eef2ff" : "transparent"); color: @(isActive ? "#4f46e5" : "#64748b");">
                        <MudIcon Icon="@nav.Icon" Size="Size.Small" Style="font-size: 18px; flex-shrink: 0;" />
                        <span>@nav.Label</span>
                    </button>
                }
            </div>
        </div>

    </aside>

    @* ── Main Content Area ── *@
    <main style="flex: 1; display: flex; flex-direction: column; overflow: hidden;">
        @* Top Header *@
        <div style="padding: 24px 32px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid #e2e8f0; background: #f8fafc; z-index: 10;">
            <div>
                <div style="font-weight: 800; font-size: 1.6rem; color: #111827; letter-spacing: -0.03em; line-height: 1.1; margin-bottom: 4px;">
                    @_navItems.First(n => n.Id == _activeTab).Label
                </div>
                <div style="color: #64748b; font-size: 0.85rem;">
                    @if (_activeTab == "current")
                    {
                        <span>@_seriesData.Count active projects in your catalog</span>
                    }
                    else
                    {
                        <span>Manage your @_navItems.First(n => n.Id == _activeTab).Label.ToLower()</span>
                    }
                </div>
            </div>
            @if (_activeTab == "current")
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="@(() => _newSeriesDialogOpen = true)"
                           StartIcon="@Icons.Material.Filled.Add">
                    New Series
                </MudButton>
            }
        </div>

        @* Scrollable Content *@
        <div style="flex: 1; overflow: auto; padding: 32px;">
            @if (_activeTab == "current")
            {
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
                    @foreach (var series in _seriesData)
                    {
                        @* ── Series Card ── *@
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 1px 4px rgba(15,23,42,0.05); position: relative; overflow: hidden; cursor: pointer; display: flex; flex-direction: column;"
                             @onclick="() => OpenSeriesCard(series)">

                            @* Cover thumbnail / placeholder *@
                            @if (!string.IsNullOrWhiteSpace(series.CoverUrl))
                            {
                                <div style="height: 130px; overflow: hidden; flex-shrink: 0;">
                                    <img src="@series.CoverUrl"
                                         alt="Cover for @series.Title"
                                         style="width: 100%; height: 100%; object-fit: cover; display: block;" />
                                </div>
                            }
                            else
                            {
                                <div style="height: 130px; background: @(series.Color + "12"); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook"
                                             Style="@($"font-size: 48px; color: {series.Color}; opacity: 0.35;")" />
                                </div>
                            }

                            @* Kebab menu — top-right over thumbnail *@
                            <div style="position: absolute; top: 8px; right: 8px; z-index: 10;" @onclick:stopPropagation>
                                <MudMenu>
                                    <ActivatorContent>
                                        <MudIconButton Icon="@Icons.Material.Filled.MoreVert" Size="Size.Small"
                                                       Style="background: rgba(255,255,255,0.85); border-radius: 50%;" />
                                    </ActivatorContent>
                                    <ChildContent>
                                        @* Cancel Draft — PROPOSAL_DRAFT only, disabled (no backend yet) *@
                                        @if (series.StatusCode == "PROPOSAL_DRAFT")
                                        {
                                            <MudTooltip Text="Cancel workflow will be available in a future update.">
                                                <MudMenuItem Disabled="true">
                                                    <MudIcon Icon="@Icons.Material.Filled.Cancel" Size="Size.Small" Style="margin-right: 8px; color: #94a3b8;" />
                                                    <span style="color: #94a3b8;">Cancel Draft</span>
                                                </MudMenuItem>
                                            </MudTooltip>
                                        }
                                    </ChildContent>
                                </MudMenu>
                            </div>

                            @* Accent bar *@
                            <div style="height: 3px; background: @series.Color; flex-shrink: 0;"></div>

                            @* Card body *@
                            <div style="padding: 16px; flex: 1; display: flex; flex-direction: column; gap: 10px;">
                                <div style="color: #111827; font-weight: 700; font-size: 0.9rem; line-height: 1.3; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@series.Title</div>

                                <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                                    <span style="background: #f1f5f9; color: #475569; font-size: 0.65rem; padding: 2px 8px; border-radius: 12px; font-weight: 500; height: 22px; display: flex; align-items: center;">@series.Genre</span>
                                    <span style="background: @SeriesStatusHelper.BadgeColor(series.StatusCode); color: @SeriesStatusHelper.TextColor(series.StatusCode); font-size: 0.65rem; padding: 2px 8px; border-radius: 12px; font-weight: 600; height: 22px; display: flex; align-items: center;">@SeriesStatusHelper.DisplayName(series.StatusCode)</span>
                                </div>

                                <div style="display: flex; align-items: center; gap: 4px;">
                                    <span style="width: 6px; height: 6px; border-radius: 50%; background: #10b981; display: inline-block;"></span>
                                    <span style="color: #94a3b8; font-size: 0.7rem;">Updated @series.LastUpdated</span>
                                </div>
                            </div>

                            @* Card action row — visible primary actions for PROPOSAL_DRAFT *@
                            @if (series.StatusCode == "PROPOSAL_DRAFT")
                            {
                                <div style="padding: 0 16px 14px; display: flex; gap: 8px;" @onclick:stopPropagation>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" FullWidth="true"
                                               OnClick="@(() => OpenDraftDetails(series))">
                                        View Draft
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.Send"
                                               OnClick="@(() => OpenSubmitProposal(series.Id, series.Title))">
                                        Submit
                                    </MudButton>
                                </div>
                            }
                            else if (series.StatusCode is "UNDER_EDITORIAL_REVIEW" or "UNDER_BOARD_REVIEW")
                            {
                                <div style="padding: 0 16px 14px;" @onclick:stopPropagation>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" FullWidth="true"
                                               OnClick="@(() => OpenReviewStatus(series))">
                                        View Status
                                    </MudButton>
                                </div>
                            }
                        </div>
                    }

                    @* Add New Series Card *@
                    <div style="background: #fafafe; border: 1.5px dashed #c7d2fe; border-radius: 12px; cursor: pointer; display: flex; align-items: center; justify-content: center; min-height: 280px;"
                         @onclick="() => _newSeriesDialogOpen = true">
                        <div style="display: flex; flex-direction: column; align-items: center; gap: 12px; padding: 24px;">
                            <div style="width: 44px; height: 44px; border-radius: 12px; background: #e0e7ff; display: flex; align-items: center; justify-content: center;">
                                <MudIcon Icon="@Icons.Material.Filled.Add" Size="Size.Small" Style="color: #4f46e5; font-size: 24px;" />
                            </div>
                            <div style="color: #4f46e5; font-weight: 600; font-size: 0.85rem;">New Series Draft</div>
                            <div style="color: #94a3b8; font-size: 0.75rem; text-align: center;">Start a new series draft</div>
                        </div>
                    </div>
                </div>
            }
            else if (_activeTab == "review")
            {
                <div style="display: flex; flex-direction: column; gap: 16px;">
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
                        <StatCard Label="Total Tasks" Value="@_taskStats.Total.ToString()" />
                        <StatCard Label="In Progress" Value="@_taskStats.Assigned.ToString()" />
                        <StatCard Label="Under Review" Value="@_taskStats.UnderReview.ToString()" />
                        <StatCard Label="Completed" Value="@_taskStats.Completed.ToString()" />
                    </div>
                    <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px;">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Assigned Tasks</MudText>
                        @if (_tasks.Count == 0)
                        {
                            <MudText Typo="Typo.body2" Style="color: #94a3b8;">No tasks assigned yet.</MudText>
                        }
                        else
                        {
                            <MudTable Items="_tasks" Hover="true">
                                <HeaderContent>
                                    <MudTh>Title</MudTh><MudTh>Type</MudTh><MudTh>Assigned To</MudTh><MudTh>Status</MudTh><MudTh>Due</MudTh><MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.TaskTitle</MudTd>
                                    <MudTd>@context.TypeCode</MudTd>
                                    <MudTd>@context.AssignedToDisplayName</MudTd>
                                    <MudTd><MudChip T="string" Color="@GetTaskChipColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                                    <MudTd>@FormatDate(context.DueAtUtc)</MudTd>
                                    <MudTd>
                                        @if (context.SeriesId.HasValue)
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary"
                                                       OnClick="@(() => Nav.NavigateTo($"/mangaka/workspace/{context.SeriesId}?taskId={context.ChapterPageTaskId}"))">
                                                Open in Workspace
                                            </MudButton>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </div>
                </div>
            }
            else if (_activeTab == "ranking")
            {
                <div style="display: flex; flex-direction: column; gap: 24px;">
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">Decision Support Alert: low-performing series may require board review.</MudAlert>
                    <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;">
                        <StatCard Label="Total Serialized" Value="24" />
                        <StatCard Label="Series at Risk" Value="3" />
                        <StatCard Label="Avg Performance" Value="87.2%" />
                        <StatCard Label="Total Poll Votes" Value="156.2K" />
                    </div>
                    <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px;">
                        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px;">
                            <div>
                                <div style="font-weight: 600; color: #111827;">Weekly reader poll results and status tracking</div>
                                <div style="color: #94a3b8; font-size: 0.85rem;">@_rankingWeek</div>
                            </div>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => _showRankingUpdate = true)">Update Weekly Poll Results</MudButton>
                        </div>
                        <MudTable Items="_rankingData" Hover="true">
                            <HeaderContent>
                                <MudTh>#</MudTh><MudTh>Series</MudTh><MudTh>Total Votes</MudTh><MudTh>Performance</MudTh><MudTh>Risk</MudTh><MudTh>Action</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Rank</MudTd>
                                <MudTd>@context.Series</MudTd>
                                <MudTd>@context.Votes</MudTd>
                                <MudTd>@context.Performance%</MudTd>
                                <MudTd><MudChip T="string" Color="@context.Color" Size="Size.Small">@context.Risk</MudChip></MudTd>
                                <MudTd>@if (context.Risk == "Danger Zone") { <MudButton Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled">Prepare Board Review</MudButton> }</MudTd>
                            </RowTemplate>
                        </MudTable>
                    </div>
                    @if (_showRankingUpdate)
                    {
                        <div style="background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; padding: 24px;">
                            <div style="font-weight: 600; color: #111827; margin-bottom: 16px;">Update Weekly Poll Results</div>
                            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                                <MudTextField Label="Week" @bind-Value="_pollWeek" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudTextField Label="Series" @bind-Value="_pollSeries" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudTextField Label="Total Votes" @bind-Value="_pollVotes" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                <MudTextField Label="Rank" @bind-Value="_pollRank" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </div>
                            <MudTextField Label="Notes" @bind-Value="_pollNotes" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3" FullWidth="true" Class="mt-3" />
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-3" OnClick="@(() => _showRankingUpdate = false)">Save Update</MudButton>
                        </div>
                    }
                </div>
            }
            else if (_activeTab == "audit")
            {
                <div style="padding: 32px; background: #fff; border-radius: 12px; border: 1px solid #e2e8f0; text-align: center;">
                    <MudIcon Icon="@Icons.Material.Filled.Notifications" Size="Size.Large" Style="font-size: 40px; color: #cbd5e1; margin-bottom: 16px;" />
                    <div style="font-weight: 600; color: #111827; margin-bottom: 8px;">Audit Log Notifications</div>
                    <div style="color: #64748b; font-size: 0.85rem;">Activity feed displaying real-time updates from the production loop.</div>
                </div>
            }
        </div>
    </main>
</div>

@* ── New Series Draft Modal (creates manga.Series with status PROPOSAL_DRAFT) ── *@
<MudOverlay Visible="@_newSeriesDialogOpen" OnClick="@(() => _newSeriesDialogOpen = false)">
    <MudCard Style="width: 480px; max-width: 90vw; margin: 5% auto 0; border-radius: 14px;" @onclick:stopPropagation>
        <MudCardContent Style="padding: 0;">
            @* Modal Header *@
            <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">New Series Draft</div>
                    <div style="color: #94a3b8; font-size: 0.72rem;">Create a draft. You can submit it for review later.</div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _newSeriesDialogOpen = false)" />
            </div>

            @if (_draftCreated)
            {
                <div style="display: flex; flex-direction: column; align-items: center; padding: 48px; gap: 12px;">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Style="font-size: 48px; color: #059669;" />
                    <div style="font-weight: 700; color: #111827; font-size: 1rem;">Draft Created!</div>
                    <div style="color: #64748b; font-size: 0.85rem;">Status: @SeriesStatusHelper.DisplayName("PROPOSAL_DRAFT")</div>
                </div>
            }
            else
            {
                <div style="padding: 24px; display: flex; flex-direction: column; gap: 16px;">
                    <MudTextField Label="Title" @bind-Value="_newDraftTitle"
                                  Placeholder="e.g. The Immortal Blade Sect"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />

                    <MudTextField Label="Synopsis / Description" @bind-Value="_newDraftSynopsis"
                                  Placeholder="Describe the story, world, and main characters..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Lines="3" />

                    <MudSelect T="string" Label="Genre" @bind-Value="_newDraftGenre"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        @foreach (var g in _genres)
                        {
                            <MudSelectItem Value="@g">@g</MudSelectItem>
                        }
                    </MudSelect>

                    <MudSelect T="string" Label="Content Language" @bind-Value="_newDraftLanguage"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        @foreach (var lang in _languages)
                        {
                            <MudSelectItem Value="@lang.Code">@lang.Label</MudSelectItem>
                        }
                    </MudSelect>

                    @* Optional Series Cover Upload (purpose SERIES_COVER) *@
                    <div>
                        <div style="font-size: 0.78rem; font-weight: 600; color: #374151; margin-bottom: 6px;">Series Cover (optional)</div>
                        @if (_draftCoverFileName != null)
                        {
                            <div style="position: relative; display: flex; align-items: center; gap: 8px; padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 8px; background: #fafafe;">
                                <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Style="font-size: 20px; color: #4f46e5;" />
                                <span style="flex: 1; font-size: 0.82rem; color: #374151; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@_draftCoverFileName</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                               Style="color: #dc2626;"
                                               OnClick="@(() => { _draftCoverBytes = null; _draftCoverFileName = null; _draftCoverContentType = null; })" />
                            </div>
                        }
                        else
                        {
                            <MudFileUpload T="IBrowserFile" FilesChanged="@(async (IBrowserFile f) => { if (f == null) return; _draftCoverFileName = f.Name; _draftCoverContentType = f.ContentType; using var s = f.OpenReadStream(5*1024*1024); using var ms = new MemoryStream(); await s.CopyToAsync(ms); _draftCoverBytes = ms.ToArray(); })">
                                <ActivatorContent>
                                    <div style="border: 1.5px dashed #c7d2fe; border-radius: 8px; padding: 20px; display: flex; flex-direction: column; align-items: center; gap: 6px; cursor: pointer; background: #fafafe;">
                                        <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Style="font-size: 28px; color: #a5b4fc;" />
                                        <div style="color: #64748b; font-size: 0.75rem; font-weight: 500;">Click to upload cover art</div>
                                        <div style="color: #94a3b8; font-size: 0.65rem;">PNG, JPG, WEBP · Max 5MB</div>
                                    </div>
                                </ActivatorContent>
                            </MudFileUpload>
                        }
                    </div>

                    <MudButton Variant="Variant.Filled" FullWidth="true"
                               Disabled="@(_draftSaving || string.IsNullOrWhiteSpace(_newDraftTitle) || string.IsNullOrWhiteSpace(_newDraftGenre))"
                               OnClick="CreateSeriesDraft">
                        @(_draftSaving ? "Creating..." : "Create Draft")
                    </MudButton>
                </div>
            }
        </MudCardContent>
    </MudCard>
</MudOverlay>

@* ── Edit Draft Modal (BF-SERIES-002 — Edit Series Draft Profile) ── *@
@* Cover editing only allowed for PROPOSAL_DRAFT; status guard enforced by stored procedure. *@
<MudOverlay Visible="@_draftDetailsOpen" OnClick="@(() => _draftDetailsOpen = false)">
    <MudCard Style="width: 540px; max-width: 94vw; margin: 3% auto 0; border-radius: 14px; max-height: 92vh; overflow-y: auto;" @onclick:stopPropagation>
        <MudCardContent Style="padding: 0;">
            <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; background: #fff; z-index: 2;">
                <div>
                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">Edit Draft</div>
                    <div style="color: #94a3b8; font-size: 0.72rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 320px;"
                         title="@_detailSeries?.Title">@_detailSeries?.Title</div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _draftDetailsOpen = false)" />
            </div>

            <div style="padding: 24px; display: flex; flex-direction: column; gap: 16px;">

                @* Cover section *@
                <div>
                    <div style="font-size: 0.78rem; font-weight: 600; color: #374151; margin-bottom: 8px;">Series Cover</div>

                    @* Preview: new selection takes priority, then existing cover *@
                    @if (_editCoverPreviewUrl != null)
                    {
                        <div style="display: flex; justify-content: center; margin-bottom: 10px;">
                            <img src="@_editCoverPreviewUrl" alt="New cover preview"
                                 style="width: 80px; height: 113px; object-fit: cover; border-radius: 8px; border: 2px solid #6366f1;" />
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_detailSeries?.CoverUrl))
                    {
                        <div style="display: flex; justify-content: center; margin-bottom: 10px;">
                            <div style="position: relative; display: inline-block;">
                                <img src="@_detailSeries.CoverUrl" alt="Current cover"
                                     style="width: 80px; height: 113px; object-fit: cover; border-radius: 8px; border: 1px solid #e2e8f0;" />
                                <div style="position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%); background: #f1f5f9; color: #64748b; font-size: 0.6rem; padding: 1px 6px; border-radius: 6px; white-space: nowrap;">Current</div>
                            </div>
                        </div>
                    }

                    @if (_editCoverFileName != null)
                    {
                        <div style="display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 8px; background: #fafafe;">
                            <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Style="color: #4f46e5;" />
                            <span style="flex: 1; font-size: 0.8rem; color: #374151; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@_editCoverFileName</span>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Style="color: #dc2626;"
                                           OnClick="@ClearEditCover" />
                        </div>
                    }
                    else
                    {
                        <MudFileUpload T="IBrowserFile" FilesChanged="@OnEditCoverChanged">
                            <ActivatorContent>
                                <div style="border: 1.5px dashed #c7d2fe; border-radius: 8px; padding: 16px; display: flex; flex-direction: column; align-items: center; gap: 4px; cursor: pointer; background: #fafafe;">
                                    <MudIcon Icon="@Icons.Material.Filled.CloudUpload" Size="Size.Small" Style="font-size: 24px; color: #a5b4fc;" />
                                    <div style="color: #64748b; font-size: 0.75rem; font-weight: 500;">Click to replace cover</div>
                                    <div style="color: #94a3b8; font-size: 0.65rem;">PNG, JPG, WEBP · Max 5 MB</div>
                                </div>
                            </ActivatorContent>
                        </MudFileUpload>
                    }
                </div>

                @* Profile fields *@
                <MudTextField Label="Title" @bind-Value="_editTitle"
                              Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />

                <MudTextField Label="Synopsis / Description" @bind-Value="_editSynopsis"
                              Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Lines="3" />

                <MudSelect T="string" Label="Genre" @bind-Value="_editGenre"
                           Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    @foreach (var g in _genres)
                    {
                        <MudSelectItem Value="@g">@g</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Content Language" @bind-Value="_editLanguage"
                           Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    @foreach (var lang in _languages)
                    {
                        <MudSelectItem Value="@lang.Code">@lang.Label</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="string" Label="Publication Frequency" @bind-Value="_editFrequency"
                           Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    <MudSelectItem Value="@((string?)null)">— Not set —</MudSelectItem>
                    <MudSelectItem Value="@("WEEKLY")">Weekly</MudSelectItem>
                    <MudSelectItem Value="@("MONTHLY")">Monthly</MudSelectItem>
                    <MudSelectItem Value="@("IRREGULAR")">Irregular</MudSelectItem>
                </MudSelect>

                @* Action buttons *@
                <div style="display: flex; gap: 10px; padding-top: 4px;">
                    <MudButton Variant="Variant.Outlined" FullWidth="true"
                               Disabled="@_draftSavingEdit"
                               OnClick="@(() => _draftDetailsOpen = false)">
                        Cancel
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                               Disabled="@(_draftSavingEdit || string.IsNullOrWhiteSpace(_editTitle) || string.IsNullOrWhiteSpace(_editGenre))"
                               OnClick="SaveDraftEditAsync">
                        @(_draftSavingEdit ? "Saving..." : "Save Changes")
                    </MudButton>
                </div>

                <MudDivider />

                @* Submit Proposal — secondary action inside edit modal *@
                <MudButton Variant="Variant.Outlined" Color="Color.Success" FullWidth="true"
                           StartIcon="@Icons.Material.Filled.Send"
                           Disabled="@_draftSavingEdit"
                           OnClick="@(() => { _draftDetailsOpen = false; if (_detailSeries != null) OpenSubmitProposal(_detailSeries.Id, _editTitle ?? _detailSeries.Title); })">
                    Submit Proposal for Review
                </MudButton>
            </div>
        </MudCardContent>
    </MudCard>
</MudOverlay>

@* ── Review Status Modal (read-only — UNDER_EDITORIAL_REVIEW / UNDER_BOARD_REVIEW / etc.) ── *@
<MudOverlay Visible="@_reviewStatusOpen" OnClick="@(() => _reviewStatusOpen = false)">
    <MudCard Style="width: 440px; max-width: 92vw; margin: 8% auto 0; border-radius: 14px;" @onclick:stopPropagation>
        <MudCardContent Style="padding: 0;">
            <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">Series Status</div>
                    <div style="color: #94a3b8; font-size: 0.72rem; max-width: 280px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;"
                         title="@_reviewSeries?.Title">
                        @_reviewSeries?.Title
                    </div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="@(() => _reviewStatusOpen = false)" />
            </div>

            <div style="padding: 24px; display: flex; flex-direction: column; gap: 16px;">
                @* Cover *@
                @if (!string.IsNullOrWhiteSpace(_reviewSeries?.CoverUrl))
                {
                    <div style="display: flex; justify-content: center;">
                        <img src="@_reviewSeries.CoverUrl" alt="Series cover"
                             style="width: 70px; height: 100px; object-fit: cover; border-radius: 6px; border: 1px solid #e2e8f0;" />
                    </div>
                }

                <div style="display: flex; align-items: center; gap: 10px; justify-content: center;">
                    <span style="background: @SeriesStatusHelper.BadgeColor(_reviewSeries?.StatusCode ?? ""); color: @SeriesStatusHelper.TextColor(_reviewSeries?.StatusCode ?? ""); font-size: 0.8rem; padding: 4px 14px; border-radius: 12px; font-weight: 600;">
                        @SeriesStatusHelper.DisplayName(_reviewSeries?.StatusCode ?? "")
                    </span>
                </div>

                @{
                    var statusMsg = _reviewSeries?.StatusCode switch
                    {
                        "UNDER_EDITORIAL_REVIEW" => "This series is currently under editorial review. Normal draft editing is locked until the editor returns it for revision or it advances to board review.",
                        "UNDER_BOARD_REVIEW" => "This series is under board review. Editing is locked while the board evaluates it for serialization.",
                        "HIATUS" => "This series is on hiatus. It is not accepting new chapter submissions at this time.",
                        "CANCELLED" => "This series has been cancelled.",
                        "COMPLETED" => "This series is completed. The story has concluded.",
                        _ => "This series is locked from normal editing in its current status."
                    };
                }
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true" Style="font-size: 0.82rem;">
                    @statusMsg
                </MudAlert>

                <MudButton Variant="Variant.Outlined" FullWidth="true"
                           OnClick="@(() => _reviewStatusOpen = false)">
                    Close
                </MudButton>
            </div>
        </MudCardContent>
    </MudCard>
</MudOverlay>

@* ── Submit Proposal Modal (BF-SERIES-003) ── *@
@* Only reachable for series with StatusCode == PROPOSAL_DRAFT. *@
<MudOverlay Visible="@_submitProposalDialogOpen" OnClick="@CloseSubmitProposal">
    <MudCard Style="width: 480px; max-width: 90vw; margin: 5% auto 0; border-radius: 14px;" @onclick:stopPropagation>
        <MudCardContent Style="padding: 0;">
            @* Modal Header *@
            <div style="padding: 20px 24px; border-bottom: 1px solid #f1f5f9; display: flex; align-items: center; justify-content: space-between;">
                <div>
                    <div style="font-weight: 700; font-size: 1rem; color: #111827;">Submit Proposal for Review</div>
                    <div style="color: #94a3b8; font-size: 0.72rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px;"
                         title="@_submitProposalSeriesTitle">
                        @_submitProposalSeriesTitle
                    </div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               OnClick="CloseSubmitProposal" />
            </div>

            <div style="padding: 24px; display: flex; flex-direction: column; gap: 16px;">
                @* Warning text *@
                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                    Submitting will send this draft to editorial review and <strong>lock normal draft editing</strong>.
                    Once submitted, you cannot edit the series profile until revision is returned.
                </MudAlert>

                @* Proposal file upload (required, PDF/DOC/DOCX only, max 10 MB) *@
                <div>
                    <div style="font-size: 0.78rem; font-weight: 600; color: #374151; margin-bottom: 6px;">
                        Proposal Document <span style="color: #dc2626;">*</span>
                        <span style="font-weight: 400; color: #94a3b8; margin-left: 4px;">PDF, DOC, DOCX · Max 10 MB</span>
                    </div>
                    @if (_proposalFileName != null)
                    {
                        <div style="position: relative; display: flex; align-items: center; gap: 8px; padding: 10px 14px; border: 1px solid #e2e8f0; border-radius: 8px; background: #fafafe;">
                            <MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Style="font-size: 20px; color: #059669;" />
                            <span style="flex: 1; font-size: 0.82rem; color: #374151; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">@_proposalFileName</span>
                            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                           Style="color: #dc2626;"
                                           OnClick="@ClearProposalFile" />
                        </div>
                    }
                    else
                    {
                        <MudFileUpload T="IBrowserFile" FilesChanged="@OnProposalFileChanged">
                            <ActivatorContent>
                                <div style="border: 1.5px dashed #bbf7d0; border-radius: 8px; padding: 20px; display: flex; flex-direction: column; align-items: center; gap: 6px; cursor: pointer; background: #f0fdf4;">
                                    <MudIcon Icon="@Icons.Material.Filled.UploadFile" Size="Size.Small" Style="font-size: 28px; color: #059669;" />
                                    <div style="color: #064e3b; font-size: 0.75rem; font-weight: 500;">Click to upload proposal document</div>
                                    <div style="color: #6b7280; font-size: 0.65rem;">PDF, DOC, DOCX · Max 10 MB</div>
                                </div>
                            </ActivatorContent>
                        </MudFileUpload>
                    }
                </div>

                @* Action buttons *@
                <div style="display: flex; gap: 12px;">
                    <MudButton Variant="Variant.Outlined" FullWidth="true"
                               Disabled="@_proposalSubmitting"
                               OnClick="CloseSubmitProposal">
                        Cancel
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" FullWidth="true"
                               Disabled="@(_proposalSubmitting || _proposalFileBytes == null)"
                               OnClick="SubmitProposalAsync">
                        @(_proposalSubmitting ? "Submitting..." : "Submit Proposal")
                    </MudButton>
                </div>
            </div>
        </MudCardContent>
    </MudCard>
</MudOverlay>

@code {
    private string _activeTab = "current";
    private bool _newSeriesDialogOpen;
    private bool _draftCreated;
    private bool _draftSaving;

    private string _newDraftTitle = "";
    private string _newDraftSynopsis = "";
    private string _newDraftGenre = "";
    private string _newDraftLanguage = "ja";
    private byte[]? _draftCoverBytes;
    private string? _draftCoverFileName;
    private string? _draftCoverContentType;

    // ── Edit Draft modal state (BF-SERIES-002) ────────────────────────────────
    private bool _draftDetailsOpen;
    private SeriesCardData? _detailSeries;

    // Editable form fields — populated when the modal opens
    private string _editTitle = "";
    private string _editSynopsis = "";
    private string _editGenre = "";
    private string _editLanguage = "ja";
    private string? _editFrequency;
    private bool _draftSavingEdit;

    // Cover replacement (optional, PROPOSAL_DRAFT only)
    private byte[]? _editCoverBytes;
    private string? _editCoverFileName;
    private string? _editCoverContentType;
    private string? _editCoverPreviewUrl; // data: URI for immediate preview

    // ── Review Status modal state ────────────────────────────────────────────
    private bool _reviewStatusOpen;
    private SeriesCardData? _reviewSeries;

    private Guid? _currentUserId;

    private string _rankingWeek = "Week 21 - May 2026";
    private bool _showRankingUpdate;
    private string _pollWeek = "Week 21 - May 2026";
    private string _pollSeries = "";
    private string _pollVotes = "";
    private string _pollRank = "";
    private string _pollNotes = "";
    private readonly List<RankingRow> _rankingData =
    [
        new(1, "Crimson Moon Academy", "23,450", 98, "Stable", Color.Success),
        new(2, "Neon Samurai Path", "21,900", 94, "Stable", Color.Success),
        new(9, "Shadow Garden Tales", "4,123", 42, "Danger Zone", Color.Error),
        new(10, "Phoenix Rising Team", "3,867", 39, "Danger Zone", Color.Error),
    ];

    private List<ChapterPageTaskDto> _tasks = [];
    private TaskStats _taskStats = new(0, 0, 0, 0);

    private Color GetTaskChipColor(string status) => status switch
    {
        "ASSIGNED" => Color.Primary,
        "UNDER_REVIEW" => Color.Warning,
        "COMPLETED" => Color.Success,
        "CANCELLED" => Color.Error,
        _ => Color.Default,
    };

    private static string FormatDate(DateTime? dt) => dt?.ToString("MMM dd") ?? "—";

    private static string LanguageLabel(string? code) => code switch
    {
        "ja" => "Japanese",
        "en" => "English",
        "vi" => "Vietnamese",
        _ => code ?? "—"
    };

    private async Task LoadTasksAsync()
    {
        try
        {
            if (_currentUserId == null) return;
            var tasks = (await TaskService.GetChapterPageTasksByCreatorUserIdAsync(_currentUserId.Value)).ToList();
            _tasks = tasks;
            _taskStats = new TaskStats(
                tasks.Count,
                tasks.Count(t => t.StatusCode == "ASSIGNED"),
                tasks.Count(t => t.StatusCode == "UNDER_REVIEW"),
                tasks.Count(t => t.StatusCode == "COMPLETED")
            );
        }
        catch
        {
            _tasks = [];
            _taskStats = new(0, 0, 0, 0);
        }
    }

    // ── Submit Proposal state (BF-SERIES-003) ────────────────────────────────────
    private bool _submitProposalDialogOpen;
    private Guid _submitProposalSeriesId;
    private string? _submitProposalSeriesTitle;
    private byte[]? _proposalFileBytes;
    private string? _proposalFileName;
    private string? _proposalContentType;
    private bool _proposalSubmitting;

    // Allowed proposal document extensions and MIME types (enforced in UI for fast feedback;
    // backend also validates in SubmitSeriesProposalCommandHandler).
    private static readonly HashSet<string> AllowedProposalExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".pdf", ".doc", ".docx"
    };

    private static readonly HashSet<string> AllowedProposalContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "application/pdf",
        "application/msword",
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
    };

    private const long MaxProposalFileSizeBytes = 10 * 1024 * 1024; // 10 MB

    // ── Navigation dispatcher ─────────────────────────────────────────────────────
    /// <summary>
    /// Routes card clicks to the correct behaviour based on status.
    /// PROPOSAL_DRAFT → Draft Details modal (not workspace).
    /// UNDER_EDITORIAL_REVIEW / UNDER_BOARD_REVIEW → Review Status modal.
    /// SERIALIZED → navigate to /series/{slug}.
    /// HIATUS / CANCELLED / COMPLETED → Review Status modal (read-only).
    /// </summary>
    private void OpenSeriesCard(SeriesCardData series)
    {
        switch (series.StatusCode)
        {
            case "PROPOSAL_DRAFT":
                OpenDraftDetails(series);
                break;
            case "SERIALIZED":
                if (!string.IsNullOrWhiteSpace(series.Slug))
                    Nav.NavigateTo($"/series/{series.Slug}");
                else
                    Snackbar.Add("Series page is not available yet.", Severity.Info);
                break;
            default:
                OpenReviewStatus(series);
                break;
        }
    }

    private void OpenDraftDetails(SeriesCardData series)
    {
        _detailSeries = series;
        // Seed the edit form fields from the current card data
        _editTitle = series.Title;
        _editSynopsis = series.Synopsis ?? "";
        _editGenre = series.Genre;
        _editLanguage = series.ContentLanguageCode ?? "ja";
        _editFrequency = null; // not currently stored in SeriesCardData; defaults to null
        _draftSavingEdit = false;
        ClearEditCover();
        _draftDetailsOpen = true;
    }

    private void ClearEditCover()
    {
        _editCoverBytes = null;
        _editCoverFileName = null;
        _editCoverContentType = null;
        _editCoverPreviewUrl = null;
    }

    /// <summary>
    /// Pre-read IBrowserFile bytes immediately for cover replacement.
    /// Validates image type (PNG/JPG/WEBP) and size (max 5 MB).
    /// Generates a data: URI preview so the user can verify the selection before saving.
    /// Does NOT call IFileStorageService — that happens in UpdateSeriesDraftCommandHandler via API.
    /// </summary>
    private async Task OnEditCoverChanged(IBrowserFile file)
    {
        if (file == null) return;

        const long maxCoverBytes = 5 * 1024 * 1024; // 5 MB

        var allowedCoverTypes = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            "image/png", "image/jpeg", "image/webp"
        };

        var allowedCoverExtensions = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
        {
            ".png", ".jpg", ".jpeg", ".webp"
        };

        var ext = Path.GetExtension(file.Name);
        if (!allowedCoverExtensions.Contains(ext))
        {
            Snackbar.Add("Only PNG, JPG, and WEBP images are accepted as series covers.", Severity.Warning);
            return;
        }

        if (!allowedCoverTypes.Contains(file.ContentType))
        {
            Snackbar.Add("The selected file type is not accepted. Please upload a PNG, JPG, or WEBP image.", Severity.Warning);
            return;
        }

        if (file.Size > maxCoverBytes)
        {
            Snackbar.Add("The cover image exceeds the maximum size of 5 MB.", Severity.Warning);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxCoverBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _editCoverBytes = ms.ToArray();
            _editCoverFileName = file.Name;
            _editCoverContentType = file.ContentType;
            // Generate a data: URI so the user sees a preview before saving
            _editCoverPreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(_editCoverBytes)}";
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to read the selected cover image. Please try again.", Severity.Error);
            ClearEditCover();
        }
    }

    private async Task SaveDraftEditAsync()
    {
        if (string.IsNullOrWhiteSpace(_editTitle) || string.IsNullOrWhiteSpace(_editGenre)) return;

        if (_currentUserId is null || _currentUserId == Guid.Empty)
        {
            Snackbar.Add("Could not identify the signed-in user. Please sign in again.", Severity.Error);
            return;
        }

        if (_detailSeries == null) return;

        _draftSavingEdit = true;
        try
        {
            var result = await MangakaSeriesApiClient.UpdateDraftAsync(
                actorUserId: _currentUserId.Value,
                seriesId: _detailSeries.Id,
                title: _editTitle.Trim(),
                synopsis: string.IsNullOrWhiteSpace(_editSynopsis) ? _editTitle.Trim() : _editSynopsis.Trim(),
                genre: _editGenre,
                contentLanguageCode: _editLanguage,
                publicationFrequencyCode: _editFrequency,
                slug: null, // auto-derived from title in the handler
                coverFileBytes: _editCoverBytes,
                coverFileName: _editCoverFileName,
                coverContentType: _editCoverContentType,
                cancellationToken: default);

            // Update the in-memory card to reflect the saved changes
            var idx = _seriesData.FindIndex(s => s.Id == _detailSeries.Id);
            if (idx >= 0)
            {
                var updated = _seriesData[idx] with
                {
                    Title = result.Title,
                    Genre = result.Genre,
                    Synopsis = result.Synopsis,
                    ContentLanguageCode = result.ContentLanguageCode,
                    Slug = result.Slug,
                    // Use the new cover URL if one was uploaded; otherwise keep the existing one
                    CoverUrl = result.NewCoverUrl ?? _seriesData[idx].CoverUrl
                };
                _seriesData[idx] = updated;
                // Also update the detail series reference so the modal reflects the change
                _detailSeries = updated;
                _editTitle = result.Title;
                _editSynopsis = result.Synopsis;
                _editGenre = result.Genre;
                _editLanguage = result.ContentLanguageCode;
                if (result.NewCoverUrl != null)
                {
                    _editCoverPreviewUrl = null; // clear local preview; real URL is now in CoverUrl
                    ClearEditCover();
                }
            }

            Snackbar.Add("Draft profile saved.", Severity.Success);
            _draftDetailsOpen = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _draftSavingEdit = false;
        }
    }

    private void OpenReviewStatus(SeriesCardData series)
    {
        _reviewSeries = series;
        _reviewStatusOpen = true;
    }

    private void OpenSubmitProposal(Guid seriesId, string title)
    {
        _submitProposalSeriesId = seriesId;
        _submitProposalSeriesTitle = title;
        _proposalFileBytes = null;
        _proposalFileName = null;
        _proposalContentType = null;
        _proposalSubmitting = false;
        _submitProposalDialogOpen = true;
    }

    private void CloseSubmitProposal()
    {
        _submitProposalDialogOpen = false;
    }

    private void ClearProposalFile()
    {
        _proposalFileBytes = null;
        _proposalFileName = null;
        _proposalContentType = null;
    }

    /// <summary>
    /// Pre-read IBrowserFile bytes immediately — do not hold IBrowserFile across re-renders.
    /// Validates extension, content type, and size before storing in component state.
    /// </summary>
    private async Task OnProposalFileChanged(IBrowserFile file)
    {
        if (file == null) return;

        var ext = Path.GetExtension(file.Name);
        if (!AllowedProposalExtensions.Contains(ext))
        {
            Snackbar.Add("Only PDF, DOC, and DOCX files are accepted as proposal documents.", Severity.Warning);
            return;
        }

        if (!AllowedProposalContentTypes.Contains(file.ContentType))
        {
            Snackbar.Add("The selected file type is not accepted. Please upload a PDF, DOC, or DOCX document.", Severity.Warning);
            return;
        }

        if (file.Size > MaxProposalFileSizeBytes)
        {
            Snackbar.Add("The proposal file exceeds the maximum allowed size of 10 MB.", Severity.Warning);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(MaxProposalFileSizeBytes);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            _proposalFileBytes = ms.ToArray();
            _proposalFileName = file.Name;
            _proposalContentType = file.ContentType;
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to read the selected file. Please try again.", Severity.Error);
            ClearProposalFile();
        }
    }

    private async Task SubmitProposalAsync()
    {
        if (_proposalFileBytes == null || string.IsNullOrWhiteSpace(_proposalFileName))
        {
            Snackbar.Add("Please select a proposal document before submitting.", Severity.Warning);
            return;
        }

        if (_currentUserId is null || _currentUserId == Guid.Empty)
        {
            Snackbar.Add("Could not identify the signed-in user. Please sign in again.", Severity.Error);
            return;
        }

        _proposalSubmitting = true;
        try
        {
            var result = await MangakaSeriesApiClient.SubmitProposalAsync(
                actorUserId: _currentUserId.Value,
                seriesId: _submitProposalSeriesId,
                proposalFileBytes: _proposalFileBytes,
                proposalFileName: _proposalFileName,
                proposalContentType: _proposalContentType ?? "application/octet-stream",
                cancellationToken: default);

            // Update the affected card status in the in-memory list.
            var idx = _seriesData.FindIndex(s => s.Id == _submitProposalSeriesId);
            if (idx >= 0)
            {
                _seriesData[idx] = _seriesData[idx] with { StatusCode = "UNDER_EDITORIAL_REVIEW" };
            }

            Snackbar.Add(
                $"Proposal submitted (v{result.ProposalVersionNo}) — series is now Under Editorial Review.",
                Severity.Success);

            _submitProposalDialogOpen = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _proposalSubmitting = false;
        }
    }

    private static readonly string[] _genres = ["Tiên hiệp", "Wuxia", "Xianxia", "Action", "Fantasy", "Romance", "Horror", "Slice of Life"];

    private readonly (string Code, string Label)[] _languages =
    [
        ("ja", "Japanese"),
        ("en", "English"),
        ("vi", "Vietnamese"),
    ];

    private readonly List<NavItem> _navItems =
    [
        new("current", "Current Series", Icons.Material.Filled.ViewModule),
        new("review", "Assistant Review", Icons.Material.Filled.AssignmentTurnedIn),
        new("ranking", "Ranking Tracker", Icons.Material.Filled.TrendingUp),
        new("audit", "Audit Log", Icons.Material.Filled.Notifications),
    ];

    private string _currentDisplayName = "Mangaka";
    private string _currentRoleName = "Mangaka";
    private string _currentAvatarInitial = "M";
    private string? _currentAvatarUrl;
    private List<SeriesCardData> _seriesData = [];

    private async Task LoadCurrentUserSummaryAsync(Guid userId)
    {
        var currentUser = await ProfileApiClient.GetProfileAsync(userId);

        _currentDisplayName =
            string.IsNullOrWhiteSpace(currentUser.DisplayName)
                ? currentUser.Username
                : currentUser.DisplayName.Trim();

        _currentRoleName =
            string.IsNullOrWhiteSpace(currentUser.RoleName)
                ? "Mangaka"
                : currentUser.RoleName.Trim();

        _currentAvatarInitial =
            string.IsNullOrWhiteSpace(_currentDisplayName)
                ? "?"
                : _currentDisplayName.Substring(0, 1).ToUpperInvariant();

        _currentAvatarUrl = null;

        if (!currentUser.AvatarFileId.HasValue) return;

        var avatarFile = await ProfileApiClient.GetFileAsync(currentUser.AvatarFileId.Value);

        if (avatarFile?.DeletedAtUtc == null &&
            !string.IsNullOrWhiteSpace(avatarFile?.CloudinarySecureUrl))
        {
            _currentAvatarUrl = avatarFile.CloudinarySecureUrl;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var uid))
            {
                _currentUserId = uid;
                await LoadCurrentUserSummaryAsync(uid);
            }
        }
        catch { }

        await LoadSeriesAsync();
        await LoadTasksAsync();
    }

    private async Task LoadSeriesAsync()
    {
        try
        {
            var dtos = await SeriesService.GetAllSeriesAsync();
            _seriesData = dtos.Select(s => new SeriesCardData(
                Id: s.SeriesId,
                Title: s.Title,
                Genre: s.Genre,
                StatusCode: s.StatusCode,
                Slug: s.Slug,
                Synopsis: s.Synopsis,
                ContentLanguageCode: s.ContentLanguageCode,
                CoverUrl: s.CoverUrl,
                CreatedAtUtc: s.CreatedAtUtc,
                UpdatedAtUtc: s.UpdatedAtUtc
            )).ToList();
        }
        catch
        {
            _seriesData = [];
        }
    }

    private async Task CreateSeriesDraft()
    {
        if (string.IsNullOrWhiteSpace(_newDraftTitle) || string.IsNullOrWhiteSpace(_newDraftGenre)) return;

        if (_currentUserId is null || _currentUserId == Guid.Empty)
        {
            Snackbar.Add("Could not identify the signed-in user. Please sign in again.", Severity.Error);
            return;
        }

        _draftSaving = true;
        try
        {
            // Flow: Dashboard -> typed Web API client -> API controller -> Application service
            // -> Infrastructure -> manga.usp_Series_Create. The stored procedure creates the
            // Series (PROPOSAL_DRAFT), the optional SERIES_COVER FileResource, the creator
            // contributor, and the audit event. No SeriesProposal is created here.
            var created = await MangakaSeriesApiClient.CreateDraftAsync(
                actorUserId: _currentUserId.Value,
                title: _newDraftTitle.Trim(),
                synopsis: string.IsNullOrWhiteSpace(_newDraftSynopsis) ? _newDraftTitle.Trim() : _newDraftSynopsis.Trim(),
                genre: _newDraftGenre,
                contentLanguageCode: _newDraftLanguage,
                slug: null,
                publicationFrequencyCode: null,
                sourceSeriesId: null,
                coverFileBytes: _draftCoverBytes,
                coverFileName: _draftCoverFileName,
                coverContentType: _draftCoverContentType);

            _seriesData.Add(new SeriesCardData(
                Id: created.SeriesId,
                Title: created.Title,
                Genre: _newDraftGenre,
                StatusCode: created.StatusCode,
                Slug: created.Slug,
                Synopsis: string.IsNullOrWhiteSpace(_newDraftSynopsis) ? created.Title : _newDraftSynopsis.Trim(),
                ContentLanguageCode: _newDraftLanguage,
                CoverUrl: null, // cover URL requires a DB round-trip; will show on next full load
                CreatedAtUtc: DateTime.UtcNow,
                UpdatedAtUtc: null
            ));

            _draftCreated = true;
            Snackbar.Add($"Draft created — status {SeriesStatusHelper.DisplayName(created.StatusCode)}.", Severity.Success);

            await Task.Delay(1200);

            _draftCreated = false;
            _newDraftTitle = "";
            _newDraftSynopsis = "";
            _newDraftGenre = "";
            _newDraftLanguage = "ja";
            _draftCoverBytes = null;
            _draftCoverFileName = null;
            _draftCoverContentType = null;
            _newSeriesDialogOpen = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _draftSaving = false;
        }
    }

    private record NavItem(string Id, string Label, string Icon);
    private record RankingRow(int Rank, string Series, string Votes, int Performance, string Risk, Color Color);
    private record TaskStats(int Total, int Assigned, int UnderReview, int Completed);

    private record SeriesCardData(
        Guid Id,
        string Title,
        string Genre,
        string StatusCode,
        string Slug,
        string? Synopsis,
        string? ContentLanguageCode,
        string? CoverUrl,
        DateTime CreatedAtUtc,
        DateTime? UpdatedAtUtc)
    {
        public string Color => StatusCode switch
        {
            "PROPOSAL_DRAFT" => "#6366f1",
            "UNDER_EDITORIAL_REVIEW" => "#0ea5e9",
            "UNDER_BOARD_REVIEW" => "#8b5cf6",
            "SERIALIZED" => "#059669",
            "HIATUS" => "#d97706",
            "CANCELLED" => "#dc2626",
            "COMPLETED" => "#4f46e5",
            _ => "#64748b",
        };

        public string LastUpdated
        {
            get
            {
                var dt = UpdatedAtUtc ?? CreatedAtUtc;
                var ago = DateTime.UtcNow - dt;
                if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes} min{(ago.TotalMinutes < 2 ? "" : "s")} ago";
                if (ago.TotalHours < 24) return $"{(int)ago.TotalHours} hour{(ago.TotalHours < 2 ? "" : "s")} ago";
                return $"{(int)ago.TotalDays} day{(ago.TotalDays < 2 ? "" : "s")} ago";
            }
        }
    }
}
