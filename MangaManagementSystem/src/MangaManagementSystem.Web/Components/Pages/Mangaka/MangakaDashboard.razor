@page "/mangaka"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Mangaka")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ISeriesService SeriesService

<MangakaLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Mangaka Dashboard</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Manage your series, chapters, and production tasks</MudText>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" md="3"><StatCard Label="Draft / Active Work" Value="@_inProgressCount.ToString()" Description="Series in progress" /></MudItem>
            <MudItem xs="12" md="3"><StatCard Label="Total Series" Value="@_totalCount.ToString()" Description="All series in catalog" /></MudItem>
            <MudItem xs="12" md="3"><StatCard Label="Pending Review" Value="@_pendingReviewCount.ToString()" Description="Editorial or board review" /></MudItem>
            <MudItem xs="12" md="3"><StatCard Label="Tasks Assigned" Value="—" Description="Not wired yet" /></MudItem>
        </MudGrid>
        <MudGrid>
            <MudItem xs="12" md="7">
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">My Series</MudText>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="/mangaka/series">View all</MudButton>
                    </MudStack>
                    @if (_loading)
                    {
                        <MudProgressLinear Indeterminate="true" />
                    }
                    else if (_error != null)
                    {
                        <MudAlert Severity="Severity.Error">Failed to load series: @_error</MudAlert>
                    }
                    else if (_series == null || !_series.Any())
                    {
                        <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Outlined.LibraryBooks" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-1">No series found in the connected database</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted">Run the demo seed against the same database used by the app, then refresh this page.</MudText>
                            <MudText Typo="Typo.caption" Class="mf-muted mt-2">The dashboard uses live series data from the database.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        <MudTable Items="_series" Hover="true">
                            <HeaderContent><MudTh>Title</MudTh><MudTh>Status</MudTh><MudTh>Updated</MudTh><MudTh></MudTh></HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Title</MudTd>
                                <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                                <MudTd>@FormatDate(context.UpdatedAtUtc ?? context.CreatedAtUtc)</MudTd>
                                <MudTd><MudButton Size="Size.Small" Href="@($"/mangaka/workspace/{context.SeriesId}")">Open</MudButton></MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="5"><MudPaper Class="pa-5 mf-card mb-4" Elevation="0"><MudText Typo="Typo.h6">Pending Submissions</MudText><MudText class="mf-muted">Review assistant work before sending chapters forward.</MudText><MudButton Href="/mangaka/review-submissions" Variant="Variant.Filled" Color="Color.Primary" Class="mt-3">Review Submissions</MudButton></MudPaper></MudItem>
        </MudGrid>

    </div>
</MangakaLayout>

@code {
    private bool _loading = true;
    private string? _error;
    // GetAllSeriesAsync() returns all series; owner-specific filtering is deferred
    // (ISeriesService has no current-Mangaka method yet).
    private IEnumerable<SeriesRow>? _series;

    // Stat counts are computed over the full fetched list (not the top-5 table slice).
    private int _totalCount;
    private int _inProgressCount;
    private int _pendingReviewCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadSeriesAsync();
    }

    private async Task LoadSeriesAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var series = (await SeriesService.GetAllSeriesAsync()).ToList();

            _totalCount = series.Count;
            // Valid Series statuses only (Series.status_code CHECK):
            // PROPOSAL_DRAFT, UNDER_EDITORIAL_REVIEW, UNDER_BOARD_REVIEW, SERIALIZED, HIATUS, CANCELLED, COMPLETED.
            _inProgressCount = series.Count(s =>
                s.StatusCode == "PROPOSAL_DRAFT"
                || s.StatusCode == "UNDER_EDITORIAL_REVIEW"
                || s.StatusCode == "UNDER_BOARD_REVIEW"
                || s.StatusCode == "SERIALIZED");
            _pendingReviewCount = series.Count(s =>
                s.StatusCode == "UNDER_EDITORIAL_REVIEW"
                || s.StatusCode == "UNDER_BOARD_REVIEW");

            _series = series
                .OrderByDescending(s => s.UpdatedAtUtc ?? s.CreatedAtUtc)
                .Take(5)
                .Select(s => new SeriesRow(
                    s.SeriesId,
                    s.Title,
                    s.StatusCode,
                    s.CreatedAtUtc,
                    s.UpdatedAtUtc))
                .ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
            Snackbar.Add($"Could not load series: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private static string FormatDate(DateTime value) =>
        value.ToLocalTime().ToString("MMM d, yyyy");

    private Color GetStatusColor(string status) => status switch
    {
        "SERIALIZED"              => Color.Success,
        "HIATUS"                  => Color.Warning,
        "CANCELLED"               => Color.Error,
        "PROPOSAL_DRAFT"          => Color.Info,
        "UNDER_EDITORIAL_REVIEW"  => Color.Warning,
        "UNDER_BOARD_REVIEW"      => Color.Info,
        _                         => Color.Default
    };

    private record SeriesRow(
        Guid SeriesId,
        string Title,
        string StatusCode,
        DateTime CreatedAtUtc,
        DateTime? UpdatedAtUtc);
}
