    // ── Proposal tracking state ───────────────────────────────────────────────
    private bool _proposalDetailOpen;
    private MangakaSeriesProposalDto? _selectedProposal;
    private string _proposalSelectedFilter = "All";
    private string _proposalSearchText = "";
    private string _proposalSortMode = "submitted";
    private int _proposalPage = 1;
    private const int ProposalPageSize = 8;
    private List<MangakaSeriesProposalDto> _proposalData = [];

    private static readonly (string Label, string[] Statuses)[] ProposalFilterGroups =
    [
        ("All", []),
        ("Under Editorial Review", ["UNDER_EDITORIAL_REVIEW"]),
        ("Under Board Review", ["UNDER_BOARD_REVIEW"]),
        ("Revision Requested", ["REVISION_REQUESTED"]),
        ("Approved", ["APPROVED"]),
        ("Cancelled", ["CANCELLED"]),
        ("Withdrawn", ["WITHDRAWN"]),
    ];

    private int ProposalFilterCount(string[] statuses)
        => statuses.Length == 0
            ? _proposalData.Count
            : _proposalData.Count(p => statuses.Contains(p.StatusCode));

    private List<MangakaSeriesProposalDto> AllFilteredProposals
    {
        get
        {
            var group = ProposalFilterGroups.FirstOrDefault(g => g.Label == _proposalSelectedFilter);
            IEnumerable<MangakaSeriesProposalDto> result = _proposalData;

            if (group.Statuses is { Length: > 0 })
                result = result.Where(p => group.Statuses.Contains(p.StatusCode));

            if (!string.IsNullOrWhiteSpace(_proposalSearchText))
            {
                var term = _proposalSearchText.Trim();
                result = result.Where(p =>
                    p.SeriesTitle.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    p.ProposalTitle.Contains(term, StringComparison.OrdinalIgnoreCase) ||
                    p.Genres.Any(g => g.GenreName.Contains(term, StringComparison.OrdinalIgnoreCase)));
            }

            result = _proposalSortMode switch
            {
                "reviewed" => result.OrderByDescending(p => p.ReviewedAtUtc ?? DateTime.MinValue),
                "title" => result.OrderBy(p => p.ProposalTitle, StringComparer.OrdinalIgnoreCase),
                "status" => result.OrderBy(p => ProposalStatusLabel(p.StatusCode), StringComparer.OrdinalIgnoreCase),
                _ => result.OrderByDescending(p => p.SubmittedAtUtc),
            };

            return result.ToList();
        }
    }

    private int ProposalTotalPages => ProposalPageSize == 0
        ? 0
        : (int)Math.Ceiling((double)AllFilteredProposals.Count / ProposalPageSize);

    private List<MangakaSeriesProposalDto> PagedProposals =>
        AllFilteredProposals
            .Skip((_proposalPage - 1) * ProposalPageSize)
            .Take(ProposalPageSize)
            .ToList();

    private void ResetProposalPage() => _proposalPage = 1;

    private static string ProposalStatusLabel(string statusCode) => statusCode switch
