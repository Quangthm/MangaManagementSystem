            Style="display: flex; align-items: flex-start; justify-content: center; overflow-y: auto; padding: 24px 0;">
    <MudCard Style="width: 540px; max-width: 94vw; border-radius: 14px; max-height: calc(100vh - 48px); overflow-y: auto;" @onclick:stopPropagation>
