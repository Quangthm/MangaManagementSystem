    private async Task SendFrequencyRequestAsync()
    {
        if (_frequencyRequestSeries is null)
        {
            Snackbar.Add(
                "The selected series is no longer available.",
                Severity.Error);

            return;
        }

        if (_currentUserId is null
            || _currentUserId == Guid.Empty)
        {
            Snackbar.Add(
                "Could not identify the signed-in user. Please sign in again.",
                Severity.Error);

            return;
        }

        var reason =
            _frequencyRequestReason.Trim();

        if (string.IsNullOrWhiteSpace(reason))
        {
            Snackbar.Add(
                "Please enter a request or reason.",
                Severity.Warning);

            return;
        }

        _frequencyRequestBusy =
            true;

        try
        {
            var result =
                await MangakaSeriesApiClient
                    .RequestPublicationFrequencyChangeAsync(
                        actorUserId:
                            _currentUserId.Value,
                        seriesId:
                            _frequencyRequestSeries.Id,
                        reason:
                            reason,
                        cancellationToken:
                            default);

            Snackbar.Add(
                $"Frequency change request sent to {result.NotificationCount} Editorial Board Chief account(s). "
                + $"Current official frequency remains {DisplayPublicationFrequency(result.CurrentPublicationFrequencyCode)}.",
                Severity.Success);

            _frequencyRequestDialogOpen =
                false;

            _frequencyRequestReason =
                string.Empty;

            _frequencyRequestSeries =
                null;
        }
        catch (Exception ex)
        {
            Snackbar.Add(
                ex.Message,
                Severity.Error);
        }
        finally
        {
            _frequencyRequestBusy =
                false;
        }
    }

