    private async Task SaveCoverUpload()
    {
        if (_editCoverBytes == null) return;

        try
        {
            var uploadResult = await FileStorageService.UploadFileAsync(
                _editCoverBytes,
                _editCoverFileName ?? "cover.png",
                _editCoverContentType ?? "image/png",
                "SERIES_COVER",
                null
            );

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    FilePurposeCode: "SERIES_COVER",
                    OriginalFileName: uploadResult.OriginalFileName,
                    CloudinaryPublicId: uploadResult.PublicId,
                    CloudinarySecureUrl: uploadResult.SecureUrl,
                    ContentType: uploadResult.ContentType,
                    FileSizeBytes: uploadResult.FileSizeBytes,
                    Sha256Hash: uploadResult.Sha256Hash,
                    UploadedByUserId: _currentUserId
                )
            );

            var series = _seriesData.FirstOrDefault(s => s.Id == _editingSeriesId);
            if (series == null) return;

            var updateDto = new UpdateSeriesDto(
                SeriesId: _editingSeriesId,
                Title: series.Title,
                Slug: series.Title.ToLower().Replace(' ', '-'),
                Synopsis: "",
                Genre: series.Genre,
                CoverFileId: fileResource.FileResourceId,
                StatusCode: series.StatusCode,
                ContentLanguageCode: "ja",
                SourceSeriesId: null,
                PublicationFrequencyCode: null,
                UpdatedByUserId: _currentUserId
            );

            var updated = await SeriesService.UpdateSeriesAsync(updateDto);
            if (updated != null)
            {
                Snackbar.Add("Cover updated successfully", Severity.Success);
            }

            _editCoverDialogOpen = false;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update cover: {ex.Message}", Severity.Error);
        }
    }

    private async Task SubmitNewSeriesProposal()
    {
        if (string.IsNullOrWhiteSpace(_newProposalTitle) || string.IsNullOrWhiteSpace(_newProposalGenre) || _proposalFileBytes == null) return;

        try
        {
            var uploadResult = await FileStorageService.UploadFileAsync(
                _proposalFileBytes,
                _proposalFileName ?? "proposal.pdf",
                _proposalFileContentType ?? "application/pdf",
                "SERIES_PROPOSAL",
                null
            );

            var fileResource = await FileResourceService.CreateFileResourceAsync(
                new CreateFileResourceDto(
                    FilePurposeCode: "SERIES_PROPOSAL",
                    OriginalFileName: uploadResult.OriginalFileName,
                    CloudinaryPublicId: uploadResult.PublicId,
                    CloudinarySecureUrl: uploadResult.SecureUrl,
                    ContentType: uploadResult.ContentType,
                    FileSizeBytes: uploadResult.FileSizeBytes,
                    Sha256Hash: uploadResult.Sha256Hash,
                    UploadedByUserId: _currentUserId
                )
            );

            var slug = _newProposalTitle.ToLower()
                .Replace(" ", "-")
                .Replace("--", "-")
                .Trim('-');

            var seriesDto = new CreateSeriesDto(
                Title: _newProposalTitle.Trim(),
                Slug: slug,
                Synopsis: string.IsNullOrWhiteSpace(_newProposalSynopsis) ? _newProposalTitle.Trim() : _newProposalSynopsis.Trim(),
                Genre: _newProposalGenre,
                CoverFileId: null,
                StatusCode: "PROPOSAL_DRAFT",
                ContentLanguageCode: "ja",
                SourceSeriesId: null,
                PublicationFrequencyCode: null
            );

            var createdSeries = await SeriesService.CreateSeriesAsync(seriesDto);

            await SeriesProposalService.CreateProposalAsync(
                new CreateProposalDto(
                    SeriesId: createdSeries.SeriesId,
                    ProposalTitle: _newProposalTitle.Trim(),
                    SynopsisSnapshot: string.IsNullOrWhiteSpace(_newProposalSynopsis) ? _newProposalTitle.Trim() : _newProposalSynopsis.Trim(),
                    GenreSnapshot: _newProposalGenre,
                    ProposalFileId: fileResource.FileResourceId,
                    SubmittedByUserId: _currentUserId ?? Guid.Empty
                )
            );

            _seriesData.Add(new SeriesCardData(
                createdSeries.SeriesId,
                createdSeries.Title,
                createdSeries.Genre,
                createdSeries.StatusCode,
                createdSeries.CreatedAtUtc,
                null
            ));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to create series: {ex.Message}", Severity.Error);
        }

        _proposalSubmitted = true;
        await Task.Delay(1200);
        _proposalSubmitted = false;
        _newProposalTitle = "";
        _newProposalSynopsis = "";
        _newProposalGenre = "";
        _proposalFileBytes = null;
        _proposalFileName = null;
        _proposalFileContentType = null;
        _newSeriesDialogOpen = false;
    }

    private record NavItem(string Id, string Label, string Icon);
    private record RankingRow(int Rank, string Series, string Votes, int Performance, string Risk, Color Color);
    private record TaskStats(int Total, int Assigned, int UnderReview, int Completed);
    private record SeriesCardData(Guid Id, string Title, string Genre, string StatusCode, DateTime CreatedAtUtc, DateTime? UpdatedAtUtc)
    {
        public string Color => StatusCode switch
        {
            "SERIALIZED" => "#059669",
            "HIATUS" => "#d97706",
            "CANCELLED" => "#dc2626",
            "COMPLETED" => "#4f46e5",
            _ => "#64748b",
        };

        public string ColorHex => Color;

        public string LastUpdated
        {
            get
            {
                var dt = UpdatedAtUtc ?? CreatedAtUtc;
                var ago = DateTime.UtcNow - dt;
                if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes} min{(ago.TotalMinutes < 2 ? "" : "s")} ago";
                if (ago.TotalHours < 24) return $"{(int)ago.TotalHours} hour{(ago.TotalHours < 2 ? "" : "s")} ago";
                return $"{(int)ago.TotalDays} day{(ago.TotalDays < 2 ? "" : "s")} ago";
            }
        }
    }
