@page "/mangaka"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Mangaka")]
@inject NavigationManager Nav

<MangakaLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Mangaka Dashboard</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Manage your series, chapters, and production tasks</MudText>
        </div>

        <MudGrid Class="mb-6"><MudItem xs="12" md="3"><StatCard Label="Active Series" Value="3" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Chapter Drafts" Value="7" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Pending Review" Value="2" /></MudItem><MudItem xs="12" md="3"><StatCard Label="Tasks Assigned" Value="5" /></MudItem></MudGrid>
        <MudGrid>
            <MudItem xs="12" md="7"><MudPaper Class="pa-5 mf-card" Elevation="0"><MudText Typo="Typo.h6" Class="font-weight-bold mb-4">My Series</MudText><MudTable Items="Series" Hover="true"><HeaderContent><MudTh>Title</MudTh><MudTh>Chapters</MudTh><MudTh>Status</MudTh><MudTh></MudTh></HeaderContent><RowTemplate><MudTd>@context.Title</MudTd><MudTd>-</MudTd><MudTd><MudChip T="string" Color="Color.Success" Size="Size.Small">Active</MudChip></MudTd><MudTd><MudButton Size="Size.Small" Href="@($"/mangaka/workspace/{context.SeriesId}")">Open</MudButton></MudTd></RowTemplate></MudTable></MudPaper></MudItem>
            <MudItem xs="12" md="5"><MudPaper Class="pa-5 mf-card mb-4" Elevation="0"><MudText Typo="Typo.h6">Pending Submissions</MudText><MudText class="mf-muted">Review assistant work before sending chapters forward.</MudText><MudButton Href="/mangaka/review-submissions" Variant="Variant.Filled" Color="Color.Primary" Class="mt-3">Review Submissions</MudButton></MudPaper></MudItem>
        </MudGrid>

    </div>
</MangakaLayout>

@code {

    private readonly List<SeriesRow> Series = new()
{
    new(
        Guid.Parse("11111111-1111-1111-1111-111111111111"),
        "Crimson Moon Academy",
        "PROPOSAL_DRAFT",
        new DateTime(2026, 6, 1, 9, 0, 0, DateTimeKind.Utc),
        new DateTime(2026, 6, 5, 14, 30, 0, DateTimeKind.Utc)
    ),
    new(
        Guid.Parse("22222222-2222-2222-2222-222222222222"),
        "Neon Samurai Path",
        "UNDER_EDITORIAL_REVIEW",
        new DateTime(2026, 6, 3, 10, 15, 0, DateTimeKind.Utc),
        new DateTime(2026, 6, 8, 16, 45, 0, DateTimeKind.Utc)
    ),
    new(
        Guid.Parse("33333333-3333-3333-3333-333333333333"),
        "Lunar Eclipse Academy",
        "SERIALIZATION_APPROVED",
        new DateTime(2026, 6, 6, 8, 45, 0, DateTimeKind.Utc),
        null
    )
};

    private record SeriesRow(
        Guid SeriesId,
        string Title,
        string StatusCode,
        DateTime CreatedAtUtc,
        DateTime? UpdatedAtUtc);
}
