@page "/mangaka/chapters"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.DTOs.Editor
@using MangaManagementSystem.Domain.Policies
@using MangaManagementSystem.Web.Services.Api
@using MangaManagementSystem.Web.Helpers
@attribute [Authorize(Roles = "Mangaka")]
@inject IMangakaChapterApiClient ChapterClient
@inject IMangakaSeriesApiClient SeriesClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<MangakaLayout>
    <div class="mf-page" style="padding: 24px;">
        <MudButton Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Style="color: #64748b; margin-bottom: 16px;"
                   OnClick="@(() => Nav.NavigateTo("/mangaka"))">
            Back to Mangaka Dashboard
        </MudButton>

        <div class="mf-page-header" style="margin-bottom: 24px;">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Chapter Submission Management</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Create, edit, and submit chapter drafts for editorial review</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else
        {
            @* Filters *@
            <MudPaper Class="pa-4 mb-4 mf-card" Elevation="0">
                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudSelect T="Guid" Label="Series" Value="@_selectedSeriesId"
                                   Variant="Variant.Outlined"
                                   ValueChanged="OnSeriesFilterChanged">
                            <MudSelectItem T="Guid" Value="@AllSeriesFilterValue">All Series</MudSelectItem>
                            @foreach (var series in _seriesList)
                            {
                                <MudSelectItem T="Guid" Value="@series.SeriesId">@series.Title</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudSelect T="string" Label="Status" Value="@_statusFilter"
                                   Variant="Variant.Outlined" Clearable="true"
                                   ValueChanged="OnStatusFilterChanged">
                            <MudSelectItem T="string" Value="@("ALL")">All Statuses</MudSelectItem>
                            <MudSelectItem T="string" Value="@("DRAFT")">Draft</MudSelectItem>
                            <MudSelectItem T="string" Value="@("UNDER_REVIEW")">Under Review</MudSelectItem>
                            <MudSelectItem T="string" Value="@("REVISION_REQUESTED")">Revision Requested</MudSelectItem>
                            <MudSelectItem T="string" Value="@("APPROVED")">Approved</MudSelectItem>
                            <MudSelectItem T="string" Value="@("SCHEDULED")">Scheduled</MudSelectItem>
                            <MudSelectItem T="string" Value="@("RELEASED")">Released</MudSelectItem>
                            <MudSelectItem T="string" Value="@("ON_HOLD")">On Hold</MudSelectItem>
                            <MudSelectItem T="string" Value="@("CANCELLED")">Cancelled</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="4" Style="display: flex; align-items: flex-end;">
                        <MudTooltip Text="New chapters require a serialized or hiatus series."
                                    Disabled="@_eligibleSeries.Any()">
                            <span style="width: 100%;">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           Disabled="@(!_eligibleSeries.Any())"
                                           FullWidth="true"
                                           OnClick="OpenCreateDialog">
                                    Create Chapter Draft
                                </MudButton>
                            </span>
                        </MudTooltip>
                    </MudItem>

                    @if (!_eligibleSeries.Any())
                    {
                        <MudItem xs="12">
                            <MudAlert Severity="Severity.Info"
                                      Variant="Variant.Outlined"
                                      Dense="true"
                                      Icon="@Icons.Material.Filled.Info"
                                      Class="mt-2">
                                No series is currently available for chapter creation.
                                A series must be <strong>Serialized</strong> or <strong>On Hiatus</strong>.
                            </MudAlert>
                        </MudItem>
                    }
                </MudGrid>
            </MudPaper>

            @* Chapter List *@
            @if (!_filteredChapters.Any())
            {
                <MudPaper Class="pa-8 mf-card text-center" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Large" Color="Color.Default" />
                    <MudText Typo="Typo.h5" Class="mt-2">No Chapters Found</MudText>
                    <MudText Class="mf-muted">Create your first chapter draft to get started.</MudText>
                </MudPaper>
            }
            else
            {
                <MudGrid>
                    @foreach (var chapter in GetPagedChapters())
                    {
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-5 mf-card" Elevation="0">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                                    <MudText Typo="Typo.h6" Class="font-weight-bold">
                                        @chapter.ChapterNumberLabel
                                        @if (!string.IsNullOrWhiteSpace(chapter.ChapterTitle))
                                        {
                                            <span style="color: #64748b; font-weight: 400;">— @chapter.ChapterTitle</span>
                                        }
                                    </MudText>
                                    <MudChip T="string" Color="@GetStatusColor(chapter.StatusCode)" Size="Size.Small">@GetStatusLabel(chapter.StatusCode)</MudChip>
                                </MudStack>

                                <MudText Typo="Typo.body2" Class="mf-muted mb-1">
                                    <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Class="mr-1" />
                                    @chapter.SeriesTitle
                                </MudText>

                                @if (chapter.PlannedReleaseDate.HasValue)
                                {
                                    <MudText Typo="Typo.body2" Class="mf-muted mb-1">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Class="mr-1" />
                                        Planned Release: @chapter.PlannedReleaseDate.Value.ToString("MMM dd, yyyy")
                                    </MudText>
                                }

                                @if (chapter.LatestReview != null)
                                {
                                    <MudAlert Severity="@GetReviewSeverity(chapter.LatestReview.DecisionCode)"
                                              Class="mt-3 mb-2" Dense="true" Variant="Variant.Outlined">
                                        <MudText Typo="Typo.caption" Class="font-weight-bold">
                                            Latest Review: @chapter.LatestReview.DecisionCode
                                        </MudText>
                                        <MudText Typo="Typo.caption">
                                            By @chapter.LatestReview.ReviewerDisplayName on @chapter.LatestReview.ReviewedAtUtc.ToString("MMM dd, yyyy")
                                        </MudText>
                                        @if (!string.IsNullOrWhiteSpace(chapter.LatestReview.Comments))
                                        {
                                            <MudText Typo="Typo.body2" Class="mt-1">
                                                @chapter.LatestReview.Comments
                                            </MudText>
                                        }
                                    </MudAlert>
                                }

                                @if (chapter.StatusCode == "UNDER_REVIEW")
                                {
                                    <MudAlert Severity="Severity.Info" Class="mt-2" Dense="true" Variant="Variant.Filled">
                                        Awaiting Tantou Editor review
                                    </MudAlert>
                                }

                                <MudStack Row="true" Class="mt-3" Style="flex-wrap: wrap;" Spacing="2">
                                    @if (CanViewWorkspace(chapter))
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.OpenInNew"
                                                   OnClick="@(() => Nav.NavigateTo(BuildWorkspaceLink(chapter)))">
                                            View Workspace
                                        </MudButton>
                                    }
                                    @if (chapter.StatusCode == "DRAFT" || chapter.StatusCode == "REVISION_REQUESTED")
                                    {
                                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                                   OnClick="@(() => OpenEditDialog(chapter))"
                                        >
                                            Edit
                                        </MudButton>
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small"
                                                   Disabled="@_actionInProgress"
                                                   OnClick="@(() => SubmitForReview(chapter.ChapterId))"
                                        >
                                            Submit for Review
                                        </MudButton>
                                    }
                                    @if (chapter.StatusCode is not ("CANCELLED" or "RELEASED"))
                                    {
                                        var isSchedulingRelevant = chapter.StatusCode is "APPROVED" or "SCHEDULED" or "ON_HOLD";
                                        <MudButton Variant="@(isSchedulingRelevant ? Variant.Filled : Variant.Outlined)"
                                                   Color="@(isSchedulingRelevant ? Color.Primary : Color.Secondary)"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.CalendarMonth"
                                                   OnClick="@(() => NavigateToCalendar(chapter))"
                                        >
                                            @(isSchedulingRelevant ? "Manage in Calendar" : "View Calendar")
                                        </MudButton>
                                    }
                                    @if (chapter.EditorialReviewHistory != null && chapter.EditorialReviewHistory.Count > 0)
                                    {
                                        <MudButton Variant="Variant.Text" Size="Size.Small"
                                                   StartIcon="@(IsReviewHistoryExpanded(chapter.ChapterId) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.History)"
                                                   OnClick="@(() => ToggleReviewHistory(chapter.ChapterId))"
>
                                            @(IsReviewHistoryExpanded(chapter.ChapterId) ? "Hide History" : "Review History")
                                        </MudButton>
                                    }
                                </MudStack>

                                @if (IsReviewHistoryExpanded(chapter.ChapterId))
                                {
                                    <MudDivider Class="my-3" />
                                    <ChapterEditorialReviewHistoryPanel
                                        Reviews="@(chapter.EditorialReviewHistory ?? Array.Empty<EditorChapterReviewHistoryDto>())"
                                        PageSize="3"
                                        ShowTitle="true"
                                        EmptyText="No editorial review history yet." />
                                }
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>

                @if (GetChapterCardsTotalPages() > 1)
                {
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Outlined"
                                   Disabled="@(_chapterCardsPage <= 1)"
                                   OnClick="PreviousChapterCardsPage">
                            Previous
                        </MudButton>
                        <MudText Typo="Typo.body2">Page @_chapterCardsPage of @GetChapterCardsTotalPages()</MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Disabled="@(_chapterCardsPage >= GetChapterCardsTotalPages())"
                                   OnClick="NextChapterCardsPage">
                            Next
                        </MudButton>
                    </MudStack>
                }
            }
        }

        @* Create Dialog *@
        <MudDialog @bind-Visible="_showCreateDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Create Chapter Draft</TitleContent>
            <DialogContent>
                <MudSelect T="Guid" Label="Series" @bind-Value="_createSeriesId" Variant="Variant.Outlined" Required="true" Class="mb-3">
                    @foreach (var series in _eligibleSeries)
                    {
                        <MudSelectItem T="Guid" Value="@series.SeriesId">@series.Title</MudSelectItem>
                    }
                </MudSelect>
                <MudTextField @bind-Value="_createChapterNumberLabel" Label="Chapter Number Label"
                              Variant="Variant.Outlined" Required="true" MaxLength="20"
                              HelperText="Required. Must be unique within the series (e.g., '1', '2.5', 'Prologue')." />
                <MudTextField @bind-Value="_createChapterTitle" Label="Chapter Title (optional)"
                              Variant="Variant.Outlined" MaxLength="200" Class="mt-3" />
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showCreateDialog = false)">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           Disabled="@(_createSeriesId == Guid.Empty || string.IsNullOrWhiteSpace(_createChapterNumberLabel) || _actionInProgress)"
                           OnClick="CreateChapterDraft">
                    Create
                </MudButton>
            </DialogActions>
        </MudDialog>

        @* Edit Dialog *@
        <MudDialog @bind-Visible="_showEditDialog" Options="new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true }">
            <TitleContent>Edit Chapter Draft</TitleContent>
            <DialogContent>
                @if (_editChapter != null)
                {
                    <MudText Typo="Typo.body2" Class="mb-2 mf-muted">
                        Series: @_editChapter.SeriesTitle
                    </MudText>
                    <MudTextField @bind-Value="_editChapterNumberLabel" Label="Chapter Number Label"
                                  Variant="Variant.Outlined" Required="true" MaxLength="20"
                                  HelperText="Must be unique within the series." />
                    <MudTextField @bind-Value="_editChapterTitle" Label="Chapter Title (optional)"
                                  Variant="Variant.Outlined" MaxLength="200" Class="mt-3" />
                }
            </DialogContent>
            <DialogActions>
                <MudButton OnClick="@(() => _showEditDialog = false)">Cancel</MudButton>
                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                           Disabled="@(string.IsNullOrWhiteSpace(_editChapterNumberLabel) || _actionInProgress)"
                           OnClick="UpdateChapterDraft">
                    Save Changes
                </MudButton>
            </DialogActions>
        </MudDialog>

    </div>
</MangakaLayout>

@code {
    private Guid _currentUserId;
    private bool _loading = true;
    private string? _error;
    private bool _actionInProgress;

    private IReadOnlyList<MangakaChapterListItemDto> _chapters = Array.Empty<MangakaChapterListItemDto>();
    private IReadOnlyList<SeriesDto> _seriesList = Array.Empty<SeriesDto>();

    private static readonly Guid AllSeriesFilterValue = Guid.Empty;
    private Guid _selectedSeriesId = AllSeriesFilterValue;
    private string _statusFilter = "ALL";

    private string CurrentUrl => $"/{Nav.ToBaseRelativePath(Nav.Uri)}";

    // Create dialog state
    private bool _showCreateDialog;
    private Guid _createSeriesId;
    private string _createChapterNumberLabel = string.Empty;
    private string? _createChapterTitle;

    // Edit dialog state
    private bool _showEditDialog;
    private MangakaChapterListItemDto? _editChapter;
    private string _editChapterNumberLabel = string.Empty;
    private string? _editChapterTitle;

    private readonly HashSet<Guid> _expandedReviewHistoryChapterIds = new();

    private const int ChapterCardsPageSize = 10;
    private int _chapterCardsPage = 1;

    private IEnumerable<MangakaChapterListItemDto> _filteredChapters => ApplyFilters(_chapters);
    private IEnumerable<SeriesDto> _eligibleSeries =>
        _seriesList.Where(series => SeriesProductionPolicy.AllowsNormalProduction(series.StatusCode));

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (string.IsNullOrWhiteSpace(userIdClaim) || !Guid.TryParse(userIdClaim, out _currentUserId))
            {
                _error = "Could not identify the current user. Please sign in again.";
                return;
            }

            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load data: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _seriesList = await SeriesClient.GetMySeriesAsync();
            _chapters = await ChapterClient.GetMyChaptersAsync();
        }
        catch (Exception ex)
        {
            _error = $"Failed to load data: {ex.Message}";
        }
    }

    private IEnumerable<MangakaChapterListItemDto> ApplyFilters(IEnumerable<MangakaChapterListItemDto> source)
    {
        var query = source.AsEnumerable();

        if (_selectedSeriesId != AllSeriesFilterValue)
        {
            query = query.Where(c => c.SeriesId == _selectedSeriesId);
        }

        if (_statusFilter != "ALL")
        {
            query = query.Where(c => c.StatusCode == _statusFilter);
        }

        return query;
    }

    private void OnSeriesFilterChanged(Guid value)
    {
        _selectedSeriesId = value;
        ResetChapterCardsPage();
    }

    private static bool CanViewWorkspace(MangakaChapterListItemDto chapter) =>
        !string.IsNullOrWhiteSpace(chapter.SeriesSlug) &&
        chapter.StatusCode is "DRAFT" or "REVISION_REQUESTED" or "UNDER_REVIEW" or "APPROVED" or "SCHEDULED" or "ON_HOLD" or "RELEASED";

    private string BuildWorkspaceLink(MangakaChapterListItemDto chapter)
    {
        var targetUrl = $"/series/{chapter.SeriesSlug}/workspace?chapterId={chapter.ChapterId}";
        return SafeReturnUrl.AppendReturnUrl(targetUrl, CurrentUrl);
    }

    private void OnStatusFilterChanged(string value)
    {
        _statusFilter = value ?? "ALL";
        ResetChapterCardsPage();
    }

    private void OpenCreateDialog()
    {
        var firstEligibleSeries = _eligibleSeries.FirstOrDefault();
        if (firstEligibleSeries == null)
        {
            Snackbar.Add(
                "New chapters can only be created while a series is SERIALIZED or HIATUS.",
                Severity.Info);
            return;
        }

        _createSeriesId = firstEligibleSeries.SeriesId;
        _createChapterNumberLabel = string.Empty;
        _createChapterTitle = null;
        _showCreateDialog = true;
    }

    private async Task CreateChapterDraft()
    {
        if (_createSeriesId == Guid.Empty || string.IsNullOrWhiteSpace(_createChapterNumberLabel))
            return;

        if (!_eligibleSeries.Any(series => series.SeriesId == _createSeriesId))
        {
            Snackbar.Add(
                "New chapters can only be created while the series is SERIALIZED or HIATUS.",
                Severity.Error);
            return;
        }

        _actionInProgress = true;
        try
        {
            var request = new CreateChapterDraftRequest(
                _createSeriesId,
                _createChapterNumberLabel.Trim(),
                string.IsNullOrWhiteSpace(_createChapterTitle) ? null : _createChapterTitle.Trim());

            await ChapterClient.CreateChapterDraftAsync(request);
            _showCreateDialog = false;
            Snackbar.Add("Chapter draft created successfully.", Severity.Success);
            await RefreshAfterMutation();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private void OpenEditDialog(MangakaChapterListItemDto chapter)
    {
        _editChapter = chapter;
        _editChapterNumberLabel = chapter.ChapterNumberLabel;
        _editChapterTitle = chapter.ChapterTitle;
        _showEditDialog = true;
    }

    private async Task UpdateChapterDraft()
    {
        if (_editChapter == null || string.IsNullOrWhiteSpace(_editChapterNumberLabel))
            return;

        _actionInProgress = true;
        try
        {
            var request = new UpdateChapterDraftRequest(
                _editChapterNumberLabel.Trim(),
                string.IsNullOrWhiteSpace(_editChapterTitle) ? null : _editChapterTitle.Trim());

            await ChapterClient.UpdateChapterDraftAsync(_editChapter.ChapterId, request);
            _showEditDialog = false;
            Snackbar.Add("Chapter draft updated successfully.", Severity.Success);
            await RefreshAfterMutation();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private async Task SubmitForReview(Guid chapterId)
    {
        _actionInProgress = true;
        try
        {
            await ChapterClient.SubmitChapterForReviewAsync(chapterId);
            Snackbar.Add("Chapter submitted for review.", Severity.Success);
            await RefreshAfterMutation();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _actionInProgress = false;
        }
    }

    private async Task RefreshAfterMutation()
    {
        try
        {
            _chapters = await ChapterClient.GetMyChaptersAsync();
            ResetChapterCardsPage();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to refresh: {ex.Message}", Severity.Warning);
        }
    }

    private static Severity GetReviewSeverity(string decisionCode) => decisionCode switch
    {
        "APPROVED" => Severity.Success,
        "REVISION_REQUESTED" => Severity.Warning,
        "CANCELLED" => Severity.Error,
        _ => Severity.Info
    };

    private static Color GetStatusColor(string? status) => status switch
    {
        "DRAFT" => Color.Default,
        "UNDER_REVIEW" => Color.Info,
        "REVISION_REQUESTED" => Color.Warning,
        "APPROVED" => Color.Success,
        "SCHEDULED" => Color.Primary,
        "RELEASED" => Color.Success,
        "ON_HOLD" => Color.Dark,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string GetStatusLabel(string? status) => status switch
    {
        "DRAFT" => "Draft",
        "UNDER_REVIEW" => "Under Review",
        "REVISION_REQUESTED" => "Revision Requested",
        "APPROVED" => "Approved",
        "SCHEDULED" => "Scheduled",
        "RELEASED" => "Released",
        "ON_HOLD" => "On Hold",
        "CANCELLED" => "Cancelled",
        _ => status ?? "Unknown"
    };

    // ── Review History helpers ─────────────────────────────────────────

    private bool IsReviewHistoryExpanded(Guid chapterId)
        => _expandedReviewHistoryChapterIds.Contains(chapterId);

    private void ToggleReviewHistory(Guid chapterId)
    {
        if (!_expandedReviewHistoryChapterIds.Add(chapterId))
        {
            _expandedReviewHistoryChapterIds.Remove(chapterId);
        }
    }

    // ── Chapter Card Pagination helpers ──────────────────────────────────

    private IReadOnlyList<MangakaChapterListItemDto> GetPagedChapters()
    {
        return _filteredChapters
            .Skip((_chapterCardsPage - 1) * ChapterCardsPageSize)
            .Take(ChapterCardsPageSize)
            .ToList();
    }

    private int GetChapterCardsTotalPages()
    {
        var count = _filteredChapters.Count();
        return Math.Max(1, (int)Math.Ceiling(count / (double)ChapterCardsPageSize));
    }

    private void PreviousChapterCardsPage()
    {
        _chapterCardsPage = Math.Max(1, _chapterCardsPage - 1);
    }

    private void NextChapterCardsPage()
    {
        _chapterCardsPage = Math.Min(GetChapterCardsTotalPages(), _chapterCardsPage + 1);
    }

    private void ResetChapterCardsPage()
    {
        _chapterCardsPage = 1;
    }

    private void NavigateToCalendar(MangakaChapterListItemDto chapter)
    {
        var anchorDate = chapter.PlannedReleaseDate?.ToString("yyyy-MM-dd")
            ?? DateTime.UtcNow.ToString("yyyy-MM-dd");
        var url = PublicationScheduleNavigation.BuildUrl(
            chapter.SeriesId, chapter.SeriesSlug,
            chapter.PlannedReleaseDate ?? DateTime.UtcNow.Date);
        Nav.NavigateTo(url);
    }
}
