@page "/dashboard"
@layout DashboardLayout
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Demo Workspace Overview</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Here's a summary of your editorial platform activity.</MudText>
        </div>

    @if (_redirecting)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-6">
            This overview is a demo. You are redirected to your primary workspace when assigned a role.
        </MudAlert>
        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Active Reviews" Value="1" Description="Updated recently" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Total Annotations" Value="23" Description="+5 this week" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Pending Documents" Value="2" Description="Needs review" /></MudItem>
            <MudItem xs="12" sm="6" md="3"><StatCard Label="Delayed Tasks" Value="1" Description="Due today" /></MudItem>
        </MudGrid>
        <MudText Typo="Typo.overline" Class="mf-muted">EDITORIAL MODULES</MudText>
        <MudGrid Class="mb-8">
            <MudItem xs="12" md="4"><WorkspaceCard Title="Manga Editorial Review" Description="Annotate chapters, review dialogue and layouts." Href="/dashboard/workspace" /></MudItem>
            <MudItem xs="12" md="4"><WorkspaceCard Title="Editorial Records" Description="Manage series defense documents and production files." Href="/dashboard/records" /></MudItem>
            <MudItem xs="12" md="4"><WorkspaceCard Title="Studio Progress" Description="Monitor production tasks and deadlines." Href="/dashboard/studio" /></MudItem>
        </MudGrid>
        <MudText Typo="Typo.overline" Class="mf-muted">ALL WORKSPACES</MudText>
        <MudGrid>
            @if (_showMangakaLink)
            {
                <MudItem xs="12" md="3"><WorkspaceCard Title="Mangaka Workspace" Description="Series, chapters, assistants and submissions." Href="/mangaka" /></MudItem>
            }
            @if (_showAssistantLink)
            {
                <MudItem xs="12" md="3"><WorkspaceCard Title="Assistant Workspace" Description="Assigned tasks and submission flow." Href="/assistant" /></MudItem>
            }
            @if (_showAdminLink)
            {
                <MudItem xs="12" md="3"><WorkspaceCard Title="System Admin Workspace" Description="Users, registrations, audit logs and settings." Href="/admin" /></MudItem>
            }
            @if (_showRankingLink)
            {
                <MudItem xs="12" md="3"><WorkspaceCard Title="Board & Ranking" Description="Series ranking and board decision support." Href="/ranking" /></MudItem>
            }
        </MudGrid>
    }

    </div>

@code {
    private bool _redirecting = true;
    private bool _showMangakaLink;
    private bool _showAssistantLink;
    private bool _showAdminLink;
    private bool _showRankingLink;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        if (user?.Identity?.IsAuthenticated == true)
        {
            if (user.IsInRole("Admin"))
            {
                _showAdminLink = true;
                // Admin users redirect to the admin home workspace
                Nav.NavigateTo("/admin");
                return;
            }
            if (user.IsInRole("Mangaka"))
            {
                _showMangakaLink = true;
                Nav.NavigateTo("/mangaka");
                return;
            }
            if (user.IsInRole("Assistant"))
            {
                _showAssistantLink = true;
                Nav.NavigateTo("/assistant");
                return;
            }
            if (user.IsInRole("Tantou Editor"))
            {
                // Tantou Editor has a dedicated editor workspace
                Nav.NavigateTo("/editor");
                return;
            }
            if (user.IsInRole("Editorial Board Member"))
            {
                _showRankingLink = true;
                Nav.NavigateTo("/demo/mangaflow/editorial");
                return;
            }
            if (user.IsInRole("Editorial Board Chief"))
            {
                _showRankingLink = true;
                Nav.NavigateTo("/demo/mangaflow/editorial");
                return;
            }
        }

        // no redirect, show overview with links based on available roles
        _redirecting = false;
    }
}
