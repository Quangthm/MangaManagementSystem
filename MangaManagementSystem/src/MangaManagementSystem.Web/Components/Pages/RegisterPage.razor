@page "/register"
@layout PublicLayout
@using Microsoft.AspNetCore.WebUtilities
@using MangaManagementSystem.Web.Options
@using MangaManagementSystem.Web.Services.Api
@inject IRegistrationApiClient RegistrationClient
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject RecaptchaService RecaptchaService
@inject Microsoft.Extensions.Options.IOptions<RecaptchaOptions> RecaptchaOptions


<PageTitle>Register - MangaFlow</PageTitle>

<div class="mf-gradient-bg d-flex align-center justify-center pa-4">
    <MudContainer MaxWidth="MaxWidth.Small">
        <div class="text-center mb-6">
            <MudText Typo="Typo.h3" Class="font-weight-bold mf-gradient-text">MangaFlow</MudText>
            <MudText Typo="Typo.h6" Class="mf-muted mt-2">Start your manga production journey</MudText>
        </div>
        <MudPaper Class="pa-8 mf-card" Elevation="8">
            @if (!string.IsNullOrWhiteSpace(_registrationMessage))
            {
                <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="4" Class="text-center py-4">
                    <MudAvatar Color="Color.Success" Variant="Variant.Filled" Size="Size.Large" Class="mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Large" />
                    </MudAvatar>
                    <MudText Typo="Typo.h4" Class="font-weight-bold text-success">Registration Complete</MudText>
                    <MudAlert Severity="@_registrationSeverity" Class="mt-4 w-100">
                        @_registrationMessage
                    </MudAlert>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="GoToLogin" Size="Size.Large" Class="px-8 mt-4">
                        Go to Login
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudText Typo="Typo.h4" Class="font-weight-bold mb-2">Create Your Account</MudText>
                <MudAlert Severity="Severity.Info" Class="mb-4">
                    Verify your email with a one-time code. Your account will be saved as pending admin approval after verification.
                </MudAlert>

                @if (!_isOtpSent)
                {
                    <MudStack Spacing="3">
                        <MudTextField Label="Username"
                                      @bind-Value="_username"
                                      Variant="Variant.Outlined"
                                      Required="true"
                                      Disabled="_isSendingOtp" />
                        <MudTextField Label="Display Name (optional)"
                                      @bind-Value="_displayName"
                                      Variant="Variant.Outlined"
                                      HelperText="Display name shown publicly. Defaults to username if left empty."
                                      Disabled="_isSendingOtp" />
                        <!-- FullName removed to match DB schema (no full_name column) -->
                        <MudSelect T="string"
                                   Label="Role"
                                   @bind-Value="_roleName"
                                   Variant="Variant.Outlined"
                                   Required="true"
                                   Disabled="_isSendingOtp">
                            <MudSelectItem T="string" Value="@("Mangaka")">Mangaka</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Assistant")">Assistant</MudSelectItem>
                            <MudSelectItem T="string" Value="@("Tantou Editor")">Tantou Editor</MudSelectItem>
                        </MudSelect>
                        <MudTextField Label="Email"
                                      @bind-Value="_email"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Email"
                                      Required="true"
                                      Disabled="_isSendingOtp" />
                        <MudTextField Label="Password"
                                      @bind-Value="_password"
                                      Variant="Variant.Outlined"
                                      InputType="InputType.Password"
                                      Required="true"
                                      Disabled="_isSendingOtp" />
                        <div>
                            <label class="mf-muted">Portfolio (optional)</label>
                            <InputFile OnChange="HandleFileSelected" />
                            @if (!string.IsNullOrEmpty(_selectedFileName))
                            {
                                <div class="mf-muted mt-1">Selected: @_selectedFileName (@_selectedFileSizeDisplay)</div>
                            }
                            @if (!string.IsNullOrEmpty(_fileValidationError))
                            {
                                <MudText Color="Color.Error">@_fileValidationError</MudText>
                            }
                        </div>
                        <div id="register-recaptcha" @key="@("register-recaptcha-key")" class="my-2 d-flex justify-center"></div>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Disabled="_isSendingOtp"
                                   OnClick="HandleSendOtp">
                            @if (_isSendingOtp)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Send OTP
                        </MudButton>
                    </MudStack>
                }
                else
                {
                    <MudStack Spacing="3">
                        <MudAlert Severity="Severity.Success" Class="mb-2">
                            A 6-digit verification code was sent to <strong>@_email</strong>. Check your inbox or the server console in development.
                        </MudAlert>
                        <MudTextField Label="6-Digit Verification Code"
                                      @bind-Value="_otpCode"
                                      Variant="Variant.Outlined"
                                      MaxLength="6"
                                      Required="true"
                                      Disabled="_isVerifyingOtp" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   Size="Size.Large"
                                   Disabled="_isVerifyingOtp"
                                   OnClick="HandleVerifyOtp">
                            @if (_isVerifyingOtp)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Verify &amp; Register
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   FullWidth="true"
                                   Disabled="_isVerifyingOtp"
                                   OnClick="ResetRegistration">
                            Use a different email
                        </MudButton>
                    </MudStack>
                }

                <MudDivider Class="my-4" />
                <form action="/api/auth/google-signup" method="post" data-enhance="false">
                    <button type="submit" class="google-auth-button">
                        <span class="google-auth-button__content">
                            <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                                 alt=""
                                 width="18"
                                 height="18"
                                 class="google-auth-button__icon" />
                            <span>Sign up with Google</span>
                        </span>
                    </button>
                </form>
                <MudDivider Class="my-2" />
                <MudText Align="Align.Center">
                    Already have an account? <MudLink Href="/login">Login to Your Account</MudLink>
                </MudText>
            }
        </MudPaper>
    </MudContainer>
</div>

<style>
    .google-auth-button {
        display: block;
        width: 100%;
        padding: 10px 16px;
        border: 1px solid #dadce0;
        border-radius: 4px;
        background: #fff;
        color: #3c4043;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        text-transform: none;
    }

    .google-auth-button:hover {
        background: #f8f9fa;
    }

    .google-auth-button__content {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        width: 100%;
        font-weight: 500;
    }

    .google-auth-button__icon {
        display: block;
    }
</style>

@code {
    private string _username = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private string _roleName = "Mangaka";
    private string? _displayName = null;
    private string _otpCode = string.Empty;

    private bool _isOtpSent;
    private bool _isSendingOtp;
    private bool _isVerifyingOtp;
    private bool _recaptchaRendered;
    private string? _registrationMessage;
    private Severity _registrationSeverity = Severity.Success;
    private const long MaxFileSizeBytes = 10 * 1024 * 1024; // 10 MB
    private readonly string[] AllowedFileTypes = new[] { "application/pdf", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "image/png", "image/jpeg", "image/webp" };
    private IBrowserFile? _selectedFile;
    private string _selectedFileName = string.Empty;
    private string _selectedFileSizeDisplay = string.Empty;
    private string _selectedFileContentType = string.Empty;
    private byte[]? _selectedFileBytes;
    private string _fileValidationError = string.Empty;
    private int? _recaptchaWidgetId;

    protected override void OnInitialized()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var error))
        {
            var message = error.ToString() switch
            {
                "GoogleEmailMissing" => "Google did not return an email address. Try another account or use email registration.",
                "account_pending" => "An account with this email is pending approval. Check your email for a verification code or complete verification below.",
                "account_disabled" => "This account cannot be used for sign-up. Contact support.",
                _ => Uri.UnescapeDataString(error.ToString())
            };
            Snackbar.Add(message, Severity.Error);
        }
    }

    private async Task HandleSendOtp()
    {
        if (_isSendingOtp)
        {
            return;
        }

        _isSendingOtp = true;
        try
        {
            if (_recaptchaWidgetId is null)
            {
                Snackbar.Add("reCAPTCHA is not available. Please refresh the page and try again.", Severity.Error);
                _isSendingOtp = false;
                return;
            }

            var token = await JSRuntime.InvokeAsync<string>("recaptchaInterop.getResponse", _recaptchaWidgetId);
            if (string.IsNullOrWhiteSpace(token))
            {
                Snackbar.Add("Please solve the reCAPTCHA challenge.", Severity.Warning);
                _isSendingOtp = false;
                return;
            }

            var isRecaptchaValid = await RecaptchaService.VerifyTokenAsync(token);
            if (!isRecaptchaValid)
            {
                Snackbar.Add("reCAPTCHA verification failed. Please try again.", Severity.Error);
                await JSRuntime.InvokeVoidAsync("recaptchaInterop.reset", _recaptchaWidgetId);
                _isSendingOtp = false;
                return;
            }

            await RegistrationClient.SendOtpAsync(_username, _email, _password, _roleName, _displayName);
            _isOtpSent = true;
            Snackbar.Add("Verification code sent. Enter the 6-digit OTP to complete registration.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            if (_recaptchaWidgetId != null)
            {
                await JSRuntime.InvokeVoidAsync("recaptchaInterop.reset", _recaptchaWidgetId);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to send verification code. Please try again.", Severity.Error);
            if (_recaptchaWidgetId != null)
            {
                await JSRuntime.InvokeVoidAsync("recaptchaInterop.reset", _recaptchaWidgetId);
            }
        }
        finally
        {
            _isSendingOtp = false;
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        _fileValidationError = string.Empty;
        _selectedFile = e.File;
        if (_selectedFile == null)
        {
            _selectedFileName = string.Empty;
            _selectedFileBytes = null;
            _selectedFileContentType = string.Empty;
            _selectedFileSizeDisplay = string.Empty;
            return;
        }

        if (_selectedFile.Size > MaxFileSizeBytes)
        {
            _fileValidationError = $"File is too large. Maximum allowed is {MaxFileSizeBytes / (1024 * 1024)} MB.";
            _selectedFileName = string.Empty;
            _selectedFileBytes = null;
            _selectedFileContentType = string.Empty;
            _selectedFileSizeDisplay = string.Empty;
            return;
        }

        if (!AllowedFileTypes.Contains(_selectedFile.ContentType))
        {
            _fileValidationError = "Unsupported file type. Allowed: PDF, DOCX, PNG, JPG/JPEG, WEBP.";
            _selectedFileName = string.Empty;
            _selectedFileBytes = null;
            _selectedFileContentType = string.Empty;
            _selectedFileSizeDisplay = string.Empty;
            return;
        }

        _selectedFileName = _selectedFile.Name;
        _selectedFileContentType = _selectedFile.ContentType;
        _selectedFileSizeDisplay = $"{_selectedFile.Size / 1024} KB";
        using var ms = new MemoryStream();
        await _selectedFile.OpenReadStream(MaxFileSizeBytes).CopyToAsync(ms);
        _selectedFileBytes = ms.ToArray();
    }

    private async Task HandleVerifyOtp()
    {
        if (_isVerifyingOtp)
        {
            return;
        }

        _isVerifyingOtp = true;
        try
        {
            var hasPortfolio = _selectedFileBytes is not null;
            var created = await RegistrationClient.CompleteRegistrationAsync(
                _email,
                _otpCode,
                portfolioFileBytes: hasPortfolio ? _selectedFileBytes : null,
                portfolioFileName: hasPortfolio && _selectedFileName != string.Empty ? _selectedFileName : null,
                portfolioContentType: hasPortfolio && !string.IsNullOrEmpty(_selectedFileContentType) ? _selectedFileContentType : null);

            // Determine portfolio presence using returned UserDto.PortfolioFileId
            if (created?.PortfolioFileId != null && created.PortfolioFileId != Guid.Empty)
            {
                _registrationMessage = "Registration successful. Your account is waiting for Admin approval. Your portfolio was uploaded for Admin review.";
                _registrationSeverity = Severity.Success;
            }
            else
            {
                _registrationMessage = "Registration successful. Your account is now waiting for Admin approval.";
                _registrationSeverity = Severity.Success;
            }

            // Keep user on page per decision (do not auto-redirect). Show snackbar as well but the page-level alert remains.
            Snackbar.Add(_registrationMessage, Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception)
        {
            Snackbar.Add("Unable to complete registration. Please try again.", Severity.Error);
        }
        finally
        {
            _isVerifyingOtp = false;
        }
    }

    private async Task ResetRegistration()
    {
        _isOtpSent = false;
        _otpCode = string.Empty;
        _recaptchaWidgetId = null;

        if (_recaptchaWidgetId.HasValue)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("recaptchaInterop.reset", _recaptchaWidgetId.Value);
            }
            catch
            {
                // Widget may have been destroyed; fall through and re-render.
                _recaptchaWidgetId = null;
                _recaptchaRendered = false;
            }
        }
    }

    private void GoToLogin()
    {
        NavigationManager.NavigateTo("/login");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_recaptchaRendered || _isOtpSent)
        {
            return;
        }

        try
        {
            var siteKey = RecaptchaOptions.Value.SiteKey;
            var widgetId = await JSRuntime.InvokeAsync<int>("recaptchaInterop.render", "register-recaptcha", siteKey);
            if (widgetId > -1)
            {
                _recaptchaWidgetId = widgetId;
                _recaptchaRendered = true;
            }
            else
            {
                Console.WriteLine("Warning: reCAPTCHA could not be rendered (widgetId = {0})", widgetId);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Warning: reCAPTCHA render failed: " + ex.Message);
        }
    }
}
