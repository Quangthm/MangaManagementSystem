@page "/editor/proposals/{ProposalId:guid}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorProposalApiClient EditorProposalApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mb-2">Back to Queue</MudButton>
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review the proposal material, add feedback, and move it to the next workflow step</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_proposal != null)
        {
            <MudGrid>
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
                            <div>
                                <MudText Typo="Typo.h5" Class="font-weight-bold">@_proposal.ProposalTitle</MudText>
                                <MudText Class="mf-muted">@_proposal.SeriesTitle · Proposal v@_proposal.ProposalVersionNo</MudText>
                            </div>
                            <MudChip T="string" Color="@GetStatusColor(_proposal.StatusCode)">@_proposal.StatusCode.Replace("_", " ")</MudChip>
                        </MudStack>

                        <MudDivider Class="mb-3" />

                        <MudText Typo="Typo.subtitle2" Class="mf-muted">Series</MudText>
                        <MudText Class="mb-1">@_proposal.SeriesTitle</MudText>
                        <MudText Typo="Typo.caption" Class="mf-muted mb-3">
                            Slug: <code>@_proposal.SeriesSlug</code>
                        </MudText>

                        <MudText Typo="Typo.subtitle2" Class="mf-muted mt-3">Genre</MudText>
                        <MudText Class="mb-3">@_proposal.GenreSnapshot</MudText>

                        <MudText Typo="Typo.subtitle2" Class="mf-muted mt-3">Synopsis</MudText>
                        <MudPaper Elevation="0" Class="pa-3" Style="max-height: 260px; overflow-y: auto; background: var(--mud-palette-background-grey);">
                            <MudText Style="white-space: pre-wrap;">@_proposal.SynopsisSnapshot</MudText>
                        </MudPaper>

                        <MudDivider Class="my-4" />

                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold mb-2">Proposal File</MudText>
                        @if (!string.IsNullOrEmpty(_proposal.ProposalFileUrl))
                        {
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.OpenInNew"
                                       Href="@_proposal.ProposalFileUrl" Target="_blank">
                                Open Proposal File
                            </MudButton>
                            @if (!string.IsNullOrEmpty(_proposal.ProposalFileName))
                            {
                                <MudText Typo="Typo.caption" Class="mf-muted mt-1">@_proposal.ProposalFileName</MudText>
                            }
                        }
                        else
                        {
                            <MudText Class="mf-muted">Proposal file is unavailable.</MudText>
                        }
                    </MudPaper>

                    @if (_proposal.HasEditorialDecision)
                    {
                        <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Editorial Decision</MudText>
                            @if (!string.IsNullOrWhiteSpace(_proposal.ReviewerDisplayName))
                            {
                                <MudText Typo="Typo.body2" Class="mf-muted mb-1">
                                    Reviewed by @_proposal.ReviewerDisplayName
                                    @if (_proposal.ReviewedAtUtc.HasValue)
                                    {
                                        <span> on @_proposal.ReviewedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                                    }
                                </MudText>
                            }
                            @if (!string.IsNullOrWhiteSpace(_proposal.Comments))
                            {
                                <MudPaper Elevation="0" Class="pa-3 mt-2" Style="background: var(--mud-palette-warning-hover);">
                                    <MudText Style="white-space: pre-wrap;">@_proposal.Comments</MudText>
                                </MudPaper>
                            }
                            @if (!string.IsNullOrEmpty(_proposal.MarkupFileUrl))
                            {
                                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Class="mt-3"
                                           StartIcon="@Icons.Material.Filled.OpenInNew"
                                           Href="@_proposal.MarkupFileUrl" Target="_blank">
                                    Open Markup File
                                </MudButton>
                                @if (!string.IsNullOrEmpty(_proposal.MarkupFileName))
                                {
                                    <MudText Typo="Typo.caption" Class="mf-muted mt-1">@_proposal.MarkupFileName</MudText>
                                }
                            }
                        </MudPaper>
                    }
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Submission</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted">Submitted by</MudText>
                        <MudText Class="mb-2">@_proposal.SubmitterDisplayName</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted">Submitted at</MudText>
                        <MudText class="mb-2">@_proposal.SubmittedAtUtc.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</MudText>
                    </MudPaper>

                    @if (_proposal.CanClaim)
                    {
                        <MudPaper Class="pa-5 mf-card mb-5" Elevation="0" Style="border: 2px dashed var(--mud-palette-warning);">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Unclaimed Proposal</MudText>
                            <MudText Class="mb-4">Claim this proposal to become its active Tantou Editor reviewer before recording a decision.</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                       OnClick="ClaimProposal" Disabled="_processing">
                                Claim Review
                            </MudButton>
                        </MudPaper>
                    }

                    @if (_proposal.CanRequestRevision || _proposal.CanPassToBoard || _proposal.CanCancel)
                    {
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Decision Actions</MudText>
                            <MudStack Spacing="2">
                                @if (_proposal.CanPassToBoard)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                                               OnClick="OpenPassToBoard" Disabled="_processing">Pass To Board</MudButton>
                                }
                                @if (_proposal.CanRequestRevision)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                               OnClick="OpenRequestRevision" Disabled="_processing">Request Revision</MudButton>
                                }
                                @if (_proposal.CanCancel)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="OpenCancel" Disabled="_processing">Cancel Proposal</MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                    else if (!_proposal.CanClaim && !_proposal.HasEditorialDecision
                             && _proposal.StatusCode == "UNDER_EDITORIAL_REVIEW"
                             && !_proposal.CurrentActorIsActiveTantouEditorContributor)
                    {
                        <MudAlert Severity="Severity.Info">
                            This proposal is under editorial review. Claim it to record a decision.
                        </MudAlert>
                    }
                </MudItem>
            </MudGrid>
        }
    </div>

    @* ── Request Revision modal ─────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_revisionDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Request Revision</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3 mf-muted">Comments are required. A markup file is optional.</MudText>
            <MudTextField @bind-Value="_comments" Label="Review comments" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true"
                          Error="_commentsError" ErrorText="Comments are required." />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (optional)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="SubmitRequestRevision" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Request Revision
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Pass To Board modal ────────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_boardDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Pass To Board</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3 mf-muted">Comments and a markup file are both optional. This moves the proposal to board review.</MudText>
            <MudTextField @bind-Value="_comments" Label="Review comments (optional)" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true" />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (optional)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitPassToBoard" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Pass To Board
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Cancel Proposal modal ──────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_cancelDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Cancel Proposal</MudText>
        </TitleContent>
        <DialogContent>
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Cancellation requires both comments and a markup file. This cancels the proposal and its series.
            </MudAlert>
            <MudTextField @bind-Value="_comments" Label="Cancellation comments" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true"
                          Error="_commentsError" ErrorText="Comments are required." />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (required)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
                else if (_markupError)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error" Class="mt-2">A markup file is required.</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Close</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="SubmitCancel" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Cancel Proposal
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditorLayout>

@code {
    [Parameter] public Guid ProposalId { get; set; }

    private EditorProposalDetailDto? _proposal;
    private bool _loading = true;
    private bool _processing;
    private string? _error;
    private Guid _currentUserId;

    // Modal state
    private bool _revisionDialogOpen;
    private bool _boardDialogOpen;
    private bool _cancelDialogOpen;
    private string _comments = string.Empty;
    private bool _commentsError;
    private bool _markupError;

    private IBrowserFile? _markupFile;
    private byte[]? _markupBytes;

    private const long MaxMarkupSize = 10 * 1024 * 1024; // 10 MB

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadProposal();
    }

    private async Task LoadProposal()
    {
        _loading = true;
        _error = null;
        try
        {
            _proposal = await EditorProposalApiClient.GetDetailAsync(_currentUserId, ProposalId);
            if (_proposal == null)
            {
                _error = "Proposal not found.";
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/editor/proposals");

    private Color GetStatusColor(string status) => status switch
    {
        "UNDER_EDITORIAL_REVIEW" => Color.Warning,
        "UNDER_BOARD_REVIEW" => Color.Info,
        "REVISION_REQUESTED" => Color.Error,
        "CANCELLED" => Color.Default,
        "APPROVED" => Color.Success,
        _ => Color.Default
    };

    private async Task OnMarkupChanged(IBrowserFile file)
    {
        _markupError = false;

        if (file == null)
        {
            _markupFile = null;
            _markupBytes = null;
            return;
        }

        if (file.Size > MaxMarkupSize)
        {
            Snackbar.Add("The markup file exceeds the maximum allowed size of 10 MB.", Severity.Warning);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: MaxMarkupSize);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            _markupBytes = ms.ToArray();
            _markupFile = file;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read the markup file: {ex.Message}", Severity.Error);
            _markupFile = null;
            _markupBytes = null;
        }
    }

    private void ResetModalState()
    {
        _comments = string.Empty;
        _commentsError = false;
        _markupError = false;
        _markupFile = null;
        _markupBytes = null;
    }

    private void CloseDialogs()
    {
        _revisionDialogOpen = false;
        _boardDialogOpen = false;
        _cancelDialogOpen = false;
        ResetModalState();
    }

    private void OpenRequestRevision()
    {
        ResetModalState();
        _revisionDialogOpen = true;
    }

    private void OpenPassToBoard()
    {
        ResetModalState();
        _boardDialogOpen = true;
    }

    private void OpenCancel()
    {
        ResetModalState();
        _cancelDialogOpen = true;
    }

    private async Task ClaimProposal()
    {
        _processing = true;
        try
        {
            await EditorProposalApiClient.ClaimAsync(_currentUserId, ProposalId, "Claimed via Editor UI");
            Snackbar.Add("Proposal claimed for review.", Severity.Success);
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitRequestRevision()
    {
        _commentsError = string.IsNullOrWhiteSpace(_comments);
        if (_commentsError)
        {
            return;
        }

        _processing = true;
        try
        {
            await EditorProposalApiClient.RequestRevisionAsync(
                _currentUserId, ProposalId, _comments,
                _markupBytes, _markupFile?.Name, _markupFile?.ContentType);

            Snackbar.Add("Revision requested.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitPassToBoard()
    {
        _processing = true;
        try
        {
            await EditorProposalApiClient.PassToBoardAsync(
                _currentUserId, ProposalId,
                string.IsNullOrWhiteSpace(_comments) ? null : _comments,
                _markupBytes, _markupFile?.Name, _markupFile?.ContentType);

            Snackbar.Add("Proposal passed to board review.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitCancel()
    {
        _commentsError = string.IsNullOrWhiteSpace(_comments);
        _markupError = _markupBytes is not { Length: > 0 };
        if (_commentsError || _markupError)
        {
            return;
        }

        _processing = true;
        try
        {
            await EditorProposalApiClient.CancelAsync(
                _currentUserId, ProposalId, _comments,
                _markupBytes!, _markupFile!.Name, _markupFile!.ContentType);

            Snackbar.Add("Proposal cancelled.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
