@page "/editor/proposals/{SeriesId:guid}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ISeriesProposalService ProposalService
@inject IFileResourceService FileResourceService
@inject ISeriesService SeriesService
@inject IUserService UserService
@inject AuthenticationStateProvider AuthStateProvider

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review proposal material, add feedback, and move it to the next workflow step</MudText>
        </div>

        <MudGrid>
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start" Class="mb-4">
                        <div>
                            @if (_proposal != null)
                            {
                                <MudText Typo="Typo.h5" Class="font-weight-bold">@(_proposal.ProposalTitle)</MudText>
                                <MudText Class="mf-muted">
                                    Proposal v@(_proposal.ProposalVersionNo)
                                    • Submitted by @_submitterDisplayName
                                    @if (!string.IsNullOrWhiteSpace(_series?.ContentLanguageCode))
                                    {
                                        <span> • @_series.ContentLanguageCode</span>
                                    }
                                </MudText>
                            }
                            else
                            {
                                <MudSkeleton Width="220px" Height="28px" Class="mb-1" />
                                <MudSkeleton Width="300px" Height="20px" />
                            }
                        </div>
                        <MudChip T="string" Color="Color.Warning">@(_proposal?.StatusCode ?? "—")</MudChip>
                    </MudStack>

                    <MudTabs>
                        <MudTabPanel Text="Synopsis">
                            <MudText Typo="Typo.h6" Class="mb-2">Story Summary</MudText>
                            @if (_proposal != null)
                            {
                                <MudText Class="mf-muted">@_proposal.SynopsisSnapshot</MudText>
                            }
                            else
                            {
                                <MudSkeleton Width="100%" Height="80px" />
                            }
                        </MudTabPanel>
                        <MudTabPanel Text="Proposal File">
                            <MudPaper Class="pa-6 text-center mf-card" Elevation="0">
                                <MudIcon Icon="mdi-file-document-outline" Size="Size.Large" Color="Color.Primary" Class="mb-3" />
                                <MudText Typo="Typo.h6" Class="mb-2">Proposal Document</MudText>
                                @if (_fileLoading)
                                {
                                    <MudProgressLinear Indeterminate="true" Class="mb-3" />
                                    <MudText Class="mf-muted">Loading proposal file…</MudText>
                                }
                                else if (_proposalFileUrl != null)
                                {
                                    <MudText Class="mf-muted mb-3">Proposal file submitted by the Mangaka. Opens in a new tab.</MudText>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@_proposalFileUrl" Target="_blank">
                                        Open Proposal File
                                    </MudButton>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Class="mb-3">No proposal file has been submitted yet.</MudAlert>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Default" Disabled="true">Open Proposal File</MudButton>
                                }
                            </MudPaper>
                        </MudTabPanel>
                        <MudTabPanel Text="Review Criteria">
                            <MudList T="string">
                                <MudListItem T="string" Text="Series premise is clear and suitable for serialization" />
                                <MudListItem T="string" Text="Chapter direction has enough production detail" />
                                <MudListItem T="string" Text="Art references and portfolio evidence are sufficient" />
                                <MudListItem T="string" Text="Potential ranking/publication risk is documented" />
                            </MudList>
                        </MudTabPanel>
                    </MudTabs>
                </MudPaper>

                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Editorial Feedback</MudText>
                    <MudTextField Label="Review comments" @bind-Value="ReviewComments" Lines="6" Variant="Variant.Outlined" FullWidth="true" />
                    <MudAlert Severity="Severity.Info" Class="mt-4">
                        Revision or cancellation decisions should include clear comments or markup according to the MVP workflow.
                    </MudAlert>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Decision Actions</MudText>
                    <MudStack Spacing="2">
                        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="PassToBoard" Disabled="@_decisionDisabled">Pass to Board Review</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" OnClick="RequestRevision" Disabled="@_decisionDisabled">Request Revision</MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="CancelProposal" Disabled="@_decisionDisabled">Cancel Proposal</MudButton>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Workflow Trace</MudText>
                    <MudTimeline>
                        <MudTimelineItem Color="Color.Success">Proposal submitted</MudTimelineItem>
                        <MudTimelineItem Color="Color.Warning">Editorial review in progress</MudTimelineItem>
                        <MudTimelineItem Color="Color.Default">Board review pending</MudTimelineItem>
                    </MudTimeline>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </div>
</EditorLayout>

@code {
    [Parameter] public Guid SeriesId { get; set; }
    private string ReviewComments { get; set; } = string.Empty;

    private bool _fileLoading = true;
    private bool _submitting = false;
    private string? _proposalFileUrl;

    private SeriesProposalDto? _proposal;
    private SeriesDto? _series;
    private string _submitterDisplayName = "Unknown submitter";

    // Disable decision actions while loading/submitting, when no proposal is loaded,
    // or when the proposal has already reached a terminal/board state.
    private bool _decisionDisabled =>
        _submitting
        || _proposal == null
        || _proposal.StatusCode is "UNDER_BOARD_REVIEW" or "APPROVED" or "CANCELLED" or "WITHDRAWN";

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadSeriesAsync(), LoadProposalFileAsync());
    }

    private async Task LoadSeriesAsync()
    {
        try
        {
            _series = await SeriesService.GetSeriesByIdAsync(SeriesId);
        }
        catch
        {
            // Non-fatal; series details degrade gracefully
        }
    }

    private async Task LoadProposalFileAsync()
    {
        _fileLoading = true;
        _proposalFileUrl = null;
        try
        {
            var proposals = await ProposalService.GetSeriesProposalsBySeriesIdAsync(SeriesId);
            // Take the latest proposal by version number
            var latest = proposals
                .OrderByDescending(p => p.ProposalVersionNo)
                .FirstOrDefault();

            if (latest != null)
            {
                _proposal = latest;
                ReviewComments = latest.Comments ?? string.Empty;

                // Resolve submitter display name
                try
                {
                    var user = await UserService.GetUserByIdAsync(latest.SubmittedByUserId);
                    if (user != null)
                        _submitterDisplayName = !string.IsNullOrWhiteSpace(user.DisplayName)
                            ? user.DisplayName
                            : user.Username;
                }
                catch
                {
                    // Keep fallback
                }

                // Resolve proposal file
                if (latest.ProposalFileId != Guid.Empty)
                {
                    var file = await FileResourceService.GetFileResourceByIdAsync(latest.ProposalFileId);
                    if (file != null && !string.IsNullOrWhiteSpace(file.CloudinarySecureUrl))
                        _proposalFileUrl = file.CloudinarySecureUrl;
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not load proposal: {ex.Message}", Severity.Warning);
        }
        finally
        {
            _fileLoading = false;
        }
    }

    // Editor decisions map to proposal status codes defined by the schema's
    // ck_series_proposal_status_code constraint. Note: APPROVED means board
    // approval per MVP rules, so the editor only passes a proposal to the board
    // (UNDER_BOARD_REVIEW) rather than setting APPROVED directly.
    private Task PassToBoard() => ApplyDecisionAsync("UNDER_BOARD_REVIEW", requireComments: false,
        "Proposal passed to board review.");

    private Task RequestRevision() => ApplyDecisionAsync("REVISION_REQUESTED", requireComments: true,
        "Revision requested. The Mangaka can submit a revised proposal version.");

    private Task CancelProposal() => ApplyDecisionAsync("CANCELLED", requireComments: true,
        "Proposal cancelled.");

    private async Task ApplyDecisionAsync(string newStatusCode, bool requireComments, string successMessage)
    {
        if (_proposal == null)
        {
            Snackbar.Add("No proposal is loaded to act on.", Severity.Warning);
            return;
        }

        if (requireComments && string.IsNullOrWhiteSpace(ReviewComments))
        {
            Snackbar.Add("Please add review comments before requesting a revision or cancellation.", Severity.Warning);
            return;
        }

        var reviewerId = await GetCurrentUserIdAsync();
        if (reviewerId == null)
        {
            Snackbar.Add("Could not identify the current reviewer. Please sign in again.", Severity.Error);
            return;
        }

        _submitting = true;
        try
        {
            // reviewed_by_user_id and reviewed_at_utc must both be set together
            // (ck_series_proposal_review_pair).
            var dto = new UpdateSeriesProposalDto(
                _proposal.SeriesProposalId,
                _proposal.SeriesId,
                _proposal.ProposalVersionNo,
                _proposal.ProposalTitle,
                _proposal.SynopsisSnapshot,
                _proposal.GenreSnapshot,
                _proposal.ProposalFileId,
                newStatusCode,
                _proposal.SubmittedByUserId,
                reviewerId.Value,
                DateTime.UtcNow,
                string.IsNullOrWhiteSpace(ReviewComments) ? null : ReviewComments,
                _proposal.MarkupFileId);

            var updated = await ProposalService.UpdateSeriesProposalAsync(dto);
            if (updated == null)
            {
                Snackbar.Add("Proposal could not be updated. It may no longer exist.", Severity.Error);
                return;
            }

            _proposal = updated;
            ReviewComments = updated.Comments ?? string.Empty;
            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to update proposal: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task<Guid?> GetCurrentUserIdAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User;
        if (user?.Identity?.IsAuthenticated != true)
        {
            return null;
        }

        var idClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        return Guid.TryParse(idClaim?.Value, out var uid) ? uid : null;
    }
}
