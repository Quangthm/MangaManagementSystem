@page "/editor/proposals/{ProposalId:guid}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@using MangaManagementSystem.Web.Services
@using MangaManagementSystem.Web.Components.Shared
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorProposalApiClient EditorProposalApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" Href="@_backHref" Class="mb-2">@_backLabel</MudButton>
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review the proposal material, add feedback, and move it to the next workflow step</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error">@_error</MudAlert>
        }
        else if (_proposal != null)
        {
            <SeriesProposalDetailView Proposal="@_detailViewModel">
                <SidePanel>
                    @if (_proposal.CanClaim && _proposal.HasOtherActiveTantouEditor)
                    {
                        <MudPaper Class="pa-5 mf-card mb-5" Elevation="0" Style="border:2px dashed var(--mud-palette-warning);">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Active editor already assigned</MudText>
                            <MudText Typo="Typo.body2" Class="mf-muted mb-3">
                                This series already has active Tantou Editor(s):
                                @string.Join(", ", _proposal.ActiveTantouEditors
                                    .Where(a => a.UserId != _currentUserId)
                                    .Select(a => a.DisplayName))
                            </MudText>
                            <MudText Typo="Typo.body2" Class="mb-4">You can still claim this proposal if another editor is needed.</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                       OnClick="@(() => _claimAdditionalDialogOpen = true)" Disabled="_processing">
                                Claim as Additional Editor
                            </MudButton>
                        </MudPaper>
                    }
                    else if (_proposal.CanClaim)
                    {
                        <MudPaper Class="pa-5 mf-card mb-5" Elevation="0" Style="border:2px dashed var(--mud-palette-warning);">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Unclaimed Proposal</MudText>
                            <MudText Class="mb-4">Claim this proposal to become its active Tantou Editor reviewer before recording a decision.</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Warning" FullWidth="true"
                                       OnClick="ClaimProposal" Disabled="_processing">
                                Claim Review
                            </MudButton>
                        </MudPaper>
                    }

                    @if (_proposal.CanRequestRevision || _proposal.CanPassToBoard || _proposal.CanCancel)
                    {
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Decision Actions</MudText>
                            @if (_proposal.CurrentActorIsActiveTantouEditorContributor)
                            {
                                <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                                    <MudText Typo="Typo.caption">
                                        You are an active Tantou Editor for this series.
                                        @if (_proposal.ActiveTantouEditors.Count > 1)
                                        {
                                            var others = _proposal.ActiveTantouEditors
                                                .Where(a => a.UserId != _currentUserId)
                                                .Select(a => a.DisplayName).ToList();
                                            <span>Other active editor(s): @string.Join(", ", others).</span>
                                        }
                                    </MudText>
                                </MudAlert>
                            }
                            <MudStack Spacing="2">
                                @if (_proposal.CanPassToBoard)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Success"
                                               OnClick="OpenPassToBoard" Disabled="_processing">Pass To Board</MudButton>
                                }
                                @if (_proposal.CanRequestRevision)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Warning"
                                               OnClick="OpenRequestRevision" Disabled="_processing">Request Revision</MudButton>
                                }
                                @if (_proposal.CanCancel)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Error"
                                               OnClick="OpenCancel" Disabled="_processing">Cancel Proposal</MudButton>
                                }
                            </MudStack>
                        </MudPaper>
                    }
                    else if (!_proposal.CanClaim && !_proposal.HasEditorialDecision
                             && !string.IsNullOrWhiteSpace(_proposal.SeriesStatusCode)
                             && !IsExpectedProposalSeriesStatePair(_proposal.ProposalStatusCode, _proposal.SeriesStatusCode))
                    {
                        <MudAlert Severity="Severity.Warning">
                            Current series state (@_proposal.SeriesStatusCode.Replace("_", " ")) differs from this proposal version. Review actions are unavailable.
                        </MudAlert>
                    }
                    else if (!_proposal.CanClaim && !_proposal.HasEditorialDecision
                             && _proposal.ProposalStatusCode == "UNDER_EDITORIAL_REVIEW"
                             && _proposal.SeriesStatusCode == "UNDER_EDITORIAL_REVIEW"
                             && !_proposal.CurrentActorIsActiveTantouEditorContributor)
                    {
                        <MudAlert Severity="Severity.Info">
                            This proposal is under editorial review. Claim it to record a decision.
                        </MudAlert>
                    }
                </SidePanel>
            </SeriesProposalDetailView>
        }
    </div>

    @* ── Request Revision modal ─────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_revisionDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Request Revision</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3 mf-muted">Comments are required. A markup file is optional.</MudText>
            <MudTextField @bind-Value="_comments" Label="Review comments" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true"
                          Error="_commentsError" ErrorText="Comments are required." />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (optional)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="SubmitRequestRevision" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Request Revision
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Pass To Board modal ────────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_boardDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Pass To Board</MudText>
        </TitleContent>
        <DialogContent>
            <MudText Class="mb-3 mf-muted">Comments and a markup file are both optional. This moves the proposal to board review.</MudText>
            <MudTextField @bind-Value="_comments" Label="Review comments (optional)" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true" />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (optional)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="SubmitPassToBoard" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Pass To Board
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Cancel Proposal modal ──────────────────────────────────────────── *@
    <MudDialog @bind-Visible="_cancelDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Cancel Proposal</MudText>
        </TitleContent>
        <DialogContent>
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Cancellation requires both comments and a markup file. This cancels the proposal and its series.
            </MudAlert>
            <MudTextField @bind-Value="_comments" Label="Cancellation comments" Lines="5"
                          Variant="Variant.Outlined" FullWidth="true"
                          Error="_commentsError" ErrorText="Comments are required." />
            <div class="mt-3">
                <MudFileUpload T="IBrowserFile" FilesChanged="OnMarkupChanged" Disabled="_processing">
                    <ActivatorContent>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.CloudUpload">
                            Select Markup File (required)
                        </MudButton>
                    </ActivatorContent>
                </MudFileUpload>
                @if (_markupFile != null)
                {
                    <MudText Typo="Typo.body2" Class="mt-2">Selected: @_markupFile.Name</MudText>
                }
                else if (_markupError)
                {
                    <MudText Typo="Typo.body2" Color="Color.Error" Class="mt-2">A markup file is required.</MudText>
                }
            </div>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CloseDialogs" Disabled="_processing">Close</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="SubmitCancel" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Cancel Proposal
            </MudButton>
        </DialogActions>
    </MudDialog>

    @* ── Claim as Additional Editor confirmation modal ─────────────────── *@
    <MudDialog @bind-Visible="_claimAdditionalDialogOpen" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6">Additional Editor Confirmation</MudText>
        </TitleContent>
        <DialogContent>
            <MudText>
                Another Tantou Editor is already active on this series. Claiming will add you as an additional active editor. Continue?
            </MudText>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="@(() => _claimAdditionalDialogOpen = false)" Disabled="_processing">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Warning" OnClick="ClaimProposal" Disabled="_processing">
                @if (_processing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Claim Anyway
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditorLayout>

@code {
    [Parameter] public Guid ProposalId { get; set; }

    private EditorProposalDetailDto? _proposal;
    private SeriesProposalDetailViewModel? _detailViewModel;
    private bool _loading = true;
    private bool _processing;
    private string? _error;
    private Guid _currentUserId;
    private string _backLabel = "Back to Queue";
    private string _backHref = "/editor/proposals";

    // Modal state
    private bool _revisionDialogOpen;
    private bool _boardDialogOpen;
    private bool _cancelDialogOpen;
    private bool _claimAdditionalDialogOpen;
    private string _comments = string.Empty;
    private bool _commentsError;
    private bool _markupError;

    private IBrowserFile? _markupFile;
    private byte[]? _markupBytes;

    private const long MaxMarkupSize = 10 * 1024 * 1024; // 10 MB

    [SupplyParameterFromQuery] public string? returnUrl { get; set; }

    private readonly DialogOptions _dialogOptions = new()
    {
        MaxWidth = MaxWidth.Small,
        FullWidth = true,
        CloseOnEscapeKey = true
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
                _currentUserId = userId;
        }

        _backHref = SafeReturnUrl.Resolve(returnUrl, "/editor/proposals");
        _backLabel = _backHref switch
        {
            "/editor" => "Back to Dashboard",
            "/editor/series" => "Back to Series",
            "/editor/proposals" => "Back to Queue",
            _ => "Back to Queue"
        };

        await LoadProposal();
    }

    private async Task LoadProposal()
    {
        _loading = true;
        _error = null;
        try
        {
            _proposal = await EditorProposalApiClient.GetDetailAsync(ProposalId);
            if (_proposal == null)
            {
                _error = "Proposal not found.";
            }
            else
            {
                _detailViewModel = MapToDetailViewModel(_proposal);
            }
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static SeriesProposalDetailViewModel MapToDetailViewModel(EditorProposalDetailDto p) => new(
        SeriesProposalId: p.SeriesProposalId,
        SeriesTitle: p.SeriesTitle,
        SeriesSlug: p.SeriesSlug,
        SeriesCoverUrl: p.SeriesCoverUrl,
        ProposalVersionNo: p.ProposalVersionNo,
        ProposalTitle: p.ProposalTitle,
        SynopsisSnapshot: p.SynopsisSnapshot,
        Genres: p.Genres,
        Tags: p.Tags,
        StatusCode: p.ProposalStatusCode,
        SeriesStatusCode: p.SeriesStatusCode,
        SubmittedByDisplayName: p.SubmitterDisplayName,
        SubmittedAtUtc: p.SubmittedAtUtc,
        ReviewerDisplayName: p.ReviewerDisplayName,
        ReviewedAtUtc: p.ReviewedAtUtc,
        Comments: p.Comments,
        ProposalFileName: p.ProposalFileName,
        ProposalFileUrl: p.ProposalFileUrl,
        MarkupFileName: p.MarkupFileName,
        MarkupFileUrl: p.MarkupFileUrl,
        HasEditorialDecision: p.HasEditorialDecision
    );

    private bool IsExpectedProposalSeriesStatePair(string? proposalStatusCode, string? seriesStatusCode)
    {
        if (proposalStatusCode == "REVISION_REQUESTED" && seriesStatusCode == "PROPOSAL_DRAFT")
            return true;
        return proposalStatusCode == seriesStatusCode;
    }

    private async Task OnMarkupChanged(IBrowserFile file)
    {
        _markupError = false;
        if (file == null)
        {
            _markupFile = null;
            _markupBytes = null;
            return;
        }
        if (file.Size > MaxMarkupSize)
        {
            Snackbar.Add("The markup file exceeds the maximum allowed size of 10 MB.", Severity.Warning);
            return;
        }
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: MaxMarkupSize);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            _markupBytes = ms.ToArray();
            _markupFile = file;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read the markup file: {ex.Message}", Severity.Error);
            _markupFile = null;
            _markupBytes = null;
        }
    }

    private void ResetModalState()
    {
        _comments = string.Empty;
        _commentsError = false;
        _markupError = false;
        _markupFile = null;
        _markupBytes = null;
    }

    private void CloseDialogs()
    {
        _revisionDialogOpen = false;
        _boardDialogOpen = false;
        _cancelDialogOpen = false;
        _claimAdditionalDialogOpen = false;
        ResetModalState();
    }

    private void OpenRequestRevision()
    {
        ResetModalState();
        _revisionDialogOpen = true;
    }

    private void OpenPassToBoard()
    {
        ResetModalState();
        _boardDialogOpen = true;
    }

    private void OpenCancel()
    {
        ResetModalState();
        _cancelDialogOpen = true;
    }

    private async Task ClaimProposal()
    {
        _processing = true;
        _claimAdditionalDialogOpen = false;
        try
        {
            await EditorProposalApiClient.ClaimAsync(ProposalId, "Claimed via Editor UI");
            Snackbar.Add("Proposal claimed for review.", Severity.Success);
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitRequestRevision()
    {
        _commentsError = string.IsNullOrWhiteSpace(_comments);
        if (_commentsError) return;

        _processing = true;
        try
        {
            await EditorProposalApiClient.RequestRevisionAsync(
                ProposalId, _comments,
                _markupBytes, _markupFile?.Name, _markupFile?.ContentType);
            Snackbar.Add("Revision requested.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitPassToBoard()
    {
        _processing = true;
        try
        {
            await EditorProposalApiClient.PassToBoardAsync(
                ProposalId,
                string.IsNullOrWhiteSpace(_comments) ? null : _comments,
                _markupBytes, _markupFile?.Name, _markupFile?.ContentType);
            Snackbar.Add("Proposal passed to board review.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task SubmitCancel()
    {
        _commentsError = string.IsNullOrWhiteSpace(_comments);
        _markupError = _markupBytes is not { Length: > 0 };
        if (_commentsError || _markupError) return;

        _processing = true;
        try
        {
            await EditorProposalApiClient.CancelAsync(
                ProposalId, _comments,
                _markupBytes!, _markupFile!.Name, _markupFile!.ContentType);
            Snackbar.Add("Proposal cancelled.", Severity.Success);
            CloseDialogs();
            await LoadProposal();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _processing = false;
        }
    }
}
