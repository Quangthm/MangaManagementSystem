@page "/editor/chapters/{ChapterId:guid}"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Editor
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorChapterReviewApiClient ChapterReviewApiClient
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudButton Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mb-2">Back to Chapters</MudButton>
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Chapter Review</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Read-only chapter overview. Use the workspace to review pages and annotations.</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Class="my-6" />
        }
        else if (_accessDenied)
        {
            <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Outlined.Block" Size="Size.Large" Color="Color.Error" Class="mb-3" />
                <MudText Typo="Typo.h6">Access Denied</MudText>
                <MudText Class="mf-muted">You do not have access to this chapter review.</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" OnClick="GoBack">Back to Chapters</MudButton>
            </MudPaper>
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="my-4">
                @_error
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="ml-3" OnClick="LoadDetail" StartIcon="@Icons.Material.Filled.Refresh">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else if (_detail != null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">@_detail.SeriesTitle — @_detail.ChapterNumberLabel</MudText>
                    @if (!string.IsNullOrWhiteSpace(_detail.ChapterTitle))
                    {
                        <MudText Class="mf-muted">"@_detail.ChapterTitle"</MudText>
                    }
                </div>
                <MudChip T="string" Color="@GetStatusColor(_detail.StatusCode)" Size="Size.Medium">@_detail.StatusCode.Replace("_", " ")</MudChip>
            </MudStack>

            @if (_detail.StatusCode == "UNDER_REVIEW")
            {
                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Review Decision</MudText>
                    <MudStack Row="true" Spacing="3">
                        <MudButton Variant="Variant.Filled" Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.CheckCircle"
                                   OnClick="@(() => OpenDecisionDialog("APPROVED"))"
                                   Disabled="_submitting">
                            Approve Chapter
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                                   StartIcon="@Icons.Material.Filled.Comment"
                                   OnClick="@(() => OpenDecisionDialog("REVISION_REQUESTED"))"
                                   Disabled="_submitting">
                            Request Revision
                        </MudButton>
                        <MudButton Variant="Variant.Filled" Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Cancel"
                                   OnClick="@(() => OpenDecisionDialog("CANCELLED"))"
                                   Disabled="_submitting">
                            Cancel Chapter
                        </MudButton>
                    </MudStack>
                    @if (_submitting)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-3" />
                    }
                </MudPaper>
            }

            <MudGrid>
                <!-- Pages -->
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Pages (@_detail.PageCount)</MudText>
                            @if (_detail.CanOpenWorkspace && !string.IsNullOrWhiteSpace(_detail.WorkspaceUrl))
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.OpenInNew"
                                           OnClick="@(() => Nav.NavigateTo(_detail.WorkspaceUrl!))">
                                    Review in Workspace
                                </MudButton>
                            }
                        </MudStack>

                        @if (_detail.Pages.Count == 0)
                        {
                            <MudText Class="mf-muted">No pages have been uploaded for this chapter yet.</MudText>
                        }
                        else
                        {
                            <MudTable Items="_detail.Pages" Hover="true" Dense="true">
                                <HeaderContent>
                                    <MudTh>Page</MudTh>
                                    <MudTh>Current Version</MudTh>
                                    <MudTh>Preview</MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd DataLabel="Page">@context.PageNumber</MudTd>
                                    <MudTd DataLabel="Current Version">@(context.CurrentVersionNo.HasValue ? $"v{context.CurrentVersionNo}" : "—")</MudTd>
                                    <MudTd DataLabel="Preview">
                                        @if (!string.IsNullOrWhiteSpace(context.CurrentVersionFileUrl))
                                        {
                                            <MudLink Href="@context.CurrentVersionFileUrl" Target="_blank">Open image</MudLink>
                                        }
                                        else
                                        {
                                            <MudText Class="mf-muted">No image</MudText>
                                        }
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                    </MudPaper>

                    <!-- Open annotations -->
                    <MudPaper Class="pa-5 mf-card" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Open Annotations</MudText>
                        @if (_detail.OpenAnnotations.Count == 0)
                        {
                            <MudText Class="mf-muted">No open annotations for this chapter.</MudText>
                        }
                        else
                        {
                            <MudList T="EditorChapterReviewAnnotationDto">
                                @foreach (var ann in _detail.OpenAnnotations)
                                {
                                    <MudListItem T="EditorChapterReviewAnnotationDto" Value="@ann">
                                        <div>
                                            <MudChip T="string" Color="Color.Secondary" Size="Size.Small">@ann.IssueTypeCode.Replace("_", " ")</MudChip>
                                            <MudText>@ann.Comment</MudText>
                                            <MudText Typo="Typo.caption" Class="mf-muted">
                                                By @(string.IsNullOrWhiteSpace(ann.CreatedByDisplayName) ? "Unknown" : ann.CreatedByDisplayName) - @ann.CreatedAtUtc.ToLocalTime().ToString("MMM d, HH:mm")
                                            </MudText>
                                        </div>
                                    </MudListItem>
                                }
                            </MudList>
                        }
                    </MudPaper>
                </MudItem>

                <!-- Chapter info -->
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Chapter Info</MudText>
                        <MudText><strong>Series:</strong> @_detail.SeriesTitle</MudText>
                        <MudText><strong>Chapter:</strong> @_detail.ChapterNumberLabel</MudText>
                        <MudText><strong>Title:</strong> @(_detail.ChapterTitle ?? "—")</MudText>
                        <MudText><strong>Status:</strong> @_detail.StatusCode.Replace("_", " ")</MudText>
                        <MudText><strong>Pages:</strong> @_detail.PageCount</MudText>
                        <MudText><strong>Current versions:</strong> @_detail.CurrentVersionCount</MudText>
                        <MudText><strong>Created:</strong> @_detail.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</MudText>
                        <MudText><strong>Creator:</strong> @(_detail.SubmittedByDisplayName ?? "—")</MudText>
                    </MudPaper>

                    @if (_detail.CanOpenWorkspace && !string.IsNullOrWhiteSpace(_detail.WorkspaceUrl))
                    {
                        <MudPaper Class="pa-5 mf-card" Elevation="0">
                            <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Review</MudText>
                            <MudText Class="mb-3 mf-muted">Open the chapter workspace to review pages, annotations, and record editorial decisions.</MudText>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                       StartIcon="@Icons.Material.Filled.OpenInNew"
                                       OnClick="@(() => Nav.NavigateTo(_detail.WorkspaceUrl!))">
                                Review in Workspace
                            </MudButton>
                        </MudPaper>
                    }
                </MudItem>
            </MudGrid>
        }
    </div>
</EditorLayout>

<!-- Decision dialog -->
<MudDialog @bind-IsVisible="_dialogVisible" T="bool">
    <DialogContent>
        @if (_selectedDecision == "APPROVED")
        {
            <MudText Typo="Typo.h6" Class="mb-3">Approve Chapter</MudText>
            <MudText Class="mf-muted mb-3">
                This chapter will be marked as <strong>APPROVED</strong> and may proceed toward scheduling and release.
            </MudText>
            <MudTextField @bind-Value="_dialogComments" Label="Comments (optional)" Lines="3" Variant="Variant.Outlined" />
        }
        else if (_selectedDecision == "REVISION_REQUESTED")
        {
            <MudText Typo="Typo.h6" Class="mb-3">Request Revision</MudText>
            <MudText Class="mf-muted mb-3">
                Use this when the chapter can be <strong>fixed and resubmitted</strong>. The Mangaka will be able to edit and resubmit the chapter with new page versions.
            </MudText>
            <MudTextField @bind-Value="_dialogComments" Label="Comments (required)" Lines="3" Variant="Variant.Outlined" Required="true" />
            @if (_dialogValidationError != null)
            {
                <MudText Color="Color.Error" Typo="Typo.caption">@_dialogValidationError</MudText>
            }
        }
        else if (_selectedDecision == "CANCELLED")
        {
            <MudText Typo="Typo.h6" Class="mb-3">Cancel Chapter</MudText>
            <MudAlert Severity="Severity.Error" Class="mb-3">
                <strong>Warning:</strong> Cancellation is <strong>terminal</strong> for this chapter attempt.
                The chapter cannot be edited, resubmitted, approved, scheduled, or released.
                A replacement chapter draft must be created to redo the work.
            </MudAlert>
            <MudText Class="mf-muted mb-3">
                Use this <strong>only</strong> when this chapter attempt should not proceed.
                If the chapter can still be fixed, use <strong>Request Revision</strong> instead.
            </MudText>
            <MudTextField @bind-Value="_dialogComments" Label="Comments (required)" Lines="3" Variant="Variant.Outlined" Required="true" />
            @if (_dialogValidationError != null)
            {
                <MudText Color="Color.Error" Typo="Typo.caption">@_dialogValidationError</MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDialog">Cancel</MudButton>
        <MudButton Color="@GetDecisionColor(_selectedDecision)" Variant="Variant.Filled" OnClick="ConfirmDecision" Disabled="_submitting">
            @GetDecisionButtonLabel(_selectedDecision)
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid ChapterId { get; set; }

    private EditorChapterReviewDetailDto? _detail;
    private bool _loading = true;
    private bool _accessDenied;
    private string? _error;
    private Guid _currentUserId;

    private bool _dialogVisible;
    private string? _selectedDecision;
    private string? _dialogComments;
    private string? _dialogValidationError;
    private bool _submitting;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadDetail();
    }

    private async Task LoadDetail()
    {
        _loading = true;
        _error = null;
        _accessDenied = false;
        try
        {
            var result = await ChapterReviewApiClient.GetReviewDetailAsync(_currentUserId, ChapterId);
            if (result.AccessDenied)
            {
                _accessDenied = true;
                _detail = null;
            }
            else if (result.Succeeded)
            {
                _detail = result.Detail;
            }
            else
            {
                _error = result.ErrorMessage ?? "Failed to load chapter review.";
            }
        }
        catch (Exception ex)
        {
            _error = $"Failed to load chapter review: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private void GoBack() => Nav.NavigateTo("/editor/chapters");

    private void OpenDecisionDialog(string decisionCode)
    {
        _selectedDecision = decisionCode;
        _dialogComments = null;
        _dialogValidationError = null;
        _dialogVisible = true;
    }

    private void CloseDialog()
    {
        _dialogVisible = false;
        _selectedDecision = null;
        _dialogComments = null;
        _dialogValidationError = null;
    }

    private async Task ConfirmDecision()
    {
        if (_submitting) return;

        _dialogValidationError = null;

        var comments = _dialogComments?.Trim();

        if (_selectedDecision == "REVISION_REQUESTED" || _selectedDecision == "CANCELLED")
        {
            if (string.IsNullOrWhiteSpace(comments))
            {
                _dialogValidationError = "Comments are required for this decision.";
                return;
            }
        }

        _submitting = true;
        try
        {
            var request = new SubmitChapterEditorialReviewRequest(
                _selectedDecision!,
                !string.IsNullOrWhiteSpace(comments) ? comments : null,
                null);

            await ChapterReviewApiClient.SubmitReviewDecisionAsync(
                _currentUserId, ChapterId, request);

            CloseDialog();

            var decisionLabel = _selectedDecision switch
            {
                "APPROVED" => "approved",
                "REVISION_REQUESTED" => "returned for revision",
                "CANCELLED" => "cancelled",
                _ => "updated"
            };

            Snackbar.Add($"Chapter has been {decisionLabel}.", Severity.Success);

            await LoadDetail();
        }
        catch (Exception ex)
        {
            CloseDialog();
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "UNDER_REVIEW" => Color.Warning,
        "REVISION_REQUESTED" => Color.Error,
        "ON_HOLD" => Color.Info,
        "APPROVED" => Color.Success,
        "SCHEDULED" => Color.Tertiary,
        "CANCELLED" => Color.Dark,
        _ => Color.Default
    };

    private static Color GetDecisionColor(string? decision) => decision switch
    {
        "APPROVED" => Color.Success,
        "REVISION_REQUESTED" => Color.Warning,
        "CANCELLED" => Color.Error,
        _ => Color.Default
    };

    private static string GetDecisionButtonLabel(string? decision) => decision switch
    {
        "APPROVED" => "Approve Chapter",
        "REVISION_REQUESTED" => "Request Revision",
        "CANCELLED" => "Cancel Chapter",
        _ => "Confirm"
    };
}
