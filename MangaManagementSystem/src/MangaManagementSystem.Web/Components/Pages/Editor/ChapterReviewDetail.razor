@page "/editor/chapters/{ChapterId:long}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                <div>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Chapter Review</MudText>
                    <MudText Typo="Typo.body1" Class="mf-muted">Crimson Moon Academy - Ch. 45 "The Shadow Rises"</MudText>
                </div>
                <MudChip T="string" Color="Color.Warning" Size="Size.Medium">UNDER_REVIEW</MudChip>
            </MudStack>
        </div>

        <MudGrid>
            <!-- Page Preview Area -->
            <MudItem xs="12" md="8">
                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Page @_currentPage of @_totalPages</MudText>
                        <MudStack Row="true" Spacing="2">
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(_currentPage <= 1)" OnClick="PrevPage">Previous</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(_currentPage >= _totalPages)" OnClick="NextPage">Next</MudButton>
                        </MudStack>
                    </MudStack>

                    <!-- Canvas placeholder for page display -->
                    <div class="mf-canvas" style="min-height:520px">
                        <MudStack AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="mdi-image-outline" Size="Size.Large" Color="Color.Secondary" />
                            <MudText Typo="Typo.h6" Class="mf-muted">Page @_currentPage Preview</MudText>
                            <MudText Class="mf-muted">Chapter page version image will render here via FileResource</MudText>
                        </MudStack>
                    </div>

                    <!-- Page navigation thumbnails -->
                    <MudStack Row="true" Class="mt-4" Spacing="1" Wrap="Wrap.Wrap">
                        @for (int i = 1; i <= _totalPages; i++)
                        {
                            var pageNo = i;
                            <MudButton Variant="@(_currentPage == pageNo ? Variant.Filled : Variant.Outlined)"
                                       Color="@(_currentPage == pageNo ? Color.Primary : Color.Default)"
                                       Size="Size.Small"
                                       OnClick="@(() => GoToPage(pageNo))">
                                @pageNo
                            </MudButton>
                        }
                    </MudStack>
                </MudPaper>

                <!-- Annotations for current page -->
                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Page Annotations</MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddAnnotation">Add Annotation</MudButton>
                    </MudStack>

                    @if (!_annotations.Any())
                    {
                        <MudText Class="mf-muted">No annotations for this page yet.</MudText>
                    }
                    else
                    {
                        <MudList T="AnnotationRow">
                            @foreach (var ann in _annotations)
                            {
                                <MudListItem T="AnnotationRow" Value="@ann">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <div>
                                            <MudChip T="string" Color="Color.Secondary" Size="Size.Small">@ann.IssueType</MudChip>
                                            <MudText>@ann.Text</MudText>
                                            <MudText Typo="Typo.caption" Class="mf-muted">By @ann.Author - @ann.CreatedAt.ToString("MMM d, HH:mm")</MudText>
                                        </div>
                                        @if (!ann.IsResolved)
                                        {
                                            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Success" OnClick="@(() => ResolveAnnotation(ann))">Resolve</MudButton>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Resolved</MudChip>
                                        }
                                    </MudStack>
                                </MudListItem>
                            }
                        </MudList>
                    }
                </MudPaper>
            </MudItem>

            <!-- Right panel - Editorial Decision -->
            <MudItem xs="12" md="4">
                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Chapter Info</MudText>
                    <MudText><strong>Series:</strong> Crimson Moon Academy</MudText>
                    <MudText><strong>Chapter:</strong> Ch. 45</MudText>
                    <MudText><strong>Title:</strong> The Shadow Rises</MudText>
                    <MudText><strong>Pages:</strong> @_totalPages</MudText>
                    <MudText><strong>Submitted:</strong> Jun 4, 2026</MudText>
                    <MudText><strong>Creator:</strong> Ken Sato</MudText>
                </MudPaper>

                <MudPaper Class="pa-5 mf-card mb-5" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Editorial Decision</MudText>
                    <MudSelect T="string" Label="Decision" @bind-Value="_decision" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                        <MudSelectItem Value="@("APPROVED")">Approve</MudSelectItem>
                        <MudSelectItem Value="@("REVISION_REQUESTED")">Request Revision</MudSelectItem>
                        <MudSelectItem Value="@("CANCELLED")">Cancel Chapter</MudSelectItem>
                        <MudSelectItem Value="@("ON_HOLD")">Place On Hold</MudSelectItem>
                    </MudSelect>

                    <MudTextField Label="Comments" @bind-Value="_comments" Lines="5" Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />

                    @if (_decision != "APPROVED")
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-3">
                            Non-approval decisions require meaningful comments or markup.
                        </MudAlert>
                    }

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitDecision" Disabled="@(!CanSubmit)">
                        Submit Decision
                    </MudButton>
                </MudPaper>

                <MudPaper Class="pa-5 mf-card" Elevation="0">
                    <MudText Typo="Typo.h6" Class="font-weight-bold mb-3">Review History</MudText>
                    <MudTimeline>
                        <MudTimelineItem Color="Color.Info">Chapter submitted for review</MudTimelineItem>
                        <MudTimelineItem Color="Color.Warning">Editorial review in progress</MudTimelineItem>
                    </MudTimeline>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </div>
</EditorLayout>

@code {
    [Parameter] public long ChapterId { get; set; }

    private int _currentPage = 1;
    private int _totalPages = 24;
    private string _decision = "APPROVED";
    private string _comments = string.Empty;

    private bool CanSubmit => _decision == "APPROVED" || !string.IsNullOrWhiteSpace(_comments);

    private readonly List<AnnotationRow> _annotations = new()
    {
        new("DIALOGUE_ERROR", "Panel 3 speech bubble text overflows bounding box", "Editor Tanaka", DateTime.UtcNow.AddHours(-2), false),
        new("SHADING_ERROR", "Background gradient inconsistent with previous page", "Editor Tanaka", DateTime.UtcNow.AddHours(-1), false),
        new("CONTINUITY_ERROR", "Character outfit differs from previous chapter reference", "Editor Suzuki", DateTime.UtcNow.AddDays(-1), true)
    };

    private void PrevPage() { if (_currentPage > 1) _currentPage--; }
    private void NextPage() { if (_currentPage < _totalPages) _currentPage++; }
    private void GoToPage(int page) => _currentPage = page;

    private void AddAnnotation() => Snackbar.Add("Annotation creation dialog — connects to PageRegion workflow", Severity.Info);
    private void ResolveAnnotation(AnnotationRow ann) => Snackbar.Add($"Resolved: {ann.IssueType}", Severity.Success);

    private void SubmitDecision()
    {
        Snackbar.Add($"Decision submitted: {_decision}", _decision == "APPROVED" ? Severity.Success : Severity.Warning);
    }

    private record AnnotationRow(string IssueType, string Text, string Author, DateTime CreatedAt, bool IsResolved);
}
