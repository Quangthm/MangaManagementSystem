@page "/editor"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Editor
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorDashboardApiClient EditorDashboardApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Editor Dashboard</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review submissions and guide manga through editorial process</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Class="my-6" />
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="my-4">
                @_error
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="ml-3" OnClick="LoadDashboard" StartIcon="@Icons.Material.Filled.Refresh">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else if (_dashboard != null)
        {
            <!-- Stats Row -->
            <MudGrid Class="mb-6">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_dashboard.PendingProposalCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Pending Proposals</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" Class="mt-2" OnClick="@(() => Nav.NavigateTo("/editor/proposals"))">
                            Review Queue
                        </MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_dashboard.ChaptersUnderReviewCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Chapters Under Review</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" Class="mt-2" OnClick="@(() => Nav.NavigateTo("/editor/chapters"))">
                            Review Queue
                        </MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_dashboard.PendingAnnotationCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Pending Annotations</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" Class="mt-2" OnClick="@(() => Nav.NavigateTo("/editor/annotations"))">
                            View All
                        </MudButton>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_dashboard.SerializedSeriesCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Serialized Series</MudText>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" Class="mt-2" OnClick="@(() => Nav.NavigateTo("/ranking"))">
                            View Ranking
                        </MudButton>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <!-- Proposals Queue -->
            <MudPaper Class="pa-5 mf-card mb-6" Elevation="0">
                <div class="mf-section-header">
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Proposal Review Queue</MudText>
                    <MudChip T="string" Color="Color.Info" Size="Size.Small">@_dashboard.PendingProposalCount Active</MudChip>
                </div>

                @if (_dashboard.ProposalReviewQueue.Count == 0)
                {
                    <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                        <MudText Typo="Typo.h6">All Caught Up!</MudText>
                        <MudText Class="mf-muted">No pending proposals to review.</MudText>
                    </MudPaper>
                }
                else
                {
                    <MudTable Items="_dashboard.ProposalReviewQueue" Hover="true">
                        <HeaderContent>
                            <MudTh>Series</MudTh>
                            <MudTh>Version</MudTh>
                            <MudTh>Submitted By</MudTh>
                            <MudTh>Submitted</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Series">
                                <MudText Typo="Typo.body1" Class="font-weight-bold">@context.SeriesTitle</MudText>
                                <MudText Typo="Typo.caption" Class="mf-muted">@context.ProposalTitle</MudText>
                            </MudTd>
                            <MudTd DataLabel="Version">v@context.ProposalVersionNo</MudTd>
                            <MudTd DataLabel="Submitted By">@context.SubmittedByDisplayName</MudTd>
                            <MudTd DataLabel="Submitted">@context.SubmittedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</MudTd>
                            <MudTd DataLabel="Status"><MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.StatusCode.Replace("_", " ")</MudChip></MudTd>
                            <MudTd DataLabel="Actions">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenProposal(context.SeriesProposalId))">
                                    Review
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

            <!-- Recent Series -->
            <MudPaper Class="pa-5 mf-card" Elevation="0">
                <div class="mf-section-header">
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Recent Series Activity</MudText>
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="@(() => Nav.NavigateTo("/editor/series"))">
                        View All
                    </MudButton>
                </div>

                @if (_dashboard.RecentSeriesActivity.Count == 0)
                {
                    <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Outlined.Inbox" Size="Size.Large" Class="mb-3 mf-muted" />
                        <MudText Typo="Typo.h6">No Recent Activity</MudText>
                        <MudText Class="mf-muted">There are no series to display yet.</MudText>
                    </MudPaper>
                }
                else
                {
                    <MudTable Items="_dashboard.RecentSeriesActivity" Hover="true">
                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Latest Chapter</MudTh>
                            <MudTh>Last Activity</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Title">
                                @if (!string.IsNullOrWhiteSpace(context.SeriesSlug))
                                {
                                    <MudLink Href="@($"/series/{context.SeriesSlug}")">@context.SeriesTitle</MudLink>
                                }
                                else
                                {
                                    <MudText>@context.SeriesTitle</MudText>
                                }
                            </MudTd>
                            <MudTd DataLabel="Status"><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode.Replace("_", " ")</MudChip></MudTd>
                            <MudTd DataLabel="Latest Chapter">@(string.IsNullOrWhiteSpace(context.LatestChapterLabel) ? "—" : context.LatestChapterLabel)</MudTd>
                            <MudTd DataLabel="Last Activity">@(context.LastActivityAtUtc.HasValue ? context.LastActivityAtUtc.Value.ToLocalTime().ToString("MMM d, HH:mm") : "—")</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        }
    </div>
</EditorLayout>

@code {
    private EditorDashboardDto? _dashboard;
    private bool _loading = true;
    private string? _error;
    private Guid _currentUserId;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthState != null)
        {
            var authState = await AuthState;
            var idClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadDashboard();
    }

    private async Task LoadDashboard()
    {
        _loading = true;
        _error = null;
        try
        {
            _dashboard = await EditorDashboardApiClient.GetDashboardAsync(_currentUserId);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load dashboard: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "SERIALIZED" => Color.Success,
        "HIATUS" => Color.Warning,
        "CANCELLED" => Color.Error,
        "COMPLETED" => Color.Info,
        "UNDER_EDITORIAL_REVIEW" => Color.Warning,
        "UNDER_BOARD_REVIEW" => Color.Info,
        "PROPOSAL_DRAFT" => Color.Default,
        _ => Color.Default
    };

    private void OpenProposal(Guid seriesProposalId)
    {
        Nav.NavigateTo($"/editor/proposals/{seriesProposalId}");
    }
}
