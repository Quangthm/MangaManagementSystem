@page "/editor/annotations"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Annotation Workspace</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Track page-region feedback, unresolved issues, and review evidence</MudText>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 mf-card text-center" Elevation="0"><MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_openCount</MudText><MudText Class="mf-muted">Open</MudText></MudPaper></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 mf-card text-center" Elevation="0"><MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_resolvedCount</MudText><MudText Class="mf-muted">Resolved</MudText></MudPaper></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 mf-card text-center" Elevation="0"><MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_pagesWithIssues</MudText><MudText Class="mf-muted">Pages With Issues</MudText></MudPaper></MudItem>
            <MudItem xs="12" sm="6" md="3"><MudPaper Class="pa-4 mf-card text-center" Elevation="0"><MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_criticalCount</MudText><MudText Class="mf-muted">Critical</MudText></MudPaper></MudItem>
        </MudGrid>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6" Class="font-weight-bold">Editorial Annotations</MudText>
                <MudSelect T="string" Label="Issue Type" @bind-Value="_issueFilter" Variant="Variant.Outlined" Style="max-width:220px">
                    <MudSelectItem Value="@("all")">All Issues</MudSelectItem>
                    <MudSelectItem Value="@("DIALOGUE_ERROR")">Dialogue</MudSelectItem>
                    <MudSelectItem Value="@("SHADING_ERROR")">Shading</MudSelectItem>
                    <MudSelectItem Value="@("CONTINUITY_ERROR")">Continuity</MudSelectItem>
                    <MudSelectItem Value="@("PANEL_ORDER_ERROR")">Panel Order</MudSelectItem>
                </MudSelect>
            </MudStack>

            <MudTable Items="FilteredAnnotations" Hover="true" Dense="true">
                <HeaderContent>
                    <MudTh>Series</MudTh>
                    <MudTh>Chapter/Page</MudTh>
                    <MudTh>Region</MudTh>
                    <MudTh>Issue</MudTh>
                    <MudTh>Text</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.Series</MudTd>
                    <MudTd>@context.ChapterPage</MudTd>
                    <MudTd><MudChip T="string" Color="Color.Info" Size="Size.Small">@context.RegionType</MudChip></MudTd>
                    <MudTd>@context.IssueType</MudTd>
                    <MudTd>@context.Text</MudTd>
                    <MudTd>
                        @if (context.IsResolved)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small">Resolved</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small">Open</MudChip>
                        }
                    </MudTd>
                    <MudTd>
                        <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo($"/editor/chapters/{context.ChapterId}?page={context.PageNumber}"))">Open Page</MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </div>
</EditorLayout>

@code {
    private int _openCount = 8;
    private int _resolvedCount = 14;
    private int _pagesWithIssues = 6;
    private int _criticalCount = 2;
    private string _issueFilter = "all";

    private readonly List<AnnotationRow> _annotations = new()
    {
        new(101, 3,  "Crimson Moon Academy", "Ch.45 / Pg.03", "SPEECH_BUBBLE", "DIALOGUE_ERROR",   "Dialogue text exceeds bubble area",               false),
        new(101, 7,  "Crimson Moon Academy", "Ch.45 / Pg.07", "BACKGROUND",    "SHADING_ERROR",    "Background shading breaks continuity",            false),
        new(102, 12, "Neon Samurai Path",    "Ch.19 / Pg.12", "PANEL",         "PANEL_ORDER_ERROR","Panel read order is ambiguous",                   false),
        new(103, 2,  "Lunar Eclipse Academy","Ch.13 / Pg.02", "CHARACTER",     "CONTINUITY_ERROR", "Character outfit differs from previous page",     true)
    };

    private IEnumerable<AnnotationRow> FilteredAnnotations =>
        string.IsNullOrEmpty(_issueFilter) || _issueFilter == "all"
            ? _annotations
            : _annotations.Where(a => a.IssueType == _issueFilter);

    private record AnnotationRow(long ChapterId, int PageNumber, string Series, string ChapterPage, string RegionType, string IssueType, string Text, bool IsResolved);
}
