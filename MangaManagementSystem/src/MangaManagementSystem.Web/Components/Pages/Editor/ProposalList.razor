@page "/editor/proposals"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@using MangaManagementSystem.Web.Components.Shared
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorProposalApiClient EditorProposalApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review Queue</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review submitted proposals and make editorial decisions</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error">Failed to load proposals: @_error</MudAlert>
        }
        else if (_proposals == null || !_proposals.Any())
        {
            <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                <MudText Typo="Typo.h6">All Caught Up!</MudText>
                <MudText Class="mf-muted">No proposals match your filter.</MudText>
            </MudPaper>
        }
        else
        {
            <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
                <MudCheckBox T="bool" @bind-Value="_mySeriesOnly" Label="My Series Only"
                             Color="Color.Primary" Dense="true"
                             Style="font-size: 0.82rem;" />
                <MudText Typo="Typo.caption" Class="mf-muted">
                    Show only proposals for series where you are an active contributor
                </MudText>
            </div>

            <SeriesProposalTable Items="@GetDisplayItems()"
                                 DefaultStatusFilterCode="UNDER_EDITORIAL_REVIEW"
                                 ShowGenreFilter="true"
                                 ShowTagFilter="true"
                                 ShowSubmitterColumn="true"
                                 ShowReviewerColumns="true"
                                 AvailableGenres="_availableGenres"
                                 AvailableTags="_availableTags"
                                 RowClicked="OnRowClicked" />
        }
    </div>
</EditorLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private bool _mySeriesOnly;
    private IReadOnlyList<ProposalQueueItemDto>? _proposals;
    private IReadOnlyList<SeriesProposalListItemModel> _mappedItems = Array.Empty<SeriesProposalListItemModel>();
    private IReadOnlyList<GenreDto> _availableGenres = Array.Empty<GenreDto>();
    private IReadOnlyList<TagDto> _availableTags = Array.Empty<TagDto>();
    protected override async Task OnInitializedAsync()
    {
        await LoadProposals();
    }

    private IReadOnlyList<SeriesProposalListItemModel> GetDisplayItems()
    {
        if (!_mySeriesOnly)
            return _mappedItems;

        return _mappedItems
            .Where(p => p.CurrentActorIsActiveContributor)
            .ToList()
            .AsReadOnly();
    }

    private async Task LoadProposals()
    {
        _loading = true;
        _error = null;
        try
        {
            _proposals = await EditorProposalApiClient.GetQueueAsync(statusCode: null);
            _mappedItems = _proposals.Select(MapToListItem).ToList().AsReadOnly();
            _availableGenres = _proposals
                .SelectMany(p => p.Genres)
                .DistinctBy(g => g.GenreId)
                .OrderBy(g => g.GenreName)
                .ToList()
                .AsReadOnly();
            _availableTags = _proposals
                .SelectMany(p => p.Tags)
                .DistinctBy(t => t.TagId)
                .OrderBy(t => t.TagName)
                .ToList()
                .AsReadOnly();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static SeriesProposalListItemModel MapToListItem(ProposalQueueItemDto p) => new(
        SeriesProposalId: p.SeriesProposalId,
        SeriesId: p.SeriesId,
        SeriesTitle: p.SeriesTitle,
        ProposalTitle: p.ProposalTitle,
        ProposalVersionNo: p.ProposalVersionNo,
        SubmittedByDisplayName: p.SubmitterDisplayName,
        SubmittedAtUtc: p.SubmittedAtUtc,
        ReviewerDisplayName: p.ReviewerDisplayName,
        ReviewedAtUtc: p.ReviewedAtUtc,
        StatusCode: p.StatusCode,
        HasMarkup: p.MarkupFileId.HasValue,
        Genres: p.Genres,
        Tags: p.Tags,
        CurrentActorIsActiveContributor: p.CurrentEditorIsActiveContributor
    );

    private void OnRowClicked(Guid seriesProposalId)
    {
        Nav.NavigateTo($"/editor/proposals/{seriesProposalId}");
    }
}
