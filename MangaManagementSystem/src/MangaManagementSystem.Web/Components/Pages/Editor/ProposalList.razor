@page "/editor/proposals"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorProposalApiClient EditorProposalApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review Queue</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review submitted proposals and make editorial decisions</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <div class="d-flex align-center mb-4">
                <MudSelect T="string" Label="Filter by Status" Value="@_statusFilter" ValueChanged="OnFilterChanged" Variant="Variant.Outlined" Class="max-w-xs">
                    <MudSelectItem Value="@((string?)null)">All Proposals</MudSelectItem>
                    <MudSelectItem Value="@("UNDER_EDITORIAL_REVIEW")">Under Editorial Review</MudSelectItem>
                    <MudSelectItem Value="@("UNDER_BOARD_REVIEW")">Under Board Review</MudSelectItem>
                    <MudSelectItem Value="@("REVISION_REQUESTED")">Revision Requested</MudSelectItem>
                    <MudSelectItem Value="@("CANCELLED")">Cancelled</MudSelectItem>
                    <MudSelectItem Value="@("APPROVED")">Approved</MudSelectItem>
                </MudSelect>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadProposals" StartIcon="@Icons.Material.Filled.Refresh">Refresh</MudButton>
            </div>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_error != null)
            {
                <MudAlert Severity="Severity.Error">Failed to load proposals: @_error</MudAlert>
            }
            else if (_proposals == null || !_proposals.Any())
            {
                <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                    <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                    <MudText Typo="Typo.h6">All Caught Up!</MudText>
                    <MudText Class="mf-muted">No proposals match your filter.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_proposals" Hover="true">
                    <HeaderContent>
                        <MudTh>Series</MudTh>
                        <MudTh>Version</MudTh>
                        <MudTh>Submitted By</MudTh>
                        <MudTh>Submitted</MudTh>
                        <MudTh>Reviewer</MudTh>
                        <MudTh>Reviewed</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Series">
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@context.SeriesTitle</MudText>
                            <MudText Typo="Typo.caption" Class="mf-muted">@context.ProposalTitle</MudText>
                        </MudTd>
                        <MudTd DataLabel="Version">v@context.ProposalVersionNo</MudTd>
                        <MudTd DataLabel="Submitted By">@context.SubmitterDisplayName</MudTd>
                        <MudTd DataLabel="Submitted">@context.SubmittedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</MudTd>
                        <MudTd DataLabel="Reviewer">
                            @(string.IsNullOrWhiteSpace(context.ReviewerDisplayName) ? "—" : context.ReviewerDisplayName)
                        </MudTd>
                        <MudTd DataLabel="Reviewed">
                            @(context.ReviewedAtUtc.HasValue ? context.ReviewedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy") : "—")
                        </MudTd>
                        <MudTd DataLabel="Status">
                            <MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode.Replace("_", " ")</MudChip>
                        </MudTd>
                        <MudTd DataLabel="Actions">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenProposal(context.SeriesProposalId))">Review</MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </div>
</EditorLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private IReadOnlyList<ProposalQueueItemDto>? _proposals;
    private string? _statusFilter = "UNDER_EDITORIAL_REVIEW";
    private Guid _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadProposals();
    }

    private async Task OnFilterChanged(string? newStatus)
    {
        _statusFilter = newStatus;
        await LoadProposals();
    }

    private async Task LoadProposals()
    {
        _loading = true;
        _error = null;
        try
        {
            _proposals = await EditorProposalApiClient.GetQueueAsync(_currentUserId, _statusFilter);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "UNDER_EDITORIAL_REVIEW" => Color.Warning,
        "UNDER_BOARD_REVIEW" => Color.Info,
        "REVISION_REQUESTED" => Color.Error,
        "CANCELLED" => Color.Default,
        "APPROVED" => Color.Success,
        _ => Color.Default
    };

    private void OpenProposal(Guid seriesProposalId)
    {
        Nav.NavigateTo($"/editor/proposals/{seriesProposalId}");
    }
}
