@page "/editor/proposals"
@using Microsoft.AspNetCore.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@attribute [Authorize(Roles = "Tantou Editor")]
@inject MangaManagementSystem.Application.Interfaces.ISeriesProposalService ProposalService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Proposal Review Queue</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review submitted proposals and make editorial decisions</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <div class="d-flex align-center mb-4">
                <MudSelect T="string" Label="Filter by Status" Value="@_statusFilter" ValueChanged="OnFilterChanged" Variant="Variant.Outlined" Class="max-w-xs">
                    <MudSelectItem Value="@((string?)null)">All Proposals</MudSelectItem>
                    <MudSelectItem Value="@("UNDER_EDITORIAL_REVIEW")">Under Editorial Review</MudSelectItem>
                    <MudSelectItem Value="@("UNDER_BOARD_REVIEW")">Under Board Review</MudSelectItem>
                    <MudSelectItem Value="@("REVISION_REQUESTED")">Revision Requested</MudSelectItem>
                    <MudSelectItem Value="@("CANCELLED")">Cancelled</MudSelectItem>
                    <MudSelectItem Value="@("APPROVED")">Approved</MudSelectItem>
                </MudSelect>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadProposals" StartIcon="mdi-refresh">Refresh</MudButton>
            </div>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_error != null)
            {
                <MudAlert Severity="Severity.Error">Failed to load proposals: @_error</MudAlert>
            }
            else if (_proposals == null || !_proposals.Any())
            {
                <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                    <MudIcon Icon="mdi-check-circle-outline" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                    <MudText Typo="Typo.h6">All Caught Up!</MudText>
                    <MudText Class="mf-muted">No pending proposals match your filter.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_proposals" Hover="true">
                    <HeaderContent>
                        <MudTh>Series</MudTh>
                        <MudTh>Version</MudTh>
                        <MudTh>Submitted By</MudTh>
                        <MudTh>Submitted</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.body1" Class="font-weight-bold">@context.SeriesTitle</MudText>
                            <MudText Typo="Typo.caption" Class="mf-muted">@context.ProposalTitle</MudText>
                        </MudTd>
                        <MudTd>v@context.ProposalVersionNo</MudTd>
                        <MudTd>@context.SubmitterDisplayName</MudTd>
                        <MudTd>@context.SubmittedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</MudTd>
                        <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode.Replace("_", " ")</MudChip></MudTd>
                        <MudTd>
                            <MudStack Row="true" Spacing="2">
                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenProposal(context.SeriesId))">Review</MudButton>
                                <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => RejectProposal(context.SeriesProposalId))">Reject</MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </div>
</EditorLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private IEnumerable<ProposalQueueItemDto>? _proposals;
    private string? _statusFilter = "UNDER_EDITORIAL_REVIEW";

    protected override async Task OnInitializedAsync()
    {
        await LoadProposals();
    }

    private async Task OnFilterChanged(string? newStatus)
    {
        _statusFilter = newStatus;
        await LoadProposals();
    }

    private async Task LoadProposals()
    {
        _loading = true;
        _error = null;
        try
        {
            var filter = new ProposalQueueFilterDto(StatusCode: _statusFilter);
            _proposals = await ProposalService.GetEditorialQueueAsync(filter);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "UNDER_EDITORIAL_REVIEW" => Color.Warning,
        "UNDER_BOARD_REVIEW" => Color.Info,
        "REVISION_REQUESTED" => Color.Error,
        "CANCELLED" => Color.Default,
        "APPROVED" => Color.Success,
        _ => Color.Default
    };

    private void OpenProposal(Guid proposalId)
    {
        Nav.NavigateTo($"/editor/proposals/{proposalId}");
    }
    private void RejectProposal(Guid seriesProposalId)
    {
        Snackbar.Add($"Reject proposal {seriesProposalId} - implement rejection dialog", Severity.Warning);
    }
}
