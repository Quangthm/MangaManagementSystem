@page "/editor/series"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject MangaManagementSystem.Application.Interfaces.ISeriesService SeriesService
@inject NavigationManager Nav

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Series Review Library</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Read-only review context for Tantou Editors</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card mb-6" Elevation="0">
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField Label="Search Series" @bind-Value="SearchTerm" Variant="Variant.Outlined" FullWidth="true" Adornment="Adornment.Start" AdornmentIcon="mdi-magnify" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" Label="Status" @bind-Value="SelectedStatus" Variant="Variant.Outlined" FullWidth="true">
                        <MudSelectItem Value="@("all")">All Status</MudSelectItem>
                        <MudSelectItem Value="@("PROPOSAL_DRAFT")">Proposal Draft</MudSelectItem>
                        <MudSelectItem Value="@("UNDER_EDITORIAL_REVIEW")">Under Editorial Review</MudSelectItem>
                        <MudSelectItem Value="@("UNDER_BOARD_REVIEW")">Under Board Review</MudSelectItem>
                        <MudSelectItem Value="@("SERIALIZED")">Serialized</MudSelectItem>
                        <MudSelectItem Value="@("HIATUS")">Hiatus</MudSelectItem>
                        <MudSelectItem Value="@("CANCELLED")">Cancelled</MudSelectItem>
                        <MudSelectItem Value="@("COMPLETED")">Completed</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudSelect T="string" Label="Genre" @bind-Value="SelectedGenre" Variant="Variant.Outlined" FullWidth="true">
                        <MudSelectItem Value="@("all")">All Genres</MudSelectItem>
                        <MudSelectItem Value="@("Action")">Action</MudSelectItem>
                        <MudSelectItem Value="@("Drama")">Drama</MudSelectItem>
                        <MudSelectItem Value="@("Fantasy")">Fantasy</MudSelectItem>
                        <MudSelectItem Value="@("Romance")">Romance</MudSelectItem>
                        <MudSelectItem Value="@("Sci-Fi")">Sci-Fi</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_error != null)
            {
                <MudAlert Severity="Severity.Error">Failed to load series: @_error</MudAlert>
            }
            else if (_series == null || !_series.Any())
            {
                <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                    <MudIcon Icon="mdi-book-outline" Size="Size.Large" Color="Color.Secondary" Class="mb-3" />
                    <MudText Typo="Typo.h6">No Series Found</MudText>
                    <MudText Class="mf-muted">No series matches your search criteria.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_series" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Title</MudTh>
                        <MudTh>Code</MudTh>
                        <MudTh>Genre</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Chapters</MudTh>
                        <MudTh>Last Updated</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudLink Href="@($"/editor/series/{context.SeriesId}")">@context.Title</MudLink></MudTd>
                        <MudTd>@context.SeriesCode</MudTd>
                        <MudTd>@context.Genre</MudTd>
                        <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                        <MudTd>N/A</MudTd>
                        <MudTd>@(context.UpdatedAtUtc.HasValue ? context.UpdatedAtUtc.Value.ToLocalTime().ToString("MMM d, yyyy") : context.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy"))</MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => Nav.NavigateTo($"/editor/series/{context.SeriesId}"))">
                                Open
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </div>
</EditorLayout>

@code {
    private bool _loading = true;
    private string? _error;
    private string SearchTerm = "";
    private string SelectedStatus = "all";
    private string SelectedGenre = "all";
    private IEnumerable<MangaManagementSystem.Application.DTOs.Manga.SeriesDto>? _series;

    private Color GetStatusColor(string status) => status switch
    {
        "SERIALIZED" => Color.Success,
        "HIATUS" => Color.Warning,
        "CANCELLED" => Color.Error,
        "PROPOSAL_DRAFT" => Color.Info,
        "UNDER_EDITORIAL_REVIEW" => Color.Secondary,
        "UNDER_BOARD_REVIEW" => Color.Tertiary,
        _ => Color.Default
    };

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _series = await SeriesService.GetAllSeriesAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
