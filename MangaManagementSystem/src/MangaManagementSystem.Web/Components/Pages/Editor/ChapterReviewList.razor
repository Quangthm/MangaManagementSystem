@page "/editor/chapters"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Chapter Review Queue</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Review submitted chapters page by page and record editorial decisions</MudText>
        </div>

        <MudGrid Class="mb-6">
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_underReviewCount</MudText>
                    <MudText Typo="Typo.body2" Class="mf-muted mt-1">Under Review</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_approvedCount</MudText>
                    <MudText Typo="Typo.body2" Class="mf-muted mt-1">Approved This Week</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_revisionCount</MudText>
                    <MudText Typo="Typo.body2" Class="mf-muted mt-1">Revision Requested</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                    <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_onHoldCount</MudText>
                    <MudText Typo="Typo.body2" Class="mf-muted mt-1">On Hold</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                <MudText Typo="Typo.h6" Class="font-weight-bold">Chapters Awaiting Review</MudText>
                <MudSelect T="string" Label="Filter" @bind-Value="_statusFilter" Variant="Variant.Outlined" Style="max-width:200px">
                    <MudSelectItem Value="@("all")">All</MudSelectItem>
                    <MudSelectItem Value="@("UNDER_REVIEW")">Under Review</MudSelectItem>
                    <MudSelectItem Value="@("REVISION_REQUESTED")">Revision Requested</MudSelectItem>
                    <MudSelectItem Value="@("ON_HOLD")">On Hold</MudSelectItem>
                </MudSelect>
            </MudStack>

            @if (!_chapters.Any())
            {
                <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                    <MudIcon Icon="mdi-check-circle-outline" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                    <MudText Typo="Typo.h6">No Chapters Pending Review</MudText>
                    <MudText Class="mf-muted">All submitted chapters have been reviewed.</MudText>
                </MudPaper>
            }
            else
            {
                <MudTable Items="_chapters" Hover="true" Dense="true">
                    <HeaderContent>
                        <MudTh>Series</MudTh>
                        <MudTh>Chapter</MudTh>
                        <MudTh>Title</MudTh>
                        <MudTh>Pages</MudTh>
                        <MudTh>Submitted</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Actions</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>@context.SeriesTitle</MudTd>
                        <MudTd>@context.ChapterLabel</MudTd>
                        <MudTd>@(context.ChapterTitle ?? "—")</MudTd>
                        <MudTd>@context.PageCount pages</MudTd>
                        <MudTd>@context.SubmittedAt.ToString("MMM d, yyyy")</MudTd>
                        <MudTd><MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode</MudChip></MudTd>
                        <MudTd>
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="@(() => OpenChapter(context.ChapterId))">
                                Review
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </div>
</EditorLayout>

@code {
    private int _underReviewCount = 5;
    private int _approvedCount = 12;
    private int _revisionCount = 2;
    private int _onHoldCount = 1;
    private string _statusFilter = "all";

    private readonly List<ChapterRow> _chapters = new()
    {
        new(101, "Crimson Moon Academy", "Ch. 45", "The Shadow Rises", 24, DateTime.UtcNow.AddDays(-1), "UNDER_REVIEW"),
        new(102, "Crimson Moon Academy", "Ch. 44", "Before the Dawn", 22, DateTime.UtcNow.AddDays(-3), "UNDER_REVIEW"),
        new(103, "Neon Samurai Path", "Ch. 19", "Blade of Light", 20, DateTime.UtcNow.AddDays(-2), "UNDER_REVIEW"),
        new(104, "Lunar Eclipse Academy", "Ch. 13", "New Moon Festival", 18, DateTime.UtcNow.AddDays(-5), "REVISION_REQUESTED"),
        new(105, "Shadow Garden Tales", "Ch. 9", null, 16, DateTime.UtcNow.AddDays(-7), "ON_HOLD")
    };

    private Color GetStatusColor(string status) => status switch
    {
        "UNDER_REVIEW" => Color.Warning,
        "REVISION_REQUESTED" => Color.Error,
        "ON_HOLD" => Color.Info,
        "APPROVED" => Color.Success,
        _ => Color.Default
    };

    private void OpenChapter(long chapterId)
    {
        Nav.NavigateTo($"/editor/chapters/{chapterId}");
    }

    private record ChapterRow(long ChapterId, string SeriesTitle, string ChapterLabel, string? ChapterTitle, int PageCount, DateTime SubmittedAt, string StatusCode);
}
