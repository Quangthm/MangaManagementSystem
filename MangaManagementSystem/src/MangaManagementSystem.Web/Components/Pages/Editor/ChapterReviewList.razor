@page "/editor/chapters"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using MangaManagementSystem.Application.DTOs.Editor
@using MangaManagementSystem.Web.Services.Api
@attribute [Authorize(Roles = "Tantou Editor")]
@inject IEditorChapterReviewApiClient ChapterReviewApiClient
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Chapter Review Queue</MudText>
            <MudText Typo="Typo.body1" Class="mf-muted">Track all chapters for your responsible series and record editorial decisions</MudText>
        </div>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Class="my-6" />
        }
        else if (_error != null)
        {
            <MudAlert Severity="Severity.Error" Class="my-4">
                @_error
                <MudButton Variant="Variant.Text" Color="Color.Inherit" Class="ml-3" OnClick="LoadQueue" StartIcon="@Icons.Material.Filled.Refresh">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else if (_queue != null)
        {
            <MudGrid Class="mb-6">
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_queue.UnderReviewCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Under Review</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_queue.ApprovedThisWeekCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Approved This Week</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_queue.RevisionRequestedCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">Revision Requested</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 mf-card text-center" Elevation="0">
                        <MudText Typo="Typo.h4" Class="font-weight-bold mf-gradient-text">@_queue.OnHoldCount</MudText>
                        <MudText Typo="Typo.body2" Class="mf-muted mt-1">On Hold</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            <MudPaper Class="pa-5 mf-card" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                    <MudText Typo="Typo.h6" Class="font-weight-bold">Chapters</MudText>
                    <div class="d-flex align-center gap-2">
                        <MudTextField @bind-Value="_searchText" Label="Search series, chapter, or title"
                                      Immediate="true" Variant="Variant.Outlined"
                                      Style="min-width: 300px; max-width: 400px;" />
                        <MudSelect T="string" Label="Filter" Value="@_statusFilter" ValueChanged="OnFilterChanged" Variant="Variant.Outlined" Style="width: 220px; min-width: 220px; max-width: 220px;">
                            <MudSelectItem Value="@("all")">All</MudSelectItem>
                            <MudSelectItem Value="@("DRAFT")">Draft</MudSelectItem>
                            <MudSelectItem Value="@("UNDER_REVIEW")">Under Review</MudSelectItem>
                            <MudSelectItem Value="@("REVISION_REQUESTED")">Revision Requested</MudSelectItem>
                            <MudSelectItem Value="@("APPROVED")">Approved</MudSelectItem>
                            <MudSelectItem Value="@("SCHEDULED")">Scheduled</MudSelectItem>
                            <MudSelectItem Value="@("RELEASED")">Released</MudSelectItem>
                            <MudSelectItem Value="@("ON_HOLD")">On Hold</MudSelectItem>
                            <MudSelectItem Value="@("CANCELLED")">Cancelled</MudSelectItem>
                        </MudSelect>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadQueue" StartIcon="@Icons.Material.Filled.Refresh" Size="Size.Small">Refresh</MudButton>
                    </div>
                </MudStack>

                @if (_queue.Chapters.Count == 0)
                {
                    <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                        <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                        <MudText Typo="Typo.h6">No Chapters Found</MudText>
                        <MudText Class="mf-muted">No chapters match the current filter for your responsible series.</MudText>
                    </MudPaper>
                }
                else
                {
                    var grouped = GetGroupedChapters();
                    @if (grouped.Count == 0)
                    {
                        <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Outlined.CheckCircle" Size="Size.Large" Color="Color.Success" Class="mb-3" />
                            <MudText Typo="Typo.h6">No Chapters Found</MudText>
                            <MudText Class="mf-muted">No chapters match the current filter for your responsible series.</MudText>
                        </MudPaper>
                    }
                    else
                    {
                        @foreach (var group in grouped)
                        {
                            <div class="mb-4">
                                <MudText Typo="Typo.h6" Class="font-weight-bold mb-2" Color="Color.Primary">
                                    Series: @group.SeriesTitle
                                </MudText>
                                <MudTable Items="@group.Chapters" Hover="true" Dense="true" RowsPerPage="15">
                                    <HeaderContent>
                                        <MudTh>Chapter</MudTh>
                                        <MudTh>Title</MudTh>
                                        <MudTh>Pages</MudTh>
                                        <MudTh>Created</MudTh>
                                        <MudTh>Status</MudTh>
                                        <MudTh>Actions</MudTh>
                                    </HeaderContent>
                                    <RowTemplate>
                                        <MudTd DataLabel="Chapter">@context.ChapterNumberLabel</MudTd>
                                        <MudTd DataLabel="Title">@(context.ChapterTitle ?? "—")</MudTd>
                                        <MudTd DataLabel="Pages">@context.PageCount pages</MudTd>
                                        <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("MMM d, yyyy")</MudTd>
                                        <MudTd DataLabel="Status">
                                            <MudChip T="string" Color="@GetStatusColor(context.StatusCode)" Size="Size.Small">@context.StatusCode.Replace("_", " ")</MudChip>
                                        </MudTd>
                                        <MudTd DataLabel="Actions">
                                            <MudStack Row="true" Spacing="2">
                                                <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary"
                                                           OnClick="@(() => Nav.NavigateTo($"/editor/chapters/{context.ChapterId}"))">
                                                    View Chapter
                                                </MudButton>
                                                @if (!string.IsNullOrWhiteSpace(context.WorkspaceUrl))
                                                {
                                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary"
                                                               OnClick="@(() => Nav.NavigateTo(context.WorkspaceUrl))">
                                                        Workspace
                                                    </MudButton>
                                                }
                                            </MudStack>
                                        </MudTd>
                                    </RowTemplate>
                                </MudTable>
                            </div>
                        }
                    }
                }
            </MudPaper>
        }
    </div>
</EditorLayout>

@code {
    private EditorChapterReviewQueueDto? _queue;
    private bool _loading = true;
    private string? _error;
    private string _statusFilter = "all";
    private string _searchText = "";
    private Guid _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
            {
                _currentUserId = userId;
            }
        }

        await LoadQueue();
    }

    private async Task OnFilterChanged(string newStatus)
    {
        _statusFilter = newStatus;
        await LoadQueue();
    }

    private async Task LoadQueue()
    {
        _loading = true;
        _error = null;
        try
        {
            _queue = await ChapterReviewApiClient.GetReviewQueueAsync(_currentUserId, _statusFilter);
        }
        catch (Exception ex)
        {
            _error = $"Failed to load chapter review queue: {ex.Message}";
        }
        finally
        {
            _loading = false;
        }
    }

    private Color GetStatusColor(string status) => status switch
    {
        "DRAFT" => Color.Default,
        "UNDER_REVIEW" => Color.Warning,
        "REVISION_REQUESTED" => Color.Error,
        "APPROVED" => Color.Success,
        "SCHEDULED" => Color.Tertiary,
        "RELEASED" => Color.Info,
        "ON_HOLD" => Color.Info,
        "CANCELLED" => Color.Dark,
        _ => Color.Default
    };

    private record ChapterGroup(string SeriesTitle, List<EditorChapterReviewQueueItemDto> Chapters);

    private List<ChapterGroup> GetGroupedChapters()
    {
        if (_queue?.Chapters == null) return new List<ChapterGroup>();

        var filtered = _queue.Chapters.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_searchText))
        {
            filtered = filtered.Where(c =>
                c.SeriesTitle.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                c.ChapterNumberLabel.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                (c.ChapterTitle != null && c.ChapterTitle.Contains(_searchText, StringComparison.OrdinalIgnoreCase)));
        }

        return filtered
            .GroupBy(c => new { c.SeriesId, c.SeriesTitle })
            .OrderBy(g => g.Key.SeriesTitle)
            .Select(g => new ChapterGroup(g.Key.SeriesTitle, g.OrderBy(c => c.ChapterNumberLabel).ToList()))
            .ToList();
    }
}
