@page "/editor/series/{SeriesId:long}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject ISeriesService SeriesService

<EditorLayout>
    <div class="mf-page">
        <div class="mf-page-header">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudButton Variant="Variant.Text" Color="Color.Default" StartIcon="mdi-arrow-left"
                           OnClick="@(() => Nav.NavigateTo("/editor/series"))">Back</MudButton>
                <MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Series Details</MudText>
            </MudStack>
            <MudText Typo="Typo.body1" Class="mf-muted">Series review and management details</MudText>
        </div>

        <MudPaper Class="pa-5 mf-card" Elevation="0">
            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" />
            }
            else if (_error != null)
            {
                <MudAlert Severity="Severity.Error">Failed to load series: @_error</MudAlert>
            }
            else if (_series == null)
            {
                <MudPaper Class="pa-8 text-center mf-card" Elevation="0">
                    <MudIcon Icon="mdi-book-open-page-variant" Size="Size.Large" Color="Color.Error" Class="mb-3" />
                    <MudText Typo="Typo.h6">Series not found</MudText>
                    <MudText Class="mf-muted mt-1">The requested series could not be loaded.</MudText>
                </MudPaper>
            }
            else
            {
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.h5" Class="font-weight-bold mb-2">@_series.Title</MudText>
                            <MudText Class="mf-muted"><strong>Series Code:</strong> @_series.SeriesCode</MudText>
                            <MudText Class="mf-muted">
                                <strong>Status:</strong>
                                <MudChip T="string" Color="@GetStatusColor(_series.StatusCode)" Size="Size.Small" Class="ml-1">@_series.StatusCode</MudChip>
                            </MudText>
                            <MudText Class="mf-muted"><strong>Genre:</strong> @_series.Genre</MudText>
                            <MudText Class="mf-muted"><strong>Language:</strong> @_series.ContentLanguageCode</MudText>
                            <MudText Class="mf-muted"><strong>Created:</strong> @_series.CreatedAtUtc.ToString("g")</MudText>
                            @if (!string.IsNullOrWhiteSpace(_series.PublicationFrequencyCode))
                            {
                                <MudText Class="mf-muted"><strong>Frequency:</strong> @_series.PublicationFrequencyCode</MudText>
                            }
                        </MudStack>
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-2">Synopsis</MudText>
                        <MudText Class="mf-muted">@_series.Synopsis</MudText>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="my-4" />

                <MudStack Row="true" Spacing="2">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="@(() => Nav.NavigateTo($"/editor/proposals/{SeriesId}"))">
                        Review Proposal
                    </MudButton>
                </MudStack>
            }
        </MudPaper>
    </div>
</EditorLayout>

@code {
    [Parameter] public long SeriesId { get; set; }

    private bool _loading = true;
    private string? _error;
    private SeriesDto? _series;

    private Color GetStatusColor(string status) => status switch
    {
        "SERIALIZED"              => Color.Success,
        "HIATUS"                  => Color.Warning,
        "CANCELLED"               => Color.Error,
        "PROPOSAL_DRAFT"          => Color.Info,
        "UNDER_EDITORIAL_REVIEW"  => Color.Warning,
        "UNDER_BOARD_REVIEW"      => Color.Info,
        _                         => Color.Default
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadSeriesAsync();
    }

    private async Task LoadSeriesAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            _series = await SeriesService.GetSeriesByIdAsync(SeriesId);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
