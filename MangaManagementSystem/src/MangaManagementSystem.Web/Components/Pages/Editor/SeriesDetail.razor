@page "/editor/series/{SeriesId:int}"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Tantou Editor")]
@inject NavigationManager Nav
@inject MangaManagementSystem.Application.Interfaces.ISeriesService SeriesService
@inject MangaManagementSystem.Application.Interfaces.ISeriesProposalService ProposalService
@inject MangaManagementSystem.Application.Interfaces.IChapterService ChapterService
@inject MangaManagementSystem.Application.Interfaces.ISeriesContributorService ContributorService
@inject MangaManagementSystem.Application.Interfaces.ISeriesRankingSnapshotService RankingService
@inject MangaManagementSystem.Application.Interfaces.IFileResourceService FileResourceService

<PageTitle>Series Review - Editor</PageTitle>

<EditorLayout>
	<div class="mf-page">
		<div class="mf-page-header">
			<MudText Typo="Typo.h3" Class="font-weight-bold mb-1">Series Review</MudText>
			<MudText Typo="Typo.body1" Class="mf-muted">Read-only review context for Tantou Editor</MudText>
		</div>

		<MudBreadcrumbs Class="mb-4">
			<MudBreadcrumbItem Href="/editor">Editor Dashboard</MudBreadcrumbItem>
			<MudBreadcrumbItem Disabled="true">Series Review</MudBreadcrumbItem>
		</MudBreadcrumbs>

		<MudPaper Class="pa-4 mf-card mb-4">
		@if (_loading)
		{
			<MudProgressLinear Indeterminate="true" />
		}
		else if (!string.IsNullOrWhiteSpace(_error))
		{
			<MudAlert Severity="Severity.Error">@_error</MudAlert>
		}
		else
		{
			<MudTabs>
				<MudTabPanel Text="Overview">
					<MudText Typo="Typo.h6">Overview</MudText>
					<MudGrid Class="mt-3">
						<MudItem xs="12" md="4">
							<MudPaper Class="pa-4">
								<MudText Typo="Typo.subtitle1">Title</MudText>
								<MudText Typo="Typo.h6" Class="font-weight-bold">@(_seriesDto?.Title ?? "—")</MudText>
							</MudPaper>
						</MudItem>
						<MudItem xs="12" md="4">
							<MudPaper Class="pa-4">
								<MudText Typo="Typo.subtitle1">Code / Slug</MudText>
							<MudText Typo="Typo.body1">@(_seriesDto?.Slug ?? "—")</MudText>
							</MudPaper>
						</MudItem>
						<MudItem xs="12" md="4">
							<MudPaper Class="pa-4">
								<MudText Typo="Typo.subtitle1">Status</MudText>
						@if (!string.IsNullOrWhiteSpace(_seriesDto?.StatusCode))
						{
							<MudChip T="string">@_seriesDto.StatusCode</MudChip>
						}
						else
						{
							<MudText class="mf-muted">Unknown</MudText>
						}
							</MudPaper>
						</MudItem>
						<MudItem xs="12" md="4" Class="mt-3">
							<MudPaper Class="pa-4">
								<MudText Typo="Typo.subtitle1">Genre</MudText>
						<MudText Typo="Typo.body1">@(_seriesDto?.Genre ?? "No genre specified")</MudText>
							</MudPaper>
						</MudItem>
						<MudItem xs="12" md="4" Class="mt-3">
							<MudPaper Class="pa-4">
								<MudText Typo="Typo.subtitle1">Primary Language</MudText>
						<MudText Typo="Typo.body1">@(_seriesDto?.ContentLanguageCode ?? "—")</MudText>
							</MudPaper>
						</MudItem>
				<MudItem xs="12" md="12" Class="mt-3">
					<MudPaper Class="pa-4">
						<MudText Typo="Typo.subtitle1">Synopsis</MudText>
						<MudText Typo="Typo.body2" Class="mf-muted">@(_seriesDto?.Synopsis ?? "No synopsis available")</MudText>
					</MudPaper>
				</MudItem>
					</MudGrid>
				</MudTabPanel>
			<MudTabPanel Text="Proposal">
				<MudText Typo="Typo.h6">Proposal</MudText>
				@if (_latestProposal is null)
				{
					<MudPaper Class="pa-6 text-center mf-card"><MudText>No proposal submitted yet</MudText></MudPaper>
				}
				else
				{
					<MudPaper Class="pa-4 mf-card">
						<MudText Typo="Typo.subtitle2">@_latestProposal.ProposalTitle</MudText>
						<MudText class="mf-muted">Status: @_latestProposal.StatusCode</MudText>
						<MudText class="mf-muted">Submitted: @_latestProposal.SubmittedAtUtc.ToLocalTime().ToString("g")</MudText>
						@if (_latestProposal.ProposalFileId > 0)
						{
							<MudButton Variant="Variant.Outlined" Href="@($"/files/{_latestProposal.ProposalFileId}")">Download Proposal</MudButton>
						}
					</MudPaper>
				}
			</MudTabPanel>
				<MudTabPanel Text="Chapters">
					<MudText Typo="Typo.h6">Chapters</MudText>
					@if (_chapters == null || !_chapters.Any())
					{
						<MudPaper Class="pa-6 text-center mf-card"><MudText>No chapters available</MudText></MudPaper>
					}
					else
					{
						<MudTable Items="_chapters">
							<HeaderContent><MudTh>Number</MudTh><MudTh>Title</MudTh><MudTh>Status</MudTh><MudTh>Planned</MudTh><MudTh>Released</MudTh><MudTh></MudTh></HeaderContent>
							<RowTemplate>
								<MudTd>@context.ChapterNumberLabel</MudTd>
								<MudTd>@(context.ChapterTitle ?? "—")</MudTd>
								<MudTd><MudChip T="string">@context.StatusCode</MudChip></MudTd>
								<MudTd>@(context.PlannedReleaseDate.HasValue ? context.PlannedReleaseDate.Value.ToLocalTime().ToString("d") : "—")</MudTd>
								<MudTd>@(context.ReleasedAtUtc.HasValue ? context.ReleasedAtUtc.Value.ToLocalTime().ToString("g") : "—")</MudTd>
								<MudTd><MudButton Size="Size.Small" Href="#">View</MudButton></MudTd>
							</RowTemplate>
						</MudTable>
					}
				</MudTabPanel>
				<MudTabPanel Text="Contributors">
					<MudText Typo="Typo.h6">Contributors</MudText>
					@if (_contributors == null || !_contributors.Any())
					{
						<MudPaper Class="pa-6 text-center mf-card"><MudText>No contributors found</MudText></MudPaper>
					}
					else
					{
						<MudTable Items="_contributors">
							<HeaderContent><MudTh>Name/Id</MudTh><MudTh>Start</MudTh><MudTh>End</MudTh></HeaderContent>
							<RowTemplate>
								<MudTd>@context.UserId</MudTd>
								<MudTd>@context.StartDate.ToLocalTime().ToString("d")</MudTd>
								<MudTd>@(context.EndDate.HasValue ? context.EndDate.Value.ToLocalTime().ToString("d") : "—")</MudTd>
							</RowTemplate>
						</MudTable>
					}
				</MudTabPanel>
				<MudTabPanel Text="Ranking / Publication Context">
					<MudText Typo="Typo.h6">Ranking / Publication Context</MudText>
					@if (_rankings == null || !_rankings.Any())
					{
						<MudPaper Class="pa-4 mt-3 mf-card text-center"><MudText>No ranking data available</MudText></MudPaper>
					}
					else
					{
						<MudTable Items="_rankings">
							<HeaderContent><MudTh>Period</MudTh><MudTh>Rank</MudTh><MudTh>Score</MudTh></HeaderContent>
							<RowTemplate>
								<MudTd>@context.PeriodStartDate.ToLocalTime().ToString("d") - @context.PeriodEndDate.ToLocalTime().ToString("d")</MudTd>
								<MudTd>@context.RankPosition</MudTd>
								<MudTd>@context.RankingScore</MudTd>
							</RowTemplate>
						</MudTable>
					}
				</MudTabPanel>
				<MudTabPanel Text="Editorial Notes">
					<MudText Typo="Typo.h6">Editorial Notes / Review Actions</MudText>
					<MudPaper Class="pa-4 mt-3 mf-card text-center"><MudText>Read-only review context. Use proposal or chapter review pages to take actions.</MudText></MudPaper>
				</MudTabPanel>
			</MudTabs>
			}
		</MudPaper>
	</div>
</EditorLayout>

@code {
	[Parameter] public int SeriesId { get; set; }

	private MangaManagementSystem.Application.DTOs.Manga.SeriesDto? _seriesDto;
	private MangaManagementSystem.Application.DTOs.Manga.SeriesProposalDto? _latestProposal;
	private IEnumerable<MangaManagementSystem.Application.DTOs.Manga.ChapterDto>? _chapters;
	private IEnumerable<MangaManagementSystem.Application.DTOs.Manga.SeriesContributorDto>? _contributors;
	private IEnumerable<MangaManagementSystem.Application.DTOs.Manga.SeriesRankingSnapshotDto>? _rankings;
	private string? _coverUrl;

	private bool _loading = true;
	private string? _error;

	protected override async Task OnInitializedAsync()
	{
		await LoadSeriesAsync(SeriesId);
	}

	private async Task LoadSeriesAsync(int id)
	{
		_loading = true;
		_error = null;
		try
		{
			_seriesDto = await SeriesService.GetSeriesByIdAsync(id);
			if (_seriesDto == null)
			{
				_error = "Series not found.";
				return;
			}

			// load proposal(s) - take latest by submitted date if any
			var proposals = (await ProposalService.GetSeriesProposalsBySeriesIdAsync(id)).ToList();
			_latestProposal = proposals.OrderByDescending(p => p.SubmittedAtUtc).FirstOrDefault();

			// chapters
			_chapters = (await ChapterService.GetChaptersBySeriesIdAsync(id)).OrderBy(c => c.ChapterId).ToList();

			// contributors
			_contributors = (await ContributorService.GetSeriesContributorsBySeriesIdAsync(id)).ToList();

			// rankings
			_rankings = (await RankingService.GetSeriesRankingSnapshotsBySeriesIdAsync(id)).OrderByDescending(r => r.PeriodStartDate).ToList();

			// cover image
			if (_seriesDto.CoverFileId.HasValue)
			{
				var f = await FileResourceService.GetFileResourceByIdAsync(_seriesDto.CoverFileId.Value);
				if (f != null && !string.IsNullOrWhiteSpace(f.CloudinarySecureUrl))
				{
					_coverUrl = f.CloudinarySecureUrl;
				}
			}
		}
		catch (Exception ex)
		{
			_error = ex.Message;
		}
		finally
		{
			_loading = false;
		}
	}
}
