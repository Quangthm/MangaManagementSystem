@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Application.DTOs.Manga
@using MangaManagementSystem.Application.DTOs.Editor
@using MangaManagementSystem.Web.Services.Api
@using MudBlazor

<style>
    .mf-drawer-header {
        padding: 16px 20px 12px;
        border-bottom: 1px solid #e2e8f0;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .mf-drawer-filters {
        padding: 12px 20px;
        border-bottom: 1px solid #e2e8f0;
    }

    .mf-drawer-list {
        padding: 8px 16px 16px;
        overflow-y: auto;
    }

    .mf-drawer-card {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 10px 12px;
        margin-bottom: 8px;
        display: flex;
        gap: 8px;
        align-items: flex-start;
        background: #fff;
    }

    .mf-drawer-card-cover {
        width: 36px;
        height: 52px;
        border-radius: 4px;
        object-fit: cover;
        background: #e2e8f0;
        flex-shrink: 0;
    }

        .mf-drawer-card-cover img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .mf-drawer-card-info {
        flex: 1;
        min-width: 0;
    }

    .mf-drawer-card-series {
        font-size: 0.78rem;
        font-weight: 600;
        color: #1e293b;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .mf-drawer-card-chapter {
        font-size: 0.72rem;
        color: #64748b;
    }

    .mf-drawer-card-actions {
        display: flex;
        gap: 4px;
        margin-top: 4px;
        flex-wrap: wrap;
    }

    .mf-drawer-empty {
        text-align: center;
        padding: 32px 16px;
        color: #94a3b8;
    }

    .mf-drawer-loading {
        display: flex;
        justify-content: center;
        padding: 32px;
    }

    .mf-drawer-filtered-by {
        margin-bottom: 4px;
    }

    .mf-drawer-card[draggable="true"] {
        cursor: grab;
    }

        .mf-drawer-card[draggable="true"]:active {
            cursor: grabbing;
        }
</style>

<div class="mf-drawer-header">
    <div>
        <MudText Typo="Typo.h6" Class="mb-0">Schedule Actions</MudText>
        <MudChip T="string" Size="Size.Small" Color="@(_isMangaka ? Color.Primary : Color.Secondary)">@_roleLabel</MudChip>
    </div>
    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDrawer" Size="Size.Small" />
</div>

<div class="mf-drawer-filters">
    @if (HasSeriesFilter)
    {
        <div class="mf-drawer-filtered-by">
            <MudChip T="string" Size="Size.Small" Color="Color.Default" OnClose="ClearSelectedSeriesAsync">
                Series: @SeriesChipLabel
            </MudChip>
        </div>
    }
    <MudAutocomplete T="ActionableChapterItem"
                     Value="_selectedChapter"
                     ValueChanged="OnChapterFilterChanged"
                     SearchFunc="@SearchChaptersAsync"
                     ToStringFunc="@(c => c == null ? string.Empty : $"{c.ChapterNumberLabel} {(string.IsNullOrEmpty(c.ChapterTitle) ? "" : "- " + c.ChapterTitle)}")"
                     Label="Search chapters..."
                     Variant="Variant.Outlined" Clearable="true"
                     ResetValueOnEmptyText="true"
                     DebounceInterval="200"
                     Adornment="Adornment.Start"
                     AdornmentIcon="@Icons.Material.Filled.Search" />
</div>

<div class="mf-drawer-list">
    @if (_drawerLoading)
    {
        <div class="mf-drawer-loading">
            <MudProgressCircular Indeterminate="true" Size="Size.Small" />
        </div>
    }
    else if (_error != null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-3" Dense="true">
            @_error
            <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="LoadChaptersAsync">Retry</MudButton>
        </MudAlert>
    }
    else if (_filteredChapters.Count == 0)
    {
        <div class="mf-drawer-empty">
            <MudIcon Icon="@Icons.Material.Filled.Checklist" Size="Size.Small" Color="Color.Default" Class="mb-2" />
            <MudText Typo="Typo.body2">
                @GetEmptyStateMessage()
            </MudText>
            @if (_allChapters.Count == 0 && HasSeriesFilter)
            {
                <MudText Typo="Typo.caption">Try clearing the series filter.</MudText>
            }
        </div>
    }
    else
    {
        @foreach (var chapter in _filteredChapters)
        {
            <div class="mf-drawer-card"
                 draggable="@GetDraggableAttribute(chapter)"
                 @ondragstart="e => HandleChapterDragStart(e, chapter)"
                 @ondragend="HandleChapterDragEnd">
                <div class="mf-drawer-card-cover">
                    @if (!string.IsNullOrWhiteSpace(chapter.SeriesCoverUrl))
                    {
                        <img src="@chapter.SeriesCoverUrl" alt="cover" loading="lazy" />
                    }
                    else
                    {
                        <span style="font-size:0.5rem;color:#94a3b8;display:flex;align-items:center;justify-content:center;height:100%;">N/C</span>
                    }
                </div>
                <div class="mf-drawer-card-info">
                    <div class="mf-drawer-card-series" title="@chapter.SeriesTitle">@chapter.SeriesTitle</div>
                    <div class="mf-drawer-card-chapter">@chapter.ChapterNumberLabel @(!string.IsNullOrEmpty(chapter.ChapterTitle) ? $"- {chapter.ChapterTitle}" : "")</div>
                    <div class="mf-drawer-card-chapter">
                        @if (chapter.PlannedReleaseDate.HasValue)
                        {
                            <span>Planned: @chapter.PlannedReleaseDate.Value.ToString("MMM d, yyyy") | </span>
                        }
                        <MudChip T="string" Size="Size.Small" Color="@GetBadgeColor(chapter.StatusCode)">@chapter.StatusCode</MudChip>
                    </div>
                    <div class="mf-drawer-card-actions">
                        @if (CanSchedule(chapter))
                        {
                            <MudButton Variant="Variant.Filled" Size="Size.Small"
                                       Color="@(chapter.StatusCode == "SCHEDULED" || chapter.StatusCode == "ON_HOLD" ? Color.Info : Color.Primary)"
                                       OnClick="() => OpenScheduleDialog(chapter)"
                                       StartIcon="@Icons.Material.Filled.EditCalendar">
                                @(chapter.StatusCode == "ON_HOLD" ? "Return to Schedule" :
                                  chapter.StatusCode == "SCHEDULED" ? "Reschedule" : "Schedule")
                            </MudButton>
                        }
                        else if (chapter.StatusCode == "UNDER_REVIEW" && _isMangaka)
                        {
                            <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Default" Disabled="true"
                                       StartIcon="@Icons.Material.Filled.EditCalendar"
                                       Title="Scheduling is blocked while the chapter is UNDER_REVIEW.">
                                Schedule
                            </MudButton>
                        }
                        @if (_isEditor && chapter.StatusCode == "SCHEDULED")
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                                       OnClick="() => OpenHoldDialog(chapter)"
                                       StartIcon="@Icons.Material.Filled.PauseCircle">
                                Hold
                            </MudButton>
                        }
                        @if (_isEditor && (chapter.StatusCode == "SCHEDULED" || chapter.StatusCode == "APPROVED"))
                        {
                            <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Success"
                                       OnClick="() => OpenReleaseDialog(chapter)"
                                       StartIcon="@Icons.Material.Filled.Publish">
                                Release
                            </MudButton>
                        }
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private IMangakaChapterApiClient MangakaApi { get; set; } = null!;
    [Inject] private IEditorChapterReviewApiClient EditorApi { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;

    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EventCallback OnActionCompleted { get; set; }
    [Parameter] public Guid? SelectedSeriesId { get; set; }
    [Parameter] public string? SelectedSeriesTitle { get; set; }
    [Parameter] public EventCallback OnClearSeriesRequested { get; set; }
    [Parameter] public EventCallback<ActionableChapterItem> OnChapterDragStarted { get; set; }
    [Parameter] public EventCallback OnChapterDragEnded { get; set; }
    [Parameter] public int DrawerReloadVersion { get; set; }

    private Guid _currentUserId;
    private bool _isMangaka;
    private bool _isEditor;
    private string _roleLabel = "";
    private bool _drawerLoading;
    private string? _error;
    private int _lastDrawerReloadVersion;

    private List<ActionableChapterItem> _allChapters = new();
    private List<ActionableChapterItem> _filteredChapters = new();
    private ActionableChapterItem? _selectedChapter;
    private Guid? _selectedSeriesId;
    private Guid? _lastLoadedSeriesId;
    private string? _resolvedSeriesTitle;

    private string SeriesChipLabel => SelectedSeriesTitle ?? _resolvedSeriesTitle ?? "Selected series";
    private bool HasSeriesFilter => _selectedSeriesId.HasValue;
    private bool HasChapterFilter => _selectedChapter != null;

    private static readonly HashSet<string> ScheduleActionStatuses = new(StringComparer.OrdinalIgnoreCase)
    {
        "DRAFT", "REVISION_REQUESTED", "UNDER_REVIEW", "APPROVED", "SCHEDULED", "ON_HOLD"
    };

    private static readonly HashSet<string> ExcludedStatuses = new(StringComparer.OrdinalIgnoreCase)
    {
        "RELEASED", "CANCELLED"
    };

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var idClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(idClaim, out var userId))
                _currentUserId = userId;

            _isMangaka = user.IsInRole("Mangaka");
            _isEditor = user.IsInRole("Tantou Editor");
        }
        _roleLabel = _isMangaka ? "Mangaka" : _isEditor ? "Editor" : "";
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || _currentUserId == Guid.Empty) return;

        var currentSeriesId = SelectedSeriesId;

        if (_allChapters.Count == 0)
        {
            _selectedSeriesId = currentSeriesId;
            _lastLoadedSeriesId = currentSeriesId;
            await LoadChaptersAsync();
        }
        else if (ShouldReloadChaptersForSeriesChange(currentSeriesId))
        {
            _selectedSeriesId = currentSeriesId;
            _lastLoadedSeriesId = currentSeriesId;
            if (_isEditor)
            {
                _allChapters.Clear();
                _filteredChapters.Clear();
                await LoadChaptersAsync();
            }
            else
            {
                ClearChapterSearch();
                ApplyChapterFilters();
                StateHasChanged();
            }
        }

        if (_allChapters.Count > 0 && _lastDrawerReloadVersion != DrawerReloadVersion)
        {
            _lastDrawerReloadVersion = DrawerReloadVersion;
            _allChapters.Clear();
            _filteredChapters.Clear();
            await LoadChaptersAsync();
        }
    }

    private bool ShouldReloadChaptersForSeriesChange(Guid? currentSeriesId)
        => currentSeriesId != _lastLoadedSeriesId;

    private async Task LoadChaptersAsync()
    {
        _drawerLoading = true;
        _error = null;
        StateHasChanged();

        try
        {
            _allChapters = _isMangaka
                ? await LoadMangakaChaptersAsync()
                : await LoadEditorChaptersAsync();

            ResolveSeriesDisplayTitle();
            ApplyChapterFilters();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _drawerLoading = false;
            StateHasChanged();
        }
    }

    private async Task<List<ActionableChapterItem>> LoadMangakaChaptersAsync()
    {
        var chapters = await MangakaApi.GetMyChaptersAsync(_currentUserId);
        return chapters
            .Where(c => !ExcludedStatuses.Contains(c.StatusCode))
            .Select(c => new ActionableChapterItem(
                c.ChapterId, c.SeriesId, c.SeriesTitle,
                c.ChapterNumberLabel, c.ChapterTitle,
                c.StatusCode, c.PlannedReleaseDate,
                c.ReleasedAtUtc, c.SeriesCoverUrl))
            .ToList();
    }

    private async Task<List<ActionableChapterItem>> LoadEditorChaptersAsync()
    {
        var chapters = await EditorApi.GetActionableChaptersAsync(
            _currentUserId, SelectedSeriesId);
        return chapters
            .Select(c => new ActionableChapterItem(
                c.ChapterId, c.SeriesId, c.SeriesTitle,
                c.ChapterNumberLabel, c.ChapterTitle,
                c.StatusCode, c.PlannedReleaseDate,
                c.ReleasedAtUtc, c.SeriesCoverUrl))
            .ToList();
    }

    private void ResolveSeriesDisplayTitle()
    {
        if (string.IsNullOrWhiteSpace(SelectedSeriesTitle)
            && _selectedSeriesId.HasValue
            && _allChapters.Count > 0
            && _allChapters[0].SeriesId == _selectedSeriesId.Value)
        {
            _resolvedSeriesTitle = _allChapters[0].SeriesTitle;
        }
    }

    private void ResetResolvedSeriesLabel()
    {
        _resolvedSeriesTitle = null;
    }

    private void ApplyChapterFilters()
    {
        var filtered = _allChapters.AsEnumerable();

        if (_selectedSeriesId.HasValue && _selectedSeriesId.Value != Guid.Empty)
            filtered = filtered.Where(c => c.SeriesId == _selectedSeriesId.Value);

        if (_selectedChapter != null)
            filtered = filtered.Where(c => c.ChapterId == _selectedChapter.ChapterId);

        _filteredChapters = filtered.OrderBy(c => c.SeriesTitle).ThenBy(c => c.ChapterNumberLabel).ToList();
    }

    private Task<IEnumerable<ActionableChapterItem>> SearchChaptersAsync(string searchText, CancellationToken ct)
    {
        if (string.IsNullOrWhiteSpace(searchText) || searchText.Trim().Length < 1)
            return Task.FromResult<IEnumerable<ActionableChapterItem>>(Array.Empty<ActionableChapterItem>());

        var lower = searchText.Trim().ToLowerInvariant();
        var results = GetSeriesScopedChapters()
            .Where(c =>
                c.ChapterNumberLabel.ToLowerInvariant().Contains(lower) ||
                (c.ChapterTitle?.ToLowerInvariant().Contains(lower) ?? false) ||
                $"{c.ChapterNumberLabel} {c.ChapterTitle}".ToLowerInvariant().Contains(lower))
            .Take(10);

        return Task.FromResult<IEnumerable<ActionableChapterItem>>(results);
    }

    private IEnumerable<ActionableChapterItem> GetSeriesScopedChapters()
        => HasSeriesFilter
            ? _allChapters.Where(c => c.SeriesId == _selectedSeriesId!.Value)
            : _allChapters;

    private async void OnChapterFilterChanged(ActionableChapterItem? chapter)
    {
        _selectedChapter = chapter;
        ApplyChapterFilters();
        StateHasChanged();
    }

    private async Task ClearSelectedSeriesAsync()
    {
        _selectedSeriesId = null;
        ResetResolvedSeriesLabel();
        await OnClearSeriesRequested.InvokeAsync();
    }

    private void ClearChapterSearch()
    {
        _selectedChapter = null;
        ApplyChapterFilters();
        StateHasChanged();
    }

    private async void OpenScheduleDialog(ActionableChapterItem chapter)
    {
        var parameters = new DialogParameters { ["Chapter"] = chapter };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ScheduleChapterDialog>(
            chapter.StatusCode == "ON_HOLD" ? "Return to Schedule" : "Schedule Chapter",
            parameters, options);
        var result = await dialog.Result;

        if (result?.Data is ScheduleChapterDialogResult scheduleResult)
        {
            try
            {
                if (_isMangaka)
                {
                    var response = await MangakaApi.SetPlannedReleaseDateAsync(
                        _currentUserId, chapter.ChapterId,
                        new SetPlannedReleaseDateRequest(scheduleResult.NewPlannedReleaseDate));
                    Snackbar.Add(response.ValidationMessage ?? "Planned release date updated.", Severity.Success);
                }
                else if (_isEditor)
                {
                    var response = await EditorApi.SetPlannedReleaseDateAsync(
                        _currentUserId, chapter.ChapterId,
                        new SetPlannedReleaseDateRequest(scheduleResult.NewPlannedReleaseDate));
                    Snackbar.Add(response.ValidationMessage ?? "Planned release date updated.", Severity.Success);
                }
                await ReloadAllAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async void OpenHoldDialog(ActionableChapterItem chapter)
    {
        var parameters = new DialogParameters { ["Chapter"] = chapter };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<HoldChapterDialog>("Put Chapter on Hold", parameters, options);
        var result = await dialog.Result;

        if (result?.Data is HoldChapterDialogResult holdResult)
        {
            try
            {
                await EditorApi.PutChapterOnHoldAsync(_currentUserId, chapter.ChapterId, holdResult.Reason);
                Snackbar.Add("Chapter has been put on hold.", Severity.Success);
                await ReloadAllAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async void OpenReleaseDialog(ActionableChapterItem chapter)
    {
        var parameters = new DialogParameters { ["Chapter"] = chapter };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ReleaseChapterDialog>("Release Chapter", parameters, options);
        var result = await dialog.Result;

        if (result?.Data is true)
        {
            try
            {
                await EditorApi.ReleaseChapterAsync(_currentUserId, chapter.ChapterId, true);
                Snackbar.Add("Chapter has been released.", Severity.Success);
                await ReloadAllAsync();
            }
            catch (Exception ex)
            {
                Snackbar.Add(ex.Message, Severity.Error);
            }
        }
    }

    private async Task ReloadAllAsync()
    {
        _allChapters.Clear();
        _filteredChapters.Clear();
        await LoadChaptersAsync();
        await OnActionCompleted.InvokeAsync();
    }

    private async Task CloseDrawer()
    {
        await IsOpenChanged.InvokeAsync(false);
    }

    private bool CanDragChapter(ActionableChapterItem chapter) => CanSchedule(chapter);

    private string? GetDraggableAttribute(ActionableChapterItem chapter)
        => CanDragChapter(chapter) ? "true" : null;

    private async Task HandleChapterDragStart(DragEventArgs e, ActionableChapterItem chapter)
    {
        await OnChapterDragStarted.InvokeAsync(chapter);
    }

    private async Task HandleChapterDragEnd()
    {
        await OnChapterDragEnded.InvokeAsync();
    }

    private bool CanSchedule(ActionableChapterItem chapter)
    {
        if (_isMangaka && chapter.StatusCode == "UNDER_REVIEW")
            return false;
        if (ExcludedStatuses.Contains(chapter.StatusCode))
            return false;
        return ScheduleActionStatuses.Contains(chapter.StatusCode);
    }

    private string GetEmptyStateMessage()
    {
        if (HasChapterFilter)
            return "This chapter is not available here.";
        if (HasSeriesFilter)
            return "No actionable chapters found for this series.";
        if (_allChapters.Count == 0)
            return "No actionable chapters found.";
        return "No chapters match this search.";
    }

    private static Color GetBadgeColor(string statusCode) => statusCode switch
    {
        "RELEASED" => Color.Success,
        "SCHEDULED" => Color.Info,
        "APPROVED" => Color.Info,
        "ON_HOLD" => Color.Warning,
        "UNDER_REVIEW" => Color.Secondary,
        "DRAFT" => Color.Default,
        "REVISION_REQUESTED" => Color.Tertiary,
        _ => Color.Default
    };
}
