@page "/demo/mangaflow/editorial"

@using MangaManagementSystem.Web.Services.EditorialBoard
@inject IEditorialBoardApiClient EditorialBoardApiClient

<MangaFlowShell Title="Editorial Dashboard"
                Subtitle="Overview of proposal review, board polls, and pending decisions."
                ActiveMenu="dashboard">
    <ChildContent>
        @if (_isLoading)
        {
            <section class="mf-card">
                <div class="mf-strong">Loading editorial dashboard...</div>
                <div class="mf-muted">Fetching real data from API.</div>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="mf-card">
                <div class="mf-strong">Cannot load editorial dashboard</div>
                <div class="mf-muted">@_errorMessage</div>

                <button type="button"
                        class="mf-btn mf-btn-primary mf-gap-small"
                        @onclick="LoadDashboardAsync">
                    Retry
                </button>
            </section>
        }
        else if (_dashboard is not null)
        {
            <div class="mf-grid mf-grid-3">
                <KpiCard Label="Proposal Reviews"
                         Value="@_dashboard.ProposalReviewCount.ToString()"
                         Description="Need board review"
                         Icon="▤"
                         Tone="blue" />

                <KpiCard Label="Open Polls"
                         Value="@_dashboard.OpenPollCount.ToString()"
                         Description="Active voting sessions"
                         Icon="▥"
                         Tone="green" />

                <KpiCard Label="Awaiting Decision"
                         Value="@_dashboard.AwaitingDecisionCount.ToString()"
                         Description="Ready for board chief action"
                         Icon="⌛"
                         Tone="orange" />
            </div>

            <div class="mf-grid mf-grid-2 mf-gap-top">
                <section class="mf-card">
                    <div class="mf-section-head">
                        <div class="mf-section-title-wrap">
                            <div class="mf-section-icon">▤</div>

                            <div>
                                <h2>Recent Proposal Reviews</h2>
                                <p>Submitted series proposals currently visible to the editorial board.</p>
                            </div>
                        </div>

                        <a class="mf-btn mf-btn-primary" href="/demo/mangaflow/proposals">
                            Review Proposals
                        </a>
                    </div>

                    @if (_dashboard.RecentProposals.Count == 0)
                    {
                        <div class="mf-muted">No proposal reviews found.</div>
                    }
                    else
                    {
                        @foreach (var proposal in _dashboard.RecentProposals)
                        {
                            <div class="mf-list-row">
                                <div>
                                    <div class="mf-code">@proposal.Code</div>
                                    <div class="mf-strong">@proposal.Title</div>
                                    <div class="mf-muted">@proposal.Author · @proposal.Genre</div>
                                </div>

                                <StatusBadge Status="@proposal.Status" />
                            </div>
                        }
                    }
                </section>

                <section class="mf-card">
                    <div class="mf-section-head">
                        <div class="mf-section-title-wrap">
                            <div class="mf-section-icon">▥</div>

                            <div>
                                <h2>Open Polls</h2>
                                <p>Active serialization and continuation votes.</p>
                            </div>
                        </div>

                        <a class="mf-btn mf-btn-primary" href="/demo/mangaflow/polls">
                            Manage Polls
                        </a>
                    </div>

                    @if (_dashboard.OpenPolls.Count == 0)
                    {
                        <div class="mf-muted">No open polls found.</div>
                    }
                    else
                    {
                        @foreach (var poll in _dashboard.OpenPolls)
                        {
                            <div class="mf-list-row">
                                <div>
                                    <div class="mf-strong">@poll.Name</div>
                                    <div class="mf-muted">
                                        @poll.Code · @poll.TotalVotes votes
                                    </div>
                                </div>

                                <StatusBadge Status="@poll.Status" />
                            </div>
                        }
                    }
                </section>
            </div>

            <section class="mf-card mf-gap-top">
                <div class="mf-section-head">
                    <div class="mf-section-title-wrap">
                        <div class="mf-section-icon orange">⌛</div>

                        <div>
                            <h2>Decision Queue</h2>
                            <p>Polls waiting for final publishing decision after board voting.</p>
                        </div>
                    </div>

                    <a class="mf-btn" href="/demo/mangaflow/decisions">
                        Open Decision Center
                    </a>
                </div>

                @if (_dashboard.Decisions.Count == 0)
                {
                    <div class="mf-muted">No decisions waiting.</div>
                }
                else
                {
                    <div class="mf-grid mf-grid-4">
                        @foreach (var item in _dashboard.Decisions)
                        {
                            <div class="mf-decision-mini-card">
                                <StatusBadge Status="@item.ComputedResultCode" />

                                <div class="mf-decision-title">
                                    @item.Title
                                </div>

                                <div class="mf-decision-meta">
                                    @item.Code · @item.TotalVotes votes
                                </div>

                                <span class="mf-decision-arrow">›</span>
                            </div>
                        }
                    </div>
                }
            </section>
        }
    </ChildContent>
</MangaFlowShell>

@code {
    private EditorialDashboardDto? _dashboard;
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _dashboard = await EditorialBoardApiClient.GetDashboardAsync();

            if (_dashboard is null)
            {
                _errorMessage = "API returned empty dashboard data.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }
}