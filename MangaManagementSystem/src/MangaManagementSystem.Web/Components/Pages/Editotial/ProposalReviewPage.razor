@page "/demo/mangaflow/proposals"

@using System.Globalization
@using System.Linq
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Web.Services.EditorialBoard

@inject IEditorialBoardApiClient EditorialBoardApiClient
@inject NavigationManager NavigationManager

<MangaFlowShell Title="Proposal Reviews"
                Subtitle="Review and evaluate manga proposals submitted by authors."
                ActiveMenu="proposals">
    <ChildContent>
        @if (IsLoading)
        {
            <section class="mf-card">
                <div class="mf-strong">Loading proposals...</div>
                <div class="mf-muted">Fetching proposal data from API.</div>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <section class="mf-card">
                <div class="mf-strong">Cannot load proposals</div>
                <div class="mf-muted">@ErrorMessage</div>

                <button type="button"
                        class="mf-btn mf-btn-primary mf-gap-small"
                        @onclick="LoadProposalsAsync">
                    Retry
                </button>
            </section>
        }
        else
        {
            <section class="mf-tab-card">
                <button type="button"
                        class="@GetTabClass("PROPOSAL_REVIEW")"
                        @onclick="ShowProposalReviewTab">
                    Proposal Review
                </button>

                <AuthorizeView Roles="Editorial Board Chief">
                    <Authorized>
                        <button type="button"
                                class="@GetTabClass("CANCEL_SERIALIZATION")"
                                @onclick="ShowCancelSerializationTab">
                            Cancel Serialization
                        </button>
                    </Authorized>
                </AuthorizeView>
            </section>

            @if (IsProposalReviewTab)
            {
                <section class="mf-filter-card">
                    <input class="mf-input mf-search-input"
                           placeholder="Search proposals..."
                           @bind="SearchText" />

                    <button class='@GetFilterChipClass(null)' @onclick="ClearStatusFilter">All</button>
                    <button class='@GetFilterChipClass("Draft")' @onclick="SetDraftFilter">Draft</button>
                    <button class='@GetFilterChipClass("In Review")' @onclick="SetInReviewFilter">In Review</button>
                    <button class='@GetFilterChipClass("Approved")' @onclick="SetApprovedFilter">Approved</button>
                    <button class='@GetFilterChipClass("Rejected")' @onclick="SetRejectedFilter">Rejected</button>
                </section>

                <section class="mf-card table-card">
                    <div class="mf-table-wrap">
                        <table class="mf-table">
                            <thead>
                                <tr>
                                    <th>Series Code</th>
                                    <th>Proposal Title</th>
                                    <th>Author</th>
                                    <th>Genre</th>
                                    <th>Version</th>
                                    <th>Submitted From Editor</th>
                                    <th>Status</th>
                                    <th>Assigned Editor</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>

                            <tbody>
                                @if (!FilteredProposals.Any())
                                {
                                    <tr>
                                        <td colspan="9">
                                            <div class="mf-muted">No proposals found.</div>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var proposal in FilteredProposals)
                                    {
                                        <tr>
                                            <td>
                                                <span class="mf-code">@proposal.Code</span>
                                            </td>

                                            <td class="mf-strong">@proposal.Title</td>
                                            <td>@proposal.Author</td>

                                            <td class="mf-genre-cell">
                                                @if (proposal.GenreItems.Count == 0)
                                                {
                                                    <span>Unknown Genre</span>
                                                }
                                                else
                                                {
                                                    <div class="mf-genre-list table @(IsGenreRowExpanded(proposal) ? "expanded" : "collapsed")">
                                                        @foreach (var genre in GetVisibleRowGenres(proposal))
                                                        {
                                                            <span class="mf-genre-pill">@genre</span>
                                                        }
                                                    </div>

                                                    @if (proposal.GenreItems.Count > MaxTableVisibleGenres)
                                                    {
                                                        <button type="button"
                                                                class="mf-genre-toggle"
                                                                @onclick="() => ToggleGenreRow(proposal)">
                                                            @(IsGenreRowExpanded(proposal)
                                                                ? "Show less"
                                                                : $"+{proposal.GenreItems.Count - MaxTableVisibleGenres} more")
                                                        </button>
                                                    }
                                                }
                                            </td>

                                            <td class="mf-mono">@proposal.VersionLabel</td>
                                            <td>@proposal.SubmittedFromEditor</td>

                                            <td>
                                                <StatusBadge Status="@proposal.Status" />
                                            </td>

                                            <td>@proposal.AssignedEditor</td>

                                            <td>
                                                <button type="button"
                                                        class="mf-btn mf-btn-soft"
                                                        @onclick="() => OpenDetails(proposal)">
                                                    View
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }

            <AuthorizeView Roles="Editorial Board Chief">
                <Authorized>
                    @if (IsCancelSerializationTab)
                    {
                        <section class="mf-card">
                            <div class="mf-row">
                                <div>
                                    <h3>Open Cancel Serialization Poll</h3>
                                    <p class="mf-muted">
                                        Open a CANCEL_SERIALIZATION vote for a SERIALIZED or HIATUS series.
                                    </p>
                                </div>

                                <StatusBadge Status="Board Chief" />
                            </div>

                            <div class="mf-grid mf-grid-2 mf-gap-small">
                                <div>
                                    <label class="mf-label">Series</label>

                                    <select class="mf-input"
                                            @bind="SelectedCancelSeriesIdText">
                                        <option value="">Select series...</option>

                                        @foreach (var series in CancellableSeries)
                                        {
                                            <option value="@series.SeriesId"
                                                    disabled="@series.HasOpenCancelSerializationPoll">
                                                @series.Title (@series.StatusCode)
                                                @(series.HasOpenCancelSerializationPoll ? " - Poll already open" : "")
                                            </option>
                                        }
                                    </select>
                                </div>

                                <div>
                                    <label class="mf-label">Deadline optional</label>

                                    @if (ShowDeadlinePicker)
                                    {
                                        <div class="mf-deadline-editor compact">
                                            <input class="mf-input"
                                                   type="date"
                                                   value="@OpenPollDeadlineDraftText"
                                                   @onchange="OnDeadlineInputChanged" />

                                            <div class="mf-actions tight">
                                                <button type="button"
                                                        class="mf-btn mf-btn-primary"
                                                        @onclick="ConfirmDeadline">
                                                    Save
                                                </button>

                                                <button type="button"
                                                        class="mf-btn"
                                                        @onclick="CancelDeadline">
                                                    Cancel
                                                </button>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="mf-btn mf-btn-soft full"
                                                disabled="@(SelectedCancelSeries?.HasOpenCancelSerializationPoll == true)"
                                                @onclick="StartDeadlinePicker">
                                            @(ConfirmedOpenPollDeadline is null
                                                ? "Set deadline (optional)"
                                                : $"Deadline set: {FormatDate(ConfirmedOpenPollDeadline)}")
                                        </button>
                                    }
                                </div>
                            </div>

                            @if (CancellableSeries.Count == 0)
                            {
                                <div class="mf-alert info">
                                    No SERIALIZED or HIATUS series is available for cancellation poll.
                                </div>
                            }

                            @if (SelectedCancelSeries is not null)
                            {
                                <div class="mf-muted mf-gap-small">
                                    Selected: <strong>@SelectedCancelSeries.Title</strong>
                                    · Status: <strong>@SelectedCancelSeries.StatusCode</strong>
                                </div>
                            }

                            @if (SelectedCancelSeries?.HasOpenCancelSerializationPoll == true)
                            {
                                <div class="mf-alert warning">
                                    This series already has an open cancellation poll.
                                </div>
                            }

                            <label class="mf-label mf-gap-small">Poll reason</label>

                            <textarea class="mf-textarea"
                                      @bind="CancelPollReason"
                                      placeholder="Explain why this serialized/hiatus series should be considered for cancellation..."></textarea>

                            <button type="button"
                                    class="mf-btn mf-btn-primary full mf-gap-small"
                                    disabled="@IsOpenCancelPollDisabled"
                                    @onclick="OpenCancelPollAsync">
                                @(IsOpeningCancelPoll ? "Opening..." : "Open Cancel Poll")
                            </button>

                            @if (!string.IsNullOrWhiteSpace(CancelPollMessage))
                            {
                                <div class="@CancelPollAlertClass">
                                    @CancelPollMessage
                                </div>
                            }
                        </section>
                    }
                </Authorized>
            </AuthorizeView>
        }

        @if (SelectedProposal is not null)
        {
            <div class="mf-modal-backdrop" @onclick="CloseDetails">
                <div class="mf-modal large" @onclick:stopPropagation="true">
                    <div class="mf-modal-header">
                        <div>
                            <div class="mf-modal-meta">
                                <span class="mf-code">@SelectedProposal.Code</span>
                                <StatusBadge Status="@SelectedProposal.Status" />
                            </div>

                            <h2>@SelectedProposal.Title</h2>
                        </div>

                        <button type="button"
                                class="mf-icon-btn"
                                @onclick="CloseDetails">
                            ×
                        </button>
                    </div>

                    <div class="mf-proposal-layout">
                        <div class="mf-proposal-main">
                            <h3>A. Proposal Information</h3>

                            <div class="mf-grid mf-grid-2">
                                <div class="mf-info-tile">
                                    <span>Author</span>
                                    <strong>@SelectedProposal.Author</strong>
                                </div>

                                <div class="mf-info-tile mf-genres-tile">
                                    <span>Genre</span>

                                    @if (SelectedProposal.GenreItems.Count == 0)
                                    {
                                        <strong>Unknown Genre</strong>
                                    }
                                    else
                                    {
                                        <div class="mf-genre-list @(ShowAllGenres ? "expanded" : "collapsed")">
                                            @foreach (var genre in VisibleGenres)
                                            {
                                                <span class="mf-genre-pill">@genre</span>
                                            }
                                        </div>

                                        @if (SelectedProposal.GenreItems.Count > MaxVisibleGenres)
                                        {
                                            <button type="button"
                                                    class="mf-genre-toggle"
                                                    @onclick="ToggleGenres">
                                                @(ShowAllGenres
                                                    ? "Show less"
                                                    : $"+{HiddenGenreCount} more")
                                            </button>
                                        }
                                    }
                                </div>

                                <div class="mf-info-tile mf-tags-tile">
                                    <span>Tags</span>

                                    @if (SelectedProposal.Tags.Count == 0)
                                    {
                                        <strong>No tags</strong>
                                    }
                                    else
                                    {
                                        <div class="mf-tag-list @(ShowAllTags ? "expanded" : "collapsed")">
                                            @foreach (var tag in VisibleTags)
                                            {
                                                <span class="mf-tag-pill">@tag</span>
                                            }
                                        </div>

                                        @if (SelectedProposal.Tags.Count > MaxVisibleTags)
                                        {
                                            <button type="button"
                                                    class="mf-tag-toggle"
                                                    @onclick="ToggleTags">
                                                @(ShowAllTags
                                                    ? "Show less"
                                                    : $"+{HiddenTagCount} more")
                                            </button>
                                        }
                                    }
                                </div>

                                <div class="mf-info-tile">
                                    <span>Target Audience</span>
                                    <strong>@SelectedProposal.TargetAudience</strong>
                                </div>

                                <div class="mf-info-tile">
                                    <span>Submitted From Editor</span>
                                    <strong>@SelectedProposal.SubmittedFromEditor</strong>
                                </div>

                                <div class="mf-info-tile">
                                    <span>Version</span>
                                    <strong>@SelectedProposal.VersionLabel</strong>
                                </div>
                            </div>

                            <div class="mf-info-tile wide">
                                <span>Synopsis</span>
                                <p>@SelectedProposal.Synopsis</p>
                            </div>

                            <h3>B. Version History</h3>

                            <div class="mf-timeline">
                                @foreach (var history in SelectedProposal.History)
                                {
                                    <div class="mf-timeline-row">
                                        <span class="mf-timeline-dot"></span>

                                        <div class="mf-timeline-card">
                                            <div class="mf-row">
                                                <strong>@history.Version</strong>
                                                <span>@history.Date</span>
                                            </div>

                                            <p>@history.Description</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <aside class="mf-proposal-side">
                            <section class="mf-side-panel">
                                <h3>C. Attachments</h3>

                                @if (SelectedProposal.Attachments.Count == 0)
                                {
                                    <div class="mf-attachment empty">
                                        No attachment file available.
                                    </div>
                                }
                                else
                                {
                                    @foreach (var attachment in SelectedProposal.Attachments)
                                    {
                                        @if (attachment.HasUrl)
                                        {
                                            <a class="mf-attachment"
                                               href="@attachment.Url"
                                               target="_blank"
                                               rel="noopener noreferrer">
                                                <span class="mf-attachment-main">
                                                    <strong>@attachment.Label</strong>
                                                    <small title="@attachment.DisplayName">
                                                        @attachment.DisplayName
                                                    </small>
                                                </span>

                                                <span class="mf-open-file">Open</span>
                                            </a>
                                        }
                                        else
                                        {
                                            <div class="mf-attachment empty">
                                                <span class="mf-attachment-main">
                                                    <strong>@attachment.Label</strong>
                                                    <small title="@attachment.DisplayName">
                                                        No file URL available.
                                                    </small>
                                                </span>
                                            </div>
                                        }
                                    }
                                }
                            </section>

                            <AuthorizeView Roles="Editorial Board Chief">
                                <Authorized>
                                    <section class="mf-side-panel">
                                        <h3>D. Open Poll</h3>

                                        <div class="mf-open-poll-box">
                                            <div class="mf-panel-title">
                                                Open poll for @SelectedProposal.Code
                                            </div>

                                            <label class="mf-label">Poll type</label>

                                            <select class="mf-input" @bind="PollType" disabled>
                                                <option value="START_SERIALIZATION">START_SERIALIZATION</option>
                                            </select>

                                            <label class="mf-label">Publication frequency</label>

                                            <select class="mf-input" @bind="PublicationFrequencyCode">
                                                <option value="WEEKLY">WEEKLY</option>
                                                <option value="MONTHLY">MONTHLY</option>
                                                <option value="IRREGULAR">IRREGULAR</option>
                                            </select>

                                            @if (ShowDeadlinePicker)
                                            {
                                                <div class="mf-deadline-editor compact">
                                                    <label>Set deadline <span>(optional)</span></label>

                                                    <input class="mf-input"
                                                           type="date"
                                                           value="@OpenPollDeadlineDraftText"
                                                           @onchange="OnDeadlineInputChanged" />

                                                    <div class="mf-actions tight">
                                                        <button type="button"
                                                                class="mf-btn mf-btn-primary"
                                                                @onclick="ConfirmDeadline">
                                                            Save
                                                        </button>

                                                        <button type="button"
                                                                class="mf-btn"
                                                                @onclick="CancelDeadline">
                                                            Cancel
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="mf-btn mf-btn-soft full"
                                                        disabled="@HasCurrentPollTypeConflict"
                                                        @onclick="StartDeadlinePicker">
                                                    @(ConfirmedOpenPollDeadline is null
                                                        ? "Set deadline (optional)"
                                                        : $"Deadline set: {FormatDate(ConfirmedOpenPollDeadline)}")
                                                </button>
                                            }

                                            <label class="mf-label">Poll reason</label>

                                            <textarea class="mf-textarea"
                                                      disabled="@HasCurrentPollTypeConflict"
                                                      @bind="PollReason"
                                                      placeholder="Explain why this proposal should go to board vote..."></textarea>

                                            @if (HasCurrentPollTypeConflict)
                                            {
                                                <div class="mf-alert warning">
                                                    @CurrentOpenPollConflictMessage
                                                </div>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="mf-btn mf-btn-primary full"
                                                        disabled="@IsOpenPollDisabled"
                                                        @onclick="ConfirmOpenPollAsync">
                                                    @OpenPollButtonText
                                                </button>
                                            }

                                            @if (!string.IsNullOrWhiteSpace(OpenPollMessage))
                                            {
                                                <div class="@OpenPollAlertClass">
                                                    @OpenPollMessage
                                                </div>
                                            }
                                        </div>
                                    </section>
                                </Authorized>
                            </AuthorizeView>
                        </aside>
                    </div>
                </div>
            </div>
        }
    </ChildContent>
</MangaFlowShell>

@code {
    private const string DuplicateOpenPollMessage =
        "This series already has an open board poll of this type. Close or cancel the existing poll before opening a new one.";

    private const int MaxVisibleTags = 8;
    private const int MaxVisibleGenres = 4;
    private const int MaxTableVisibleGenres = 3;

    private string ActiveTab { get; set; } = "PROPOSAL_REVIEW";

    private bool IsProposalReviewTab => ActiveTab == "PROPOSAL_REVIEW";

    private bool IsCancelSerializationTab => ActiveTab == "CANCEL_SERIALIZATION";

    private string SearchText { get; set; } = string.Empty;
    private string? StatusFilter { get; set; }
    private ProposalItem? SelectedProposal { get; set; }

    private string PollType { get; set; } = "START_SERIALIZATION";
    private string PublicationFrequencyCode { get; set; } = "WEEKLY";
    private string PollReason { get; set; } = string.Empty;

    private IReadOnlyList<CancellableBoardSeriesDto> CancellableSeries { get; set; }
        = Array.Empty<CancellableBoardSeriesDto>();

    private string SelectedCancelSeriesIdText { get; set; } = string.Empty;
    private string CancelPollReason { get; set; } = string.Empty;
    private string? CancelPollMessage { get; set; }

    private bool ShowDeadlinePicker { get; set; }
    private bool ShowAllTags { get; set; }
    private bool ShowAllGenres { get; set; }
    private bool IsOpeningPoll { get; set; }
    private bool IsOpeningCancelPoll { get; set; }
    private bool IsLoading { get; set; } = true;

    private string? OpenPollConflictType { get; set; }

    private string OpenPollDeadlineDraftText { get; set; } = string.Empty;
    private DateTime? ConfirmedOpenPollDeadline { get; set; }
    private string? OpenPollMessage { get; set; }
    private bool OpenPollSucceeded { get; set; }
    private bool CancelPollSucceeded { get; set; }

    private string? ErrorMessage { get; set; }

    private IReadOnlyList<ProposalItem> Proposals { get; set; } = Array.Empty<ProposalItem>();

    private HashSet<Guid> ExpandedGenreRows { get; } = new();

    private CancellableBoardSeriesDto? SelectedCancelSeries =>
        CancellableSeries.FirstOrDefault(series =>
            series.SeriesId.ToString().Equals(
                SelectedCancelSeriesIdText,
                StringComparison.OrdinalIgnoreCase));

    private bool IsOpenCancelPollDisabled =>
        IsOpeningCancelPoll
        || string.IsNullOrWhiteSpace(SelectedCancelSeriesIdText)
        || string.IsNullOrWhiteSpace(CancelPollReason)
        || SelectedCancelSeries?.HasOpenCancelSerializationPoll == true;

    private string CancelPollAlertClass =>
        CancelPollSucceeded
            ? "mf-alert success"
            : "mf-alert info";

    private IEnumerable<string> VisibleTags
    {
        get
        {
            if (SelectedProposal is null)
            {
                return Array.Empty<string>();
            }

            return ShowAllTags
                ? SelectedProposal.Tags
                : SelectedProposal.Tags.Take(MaxVisibleTags);
        }
    }

    private int HiddenTagCount
    {
        get
        {
            if (SelectedProposal is null)
            {
                return 0;
            }

            return Math.Max(0, SelectedProposal.Tags.Count - MaxVisibleTags);
        }
    }

    private IEnumerable<string> VisibleGenres
    {
        get
        {
            if (SelectedProposal is null)
            {
                return Array.Empty<string>();
            }

            return ShowAllGenres
                ? SelectedProposal.GenreItems
                : SelectedProposal.GenreItems.Take(MaxVisibleGenres);
        }
    }

    private int HiddenGenreCount
    {
        get
        {
            if (SelectedProposal is null)
            {
                return 0;
            }

            return Math.Max(0, SelectedProposal.GenreItems.Count - MaxVisibleGenres);
        }
    }

    private void ShowProposalReviewTab()
    {
        ActiveTab = "PROPOSAL_REVIEW";

        ShowDeadlinePicker = false;
        OpenPollDeadlineDraftText = string.Empty;
        ConfirmedOpenPollDeadline = null;
        CancelPollMessage = null;
        CancelPollSucceeded = false;
    }

    private async Task ShowCancelSerializationTab()
    {
        ActiveTab = "CANCEL_SERIALIZATION";

        ShowDeadlinePicker = false;
        OpenPollDeadlineDraftText = string.Empty;
        ConfirmedOpenPollDeadline = null;
        OpenPollMessage = null;
        OpenPollSucceeded = false;
        CancelPollMessage = null;
        CancelPollSucceeded = false;

        if (string.IsNullOrWhiteSpace(CancelPollReason))
        {
            CancelPollReason = "Board poll opened to consider cancelling serialization.";
        }

        await LoadCancellableSeriesAsync();
    }

    private string GetTabClass(string tabCode)
    {
        return ActiveTab == tabCode
            ? "mf-tab active"
            : "mf-tab";
    }

    private void ToggleTags()
    {
        ShowAllTags = !ShowAllTags;
    }

    private void ToggleGenres()
    {
        ShowAllGenres = !ShowAllGenres;
    }

    private IEnumerable<string> GetVisibleRowGenres(ProposalItem proposal)
    {
        return IsGenreRowExpanded(proposal)
            ? proposal.GenreItems
            : proposal.GenreItems.Take(MaxTableVisibleGenres);
    }

    private bool IsGenreRowExpanded(ProposalItem proposal)
    {
        return ExpandedGenreRows.Contains(GetProposalKey(proposal));
    }

    private void ToggleGenreRow(ProposalItem proposal)
    {
        var key = GetProposalKey(proposal);

        if (!ExpandedGenreRows.Add(key))
        {
            ExpandedGenreRows.Remove(key);
        }
    }

    private static Guid GetProposalKey(ProposalItem proposal)
    {
        if (proposal.ProposalId != Guid.Empty)
        {
            return proposal.ProposalId;
        }

        return proposal.SeriesId;
    }

    private bool HasCurrentPollTypeConflict
    {
        get
        {
            if (SelectedProposal is null)
            {
                return false;
            }

            if (!string.IsNullOrWhiteSpace(OpenPollConflictType)
                && OpenPollConflictType == "START_SERIALIZATION")
            {
                return true;
            }

            if (SelectedProposal.HasGenericOpenPollConflict)
            {
                return true;
            }

            return SelectedProposal.HasStartSerializationOpenPoll;
        }
    }

    private string CurrentOpenPollConflictMessage =>
        SelectedProposal?.EquivalentOpenPollMessage ?? DuplicateOpenPollMessage;

    private bool IsOpenPollDisabled =>
        IsOpeningPoll
        || SelectedProposal is null
        || HasCurrentPollTypeConflict;

    private string OpenPollButtonText
    {
        get
        {
            if (HasCurrentPollTypeConflict)
            {
                return "Poll Already Exists";
            }

            return IsOpeningPoll
                ? "Opening..."
                : "Confirm & Open Poll";
        }
    }

    private string OpenPollAlertClass =>
        OpenPollSucceeded
            ? "mf-alert success"
            : "mf-alert info";

    protected override async Task OnInitializedAsync()
    {
        await LoadProposalsAsync();
    }

    private async Task LoadProposalsAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        try
        {
            var dashboard = await EditorialBoardApiClient.GetDashboardAsync();

            Proposals = dashboard?.RecentProposals
                .Select(MapProposal)
                .ToList()
                ?? new List<ProposalItem>();
        }
        catch (Exception ex)
        {
            ErrorMessage = ex.Message;
            Proposals = Array.Empty<ProposalItem>();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadCancellableSeriesAsync()
    {
        try
        {
            CancellableSeries = await EditorialBoardApiClient
                .GetCancellableSeriesForCancelPollAsync();
        }
        catch (Exception ex)
        {
            CancelPollSucceeded = false;
            CancelPollMessage = ex.Message;
            CancellableSeries = Array.Empty<CancellableBoardSeriesDto>();
        }
    }

    private async Task OpenCancelPollAsync()
    {
        if (IsOpeningCancelPoll)
        {
            return;
        }

        if (!Guid.TryParse(SelectedCancelSeriesIdText, out var seriesId))
        {
            CancelPollSucceeded = false;
            CancelPollMessage = "Please select a valid series.";
            return;
        }

        if (SelectedCancelSeries?.HasOpenCancelSerializationPoll == true)
        {
            CancelPollSucceeded = false;
            CancelPollMessage = "This series already has an open cancellation poll.";
            return;
        }

        if (string.IsNullOrWhiteSpace(CancelPollReason))
        {
            CancelPollSucceeded = false;
            CancelPollMessage = "Poll reason is required.";
            return;
        }

        IsOpeningCancelPoll = true;
        CancelPollMessage = null;
        CancelPollSucceeded = false;

        try
        {
            var request = new OpenCancelSerializationPollRequest(
                PollReason: CancelPollReason.Trim(),
                EndsAtUtc: ConfirmedOpenPollDeadline?.ToUniversalTime());

            var result = await EditorialBoardApiClient.OpenCancelSerializationPollAsync(
                seriesId,
                request);

            if (result is null)
            {
                CancelPollSucceeded = false;
                CancelPollMessage = "API returned empty result.";
                return;
            }

            CancelPollSucceeded = true;
            CancelPollMessage = "Cancellation poll opened successfully. Redirecting to Board Polls...";

            SelectedCancelSeriesIdText = string.Empty;
            CancelPollReason = string.Empty;
            OpenPollDeadlineDraftText = string.Empty;
            ConfirmedOpenPollDeadline = null;
            ShowDeadlinePicker = false;

            await LoadCancellableSeriesAsync();

            NavigationManager.NavigateTo("/demo/mangaflow/polls");
        }
        catch (Exception ex)
        {
            CancelPollSucceeded = false;
            CancelPollMessage = ex.Message;
        }
        finally
        {
            IsOpeningCancelPoll = false;
        }
    }

    private static ProposalItem MapProposal(EditorialProposalReviewRowDto proposal)
    {
        var versionNumber = GetOptionalInt(
            proposal,
            "VersionNumber",
            "ProposalVersion",
            "VersionNo");

        var versionLabel = versionNumber > 0
            ? $"Version {versionNumber}"
            : GetOptionalString(
                proposal,
                "Version",
                "VersionLabel",
                "LatestVersionLabel");

        if (string.IsNullOrWhiteSpace(versionLabel))
        {
            versionLabel = "Version unavailable";
        }

        var assignedEditor = GetAssignedEditorOrDefault(proposal);

        var submittedFromEditor = GetOptionalString(
            proposal,
            "SubmittedByEditorName",
            "SubmittedFromEditorName",
            "ReviewedByEditorName",
            "ReviewedByName",
            "EditorName");

        if (string.IsNullOrWhiteSpace(submittedFromEditor))
        {
            submittedFromEditor = assignedEditor;
        }

        var targetAudience = GetOptionalString(
            proposal,
            "TargetAudience",
            "Audience");

        if (string.IsNullOrWhiteSpace(targetAudience))
        {
            targetAudience = "Editorial Review";
        }

        var tags = GetOptionalStringList(
            proposal,
            "Tags",
            "TagNames",
            "TagsDisplay");

        var genreItems = SplitGenreDisplay(proposal.Genre);

        var proposalFileName = GetOptionalString(
            proposal,
            "ProposalFileName",
            "ProposalOriginalFileName",
            "ProposalFileDisplayName");

        var proposalFileUrl = GetOptionalString(
            proposal,
            "ProposalFileUrl",
            "ProposalFileSecureUrl",
            "ProposalFilePublicUrl");

        var markupFileName = GetOptionalString(
            proposal,
            "MarkupFileName",
            "MarkupOriginalFileName",
            "MarkupFileDisplayName");

        var markupFileUrl = GetOptionalString(
            proposal,
            "MarkupFileUrl",
            "MarkupFileSecureUrl",
            "MarkupFilePublicUrl");

        var attachments = new List<AttachmentItem>();

        if (!string.IsNullOrWhiteSpace(proposalFileName)
            || !string.IsNullOrWhiteSpace(proposalFileUrl))
        {
            attachments.Add(new AttachmentItem(
                Label: "Proposal file",
                DisplayName: string.IsNullOrWhiteSpace(proposalFileName)
                    ? "Open proposal file"
                    : proposalFileName,
                Url: proposalFileUrl));
        }

        if (!string.IsNullOrWhiteSpace(markupFileName)
            || !string.IsNullOrWhiteSpace(markupFileUrl))
        {
            attachments.Add(new AttachmentItem(
                Label: "Markup file",
                DisplayName: string.IsNullOrWhiteSpace(markupFileName)
                    ? "Open markup file"
                    : markupFileName,
                Url: markupFileUrl));
        }

        var hasStartSerializationOpenPoll = GetOptionalBool(
            proposal,
            "HasStartSerializationOpenPoll",
            "HasStartSerializationOpenBoardPoll",
            "HasStartOpenPoll");

        var hasCancelSerializationOpenPoll = GetOptionalBool(
            proposal,
            "HasCancelSerializationOpenPoll",
            "HasCancelSerializationOpenBoardPoll",
            "HasCancelOpenPoll");

        var hasGenericOpenPollConflict = GetOptionalBool(
            proposal,
            "HasEquivalentOpenPoll",
            "HasOpenPoll",
            "HasActivePoll",
            "HasExistingOpenPoll");

        var equivalentOpenPollMessage = GetOptionalString(
            proposal,
            "EquivalentOpenPollMessage",
            "OpenPollBlockReason",
            "ExistingOpenPollMessage");

        if (string.IsNullOrWhiteSpace(equivalentOpenPollMessage))
        {
            equivalentOpenPollMessage = DuplicateOpenPollMessage;
        }

        var synopsis = GetOptionalString(
            proposal,
            "Synopsis",
            "ProposalSynopsis",
            "Summary");

        if (string.IsNullOrWhiteSpace(synopsis))
        {
            synopsis = "No synopsis is available from the current API response.";
        }

        return new ProposalItem
        {
            ProposalId = proposal.ProposalId,
            SeriesId = proposal.SeriesId,
            Code = proposal.Code,
            Title = proposal.Title,
            Author = proposal.Author,
            Genre = proposal.Genre,
            GenreItems = genreItems,
            Tags = tags,
            VersionNumber = versionNumber,
            VersionLabel = versionLabel,
            SubmittedFromEditor = submittedFromEditor,
            Status = proposal.Status,
            AssignedEditor = assignedEditor,
            TargetAudience = targetAudience,
            Synopsis = synopsis,
            HasStartSerializationOpenPoll = hasStartSerializationOpenPoll,
            HasCancelSerializationOpenPoll = hasCancelSerializationOpenPoll,
            HasGenericOpenPollConflict = hasGenericOpenPollConflict,
            EquivalentOpenPollMessage = equivalentOpenPollMessage,
            History = new List<HistoryItem>
            {
                new(
                    versionLabel,
                    submittedFromEditor,
                    $"Proposal {versionLabel.ToLowerInvariant()} is available for editorial board review.")
            },
            Attachments = attachments
        };
    }

    private void ClearStatusFilter() => StatusFilter = null;

    private void SetDraftFilter() => StatusFilter = "Draft";

    private void SetInReviewFilter() => StatusFilter = "In Review";

    private void SetApprovedFilter() => StatusFilter = "Approved";

    private void SetRejectedFilter() => StatusFilter = "Rejected";

    private string GetFilterChipClass(string? status)
    {
        return StatusFilter == status
            ? "mf-chip active"
            : "mf-chip";
    }

    private IEnumerable<ProposalItem> FilteredProposals => Proposals.Where(proposal =>
        (string.IsNullOrWhiteSpace(SearchText)
            || proposal.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
            || proposal.Code.Contains(SearchText, StringComparison.OrdinalIgnoreCase)
            || proposal.Author.Contains(SearchText, StringComparison.OrdinalIgnoreCase))
        && (StatusFilter is null || proposal.Status == StatusFilter));

    private void OpenDetails(ProposalItem proposal)
    {
        SelectedProposal = proposal;
        PollType = "START_SERIALIZATION";
        PublicationFrequencyCode = "WEEKLY";
        ShowDeadlinePicker = false;
        ShowAllTags = false;
        ShowAllGenres = false;
        OpenPollDeadlineDraftText = string.Empty;
        ConfirmedOpenPollDeadline = null;
        OpenPollMessage = null;
        OpenPollSucceeded = false;
        OpenPollConflictType = null;

        SelectedCancelSeriesIdText = string.Empty;
        CancelPollReason = string.Empty;
        CancelPollMessage = null;
        CancelPollSucceeded = false;
        IsOpeningCancelPoll = false;

        PollReason = $"Board poll opened for {proposal.Title}.";
    }

    private void CloseDetails()
    {
        SelectedProposal = null;
        OpenPollMessage = null;
        OpenPollSucceeded = false;
        OpenPollConflictType = null;
        ShowAllTags = false;
        ShowAllGenres = false;

        SelectedCancelSeriesIdText = string.Empty;
        CancelPollReason = string.Empty;
        CancelPollMessage = null;
        CancelPollSucceeded = false;
        IsOpeningCancelPoll = false;
    }

    private void StartDeadlinePicker()
    {
        if (ActiveTab == "PROPOSAL_REVIEW" && HasCurrentPollTypeConflict)
        {
            return;
        }

        if (ActiveTab == "CANCEL_SERIALIZATION"
            && SelectedCancelSeries?.HasOpenCancelSerializationPoll == true)
        {
            return;
        }

        ShowDeadlinePicker = true;
        OpenPollDeadlineDraftText = ConfirmedOpenPollDeadline?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)
            ?? DateTime.Today.AddDays(7).ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
    }

    private void OnDeadlineInputChanged(ChangeEventArgs args)
    {
        OpenPollDeadlineDraftText = args.Value?.ToString() ?? string.Empty;
    }

    private void ConfirmDeadline()
    {
        ConfirmedOpenPollDeadline = DateTime.TryParse(
            OpenPollDeadlineDraftText,
            CultureInfo.InvariantCulture,
            DateTimeStyles.None,
            out var parsedDate)
                ? parsedDate.Date
                : null;

        ShowDeadlinePicker = false;
    }

    private void CancelDeadline()
    {
        ShowDeadlinePicker = false;
        OpenPollDeadlineDraftText = ConfirmedOpenPollDeadline?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty;
    }

    private async Task ConfirmOpenPollAsync()
    {
        if (SelectedProposal is null)
        {
            return;
        }

        if (HasCurrentPollTypeConflict)
        {
            OpenPollSucceeded = false;
            OpenPollMessage = CurrentOpenPollConflictMessage;
            return;
        }

        if (SelectedProposal.ProposalId == Guid.Empty)
        {
            OpenPollSucceeded = false;
            OpenPollMessage = "This proposal does not have a real ProposalId.";
            return;
        }

        if (string.IsNullOrWhiteSpace(PollReason))
        {
            OpenPollSucceeded = false;
            OpenPollMessage = "Poll reason is required.";
            return;
        }

        if (string.IsNullOrWhiteSpace(PublicationFrequencyCode))
        {
            OpenPollSucceeded = false;
            OpenPollMessage = "Publication frequency is required for START_SERIALIZATION.";
            return;
        }

        IsOpeningPoll = true;
        OpenPollMessage = null;
        OpenPollSucceeded = false;

        try
        {
            var request = new OpenPollRequest(
                PollTypeCode: "START_SERIALIZATION",
                PollReason: PollReason,
                PublicationFrequencyCode: PublicationFrequencyCode,
                EndsAtUtc: ConfirmedOpenPollDeadline?.ToUniversalTime());

            var result = await EditorialBoardApiClient.OpenPollAsync(
                SelectedProposal.ProposalId,
                request);

            if (result is null)
            {
                OpenPollMessage = "API returned empty result.";
                return;
            }

            OpenPollSucceeded = true;
            OpenPollMessage = "Poll opened successfully. Redirecting to Board Polls...";

            NavigationManager.NavigateTo("/demo/mangaflow/polls");
        }
        catch (Exception ex)
        {
            OpenPollSucceeded = false;
            OpenPollMessage = ToOpenPollFriendlyMessage(ex.Message);

            if (IsDuplicateOpenPollMessage(ex.Message))
            {
                OpenPollConflictType = "START_SERIALIZATION";
            }
        }
        finally
        {
            IsOpeningPoll = false;
        }
    }

    private static string FormatDate(DateTime? date)
    {
        return date is null
            ? "No deadline"
            : date.Value.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);
    }

    private static string GetAssignedEditorOrDefault(EditorialProposalReviewRowDto proposal)
    {
        var assignedEditor = GetOptionalString(
            proposal,
            "AssignedEditor",
            "AssignedEditorName",
            "EditorName",
            "ReviewedByEditorName",
            "ReviewedByName");

        return string.IsNullOrWhiteSpace(assignedEditor)
            ? "Editorial Team"
            : assignedEditor;
    }

    private static string ToOpenPollFriendlyMessage(string message)
    {
        if (IsDuplicateOpenPollMessage(message))
        {
            return DuplicateOpenPollMessage;
        }

        return message;
    }

    private static bool IsDuplicateOpenPollMessage(string message)
    {
        return message.Contains("ux_series_board_poll_open_type", StringComparison.OrdinalIgnoreCase)
            || message.Contains("Cannot insert duplicate key", StringComparison.OrdinalIgnoreCase)
            || message.Contains("already has an open board poll", StringComparison.OrdinalIgnoreCase)
            || message.Contains("already exists for this series", StringComparison.OrdinalIgnoreCase);
    }

    private static IReadOnlyList<string> SplitGenreDisplay(string? genreDisplay)
    {
        if (string.IsNullOrWhiteSpace(genreDisplay))
        {
            return Array.Empty<string>();
        }

        return genreDisplay
            .Split(" / ", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(genre => !string.IsNullOrWhiteSpace(genre))
            .ToList();
    }

    private static string GetOptionalString(object source, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            var property = source.GetType().GetProperty(propertyName);

            if (property is null)
            {
                continue;
            }

            var value = property.GetValue(source);

            if (value is string stringValue && !string.IsNullOrWhiteSpace(stringValue))
            {
                return stringValue;
            }

            if (value is not null && value is not string)
            {
                return value.ToString() ?? string.Empty;
            }
        }

        return string.Empty;
    }

    private static int GetOptionalInt(object source, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            var property = source.GetType().GetProperty(propertyName);

            if (property is null)
            {
                continue;
            }

            var value = property.GetValue(source);

            if (value is int intValue)
            {
                return intValue;
            }

            if (value is long longValue)
            {
                return Convert.ToInt32(longValue);
            }

            if (value is string stringValue
                && int.TryParse(stringValue, NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
            {
                return parsed;
            }
        }

        return 0;
    }

    private static bool GetOptionalBool(object source, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            var property = source.GetType().GetProperty(propertyName);

            if (property is null)
            {
                continue;
            }

            var value = property.GetValue(source);

            if (value is bool boolValue)
            {
                return boolValue;
            }

            if (value is string stringValue
                && bool.TryParse(stringValue, out var parsed))
            {
                return parsed;
            }
        }

        return false;
    }

    private static IReadOnlyList<string> GetOptionalStringList(object source, params string[] propertyNames)
    {
        foreach (var propertyName in propertyNames)
        {
            var property = source.GetType().GetProperty(propertyName);

            if (property is null)
            {
                continue;
            }

            var value = property.GetValue(source);

            if (value is IReadOnlyList<string> readOnlyList)
            {
                return readOnlyList
                    .Where(tag => !string.IsNullOrWhiteSpace(tag))
                    .ToList();
            }

            if (value is IEnumerable<string> enumerable)
            {
                return enumerable
                    .Where(tag => !string.IsNullOrWhiteSpace(tag))
                    .ToList();
            }

            if (value is string stringValue && !string.IsNullOrWhiteSpace(stringValue))
            {
                return stringValue
                    .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                    .ToList();
            }
        }

        return Array.Empty<string>();
    }

    private sealed class ProposalItem
    {
        public Guid ProposalId { get; init; }
        public Guid SeriesId { get; init; }
        public string Code { get; init; } = string.Empty;
        public string Title { get; init; } = string.Empty;
        public string Author { get; init; } = string.Empty;
        public string Genre { get; init; } = string.Empty;
        public IReadOnlyList<string> GenreItems { get; init; } = Array.Empty<string>();
        public IReadOnlyList<string> Tags { get; init; } = Array.Empty<string>();
        public int VersionNumber { get; init; }
        public string VersionLabel { get; init; } = string.Empty;
        public string SubmittedFromEditor { get; init; } = string.Empty;
        public string Status { get; init; } = string.Empty;
        public string AssignedEditor { get; init; } = string.Empty;
        public string TargetAudience { get; init; } = string.Empty;
        public string Synopsis { get; init; } = string.Empty;
        public bool HasStartSerializationOpenPoll { get; init; }
        public bool HasCancelSerializationOpenPoll { get; init; }
        public bool HasGenericOpenPollConflict { get; init; }
        public string EquivalentOpenPollMessage { get; init; } = string.Empty;
        public IReadOnlyList<HistoryItem> History { get; init; } = Array.Empty<HistoryItem>();
        public IReadOnlyList<AttachmentItem> Attachments { get; init; } = Array.Empty<AttachmentItem>();
    }

    private sealed record HistoryItem(
        string Version,
        string Date,
        string Description);

    private sealed record AttachmentItem(
        string Label,
        string DisplayName,
        string? Url)
    {
        public bool HasUrl => !string.IsNullOrWhiteSpace(Url);
    }
}
