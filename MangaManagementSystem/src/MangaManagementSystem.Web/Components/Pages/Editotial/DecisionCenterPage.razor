@page "/demo/mangaflow/decisions"

@using Microsoft.AspNetCore.Components.Authorization
@using MangaManagementSystem.Web.Services.EditorialBoard

@inject IEditorialBoardApiClient EditorialBoardApiClient

<MangaFlowShell Title="Decision Center"
                Subtitle="Finalize publishing decisions based on board votes."
                ActiveMenu="decisions"
                Actions="@HeaderActions">
    <ChildContent>
        @if (_isLoading)
        {
            <section class="mf-card">
                <div class="mf-strong">Loading decision center...</div>
                <div class="mf-muted">Fetching board poll results from database.</div>
            </section>
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <section class="mf-card">
                <div class="mf-strong">Cannot load decision center</div>
                <div class="mf-muted">@_errorMessage</div>

                <button class="mf-btn mf-btn-primary mf-gap-small"
                        @onclick="LoadDecisionCenterAsync">
                    Retry
                </button>
            </section>
        }
        else
        {
            <section class="mf-card mf-tab-card">
                <div class="mf-filter-row">
                    <button type="button"
                            class="@TabClass(CurrentTab)"
                            @onclick="() => SetActiveTab(CurrentTab)">
                        <span class="mf-tab-icon">●</span>
                        <span>Current Polls</span>
                        <strong>@_openPolls.Count</strong>
                    </button>

                    <button type="button"
                            class="@TabClass(HistoryTab)"
                            @onclick="() => SetActiveTab(HistoryTab)">
                        <span class="mf-tab-icon">✓</span>
                        <span>Poll History</span>
                        <strong>@_pollHistory.Count</strong>
                    </button>
                </div>
            </section>

            <h2 class="mf-section-title">@SectionTitle (@VisiblePolls.Count)</h2>

            @if (VisiblePolls.Count == 0)
            {
                <section class="mf-card">
                    <div class="mf-strong">@EmptyTitle</div>
                    <div class="mf-muted">@EmptyMessage</div>
                </section>
            }
            else
            {
                <div class="mf-decision-stack">
                    @foreach (var poll in VisiblePolls)
                    {
                        <article class="mf-decision-card">
                            <div class="mf-row">
                                <div>
                                    <div class="mf-muted">
                                        @poll.Code · @DisplayPollType(poll.PollTypeCode)
                                    </div>

                                    <h3>@poll.PollName</h3>

                                    @if (_activeTab == HistoryTab)
                                    {
                                        <div class="mf-muted">
                                            Started: @FormatDate(poll.StartedAtUtc)
                                            · Ended: @FormatDate(poll.EndsAtUtc)
                                        </div>
                                    }
                                </div>

                                <StatusBadge Status="@DisplayStatus(poll)" />
                            </div>

                            <div class="mf-grid mf-grid-4 vote-summary-grid">
                                <div class="mf-vote-summary">
                                    <strong>@poll.TotalVotes</strong>
                                    <span>Total Votes</span>
                                </div>

                                <div class="mf-vote-summary">
                                    <strong class="approve">@poll.ApproveVotes</strong>
                                    <span>Approvals</span>
                                </div>

                                <div class="mf-vote-summary">
                                    <strong class="reject">@poll.RejectVotes</strong>
                                    <span>Rejections</span>
                                </div>

                                <div class="mf-vote-summary">
                                    <strong class="abstain">@poll.AbstainVotes</strong>
                                    <span>Abstentions</span>
                                </div>
                            </div>

                            <div class="mf-progress segmented large">
                                <div class="mf-segment approve"
                                     style="@($"width:{Percent(poll.ApproveVotes, poll.TotalVotes)}%")">
                                </div>

                                <div class="mf-segment reject"
                                     style="@($"width:{Percent(poll.RejectVotes, poll.TotalVotes)}%")">
                                </div>

                                <div class="mf-segment abstain"
                                     style="@($"width:{Percent(poll.AbstainVotes, poll.TotalVotes)}%")">
                                </div>
                            </div>

                            <div class="mf-vote-percent-row">
                                <span class="approve">
                                    @Percent(poll.ApproveVotes, poll.TotalVotes)% Approve (@poll.ApproveVotes)
                                </span>

                                <span class="reject">
                                    @Percent(poll.RejectVotes, poll.TotalVotes)% Reject (@poll.RejectVotes)
                                </span>

                                <span class="abstain">
                                    @Percent(poll.AbstainVotes, poll.TotalVotes)% Abstain (@poll.AbstainVotes)
                                </span>
                            </div>

                            @if (_activeTab == CurrentTab)
                            {
                                <AuthorizeView Roles="Editorial Board Chief">
                                    <Authorized>
                                        <div class="mf-grid mf-grid-2 mf-action-grid">
                                            <button class="mf-decision-action approve"
                                                    disabled="@IsActionDisabled(poll)"
                                                    @onclick="() => CloseVoteAsync(poll)">
                                                @CloseVoteButtonText(poll)
                                            </button>

                                            <button class="mf-decision-action return"
                                                    disabled="@IsActionDisabled(poll)"
                                                    @onclick="() => CancelVoteAsync(poll)">
                                                @CancelVoteButtonText(poll)
                                            </button>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                            }
                            else
                            {
                                <div class="mf-history-result-panel">
                                    <div>
                                        <div class="mf-muted">Final Result</div>
                                        <div class="mf-strong">@DisplayPollResult(poll)</div>
                                    </div>

                                    <div>
                                        <div class="mf-muted">Poll Status</div>
                                        <div class="mf-strong">@DisplayPollStatus(poll.PollStatusCode)</div>
                                    </div>

                                    <div>
                                        <div class="mf-muted">Your Vote</div>
                                        <div class="mf-strong">@DisplayUserVote(poll)</div>
                                    </div>
                                </div>
                            }
                        </article>
                    }
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(_decisionMessage))
            {
                <div class="mf-toast">@_decisionMessage</div>
            }
        }
    </ChildContent>
</MangaFlowShell>

@code {
    private const string CurrentTab = "CURRENT";
    private const string HistoryTab = "HISTORY";

    private IReadOnlyList<EditorialBoardPollDto> _openPolls = Array.Empty<EditorialBoardPollDto>();
    private IReadOnlyList<EditorialBoardPollDto> _pollHistory = Array.Empty<EditorialBoardPollDto>();

    private string _activeTab = CurrentTab;

    private bool _isLoading = true;
    private bool _isProcessing;
    private Guid? _processingPollId;
    private string? _errorMessage;
    private string? _decisionMessage;

    private IReadOnlyList<EditorialBoardPollDto> VisiblePolls =>
        _activeTab == CurrentTab
            ? _openPolls
            : _pollHistory;

    private string SectionTitle =>
        _activeTab == CurrentTab
            ? "Current Polls"
            : "Poll History";

    private string EmptyTitle =>
        _activeTab == CurrentTab
            ? "No current board polls"
            : "No poll history";

    private string EmptyMessage =>
        _activeTab == CurrentTab
            ? "When a Board Chief opens a poll, active voting items will appear here."
            : "Closed and cancelled polls will appear here after voting ends.";

    private RenderFragment HeaderActions => @<AuthorizeView Roles="Editorial Board Chief">
        <Authorized>
            <span class="mf-view-pill">Board Chief View</span>
        </Authorized>
    </AuthorizeView>;

    protected override async Task OnInitializedAsync()
    {
        await LoadDecisionCenterAsync();
    }

    private Task LoadDecisionCenterAsync()
    {
        return LoadDecisionCenterAsync(clearDecisionMessage: true);
    }

    private async Task LoadDecisionCenterAsync(bool clearDecisionMessage)
    {
        _isLoading = true;
        _errorMessage = null;

        if (clearDecisionMessage)
        {
            _decisionMessage = null;
        }

        try
        {
            _openPolls = await EditorialBoardApiClient.GetOpenPollsAsync();
            _pollHistory = await EditorialBoardApiClient.GetPollHistoryAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void SetActiveTab(string tab)
    {
        _activeTab = tab;
    }

    private string TabClass(string tab)
    {
        return _activeTab == tab
            ? "mf-filter active"
            : "mf-filter";
    }

    private async Task CloseVoteAsync(EditorialBoardPollDto poll)
    {
        if (_isProcessing)
        {
            return;
        }

        if (poll.PollStatusCode != "OPEN")
        {
            _decisionMessage = "Only OPEN polls can be closed.";
            return;
        }

        _isProcessing = true;
        _processingPollId = poll.PollId;
        _decisionMessage = null;

        try
        {
            var result = await EditorialBoardApiClient.FinalizeApprovalAsync(poll.PollId);

            if (result?.PollStatusCode == "CANCELLED")
            {
                _decisionMessage =
                    $"Vote tied for {poll.Code}. Poll was automatically cancelled and moved to Poll History.";
            }
            else
            {
                _decisionMessage =
                    $"Vote closed for {poll.Code}. Result moved to Poll History.";
            }

            await LoadDecisionCenterAsync(clearDecisionMessage: false);
        }
        catch (Exception ex)
        {
            _decisionMessage = ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingPollId = null;
        }
    }

    private async Task CancelVoteAsync(EditorialBoardPollDto poll)
    {
        if (_isProcessing)
        {
            return;
        }

        if (poll.PollStatusCode != "OPEN")
        {
            _decisionMessage = "Only OPEN polls can be cancelled.";
            return;
        }

        _isProcessing = true;
        _processingPollId = poll.PollId;
        _decisionMessage = null;

        try
        {
            await EditorialBoardApiClient.CancelPollAsync(poll.PollId);

            _decisionMessage =
                $"Vote cancelled for {poll.Code}. It was moved to Poll History.";

            await LoadDecisionCenterAsync(clearDecisionMessage: false);
        }
        catch (Exception ex)
        {
            _decisionMessage = ex.Message;
        }
        finally
        {
            _isProcessing = false;
            _processingPollId = null;
        }
    }

    private bool IsActionDisabled(EditorialBoardPollDto poll)
    {
        return _isProcessing
            || poll.PollStatusCode != "OPEN";
    }

    private string CloseVoteButtonText(EditorialBoardPollDto poll)
    {
        if (_isProcessing && _processingPollId == poll.PollId)
        {
            return "Closing...";
        }

        return "Close Vote";
    }

    private string CancelVoteButtonText(EditorialBoardPollDto poll)
    {
        if (_isProcessing && _processingPollId == poll.PollId)
        {
            return "Cancelling...";
        }

        return "Cancel Vote";
    }

    private static int Percent(int count, int total)
    {
        return total <= 0
            ? 0
            : (int)Math.Round(count * 100m / total);
    }

    private static string DisplayStatus(EditorialBoardPollDto poll)
    {
        if (poll.PollStatusCode == "CANCELLED"
            && poll.ComputedResultCode == "TIE_CANCELLED")
        {
            return "Tie Cancelled";
        }

        if (poll.PollStatusCode == "CANCELLED")
        {
            return "Cancelled";
        }

        if (poll.PollStatusCode == "CLOSED")
        {
            return poll.ComputedResultCode switch
            {
                "APPROVED" => "Approved",
                "REJECTED" => "Rejected",
                "NO_DECISION" => "No Decision",
                _ => "Closed"
            };
        }

        if (poll.PollStatusCode == "OPEN"
            && !string.IsNullOrWhiteSpace(poll.ComputedResultCode)
            && poll.ComputedResultCode != "PENDING")
        {
            return poll.ComputedResultCode switch
            {
                "APPROVED" => "Approve Leading",
                "REJECTED" => "Reject Leading",
                "NO_DECISION" => "Tie Vote",
                _ => poll.ComputedResultCode
            };
        }

        return poll.PollStatusCode switch
        {
            "OPEN" => "Voting in Progress",
            "CLOSED" => "Closed",
            "CANCELLED" => "Cancelled",
            _ => poll.PollStatusCode
        };
    }

    private static string DisplayPollResult(EditorialBoardPollDto poll)
    {
        if (poll.ComputedResultCode == "TIE_CANCELLED")
        {
            return "Tie Vote — Poll Cancelled";
        }

        if (poll.PollStatusCode == "CANCELLED")
        {
            return "Cancelled";
        }

        return poll.ComputedResultCode switch
        {
            "APPROVED" => "Approved",
            "REJECTED" => "Rejected",
            "NO_DECISION" => "No Decision",
            "PENDING" => "Pending",
            _ => poll.ComputedResultCode
        };
    }

    private static string DisplayPollStatus(string pollStatusCode)
    {
        return pollStatusCode switch
        {
            "OPEN" => "Open",
            "CLOSED" => "Closed",
            "CANCELLED" => "Cancelled",
            _ => pollStatusCode
        };
    }

    private static string DisplayUserVote(EditorialBoardPollDto poll)
    {
        return poll.CurrentUserChoiceCode switch
        {
            "APPROVE" => "Approved",
            "REJECT" => "Rejected",
            "ABSTAIN" => "Abstained",
            null => "Not voted",
            "" => "Not voted",
            _ => poll.CurrentUserChoiceCode
        };
    }

    private static string DisplayPollType(string pollTypeCode)
    {
        return pollTypeCode switch
        {
            "START_SERIALIZATION" => "Serialization",
            "CANCEL_SERIALIZATION" => "Cancellation",
            _ => pollTypeCode
        };
    }

    private static string FormatDate(DateTime dateTime)
    {
        return dateTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    private static string FormatDate(DateTime? dateTime)
    {
        return dateTime is null
            ? "N/A"
            : dateTime.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }
}