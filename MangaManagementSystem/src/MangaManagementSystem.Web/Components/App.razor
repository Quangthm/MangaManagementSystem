<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
    <link href="css/mangaflow.css?v=@CssVersion" rel="stylesheet" />
    <link href="MangaManagementSystem.Web.styles.css" rel="stylesheet" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <MudThemeProvider @rendermode="InteractiveServer" />
    <MudPopoverProvider @rendermode="InteractiveServer" />
    <MudDialogProvider @rendermode="InteractiveServer" />
    <MudSnackbarProvider @rendermode="InteractiveServer" />
    <ToastHost @rendermode="InteractiveServer" />
    <Routes @rendermode="InteractiveServer" />
    <script src="js/recaptcha.js"></script>
    <script src="js/portfolio-viewer.js"></script>
    <script src="/js/profile-settings-crop.js"></script>
    <script src="/js/image-crop.js"></script>
    <script src="/js/upload-preview.js"></script>
    <script src="_framework/blazor.web.js"></script>
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>
</body>

</html>

@code {
    // Cache-buster for local CSS: a new value each app start so a Stop→Run reliably serves the
    // latest mangaflow.css instead of a browser-cached copy (no manual hard-refresh needed).
    private static readonly string CssVersion = DateTime.UtcNow.Ticks.ToString();
}
