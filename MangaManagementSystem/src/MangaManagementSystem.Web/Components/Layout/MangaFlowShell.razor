@namespace MangaManagementSystem.Web.Components.Layouts

@using System.Security.Claims
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="mf-app-shell">
    <aside class="mf-sidebar">
        <div class="mf-brand">
            <div class="mf-brand-icon">◇</div>

            <div>
                <div class="mf-brand-title">MangaFlow</div>
                <div class="mf-brand-subtitle">Editorial System</div>
            </div>
        </div>

        <div class="mf-search">Quick search...</div>

        <div class="mf-nav-group">
            <div class="mf-nav-heading">
                <span>◇</span>
                <span>Editorial Board</span>
                <span class="mf-nav-caret">⌄</span>
            </div>

            <a class='@MenuClass("dashboard")' href="/demo/mangaflow/editorial">
                <span>Editorial Dashboard</span>
            </a>

            <a class='@MenuClass("proposals")' href="/demo/mangaflow/proposals">
                <span>Proposal Reviews</span>
                <span class="mf-side-count">4</span>
            </a>

            <a class='@MenuClass("polls")' href="/demo/mangaflow/polls">
                <span>Board Polls</span>
                <span class="mf-side-count">3</span>
            </a>

            <a class='@MenuClass("decisions")' href="/demo/mangaflow/decisions">
                <span>Decision Center</span>
            </a>
        </div>

        <AuthorizeView>
            <Authorized Context="sideAuth">
                @{
                    var sideUser = sideAuth.User;
                    var sideDisplayName = GetDisplayName(sideUser);
                    var sideRoleName = GetRoleDisplayName(sideUser);
                    var sideEmail = GetEmail(sideUser);
                    var sideInitials = GetInitials(sideDisplayName);
                }

                <div class="mf-user-card">
                    <span class="mf-avatar">@sideInitials</span>

                    <div>
                        <div class="mf-user-name">@sideDisplayName</div>
                        <div class="mf-user-email">@sideEmail</div>
                        <div class="mf-user-role">@sideRoleName</div>

                        <form method="post"
      action="/api/auth/logout"
      style="display: contents;">
    <AntiforgeryToken />

    <button type="submit"
            class="mf-sidebar-logout">
        Logout
    </button>
</form>
                    </div>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="mf-user-card">
                    <span class="mf-avatar">?</span>

                    <div>
                        <div class="mf-user-name">Guest</div>
                        <div class="mf-user-email">Not signed in</div>
                        <div class="mf-user-role">Viewer</div>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </aside>

    <main class="mf-main">
        <header class="mf-topbar">
            <div class="mf-breadcrumb">
                <span>MangaFlow</span>
                <span>/</span>
                <span>Editorial Board</span>
                <span>/</span>
                <strong>@Title</strong>
            </div>

            <div class="mf-top-actions">
                @if (Actions is not null)
                {
                    @Actions
                }

                <div class="mf-help">?</div>

                <div class="mf-notification">
                    <span>3</span>
                </div>

                <AuthorizeView>
                    <Authorized Context="topAuth">
                        @{
                            var topUser = topAuth.User;
                            var topDisplayName = GetDisplayName(topUser);
                            var topRoleName = GetRoleDisplayName(topUser);
                            var topInitials = GetInitials(topDisplayName);
                        }

                        <div class="mf-profile-pill">
                            <span class="mf-avatar small">@topInitials</span>

                            <div>
                                <div class="mf-profile-name">@topDisplayName</div>
                                <small>@topRoleName</small>
                            </div>
                        </div>

                        <form method="post"
      action="/api/auth/logout"
      style="display: contents;">
    <AntiforgeryToken />

    <button type="submit"
            class="mf-btn mf-btn-soft">
        Logout
    </button>
</form>
                    </Authorized>

                    <NotAuthorized>
                        <div class="mf-profile-pill">
                            <span class="mf-avatar small">?</span>

                            <div>
                                <div class="mf-profile-name">Guest</div>
                                <small>Not signed in</small>
                            </div>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <section class="mf-page-title-area">
            <div>
                <h1>@Title</h1>
                <p>@Subtitle</p>
            </div>

            @if (ShowLiveBadge)
            {
                <span class="mf-live-pill">● Live</span>
            }
        </section>

        <section class="mf-content">
            @ChildContent
        </section>
    </main>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string ActiveMenu { get; set; } = string.Empty;
    [Parameter] public bool ShowLiveBadge { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string MenuClass(string key)
    {
        return ActiveMenu.Equals(key, StringComparison.OrdinalIgnoreCase)
            ? "mf-side-link active"
            : "mf-side-link";
    }

    private static string GetDisplayName(ClaimsPrincipal user)
    {
        return user.FindFirst("display_name")?.Value
            ?? user.FindFirst("DisplayName")?.Value
            ?? user.FindFirst(ClaimTypes.Name)?.Value
            ?? user.FindFirst("name")?.Value
            ?? user.Identity?.Name
            ?? "Board Member";
    }

    private static string GetEmail(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst("Email")?.Value
            ?? "member@mangaflow.io";
    }

    private static string GetRoleDisplayName(ClaimsPrincipal user)
    {
        var role = user.FindFirst(ClaimTypes.Role)?.Value
            ?? user.FindFirst("role")?.Value
            ?? user.FindFirst("role_name")?.Value
            ?? user.FindFirst("Role")?.Value
            ?? user.FindFirst("RoleName")?.Value
            ?? "Viewer";

        return role switch
        {
            "Editorial Board Chief" => "Board Chief",
            "EditorialBoardChief" => "Board Chief",
            "Board Chief" => "Board Chief",

            "Editorial Board Member" => "Board Member",
            "EditorialBoardMember" => "Board Member",
            "Board Member" => "Board Member",

            "Tantou Editor" => "Tantou Editor",
            "Mangaka" => "Mangaka",
            "Assistant" => "Assistant",
            "Admin" => "Admin",

            _ => role
        };
    }

    private static string GetInitials(string displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "?";
        }

        var parts = displayName.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 1)
        {
            return parts[0].Length >= 2
                ? parts[0][..2].ToUpperInvariant()
                : parts[0].ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}