<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">MangaFlow</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="weather">
                <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Weather
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized Context="auth">
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/dashboard">Dashboard</NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="/profile/settings">Profile Settings</NavLink>
                </div>

                <AuthorizeView Roles="Admin">
                    <Authorized Context="adminAuth">
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/admin">Admin Dashboard</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/admin/user-approval">User Approval</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/admin/users">User Accounts</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/admin/settings">System Settings</NavLink></div>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Mangaka">
                    <Authorized Context="creatorAuth">
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/mangaka">Mangaka Dashboard</NavLink></div>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Assistant">
                    <Authorized Context="assistantAuth">
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/assistant">Assistant Dashboard</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/assistant/tasks">Assigned Tasks</NavLink></div>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Tantou Editor">
                    <Authorized Context="editorAuth">
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/editor">Editor Dashboard</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/editor/series">Series Review</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/editor/chapters">Chapter Review</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/editor/proposals">Proposal Review</NavLink></div>
                    </Authorized>
                </AuthorizeView>

                <AuthorizeView Roles="Editorial Board Member,Editorial Board Chief">
                    <Authorized Context="boardAuth">
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/ranking">Series Ranking</NavLink></div>
                        <div class="nav-item px-3"><NavLink class="nav-link" href="/board-decision">Board Decision</NavLink></div>

                        <AuthorizeView Roles="Editorial Board Chief">
                            <Authorized Context="boardChiefAuth">
                                <div class="nav-item px-3">
                                    <NavLink class="nav-link"
                                             href="/board/polls">
                                        Board Polls
                                    </NavLink>
                                </div>
                            </Authorized>
                        </AuthorizeView>

                    </Authorized>
                </AuthorizeView>
            </Authorized>
        </AuthorizeView>
    </nav>
</div>