@namespace MangaManagementSystem.Web.Components.Layouts

<RoleSidebarLayout SidebarCssClass="mf-assistant-sidebar"
                   NavTitle="Main Menu"
                   OverviewHref="/dashboard"
                   NavItems="_navItems">
    @ChildContent
</RoleSidebarLayout>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static readonly IReadOnlyList<RoleSidebarLayout.RoleSidebarNavItem> _navItems =
    [
        new("/assistant", "Dashboard", "", true),
        new("/assistant/tasks", "Assigned Tasks"),
        new("/assistant/completed-work", "Completed Work"),
    ];
}
