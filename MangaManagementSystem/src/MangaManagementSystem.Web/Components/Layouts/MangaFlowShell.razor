@namespace MangaManagementSystem.Web.Components.Layouts

@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization

<RoleSidebarLayout SidebarCssClass="mf-ranking-sidebar"
                   NavTitle="Editorial Board"
                   OverviewHref="/dashboard"
                   NavItems="_navItems">
    <ChildContent>
        <header class="mf-topbar">
            <div class="mf-breadcrumb">
                <span>MangaFlow</span>
                <span>/</span>
                <span>Editorial Board</span>
                <span>/</span>
                <strong>@Title</strong>
            </div>

            <div class="mf-top-actions">
                <AuthorizeView>
                    <Authorized>
                        <NotificationBell />
                    </Authorized>
                </AuthorizeView>

                @if (Actions is not null)
                {
                    @Actions
                }

                <div class="mf-help">?</div>
            </div>
        </header>

        <section class="mf-page-title-area">
            <div>
                <h1>@Title</h1>

                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <p>@Subtitle</p>
                }
            </div>

            @if (ShowLiveBadge)
            {
                <span class="mf-live-pill">● Live</span>
            }
        </section>

        <section class="mf-content">
            @ChildContent
        </section>
    </ChildContent>
</RoleSidebarLayout>

@code {
    [Parameter]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string Subtitle { get; set; } = string.Empty;

    [Parameter]
    public string ActiveMenu { get; set; } = string.Empty;

    [Parameter]
    public bool ShowLiveBadge { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    private static readonly IReadOnlyList<RoleSidebarLayout.RoleSidebarNavItem> _navItems =
    [
        new("/demo/mangaflow/editorial", "Editorial Dashboard", Icons.Material.Filled.Dashboard, true),
        new("/demo/mangaflow/proposals", "Proposal Reviews", Icons.Material.Filled.Article),
        new("/demo/mangaflow/decisions", "Decision Center", Icons.Material.Filled.HowToVote),
        new("/ranking", "Ranking", Icons.Material.Filled.Leaderboard),
    ];
}
