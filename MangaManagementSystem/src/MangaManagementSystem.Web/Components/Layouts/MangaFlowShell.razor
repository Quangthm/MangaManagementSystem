@using System.Security.Claims
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop

@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="mf-app-shell">
    <aside class="mf-sidebar">
        <div class="mf-brand">
            <div class="mf-brand-icon">◇</div>
            <div>
                <div class="mf-brand-title">MangaFlow</div>
                <div class="mf-brand-subtitle">Editorial System</div>
            </div>
        </div>

        <div class="mf-search">Quick search...</div>

        <div class="mf-nav-group">
            <div class="mf-nav-heading">
                <span>◇</span>
                <span>Editorial Board</span>
                <span class="mf-nav-caret">⌄</span>
            </div>

            <a class="@DashboardMenuClass" href="/demo/mangaflow/editorial">
                <span>Editorial Dashboard</span>
            </a>

            <a class="@ProposalsMenuClass" href="/demo/mangaflow/proposals">
                <span>Proposal Reviews</span>
                <span class="mf-side-count">4</span>
            </a>

            <a class="@PollsMenuClass" href="/demo/mangaflow/polls">
                <span>Board Polls</span>
                <span class="mf-side-count">3</span>
            </a>

            <a class="@DecisionsMenuClass" href="/demo/mangaflow/decisions">
                <span>Decision Center</span>
            </a>
        </div>

        <div class="mf-user-card">
            <div class="mf-avatar">@CurrentInitials</div>

            <div>
                <div class="mf-user-name">@CurrentRoleDisplay</div>
                <div class="mf-user-email">@CurrentEmail</div>

                @if (IsAuthenticated)
                {
                    <button type="button"
                            class="mf-sidebar-logout"
                            @onclick="LogoutAsync">
                        Logout
                    </button>
                }
            </div>
        </div>
    </aside>

    <main class="mf-main">
        <header class="mf-topbar">
            <div class="mf-breadcrumb">
                MangaFlow / Editorial Board / <span>@Title</span>
            </div>

            <div class="mf-top-actions">
                @if (Actions is not null)
                {
                    @Actions
                }

                <div class="mf-help">?</div>
                <div class="mf-notification">3</div>

                <div class="mf-profile-pill">
                    <span class="mf-avatar small">@CurrentInitials</span>
                    <span>@CurrentRoleDisplay</span>
                </div>

                @if (IsAuthenticated)
                {
                    <button type="button"
                            class="mf-btn mf-btn-soft"
                            @onclick="LogoutAsync">
                        Logout
                    </button>
                }
            </div>
        </header>

        <section class="mf-page-title-area">
            <div>
                <h1>@Title</h1>
                <p>@Subtitle</p>
            </div>
        </section>

        <section class="mf-content">
            @ChildContent
        </section>
    </main>
</div>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public string ActiveMenu { get; set; } = string.Empty;
    [Parameter] public RenderFragment? Actions { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool IsAuthenticated { get; set; }
    private string CurrentEmail { get; set; } = "Not signed in";
    private string CurrentRoleDisplay { get; set; } = "Guest";
    private string CurrentInitials { get; set; } = "?";

    private string DashboardMenuClass => MenuClass("dashboard");
    private string ProposalsMenuClass => MenuClass("proposals");
    private string PollsMenuClass => MenuClass("polls");
    private string DecisionsMenuClass => MenuClass("decisions");

    protected override async Task OnInitializedAsync()
    {
        await LoadCurrentUserAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadCurrentUserAsync();
    }

    private async Task LoadCurrentUserAsync()
    {
        var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authenticationState.User;

        IsAuthenticated = user.Identity?.IsAuthenticated == true;

        if (!IsAuthenticated)
        {
            SetGuestUser();
            return;
        }

        CurrentEmail = GetEmail(user);
        CurrentRoleDisplay = GetRoleDisplayName(user);
        CurrentInitials = GetInitials(CurrentRoleDisplay);
    }

    private string MenuClass(string key)
    {
        return ActiveMenu.Equals(key, StringComparison.OrdinalIgnoreCase)
            ? "mf-side-link active"
            : "mf-side-link";
    }

    private void SetGuestUser()
    {
        IsAuthenticated = false;
        CurrentEmail = "Not signed in";
        CurrentRoleDisplay = "Guest";
        CurrentInitials = "?";
    }

    private async Task LogoutAsync()
    {
        var keys = new[]
        {
            "authToken",
            "token",
            "jwt",
            "accessToken",
            "currentUser",
            "user",
            "role",
            "roleName"
        };

        foreach (var key in keys)
        {
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", key);
            await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", key);
        }

        NavigationManager.NavigateTo("/login", forceLoad: true);
    }

    private static string GetEmail(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Email)?.Value
            ?? user.FindFirst("email")?.Value
            ?? user.FindFirst("Email")?.Value
            ?? "No email";
    }

    private static string GetRoleDisplayName(ClaimsPrincipal user)
    {
        var role = user.FindFirst(ClaimTypes.Role)?.Value
            ?? user.FindFirst("role")?.Value
            ?? user.FindFirst("role_name")?.Value
            ?? user.FindFirst("Role")?.Value
            ?? user.FindFirst("RoleName")?.Value
            ?? "Viewer";

        return role switch
        {
            "Editorial Board Chief" => "Board Chief",
            "EditorialBoardChief" => "Board Chief",
            "Board Chief" => "Board Chief",

            "Editorial Board Member" => "Board Member",
            "EditorialBoardMember" => "Board Member",
            "Board Member" => "Board Member",

            "Tantou Editor" => "Tantou Editor",
            "Mangaka" => "Mangaka",
            "Assistant" => "Assistant",
            "Admin" => "Admin",

            _ => role
        };
    }

    private static string GetInitials(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "?";
        }

        var parts = value.Split(
            ' ',
            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 1)
        {
            return parts[0].Length >= 2
                ? parts[0][..2].ToUpperInvariant()
                : parts[0].ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}