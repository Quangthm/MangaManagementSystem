@namespace MangaManagementSystem.Web.Components.Layouts
@inject IWebHostEnvironment Environment

<RoleSidebarLayout SidebarCssClass="mf-admin-sidebar"
                   NavTitle="Main Navigation"
                   OverviewHref="/dashboard"
                   NavItems="_navItems">
    <ExtraNavContent>
        <NavLink href="/admin/users"
                 class="mf-nav-link"
                 Match="NavLinkMatch.Prefix">
            User Management
        </NavLink>

        <NavLink href="/admin/audit-logs"
                 class="mf-nav-link"
                 Match="NavLinkMatch.Prefix">
            Audit Logs
        </NavLink>

        <NavLink href="/admin/files"
                 class="mf-nav-link"
                 Match="NavLinkMatch.Prefix">
            File Management
        </NavLink>

        <AuthorizeView Roles="Admin">
            <Authorized>
                <NavLink href="/admin/user-approval"
                         class="mf-nav-link"
                         Match="NavLinkMatch.Prefix">
                    User Approval
                </NavLink>
            </Authorized>
        </AuthorizeView>

        <NavLink href="/admin/board-polls"
                 class="mf-nav-link"
                 Match="NavLinkMatch.Prefix">
            Board Polls
        </NavLink>

        <div class="mf-nav-title mt-3">System</div>

        @if (Environment.IsDevelopment())
        {
            <AuthorizeView Roles="Admin,Editorial Board Chief,EditorialBoardChief,Board Chief">
                <Authorized>
                    <NavLink href="/development/ranking-warning"
                             class="mf-nav-link"
                             Match="NavLinkMatch.Prefix">
                        Development Ranking Warning Console
                    </NavLink>
                </Authorized>
            </AuthorizeView>
        }

        <div class="mf-nav-link disabled">
            Role &amp; Permissions (Not available)
        </div>

        <div class="mf-nav-link disabled">
            System Settings (Not available)
        </div>
    </ExtraNavContent>
    <ChildContent>
        @ChildContent
    </ChildContent>
</RoleSidebarLayout>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static readonly IReadOnlyList<RoleSidebarLayout.RoleSidebarNavItem> _navItems =
[
    new("/admin", "Dashboard", "", true),
    new("/ranking", "Ranking"),
];
}