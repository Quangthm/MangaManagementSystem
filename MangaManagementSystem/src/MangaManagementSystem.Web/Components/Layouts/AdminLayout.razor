@namespace MangaManagementSystem.Web.Components.Layouts
@inject NavigationManager Nav

<div class="mf-shell">
    <aside class="mf-sidebar mf-admin-sidebar">
        <div class="mf-sidebar-header">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <span class="mf-logo-box mf-admin-logo">MF</span>
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold text-white">MangaFlow</MudText>
                    <MudText Typo="Typo.caption" Style="color:#94a3b8">System Administrator</MudText>
                </div>
            </MudStack>
        </div>
        <div class="pa-3">
            <UserAvatarMenu />
        </div>
        <nav class="mf-nav-section">
            <div class="mf-nav-title">Main Navigation</div>
            <NavLink href="/admin" class="mf-nav-link" Match="NavLinkMatch.Prefix">Dashboard</NavLink>
            <NavLink href="/admin/users" class="mf-nav-link" Match="NavLinkMatch.Prefix">User Accounts</NavLink>
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <NavLink href="/admin/user-approval" class="mf-nav-link" Match="NavLinkMatch.Prefix">User Approval</NavLink>
                </Authorized>
            </AuthorizeView>
            <!-- Audit Logs UI removed per MVP scope -->
            <NavLink href="/admin/board-polls" class="mf-nav-link" Match="NavLinkMatch.Prefix">Board Polls</NavLink>
            <div class="mf-nav-link disabled">Role & Permissions (Not available)</div>
            <div class="mf-nav-link disabled">System Settings (Not available)</div>

        </nav>
        <MudSpacer />
        <div class="pa-4">
            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" OnClick="BackToOverview">
                Back to Overview
            </MudButton>
            <div class="mt-3">
                <LogoutForm />
            </div>
        </div>
    </aside>
    <main class="mf-main">
        @ChildContent
    </main>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    private void BackToOverview() => Nav.NavigateTo("/dashboard");
}
