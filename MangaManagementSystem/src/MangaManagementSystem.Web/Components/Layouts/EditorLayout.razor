@namespace MangaManagementSystem.Web.Components.Layouts

<RoleSidebarLayout SidebarCssClass="mf-editor-sidebar"
                   NavTitle="Editorial Workflow"
                   OverviewHref="/dashboard"
                   NavItems="_navItems">
    <ExtraNavContent>
        <div class="mf-nav-title mt-4">
            Ranking &amp; Context
        </div>

        <NavLink href="/ranking"
                 class="mf-nav-link"
                 Match="NavLinkMatch.Prefix">
            <MudIcon Icon="mdi-chart-line"
                     Size="Size.Small"
                     Class="mf-nav-icon" />
            Series Ranking
        </NavLink>
    </ExtraNavContent>
    <ChildContent>
        @Body
    </ChildContent>
</RoleSidebarLayout>

@code {
    [Parameter] public RenderFragment? Body { get; set; }

    private static readonly IReadOnlyList<RoleSidebarLayout.RoleSidebarNavItem> _navItems =
    [
        new("/editor", "Dashboard", "mdi-view-dashboard", true),
        new("/editor/series", "Series Library", "mdi-book-open-page-variant"),
        new("/editor/proposals", "Proposals", "mdi-file-document-edit"),
        new("/editor/chapters", "Chapters", "mdi-bookshelf"),
        new("/editor/annotations", "Annotations", "mdi-pen"),
    ];
}
