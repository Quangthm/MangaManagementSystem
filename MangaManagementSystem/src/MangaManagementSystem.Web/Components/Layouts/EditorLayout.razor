@namespace MangaManagementSystem.Web.Components.Layouts
@inject NavigationManager Nav

<div class="mf-shell">
    <aside class="mf-sidebar mf-editor-sidebar">
        <button type="button" class="mf-sidebar-brand" @onclick="GoToEditorDashboard">
            <span class="mf-logo-box mf-editor-logo">MF</span>

            <span class="mf-brand-text">
                <span class="mf-brand-name">MangaFlow</span>
                <span class="mf-brand-subtitle">Editorial Board</span>
            </span>
        </button>

        <nav class="mf-nav-section">
            <div class="mf-nav-title">Editorial Workflow</div>

            <NavLink href="/editor" class="mf-nav-link" Match="NavLinkMatch.All">
                <MudIcon Icon="mdi-view-dashboard" Size="Size.Small" Class="mf-nav-icon" />
                Dashboard
            </NavLink>

            <NavLink href="/editor/series" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-book-open-page-variant" Size="Size.Small" Class="mf-nav-icon" />
                Series Library
            </NavLink>

            <NavLink href="/editor/proposals" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-file-document-edit" Size="Size.Small" Class="mf-nav-icon" />
                Proposals
            </NavLink>

            <NavLink href="/editor/chapters" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-bookshelf" Size="Size.Small" Class="mf-nav-icon" />
                Chapters
            </NavLink>

            <NavLink href="/editor/annotations" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-pen" Size="Size.Small" Class="mf-nav-icon" />
                Annotations
            </NavLink>

            <div class="mf-nav-title mt-4">Ranking & Context</div>

            <NavLink href="/ranking" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-chart-line" Size="Size.Small" Class="mf-nav-icon" />
                Series Ranking
            </NavLink>

            <div class="mf-nav-title mt-4">Account</div>

            <NavLink href="/profile/settings" class="mf-nav-link" Match="NavLinkMatch.Prefix">
                <MudIcon Icon="mdi-account-cog" Size="Size.Small" Class="mf-nav-icon" />
                Profile Settings
            </NavLink>
        </nav>

        <MudSpacer />

        <div class="pa-4">
            <MudButton FullWidth="true"
                       Variant="Variant.Outlined"
                       Color="Color.Default"
                       OnClick="BackToOverview">
                Back to Overview
            </MudButton>

            <div class="mt-3">
                <LogoutForm />
            </div>
        </div>
    </aside>

    <main class="mf-main">
        @ChildContent
    </main>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private void GoToEditorDashboard()
    {
        Nav.NavigateTo("/editor");
    }

    private void BackToOverview()
    {
        Nav.NavigateTo("/dashboard");
    }
}

<style>
    .mf-sidebar-brand {
        width: 100%;
        border: 0;
        background: transparent;
        padding: 22px 18px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        text-align: left;
        cursor: pointer;
    }

        .mf-sidebar-brand:hover .mf-logo-box {
            transform: translateY(-1px);
            box-shadow: 0 10px 22px rgba(236, 72, 153, 0.35);
        }

    .mf-brand-text {
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .mf-brand-name {
        color: #ffffff;
        font-weight: 800;
        font-size: 16px;
        line-height: 1.2;
    }

    .mf-brand-subtitle {
        color: #94a3b8;
        font-size: 12px;
        line-height: 1.2;
    }
</style>