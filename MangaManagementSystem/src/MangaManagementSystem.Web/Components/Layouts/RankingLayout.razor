@namespace MangaManagementSystem.Web.Components.Layouts
@inject NavigationManager Nav

<div class="mf-shell">
    <aside class="mf-sidebar">
        <div class="mf-sidebar-header">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <span class="mf-logo-box">MF</span>
                <div>
                    <MudText Typo="Typo.subtitle1" Class="font-weight-bold text-white">MangaFlow</MudText>
                    <MudText Typo="Typo.caption" Style="color:#94a3b8">Ranking Dashboard</MudText>
                </div>
            </MudStack>
        </div>
        <nav class="mf-nav-section">
            <div class="mf-nav-title">Editorial Board</div>
            <NavLink href="/ranking" class="mf-nav-link" Match="NavLinkMatch.Prefix">Dashboard</NavLink>
            <NavLink href="/ranking/series" class="mf-nav-link" Match="NavLinkMatch.Prefix">Series Rankings</NavLink>
            <NavLink href="/ranking/performance" class="mf-nav-link" Match="NavLinkMatch.Prefix">Performance Tracking</NavLink>
            <NavLink href="/ranking/risk" class="mf-nav-link" Match="NavLinkMatch.Prefix">Cancellation Risk</NavLink>
            <NavLink href="/ranking/decisions" class="mf-nav-link" Match="NavLinkMatch.Prefix">Board Decisions</NavLink>
            <NavLink href="/ranking/settings" class="mf-nav-link" Match="NavLinkMatch.Prefix">Account Settings</NavLink>
            <NavLink href="/board-decision" class="mf-nav-link" Match="NavLinkMatch.Prefix">Board Decision Workspace</NavLink>

        </nav>
        <MudSpacer />
        <div class="pa-4">
            <MudButton FullWidth="true" Variant="Variant.Outlined" Color="Color.Default" OnClick="BackToOverview">
                Back to Overview
            </MudButton>
        </div>
    </aside>
    <main class="mf-main">
        @ChildContent
    </main>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    private void BackToOverview() => Nav.NavigateTo("/dashboard");
}
