@namespace MangaManagementSystem.Web.Components.Layouts

<RoleSidebarLayout SidebarCssClass="mf-dashboard-sidebar"
                   NavTitle="Workspace"
                   OverviewHref="/dashboard"
                   NavItems="_navItems">
    @ChildContent
</RoleSidebarLayout>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private static readonly IReadOnlyList<RoleSidebarLayout.RoleSidebarNavItem> _navItems =
    [
        new("/dashboard", "Overview", "", true),
        new("/dashboard/records", "Editorial Records"),
        new("/dashboard/studio", "Studio Progress"),
        new("/dashboard/workspace", "Review Workspace"),
    ];
}
